/-!
# Subpolynomial growth of the divisor-counting function

This file provides the elementary classical bound `τ(n) ≤ C_δ · n^δ` for every `δ > 0`,
where `τ(n) = #n.divisors` is the number of divisors of `n`.

This is a self-contained, `Mathlib`-only development (it does not depend on
`PrimeNumberTheoremAnd`), proving the bound directly from the multiplicative formula
`τ(n) = ∏_{p ∣ n} (v_p(n) + 1)` (`Nat.card_divisors`) via a small/large prime split.

The main result is `PoissonCRT.divisorCount_subpoly`.
-/

open Filter Finset

namespace PoissonCRT

/-- A polynomial in `a` is eventually dominated by an exponential `2 ^ (a * δ)`, hence bounded by a
constant multiple of it for all `a`.  Concretely there is `M ≥ 1` with
`(a + 1) ^ m ≤ M * 2 ^ (a * δ)` for every `a`. -/
lemma aux_pow_le_const_mul_rpow (m : ℕ) {δ : ℝ} (hδ : 0 < δ) :
    ∃ M : ℝ, 1 ≤ M ∧ ∀ a : ℕ, ((a + 1 : ℝ)) ^ m ≤ M * (2 : ℝ) ^ ((a : ℝ) * δ) := by
  set r : ℝ := (2 : ℝ) ^ (-δ) with hr
  have hr0 : 0 < r := Real.rpow_pos_of_pos (by norm_num) _
  have hr1 : r < 1 := by
    rw [hr]; exact Real.rpow_lt_one_of_one_lt_of_neg (by norm_num) (by linarith)
  have habs : |r| < 1 := by rw [abs_of_pos hr0]; exact hr1
  have hg : Tendsto (fun n : ℕ => ((n : ℝ)) ^ m * r ^ n) atTop (nhds 0) :=
    tendsto_pow_const_mul_const_pow_of_abs_lt_one m habs
  have hshift :
      Tendsto (fun a : ℕ => (((a + 1 : ℕ) : ℝ)) ^ m * r ^ (a + 1) * r⁻¹) atTop (nhds 0) := by
    have := (hg.comp (tendsto_add_atTop_nat 1)).mul_const (r⁻¹)
    simpa [Function.comp] using this
  have hf : Tendsto (fun a : ℕ => ((a + 1 : ℝ)) ^ m * r ^ a) atTop (nhds 0) := by
    apply hshift.congr
    intro a
    have hh : r ^ (a + 1) * r⁻¹ = r ^ a := by
      rw [pow_succ, mul_assoc, mul_inv_cancel₀ hr0.ne', mul_one]
    push_cast
    rw [mul_assoc, hh]
  obtain ⟨C, hC⟩ := hf.bddAbove_range
  refine ⟨max C 1, le_max_right _ _, fun a => ?_⟩
  have hCa : ((a + 1 : ℝ)) ^ m * r ^ a ≤ max C 1 :=
    le_trans (hC ⟨a, rfl⟩) (le_max_left _ _)
  have hpos : (0 : ℝ) < (2 : ℝ) ^ ((a : ℝ) * δ) := Real.rpow_pos_of_pos (by norm_num) _
  have hrarpow : r ^ a = ((2 : ℝ) ^ ((a : ℝ) * δ))⁻¹ := by
    rw [hr, ← Real.rpow_natCast ((2 : ℝ) ^ (-δ)) a, ← Real.rpow_mul (by norm_num : (0 : ℝ) ≤ 2),
      ← Real.rpow_neg (by norm_num : (0 : ℝ) ≤ 2)]
    ring_nf
  have hmul := mul_le_mul_of_nonneg_right hCa (le_of_lt hpos)
  rw [mul_assoc, hrarpow, inv_mul_cancel₀ hpos.ne', mul_one] at hmul
  exact hmul

/-- The product over the prime factors of `n` of `p ^ (v_p(n) * δ)` equals `n ^ δ`. -/
lemma aux_prod_primeFactors_rpow {n : ℕ} (hn : n ≠ 0) (δ : ℝ) :
    ∏ p ∈ n.primeFactors, (p : ℝ) ^ ((n.factorization p : ℝ) * δ) = (n : ℝ) ^ δ := by
  have hnat : ∏ p ∈ n.primeFactors, p ^ n.factorization p = n := by
    rw [← Nat.prod_factorization_eq_prod_primeFactors (fun p k => p ^ k)]
    exact Nat.prod_factorization_pow_eq_self hn
  have hnprod : ∏ p ∈ n.primeFactors, (p : ℝ) ^ (n.factorization p) = (n : ℝ) := by
    exact_mod_cast hnat
  calc ∏ p ∈ n.primeFactors, (p : ℝ) ^ ((n.factorization p : ℝ) * δ)
      = ∏ p ∈ n.primeFactors, ((p : ℝ) ^ (n.factorization p)) ^ δ := by
        apply Finset.prod_congr rfl
        intro p hp
        rw [Real.rpow_mul (by positivity), Real.rpow_natCast]
    _ = (∏ p ∈ n.primeFactors, (p : ℝ) ^ (n.factorization p)) ^ δ :=
        Real.finsetProd_rpow _ _ (fun p hp => by positivity) δ
    _ = (n : ℝ) ^ δ := by rw [hnprod]

/-- A product of factors each equal to `M` (when `p < B`) or `1` (otherwise) is at most `M ^ B`. -/
lemma aux_prod_ite_lt_le_pow {M : ℝ} (hM : 1 ≤ M) (B : ℕ) (s : Finset ℕ) :
    ∏ p ∈ s, (if p < B then M else (1 : ℝ)) ≤ M ^ B := by
  have heq : ∏ p ∈ s, (if p < B then M else (1 : ℝ)) = M ^ (s.filter (· < B)).card := by
    rw [Finset.prod_ite, Finset.prod_const, Finset.prod_const_one, mul_one]
  rw [heq]
  apply pow_le_pow_right₀ hM
  have hsub : s.filter (· < B) ⊆ Finset.range B := by
    intro x hx
    simp only [Finset.mem_filter, Finset.mem_range] at *
    exact hx.2
  calc (s.filter (· < B)).card ≤ (Finset.range B).card := Finset.card_le_card hsub
    _ = B := Finset.card_range B

/-
For primes `p` above some threshold `B`, the local divisor factor `v_p + 1` is bounded by
`p ^ (a * δ)`, i.e. the per-prime factor in `τ(n) / n^δ` is at most `1`.
-/
lemma aux_prime_succ_threshold {δ : ℝ} (hδ : 0 < δ) :
    ∃ B : ℕ, ∀ p a : ℕ, B ≤ p → 2 ≤ p →
      ((a + 1 : ℝ)) ≤ (p : ℝ) ^ ((a : ℝ) * δ) := by
  -- By definition of exponentiation, we know that $(p : ℝ) ^ δ ≥ 2$ for sufficiently large $p$.
  obtain ⟨B₀, hB₀⟩ : ∃ B₀ : ℕ, ∀ p : ℕ, B₀ ≤ p → 2 ≤ p → (p : ℝ) ^ δ ≥ 2 := by
    have := tendsto_rpow_atTop hδ
    exact Filter.eventually_atTop.mp ( this.eventually_ge_atTop 2 ) |> fun ⟨ B₀, hB₀ ⟩ ↦
      ⟨ ⌈B₀⌉₊, fun p hp₁ hp₂ ↦ hB₀ p <| Nat.le_of_ceil_le hp₁ ⟩
  use B₀
  intro p a hp hp'; rw [ mul_comm, Real.rpow_mul ] ; norm_num
  · exact le_trans ( by
      norm_cast
      exact Nat.recOn a ( by norm_num ) fun n ihn => by
        rw [ pow_succ' ] ; nlinarith [ Nat.one_le_pow n 2 zero_lt_two ] )
      ( pow_le_pow_left₀ ( by positivity ) ( hB₀ p hp hp' ) _ )
  · positivity

/-
Core estimate: given the small-prime constant `M` and large-prime threshold `B`, the
divisor-counting function satisfies `τ(n) ≤ M ^ B * n ^ δ` for `n ≠ 0`.
-/
lemma divisorCount_le_of_bounds {δ : ℝ} (hδ : 0 < δ) {M : ℝ} (hM : 1 ≤ M) {B : ℕ}
    (hsmall : ∀ a : ℕ, ((a + 1 : ℝ)) ≤ M * (2 : ℝ) ^ ((a : ℝ) * δ))
    (hlarge : ∀ p a : ℕ, B ≤ p → 2 ≤ p →
      ((a + 1 : ℝ)) ≤ (p : ℝ) ^ ((a : ℝ) * δ))
    {n : ℕ} (hn : n ≠ 0) :
    (n.divisors.card : ℝ) ≤ M ^ B * (n : ℝ) ^ δ := by
  -- Apply the bound for each prime factor and then combine them.
  have h_combined :
      ∏ p ∈ n.primeFactors, ((n.factorization p + 1 : ℝ)) ≤
      ∏ p ∈ n.primeFactors, (if p < B then M else 1) * (p : ℝ) ^ ((n.factorization p : ℝ) * δ) := by
    gcongr
    split_ifs <;> simp_all +decide [ Nat.Prime.two_le ]
    exact le_trans ( hsmall _ ) ( mul_le_mul_of_nonneg_left ( Real.rpow_le_rpow ( by positivity )
      ( mod_cast Nat.Prime.two_le ( by tauto ) ) ( by positivity ) ) ( by positivity ) )
  convert h_combined.trans _ using 1
  · rw_mod_cast [ Nat.card_divisors hn ]
  · convert mul_le_mul_of_nonneg_right ( aux_prod_ite_lt_le_pow hM B n.primeFactors )
      ( show 0 ≤ ( n : ℝ ) ^ δ by positivity ) using 1
    rw [ Finset.prod_mul_distrib, aux_prod_primeFactors_rpow hn ]

/-
**Subpolynomial growth of the divisor-counting function.**
For every `δ > 0` there is a constant `C` with `τ(n) = #n.divisors ≤ C · n^δ` for all `n`.
-/
lemma divisorCount_subpoly {δ : ℝ} (hδ : 0 < δ) :
    ∃ C : ℝ, ∀ n : ℕ, (n.divisors.card : ℝ) ≤ C * (n : ℝ) ^ δ := by
  obtain ⟨ M, hM₁, hM₂ ⟩ := aux_pow_le_const_mul_rpow 1 hδ
  obtain ⟨ B, hB ⟩ := aux_prime_succ_threshold hδ
  use M ^ B
  intro n
  by_cases hn : n = 0
  · simp +decide [ hn, hδ.ne' ]
  · convert divisorCount_le_of_bounds hδ hM₁ ( fun a => by simpa using hM₂ a )
      ( fun p a hp ha => by simpa using hB p a hp ha ) hn using 1

end PoissonCRT
