import Mathlib

/-!
# Summation-swap helper (Blueprint §2)

This file isolates the purely combinatorial Fubini swap used in the synthesis of
`gamma_weighted_series_bound`.  It depends only on `Finset`/`Nat` API, so it is
kept in a small standalone file.
-/

open Finset BigOperators

namespace PoissonCRT

/-
**Summation swap.** Isolates the `γ`-sum outside the `T`-sum: the inner
constraint `γ.primeFactors ⊆ T` becomes the outer constraint `γ.primeFactors ⊆ T`
ranging over `T ∈ 𝒯` containing `γ.primeFactors`. This is Fubini over the finite
double index set `{(T, γ) : T ∈ 𝒯, γ ∈ [1,N], γ.primeFactors ⊆ T}`.
-/
lemma sum_T_gamma_swap (q : ℕ) (N : ℕ)
    (𝒯 : Finset (Finset ℕ)) (h𝒯 : ∀ T ∈ 𝒯, T ⊆ q.primeFactors)
    (F : Finset ℕ → ℝ) (G : Finset ℕ → ℕ → ℝ) :
    ∑ T ∈ 𝒯, F T *
      (∑ γ ∈ (Finset.Icc 1 N).filter (fun γ => γ.primeFactors ⊆ T), G T γ) =
    ∑ γ ∈ (Finset.Icc 1 N).filter (fun γ => γ.primeFactors ⊆ q.primeFactors),
      ∑ T ∈ 𝒯.filter (fun T => γ.primeFactors ⊆ T), F T * G T γ := by
  simp +decide only [mul_sum];
  rw [ Finset.sum_sigma', Finset.sum_sigma' ];
  apply Finset.sum_bij (fun x _ => ⟨x.snd, x.fst⟩);
  · grind +qlia;
  · grind;
  · aesop;
  · grind

end PoissonCRT