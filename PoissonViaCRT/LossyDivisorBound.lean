/-!
# The analytic lossy divisor sum bound

This file proves `PoissonCRT.lossy_divisor_sum_bound_core`, the analytic bound that the
"lossy" divisor sum appearing in the Fourier-ANOVA synthesis decays like `C В· s^{-Оө/2}`,
where `s = q / |О©_q|` is the average spacing.

It is kept in a separate file (with a minimal import surface that avoids the heavy
`FourierANOVA` infrastructure) so that the statement can be reused from
`FourierSynthesisHelpers.lean`.
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ### Elementary helper lemmas -/

/-
The number of divisors `П„(n) = #n.divisors` dominates `2 ^ Пү(n)`, since
`П„(n) = вҲҸ_{p вҲЈ n} (v_p(n) + 1) вүҘ вҲҸ_{p вҲЈ n} 2 = 2 ^ Пү(n)`.
-/
private lemma two_pow_primeFactors_card_le_tau {n : в„•} (hn : n вү  0) :
    (2 : в„қ) ^ n.primeFactors.card вүӨ (n.divisors.card : в„қ) := by
  rw_mod_cast [ Nat.card_divisors hn ]
  exact le_trans ( by norm_num )
    ( Finset.prod_le_prod' fun p hp =>
      Nat.succ_le_succ <| Nat.pos_of_ne_zero <| Finsupp.mem_support_iff.mp hp )

/-
A negative real power eventually dominates the logarithm: for `a > 0` the function
`x вҶҰ x ^ (-a) * (log x + 1)` is bounded on `[1, вҲһ)` by a constant.
-/
private lemma rpow_neg_mul_log_bounded {a : в„қ} (ha : 0 < a) :
    вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ x : в„қ, 1 вүӨ x вҶ’ x ^ (-a) * (Real.log x + 1) вүӨ C := by
  refine' вҹЁ 2 / a + 1, by positivity, fun x hx => _ вҹ©
  -- Apply the inequality $\log x \leq \frac{x^{a/2}}{a/2}$ to get
  -- $\log x + 1 \leq \frac{x^{a/2}}{a/2} + 1$.
  have h_log : Real.log x + 1 вүӨ (2 / a) * x ^ (a / 2) + 1 := by
    have := Real.log_le_sub_one_of_pos ( by positivity : 0 < x ^ ( a / 2 ) )
    rw [ Real.log_rpow ( by positivity ) ] at this ; ring_nf at *
    nlinarith [ inv_mul_cancel_leftвӮҖ ha.ne' ( Real.log x ), inv_mul_cancelвӮҖ ha.ne' ]
  refine le_trans ( mul_le_mul_of_nonneg_left h_log <| by positivity ) ?_
  ring_nf
  norm_num [ mul_assoc, mul_comm, mul_left_comm, вҶҗ Real.rpow_add ( by positivity : 0 < x ) ]
  exact add_le_add ( by
    simpa using Real.rpow_le_rpow_of_exponent_le hx ( show -a вүӨ 0 by linarith ) )
      ( mul_le_mul_of_nonneg_left ( mul_le_of_le_one_right ( by positivity ) ( by
        simpa using Real.rpow_le_rpow_of_exponent_le hx
          ( show -a + a * ( 1 / 2 ) вүӨ 0 by linarith ) ) ) ( by positivity ) )

/-
**Step 2a.** The summand `2^{Пү(d)} В· d^{-Оө} В· (log d + 1)` is bounded by a constant,
independent of `d`.  Split `d^{-Оө} = d^{-Оө/2} В· d^{-Оө/2}`: by `divisorCount_subpoly`
(with `Оҙ = Оө/2`) and `two_pow_primeFactors_card_le_tau` we get `2^{Пү(d)} В· d^{-Оө/2} вүӨ CвӮҒ`,
while `d^{-Оө/2} В· (log d + 1) вүӨ CвӮӮ` by `rpow_neg_mul_log_bounded`.
-/
private lemma lossy_summand_bound (Оө : в„қ) (hОө : 0 < Оө) :
    вҲғ C : в„қ, 0 < C вҲ§ вҲҖ d : в„•, d вү  0 вҶ’
      (2 : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө) * (Real.log (d : в„қ) + 1) вүӨ C := by
  -- By `divisorCount_subpoly` (with `Оҙ = Оө/2`) and `two_pow_primeFactors_card_le_tau`
  -- we get `2^{Пү(d)} В· d^{-Оө/2} вүӨ CвӮҒ`.
  obtain вҹЁCвӮҒ, hCвӮҒвҹ© : вҲғ CвӮҒ : в„қ, вҲҖ d : в„•, d вү  0 вҶ’
      (2 ^ d.primeFactors.card : в„қ) * (d : в„қ) ^ (-(Оө / 2)) вүӨ CвӮҒ := by
    obtain вҹЁ CвӮҒ, hCвӮҒ вҹ© := PoissonCRT.divisorCount_subpoly ( show 0 < Оө / 2 by linarith )
    use CвӮҒ; intro d hd; specialize hCвӮҒ d; simp_all +decide [ Real.rpow_neg ]
    rw [ вҶҗ div_eq_mul_inv, div_le_iffвӮҖ ( by positivity ) ]
    refine' le_trans _ hCвӮҒ
    exact_mod_cast PoissonCRT.two_pow_primeFactors_card_le_tau hd
  -- By `rpow_neg_mul_log_bounded` (with `a = Оө/2`), we get `d^{-Оө/2} В· (log d + 1) вүӨ CвӮӮ`.
  obtain вҹЁCвӮӮ, hCвӮӮвҹ© : вҲғ CвӮӮ : в„қ, вҲҖ d : в„•, d вү  0 вҶ’ (d : в„қ) ^ (-(Оө / 2)) * (Real.log d + 1) вүӨ CвӮӮ := by
    have := rpow_neg_mul_log_bounded ( show 0 < Оө / 2 by positivity )
    exact вҹЁ this.choose, fun d hd => this.choose_spec.2 _ <|
      mod_cast Nat.one_le_iff_ne_zero.mpr hd вҹ©
  refine' вҹЁ Max.max ( CвӮҒ * CвӮӮ ) 1, _, _ вҹ© <;> norm_num
  intro d hd; specialize hCвӮҒ d hd; specialize hCвӮӮ d hd
  rw [ show ( -Оө : в„қ ) = - ( Оө / 2 ) + - ( Оө / 2 ) by ring,
    Real.rpow_add ( Nat.cast_pos.mpr <| Nat.pos_of_ne_zero hd ) ]
  exact Or.inl ( by
    convert mul_le_mul hCвӮҒ hCвӮӮ ( by positivity ) ( by
      exact le_trans ( by positivity ) hCвӮҒ ) using 1 ; ring )

/-
The cardinality of the CRT subset factors as a product of local cardinalities
over the prime factors of squarefree `q`.
-/
private lemma crtSubset_card_eq_prod (q : в„•) [NeZero q] (hq : Squarefree q)
    (О© : вҲҖ p : в„•, Finset (ZMod p)) :
    (crtSubset q О©).card = вҲҸ p вҲҲ q.primeFactors, (О© p).card := by
  convert Fintype.card_congr ( PoissonCRT.crtDomainEquiv q hq О© ) using 1
  В· rw [ Fintype.card_of_subtype ] ; aesop
  В· simp +decide [ Fintype.card_pi ]
    conv_lhs => rw [ вҶҗ Finset.prod_attach ]

/-
For `k = 2`, the product of local means equals `|О©_q|ВІ / q`.  This is the CRT
multiplicativity of the global mean, here derived directly from `crtSubset_card_eq_prod`.
-/
private lemma prod_localMean_eq_sq_div (q : в„•) [NeZero q] (hq : Squarefree q)
    (О© : вҲҖ p : в„•, Finset (ZMod p)) :
    вҲҸ p вҲҲ q.primeFactors, localMean 2 О© p = ((crtSubset q О©).card : в„қ) ^ 2 / (q : в„қ) := by
  unfold localMean
  convert congr_arg ( fun x : в„қ => x ^ 2 / ( вҲҸ p вҲҲ q.primeFactors, ( p : в„қ ) ) )
    ( show ( вҲҸ p вҲҲ q.primeFactors, ( # ( О© p ) : в„қ ) ) = ( # ( crtSubset q О© ) : в„қ ) from ?_ )
      using 1 <;> norm_num [ Finset.prod_div_distrib, Finset.prod_pow ]
  В· rw [ вҶҗ Nat.cast_prod, Nat.prod_primeFactors_of_squarefree hq ]
  В· rw_mod_cast [ PoissonCRT.crtSubset_card_eq_prod q hq О© ]

/-
**Step 2b (spacing).** The lower bound `hsp` on each local spacing `p / |О©_p|`
multiplies up to a lower bound `s = q / |О©_q| вүҘ q ^ (О» - Оө)` on the global spacing.
-/
private lemma lossy_s_lower_bound (Оө : в„қ) (k : в„•) (О© : вҲҖ p : в„•, Finset (ZMod p))
    (hsp : вҲҖ (p : в„•), p.Prime вҶ’ (p : в„қ) ^ (lambdaExponent k - Оө) вүӨ (p : в„қ) / (О© p).card)
    (q : в„•) [NeZero q] (hq : Squarefree q) :
    (q : в„қ) ^ (lambdaExponent k - Оө) вүӨ (q : в„қ) / (crtSubset q О©).card := by
  have h_prod_div : (q : в„қ) = вҲҸ p вҲҲ q.primeFactors, (p : в„қ) := by
    rw [ вҶҗ Nat.cast_prod, Nat.prod_primeFactors_of_squarefree hq ]
  convert Finset.prod_le_prod ?_ fun p hp => hsp p <| Nat.prime_of_mem_primeFactors hp
  rw [ h_prod_div, Real.finsetProd_rpow _ _ fun p hp => by positivity ]
  В· rw [ Finset.prod_div_distrib, h_prod_div.symm, PoissonCRT.crtSubset_card_eq_prod q hq О© ]
    norm_cast
  В· exact fun p hp => Real.rpow_nonneg ( Nat.cast_nonneg _ ) _

/-
Algebraic collapse of the lossy sum.  Using `prod_localMean_eq_sq_div`
(`вҲҸ localMean = |О©_q|ВІ / q` for `k = 2`) the prefactor `(1/|О©_q|) В· q В· (вҲҸ localMean)`
collapses to `|О©_q| / q`, and the factor `d / q` combined with `q` and `d^{-(1+Оө)}`
simplifies to `d^{-Оө}`.
-/
private lemma lossy_lhs_collapse (Оө : в„қ) (k : в„•) (hk : k = 2)
    (О© : вҲҖ p : в„•, Finset (ZMod p)) (q : в„•) [NeZero q] (hq : Squarefree q) :
    ((1 : в„қ) / ((crtSubset q О©).card : в„қ)) * (q : в„қ) ^ (k - 1)
      * вҲ‘ d вҲҲ q.divisors.erase 1,
        ((k : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-(1 + Оө))
          * (вҲҸ p вҲҲ q.primeFactors, localMean k О© p)
          * ((d : в„қ) / (q : в„қ) * (Real.log (d : в„қ) + 1)))
      = ((crtSubset q О©).card : в„қ) / (q : в„қ)
        * вҲ‘ d вҲҲ q.divisors.erase 1,
          ((k : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө) * (Real.log (d : в„қ) + 1)) := by
  rw [ Finset.mul_sum _ _ _, Finset.mul_sum _ _ _ ]
  refine Finset.sum_congr rfl fun x hx => ?_
  by_cases h : ( Finset.card ( crtSubset q О© ) : в„қ ) = 0 <;> simp_all +decide [ div_eq_mul_inv,
    mul_assoc, mul_comm, mul_left_comm, pow_succ ]
  rw [ prod_localMean_eq_sq_div q hq О© ] ; ring_nf
  rw [ show ( -Оө : в„қ ) = -1 - Оө + 1 by ring, Real.rpow_add_one ( by norm_cast; aesop ) ] ; ring_nf
  grind

/-
**Analytic Lossy Divisor Sum Bound (core).**
This is the worker lemma behind `PoissonCRT.lossy_divisor_sum_bound`; see the latter for the
discussion of the corrected hypothesis `hsp` (a *lower* bound on the local spacing).
-/
lemma lossy_divisor_sum_bound_core (Оө : в„қ) (hОө : 0 < Оө) (k : в„•) (hk : k = 2)
    (О© : вҲҖ p : в„•, Finset (ZMod p))
    (hsp : вҲҖ (p : в„•), p.Prime вҶ’ (p : в„қ) ^ (lambdaExponent k - Оө) вүӨ (p : в„қ) / (О© p).card)
    (hlt : Оө < lambdaExponent k) :
    вҲғ C : в„қ, 0 < C вҲ§ вҲҖ (q : в„•) [NeZero q], Squarefree q вҶ’
    ((1 : в„қ) / ((crtSubset q О©).card : в„қ)) * (q : в„қ) ^ (k - 1)
      * вҲ‘ d вҲҲ q.divisors.erase 1,
        ((k : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-(1 + Оө))
          * (вҲҸ p вҲҲ q.primeFactors, localMean k О© p) * ((d : в„қ) / (q : в„қ) * (Real.log (d : в„қ) + 1)))
      вүӨ C * ((q : в„қ) / (crtSubset q О©).card) ^ (-(Оө / 2)) := by
  -- Set `lam := lambdaExponent k` for convenience.
  set lam := lambdaExponent k
  -- Set `Оҙ := (1/2) * (1 - Оө/2) * (lam - Оө)` for convenience.
  set Оҙ := (1 / 2) * (1 - Оө / 2) * (lam - Оө) with hОҙ_def
  have hОҙ_pos : 0 < Оҙ := by
    -- Since $k = 2$, we have $\lambda = \frac{\sqrt{17} - 3}{2}$.
    have hlam : lam = (Real.sqrt 17 - 3) / 2 := by
      aesop
    exact mul_pos ( mul_pos ( by norm_num ) ( by
        nlinarith [ Real.sqrt_nonneg 17, Real.sq_sqrt ( show 0 вүӨ 17 by norm_num ) ] ) )
      ( by linarith )
  obtain вҹЁCвӮғ, hCвӮғpos, hCвӮғвҹ© := lossy_summand_bound Оө hОө
  obtain вҹЁCвӮ„', hCвӮ„'вҹ© := divisorCount_subpoly hОҙ_pos
  set CвӮ„ := max CвӮ„' 1 with hCвӮ„_def
  set C := CвӮғ * CвӮ„ with hC_def
  use C, by
    positivity
  intro q hq hsq
  set A := (crtSubset q О©).card with hA_def
  have hA_pos : 0 < A := by
    refine' Finset.card_pos.mpr _
    -- By definition of `crtSubset`, we know that `crtSubset q О©` is nonempty if
    -- and only if `О© p` is nonempty for all prime factors `p` of `q`.
    have h_nonempty : вҲҖ p вҲҲ q.primeFactors, (О© p).Nonempty := by
      intro p hp; specialize hsp p; contrapose! hsp; simp_all +decide
      exact Real.rpow_pos_of_pos ( Nat.cast_pos.mpr hp.1.pos ) _
    obtain вҹЁx, hxвҹ© : вҲғ x : (p : q.primeFactors) вҶ’ ZMod p, вҲҖ p : q.primeFactors, x p вҲҲ О© p.val := by
      exact вҹЁ fun p => Classical.choose ( h_nonempty p p.2 ), fun p =>
        Classical.choose_spec ( h_nonempty p p.2 ) вҹ©
    generalize_proofs at *
    obtain вҹЁy, hyвҹ© : вҲғ y : ZMod q, вҲҖ p : q.primeFactors, crtRingEquiv q hsq y p = x p := by
      exact вҹЁ ( crtRingEquiv q hsq ).symm x, fun p => by simp +decide вҹ©
    generalize_proofs at *
    use y
    exact mem_crtSubset_iff_crtEquiv q hsq О© y |>.2 fun p => hy p в–ё hx p
  have hA_le_q : A вүӨ q := by
    exact le_trans ( Finset.card_le_univ _ ) ( by norm_num )
  set s := (q : в„қ) / A with hs_def
  have hs_ge_1 : 1 вүӨ s := by
    exact one_le_div ( Nat.cast_pos.mpr hA_pos ) |>.2 ( mod_cast hA_le_q )
  have hs_pow : (q : в„қ) ^ (lam - Оө) вүӨ s := by
    convert lossy_s_lower_bound Оө k О© hsp q hsq using 1
  generalize_proofs at *
  -- Rewrite the LHS with `lossy_lhs_collapse Оө k (rfl) О© q hsq`.
  have h_lhs : (1 / A : в„қ) * q ^ (k - 1) * вҲ‘ d вҲҲ q.divisors.erase 1,
      ((k : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-(1 + Оө)) *
      (вҲҸ p вҲҲ q.primeFactors, localMean k О© p) * ((d : в„қ) / q * (Real.log d + 1))) =
        (A : в„қ) / q * вҲ‘ d вҲҲ q.divisors.erase 1,
        ((2 : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө) * (Real.log d + 1)) := by
    convert lossy_lhs_collapse Оө k hk О© q hsq using 1
    norm_num [ hk ]
    exact Or.inl rfl
  generalize_proofs at *
  -- Bound the sum `ОЈ := вҲ‘ d вҲҲ q.divisors.erase 1, S(d)` where
  -- `S(d) := (2:в„қ)^d.primeFactors.card * (d:в„қ)^(-Оө) * (Real.log d + 1)`.
  have h_sum_bound : вҲ‘ d вҲҲ q.divisors.erase 1, ((2 : в„қ) ^ d.primeFactors.card *
      (d : в„қ) ^ (-Оө) * (Real.log d + 1)) вүӨ CвӮғ * (q.divisors.card : в„қ) := by
    refine' le_trans ( Finset.sum_le_sum fun x hx => hCвӮғ x <| Nat.ne_of_gt <|
      Nat.pos_of_mem_divisors <| Finset.mem_of_mem_erase hx ) _ ; norm_num [ mul_comm ]
    exact mul_le_mul_of_nonneg_left ( mod_cast Finset.card_mono <| Finset.erase_subset _ _ )
      hCвӮғpos.le
  generalize_proofs at *
  -- Bound `(q.divisors.card : в„қ)` by `CвӮ„ * (q:в„қ)^Оҙ`.
  have h_divisors_card_bound : (q.divisors.card : в„қ) вүӨ CвӮ„ * (q : в„қ) ^ Оҙ := by
    exact le_trans ( hCвӮ„' q ) ( mul_le_mul_of_nonneg_right ( le_max_left _ _ ) ( by positivity ) )
  generalize_proofs at *
  -- Bound `(q:в„қ)^Оҙ` by `s^((1/2)*(1-Оө/2))`.
  have h_q_pow_bound : (q : в„қ) ^ Оҙ вүӨ s ^ ((1 / 2) * (1 - Оө / 2)) := by
    convert Real.rpow_le_rpow ( by positivity ) hs_pow
      ( show 0 вүӨ 1 / 2 * ( 1 - Оө / 2 ) by
        norm_num [ hk, lambdaExponent ] at *
        nlinarith [ Real.sqrt_nonneg 17, Real.sq_sqrt ( show 0 вүӨ 17 by norm_num ) ] ) using 1
    rw [ вҶҗ Real.rpow_mul ( by positivity ) ] ; ring_nf
    exact congr_arg _ ( by ring )
  generalize_proofs at *
  -- Combine all the bounds to conclude the proof.
  have hCвӮ„_nonneg : (0 : в„қ) вүӨ CвӮ„ := le_trans zero_le_one (le_max_right _ _)
  have h_final_bound : (A : в„қ) / q * вҲ‘ d вҲҲ q.divisors.erase 1,
      ((2 : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө) * (Real.log d + 1)) вүӨ
      CвӮғ * CвӮ„ * s ^ ((1 / 2) * (1 - Оө / 2) - 1) := by
    have hstep : вҲ‘ d вҲҲ q.divisors.erase 1, ((2 : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө)
        * (Real.log d + 1)) вүӨ CвӮғ * CвӮ„ * s ^ ((1 / 2) * (1 - Оө / 2)) :=
      calc вҲ‘ d вҲҲ q.divisors.erase 1, ((2 : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө)
        * (Real.log d + 1))
          вүӨ CвӮғ * (q.divisors.card : в„қ) := h_sum_bound
        _ вүӨ CвӮғ * (CвӮ„ * (q : в„қ) ^ Оҙ) := mul_le_mul_of_nonneg_left h_divisors_card_bound hCвӮғpos.le
        _ вүӨ CвӮғ * (CвӮ„ * s ^ ((1 / 2) * (1 - Оө / 2))) :=
            mul_le_mul_of_nonneg_left (mul_le_mul_of_nonneg_left h_q_pow_bound hCвӮ„_nonneg)
              hCвӮғpos.le
        _ = CвӮғ * CвӮ„ * s ^ ((1 / 2) * (1 - Оө / 2)) := by ring
    have hs_pos : (0 : в„қ) < s := lt_of_lt_of_le one_pos hs_ge_1
    rw [show ((1 / 2) * (1 - Оө / 2) - 1 : в„қ) = (1 / 2) * (1 - Оө / 2) + (-1) by ring,
      Real.rpow_add hs_pos, Real.rpow_neg_one,
      show (A : в„қ) / q = sвҒ»В№ by rw [hs_def, inv_div]]
    calc sвҒ»В№ * вҲ‘ d вҲҲ q.divisors.erase 1, ((2 : в„қ) ^ d.primeFactors.card * (d : в„қ) ^ (-Оө)
        * (Real.log d + 1)) вүӨ sвҒ»В№ * (CвӮғ * CвӮ„ * s ^ ((1 / 2) * (1 - Оө / 2))) :=
          mul_le_mul_of_nonneg_left hstep (by positivity)
      _ = CвӮғ * CвӮ„ * (s ^ ((1 / 2) * (1 - Оө / 2)) * sвҒ»В№) := by ring
  generalize_proofs at *
  refine le_trans ?_ ( h_final_bound.trans ?_ ) <;> norm_num [ h_lhs ]
  В· convert h_lhs.le using 1 ; ring_nf!
    exact congrArg _ ( Finset.sum_congr rfl fun _ _ => by ring )
  В· exact mul_le_mul_of_nonneg_left ( Real.rpow_le_rpow_of_exponent_le hs_ge_1 ( by
      linarith [ show lam вүӨ 1 by exact PoissonCRT.lambdaExponent_le_one k ] ) ) ( by positivity )

