import PoissonViaCRT.MainDefs
import PoissonViaCRT.DeviationBoundHelper
import PoissonViaCRT.CRTMultiplicativity
import PoissonViaCRT.DivisorCountSubpoly
import Mathlib.Analysis.SpecialFunctions.Pow.NNReal

set_option linter.unusedVariables false

/-!
# The analytic lossy divisor sum bound

This file proves `PoissonCRT.lossy_divisor_sum_bound_core`, the analytic bound that the
"lossy" divisor sum appearing in the Fourier-ANOVA synthesis decays like `C · s^{-ε/2}`,
where `s = q / |Ω_q|` is the average spacing.

It is kept in a separate file (with a minimal import surface that avoids the heavy
`FourierANOVA` infrastructure) so that the statement can be reused from
`FourierSynthesisHelpers.lean`.
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ### Elementary helper lemmas -/

/-
The number of divisors `τ(n) = #n.divisors` dominates `2 ^ ω(n)`, since
`τ(n) = ∏_{p ∣ n} (v_p(n) + 1) ≥ ∏_{p ∣ n} 2 = 2 ^ ω(n)`.
-/
private lemma two_pow_primeFactors_card_le_tau {n : ℕ} (hn : n ≠ 0) :
    (2 : ℝ) ^ n.primeFactors.card ≤ (n.divisors.card : ℝ) := by
  rw_mod_cast [ Nat.card_divisors hn ]
  exact le_trans ( by norm_num )
    ( Finset.prod_le_prod' fun p hp =>
      Nat.succ_le_succ <| Nat.pos_of_ne_zero <| Finsupp.mem_support_iff.mp hp )

/-
A negative real power eventually dominates the logarithm: for `a > 0` the function
`x ↦ x ^ (-a) * (log x + 1)^{k-1}` is bounded on `[1, ∞)` by a constant.
-/
private lemma rpow_neg_mul_log_bounded_gen (k : ℕ) {a : ℝ} (ha : 0 < a) :
    ∃ C : ℝ, 0 ≤ C ∧ ∀ x : ℝ, 1 ≤ x → x ^ (-a) * (Real.log x + 1) ^ (k - 1) ≤ C := by
  sorry

/-
**Step 2a.** The summand `k^{ω(d)} · d^{-ε} · (log d + 1)^{k-1}` is bounded by a constant,
independent of `d`.  Split `d^{-ε} = d^{-ε/2} · d^{-ε/2}`: by a subpolynomial bound on `k^{ω(d)}`
(with `δ = ε/2`) we get `k^{ω(d)} · d^{-ε/2} ≤ C₁`,
while `d^{-ε/2} · (log d + 1)^{k-1} ≤ C₂` by `rpow_neg_mul_log_bounded_gen`.
-/
private lemma lossy_summand_bound_gen (ε : ℝ) (hε : 0 < ε) (k : ℕ) :
    ∃ C : ℝ, 0 < C ∧ ∀ d : ℕ, d ≠ 0 →
      (k : ℝ) ^ d.primeFactors.card * (d : ℝ) ^ (-ε) * (Real.log (d : ℝ) + 1) ^ (k - 1) ≤ C := by
  sorry

/-
The cardinality of the CRT subset factors as a product of local cardinalities
over the prime factors of squarefree `q`.
-/
private lemma crtSubset_card_eq_prod (q : ℕ) [NeZero q] (hq : Squarefree q)
    (Ω : ∀ p : ℕ, Finset (ZMod p)) :
    (crtSubset q Ω).card = ∏ p ∈ q.primeFactors, (Ω p).card := by
  convert Fintype.card_congr ( PoissonCRT.crtDomainEquiv q hq Ω ) using 1
  · rw [ Fintype.card_of_subtype ] ; aesop
  · simp +decide [ Fintype.card_pi ]
    conv_lhs => rw [ ← Finset.prod_attach ]

/-
For `k = 2`, the product of local means equals `|Ω_q|² / q`.  This is the CRT
multiplicativity of the global mean, here derived directly from `crtSubset_card_eq_prod`.
-/
private lemma prod_localMean_eq_sq_div (q : ℕ) [NeZero q] (hq : Squarefree q)
    (Ω : ∀ p : ℕ, Finset (ZMod p)) :
    ∏ p ∈ q.primeFactors, localMean 2 Ω p = ((crtSubset q Ω).card : ℝ) ^ 2 / (q : ℝ) := by
  unfold localMean
  convert congr_arg ( fun x : ℝ => x ^ 2 / ( ∏ p ∈ q.primeFactors, ( p : ℝ ) ) )
    ( show ( ∏ p ∈ q.primeFactors, ( # ( Ω p ) : ℝ ) ) = ( # ( crtSubset q Ω ) : ℝ ) from ?_ )
      using 1 <;> norm_num [ Finset.prod_div_distrib, Finset.prod_pow ]
  · rw [ ← Nat.cast_prod, Nat.prod_primeFactors_of_squarefree hq ]
  · rw_mod_cast [ PoissonCRT.crtSubset_card_eq_prod q hq Ω ]

/-
**Step 2b (spacing).** The lower bound `hsp` on each local spacing `p / |Ω_p|`
multiplies up to a lower bound `s = q / |Ω_q| ≥ q ^ (λ - ε)` on the global spacing.
-/
private lemma lossy_s_lower_bound (ε : ℝ) (k : ℕ) (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hsp : ∀ (p : ℕ), p.Prime → (p : ℝ) ^ (lambdaExponent k - ε) ≤ (p : ℝ) / (Ω p).card)
    (q : ℕ) [NeZero q] (hq : Squarefree q) :
    (q : ℝ) ^ (lambdaExponent k - ε) ≤ (q : ℝ) / (crtSubset q Ω).card := by
  have h_prod_div : (q : ℝ) = ∏ p ∈ q.primeFactors, (p : ℝ) := by
    rw [ ← Nat.cast_prod, Nat.prod_primeFactors_of_squarefree hq ]
  convert Finset.prod_le_prod ?_ fun p hp => hsp p <| Nat.prime_of_mem_primeFactors hp
  rw [ h_prod_div, Real.finsetProd_rpow _ _ fun p hp => by positivity ]
  · rw [ Finset.prod_div_distrib, h_prod_div.symm, PoissonCRT.crtSubset_card_eq_prod q hq Ω ]
    norm_cast
  · exact fun p hp => Real.rpow_nonneg ( Nat.cast_nonneg _ ) _

/-
Algebraic collapse of the lossy sum.  Using `prod_localMean_eq_sq_div`
(`∏ localMean = |Ω_q|² / q` for `k = 2`, and generalized for `k`) the prefactor `(1/|Ω_q|) · q^{k-1} · (∏ localMean)`
collapses to `|Ω_q|^{k-1}`, and the factor `(d / q)^{k-1}` combined with `q^{k-1}` and `d^{-(1+ε)}`
simplifies to `d^{-ε}`.
-/
private lemma lossy_lhs_collapse (ε : ℝ) (k : ℕ) (hk : 2 ≤ k)
    (Ω : ∀ p : ℕ, Finset (ZMod p)) (q : ℕ) [NeZero q] (hq : Squarefree q) :
    ((1 : ℝ) / ((crtSubset q Ω).card : ℝ)) * (q : ℝ) ^ (k - 1)
      * ∑ d ∈ q.divisors.erase 1,
        ((k : ℝ) ^ d.primeFactors.card * (d : ℝ) ^ (-(1 + ε))
          * (∏ p ∈ q.primeFactors, localMean k Ω p)
          * ((d : ℝ) / (q : ℝ) * (Real.log (d : ℝ) + 1)) ^ (k - 1))
      = ((crtSubset q Ω).card : ℝ) ^ (k - 1) / (q : ℝ) ^ (k - 1)
        * ∑ d ∈ q.divisors.erase 1,
          ((k : ℝ) ^ d.primeFactors.card * (d : ℝ) ^ (-ε) * (Real.log (d : ℝ) + 1) ^ (k - 1)) := by
  sorry

/-
**Analytic Lossy Divisor Sum Bound (core).**
This is the worker lemma behind `PoissonCRT.lossy_divisor_sum_bound`; see the latter for the
discussion of the corrected hypothesis `hsp` (a *lower* bound on the local spacing).
-/
lemma lossy_divisor_sum_bound_core (ε : ℝ) (hε : 0 < ε) (k : ℕ) (hk : 2 ≤ k)
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hsp : ∀ (p : ℕ), p.Prime → (p : ℝ) ^ (lambdaExponent k - ε) ≤ (p : ℝ) / (Ω p).card)
    (hlt : ε < lambdaExponent k) :
    ∃ C : ℝ, 0 < C ∧ ∀ (q : ℕ) [NeZero q], Squarefree q →
    ((1 : ℝ) / ((crtSubset q Ω).card : ℝ)) * (q : ℝ) ^ (k - 1)
      * ∑ d ∈ q.divisors.erase 1,
        ((k : ℝ) ^ d.primeFactors.card * (d : ℝ) ^ (-(1 + ε))
          * (∏ p ∈ q.primeFactors, localMean k Ω p) * ((d : ℝ) / (q : ℝ) * (Real.log (d : ℝ) + 1)) ^ (k - 1))
      ≤ C * ((q : ℝ) / (crtSubset q Ω).card) ^ (-(ε / 2)) := by
  sorry

end PoissonCRT
