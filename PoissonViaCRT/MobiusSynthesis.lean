    (Ω : ∀ p : ℕ, Finset (ZMod p)) (X : Box (k - 1))
    (hcard : 0 < (crtSubset q Ω).card)
    (hle : (crtSubset q Ω).card ≤ q) :
    let Ω_q := crtSubset q Ω
