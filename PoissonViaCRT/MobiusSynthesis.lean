    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (T : Finset ℕ) (hT : T ⊆ q.primeFactors) (hT_nonempty : T ≠ ∅)
    (hWD : ∀ (p : ℕ) [Fact p.Prime], WellDistributed ε p (Ω p) k)
    (hsp : ∀ (p : ℕ), p.Prime → (p : ℝ) / (Ω p).card ≤ (p : ℝ) ^ (lambdaExponent k - ε))
    (hC_lp : ∀ (s : ℝ), 1 ≤ s →
