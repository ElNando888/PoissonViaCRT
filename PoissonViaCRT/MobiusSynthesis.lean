/-- When |Ω_q| = 0, the deviation expression is zero. -/
private lemma deviation_zero_of_card_zero {k : ℕ} (q : ℕ) [NeZero q]
    (Ω : ∀ p : ℕ, Finset (ZMod p)) (X : Box (k - 1))
    (h0 : (crtSubset q Ω).card = 0) :
