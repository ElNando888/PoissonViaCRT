    simp +decide [ crtSubset ];
    intro p pp dp _; specialize hall p pp; haveI := Fact.mk pp; rw [ Finset.eq_of_subset_of_card_le ( Finset.subset_univ ( Ω p ) ) ] ; aesop;
    simp +decide [ hall, ZMod.card ];
