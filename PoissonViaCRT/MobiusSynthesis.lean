    (tupleCount (crtSubset q Ω) h : ℝ) = ∏ p ∈ q.primeFactors, localCount Ω q h p := by
  rw [ counting_function_multiplicative, Nat.cast_prod ];
  · refine' Finset.prod_bij ( fun p hp => p.val ) _ _ _ _ <;> simp +decide [ localCount ];
