private lemma crtSubset_full_of_all_full (q : ℕ) [NeZero q]
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hall : ∀ (p : ℕ), p.Prime → (Ω p).card = p) :
    (crtSubset q Ω).card = q := by
