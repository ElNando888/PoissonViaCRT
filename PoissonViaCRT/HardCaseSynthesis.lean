/-!
# Hard Case Synthesis

This file completes the final synthesis for the hard case of the deviation bound
(Proposition 3.6 of Granville–Kurlberg), assembling the geometric-to-algebraic
translation and cancellation infrastructure into a uniform bound.

## Main Results

* `PoissonCRT.divisor_period_cancellation`: For a squarefree divisor `d` with at least
  one prime factor, the sum of products of local deviation functions over the CRT product
  space `∏_{p | d} (ℤ/pℤ)^k` vanishes.

* `PoissonCRT.divisor_boundary_bound`: After complete-period cancellation, the remaining
  weighted deviation sum is bounded by the total variation of the weights times the
  pointwise deviation bound `2|Ω|`.
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ## 1. Divisor Period Cancellation -/

/-- **Divisor period cancellation.** For a squarefree divisor `d` with at least one
prime factor, the sum of products of local deviation functions over the CRT product
space `∏_{p | d} (ZMod p)^k` vanishes. This ensures that when the spatial sum
over lattice points is decomposed into complete `d`-periods plus a boundary,
the complete periods contribute exactly zero. -/
theorem divisor_period_cancellation (d : ℕ) [NeZero d]
    (hd_pos : 0 < d.primeFactors.card)
    (Ω : ∀ p : ℕ, Finset (ZMod p)) (k : ℕ) :
    ∑ x : ((p : d.primeFactors) → Fin k → ZMod ↑p),
      ∏ p : d.primeFactors, localDeviation Ω k ↑p (x p) = 0 :=
  deviation_sum_pullback d hd_pos Ω k

/-! ## 2. Divisor Boundary Bound -/

/-- **Divisor boundary bound.** Given weights `w` on residue classes `(ZMod q)^m`
whose total variation from a baseline `c` is at most `TV`, the weighted deviation
sum is bounded by `TV * (2 * |Ω|)`.

The deviations satisfy:
- **Zero-sum**: they sum to zero over all `g` (by `deviation_sum_period_zero`),
- **Pointwise bound**: each is at most `2 * |Ω|` in absolute value
  (by `individual_deviation_bound`). -/
theorem divisor_boundary_bound (q : ℕ) [NeZero q]
    (Ω : Finset (ZMod q))
    (hcard : 0 < Ω.card) (hle : (Ω.card : ℝ) ≤ (q : ℝ))
    (m : ℕ) (w : (Fin m → ZMod q) → ℝ)
    (c : ℝ) (TV : ℝ)
    (hTV : ∑ g : Fin m → ZMod q, |w g - c| ≤ TV) :
    |∑ g : Fin m → ZMod q, w g *
      ((tupleCount Ω (Fin.cons (0 : ZMod q) g) : ℝ) -
        (Ω.card : ℝ) ^ (m + 1) / (q : ℝ) ^ m)| ≤
    TV * (2 * Ω.card) :=
  total_variation_bound
    (fun g => (tupleCount Ω (Fin.cons 0 g) : ℝ) -
      (Ω.card : ℝ) ^ (m + 1) / (q : ℝ) ^ m)
    w
    (tupleCount_cons_deviation_sum_zero Ω m)
    (2 * Ω.card)
    (by positivity)
    (individual_deviation_bound Ω m hcard hle)
    c TV hTV


/-! ## 3. Möbius Boundary Sum Bound -/

/-
**Möbius boundary sum bound.** Given a sum over a finset where each summand `f(i)`
is bounded in absolute value by `C * g(i)` (as established by applying
`divisor_boundary_bound` to each divisor's contribution and factoring out the
s-dependent constant), the absolute value of the total sum is at most
`C * ∑ g(i)`.

This lemma applies the triangle inequality (`Finset.abs_sum_le_sum_abs`) and per-term
bounds (`Finset.sum_le_sum`) to produce a bound of the form
`constant × s^{k-2} × ∑_{d|q} d^{-(k-2)}`, without invoking analytic convergence.
In the Möbius decomposition context, `f(d)` is the boundary-weighted deviation for
divisor `d`, bounded by `divisor_boundary_bound`. The factored form separates
`C` (the s-dependent factor) from `g(d) = d^{-(k-2)}` (the divisor decay).
-/
theorem mobius_boundary_sum_bound {ι : Type*}
    (S : Finset ι) (f : ι → ℝ)
    (C : ℝ) (_hC : 0 ≤ C)
    (g : ι → ℝ) (_hg : ∀ i ∈ S, 0 ≤ g i)
    (hfg : ∀ i ∈ S, |f i| ≤ C * g i) :
    |∑ i ∈ S, f i| ≤ C * ∑ i ∈ S, g i := by
  simpa only [Finset.mul_sum] using
    (Finset.abs_sum_le_sum_abs _ _).trans (Finset.sum_le_sum hfg)

/-! ## 4. Deviation Synthesis (Hard Case) -/

/-
**Deviation synthesis (hard case).** Combining `mobius_boundary_sum_bound` with the
analytic convergence of divisor sums from `MobiusBounds.lean`, the finite sum
`∑_{d|q} d^{-α}` is bounded by the convergent p-series `∑' n, n^{-α}` (a q-independent
constant) via `critical_exponent_divisor_bound`. Multiplying through gives the uniform
bound `|∑ f(d)| ≤ C · (∑' n, n^{-α})` for all `q`, completing the hard case of
Proposition 3.6 of Granville–Kurlberg.

The synthesis proceeds as:
1. Apply `mobius_boundary_sum_bound` to get `|∑ f(d)| ≤ C · ∑_{d|q} d^{-α}`.
2. Apply `critical_exponent_divisor_bound` (from `MobiusBounds.lean`) to bound
   `∑_{d|q} d^{-α} ≤ ∑' n, n^{-α}`.
3. Combine via monotonicity of multiplication to conclude the `O(s⁻¹)` bound.
-/
theorem deviation_synthesis_hard_case
    (q : ℕ) (_hq : 0 < q)
    (f : ℕ → ℝ)
    (C : ℝ) (hC : 0 ≤ C)
    (α : ℝ) (hα : 1 < α)
    (hfg : ∀ d ∈ q.divisors, |f d| ≤ C * ((d : ℝ) ^ α)⁻¹) :
    |∑ d ∈ q.divisors, f d| ≤ C * ∑' n : ℕ, ((n : ℝ) ^ α)⁻¹ := by
  calc |∑ d ∈ q.divisors, f d|
      _ ≤ C * ∑ d ∈ q.divisors, ((d : ℝ) ^ α)⁻¹ :=
        mobius_boundary_sum_bound _ _ C hC _ (fun _ _ => by positivity) hfg
      _ ≤ C * ∑' n : ℕ, ((n : ℝ) ^ α)⁻¹ := by
        exact mul_le_mul_of_nonneg_left
          (critical_exponent_divisor_bound α hα q (by omega)) hC

end PoissonCRT
