/-- The binomial coefficient `(a + k - 1).choose (k - 1)` is bounded by `(a + 1) ^ (k - 1)`.
This is the elementary bound `d_k(p^a) ≤ (a + 1) ^ (k - 1)`. -/
lemma choose_add_sub_le_pow (k a : ℕ) :
    (a + k - 1).choose (k - 1) ≤ (a + 1) ^ (k - 1) := by
  suffices h : ∀ j a : ℕ, (a + j).choose j ≤ (a + 1) ^ j by
    rcases k with _ | k
    · simp
    · simpa [Nat.add_sub_cancel] using h k a
  intro j
  induction j with
  | zero => intro a; simp
  | succ j ih =>
    intro a
    have key := Nat.sum_range_add_choose a j
    calc (a + (j + 1)).choose (j + 1)
        = ∑ i ∈ range (a + 1), (i + j).choose j := by rw [key]; ring_nf
      _ ≤ ∑ i ∈ range (a + 1), (a + 1) ^ j := by
          apply Finset.sum_le_sum
          intro i hi
          simp only [Finset.mem_range] at hi
          exact (ih i).trans (Nat.pow_le_pow_left (by omega) j)
      _ = (a + 1) ^ (j + 1) := by
          rw [Finset.sum_const, Finset.card_range, pow_succ]
          simp [Nat.mul_comm]

/-- A polynomial in `a` is eventually dominated by an exponential `2 ^ (a * δ)`, hence bounded by a
constant multiple of it for all `a`.  Concretely there is `M ≥ 1` with
`(a + 1) ^ m ≤ M * 2 ^ (a * δ)` for every `a`. -/
lemma exists_pow_le_const_mul_rpow (m : ℕ) {δ : ℝ} (hδ : 0 < δ) :
    ∃ M : ℝ, 1 ≤ M ∧ ∀ a : ℕ, ((a + 1 : ℝ)) ^ m ≤ M * (2 : ℝ) ^ ((a : ℝ) * δ) := by
  set r : ℝ := (2 : ℝ) ^ (-δ) with hr
  have hr0 : 0 < r := Real.rpow_pos_of_pos (by norm_num) _
  have hr1 : r < 1 := by
    rw [hr]; exact Real.rpow_lt_one_of_one_lt_of_neg (by norm_num) (by linarith)
  have habs : |r| < 1 := by rw [abs_of_pos hr0]; exact hr1
  have hg : Tendsto (fun n : ℕ => ((n : ℝ)) ^ m * r ^ n) atTop (nhds 0) :=
    tendsto_pow_const_mul_const_pow_of_abs_lt_one m habs
  have hshift :
      Tendsto (fun a : ℕ => (((a + 1 : ℕ) : ℝ)) ^ m * r ^ (a + 1) * r⁻¹) atTop (nhds 0) := by
    have := (hg.comp (tendsto_add_atTop_nat 1)).mul_const (r⁻¹)
    simpa [Function.comp] using this
  have hf : Tendsto (fun a : ℕ => ((a + 1 : ℝ)) ^ m * r ^ a) atTop (nhds 0) := by
    apply hshift.congr
    intro a
    have hh : r ^ (a + 1) * r⁻¹ = r ^ a := by
      rw [pow_succ, mul_assoc, mul_inv_cancel₀ hr0.ne', mul_one]
    push_cast
    rw [mul_assoc, hh]
  obtain ⟨C, hC⟩ := hf.bddAbove_range
  refine ⟨max C 1, le_max_right _ _, fun a => ?_⟩
  have hCa : ((a + 1 : ℝ)) ^ m * r ^ a ≤ max C 1 :=
    le_trans (hC ⟨a, rfl⟩) (le_max_left _ _)
  have hpos : (0 : ℝ) < (2 : ℝ) ^ ((a : ℝ) * δ) := Real.rpow_pos_of_pos (by norm_num) _
  have hrarpow : r ^ a = ((2 : ℝ) ^ ((a : ℝ) * δ))⁻¹ := by
    rw [hr, ← Real.rpow_natCast ((2 : ℝ) ^ (-δ)) a, ← Real.rpow_mul (by norm_num : (0 : ℝ) ≤ 2),
      ← Real.rpow_neg (by norm_num : (0 : ℝ) ≤ 2)]
    ring_nf
  have hmul := mul_le_mul_of_nonneg_right hCa (le_of_lt hpos)
  rw [mul_assoc, hrarpow, inv_mul_cancel₀ hpos.ne', mul_one] at hmul
  exact hmul

/-- For primes `p` above some threshold `B`, the local factor `d_k(p^a)` is bounded by
`p ^ (a * δ)`, i.e. the per-prime factor in `d_k(n) / n^δ` is at most `1`. -/
lemma exists_prime_pow_threshold (k : ℕ) {δ : ℝ} (hδ : 0 < δ) :
    ∃ B : ℕ, ∀ p a : ℕ, B ≤ p → 2 ≤ p →
      (((a + k - 1).choose (k - 1) : ℝ)) ≤ (p : ℝ) ^ ((a : ℝ) * δ) := by
  have htend : Tendsto (fun p : ℕ => (p : ℝ) ^ δ) atTop atTop :=
    (tendsto_rpow_atTop hδ).comp tendsto_natCast_atTop_atTop
  have hev : ∀ᶠ p : ℕ in atTop, (2 : ℝ) ^ (k - 1) ≤ (p : ℝ) ^ δ := htend.eventually_ge_atTop _
  rw [eventually_atTop] at hev
  obtain ⟨B, hB⟩ := hev
  refine ⟨B, fun p a hp hp2 => ?_⟩
  have hp0 : (0 : ℝ) ≤ (p : ℝ) := by positivity
  have hpδ : (2 : ℝ) ^ (k - 1) ≤ (p : ℝ) ^ δ := hB p hp
  calc (((a + k - 1).choose (k - 1) : ℝ))
      ≤ ((a + 1 : ℝ)) ^ (k - 1) := by exact_mod_cast choose_add_sub_le_pow k a
    _ ≤ ((2 : ℝ) ^ a) ^ (k - 1) := by
        apply pow_le_pow_left₀ (by positivity)
        have hnat : a + 1 ≤ 2 ^ a := Nat.lt_two_pow_self
        exact_mod_cast hnat
    _ = ((2 : ℝ) ^ (k - 1)) ^ a := by rw [← pow_mul, ← pow_mul, Nat.mul_comm]
    _ ≤ ((p : ℝ) ^ δ) ^ a := pow_le_pow_left₀ (by positivity) hpδ a
    _ = (p : ℝ) ^ ((a : ℝ) * δ) := by
        rw [← Real.rpow_natCast ((p : ℝ) ^ δ) a, ← Real.rpow_mul hp0, mul_comm]

/-- The product over the prime factors of `n` of `p ^ (v_p(n) * δ)` equals `n ^ δ`. -/
lemma prod_primeFactors_rpow {n : ℕ} (hn : n ≠ 0) (δ : ℝ) :
    ∏ p ∈ n.primeFactors, (p : ℝ) ^ ((n.factorization p : ℝ) * δ) = (n : ℝ) ^ δ := by
  have hnat : ∏ p ∈ n.primeFactors, p ^ n.factorization p = n := by
    rw [← Nat.prod_factorization_eq_prod_primeFactors (fun p k => p ^ k)]
    exact Nat.prod_factorization_pow_eq_self hn
  have hnprod : ∏ p ∈ n.primeFactors, (p : ℝ) ^ (n.factorization p) = (n : ℝ) := by
    exact_mod_cast hnat
  calc ∏ p ∈ n.primeFactors, (p : ℝ) ^ ((n.factorization p : ℝ) * δ)
      = ∏ p ∈ n.primeFactors, ((p : ℝ) ^ (n.factorization p)) ^ δ := by
        apply Finset.prod_congr rfl
        intro p hp
        rw [Real.rpow_mul (by positivity), Real.rpow_natCast]
    _ = (∏ p ∈ n.primeFactors, (p : ℝ) ^ (n.factorization p)) ^ δ :=
        Real.finsetProd_rpow _ _ (fun p hp => by positivity) δ
    _ = (n : ℝ) ^ δ := by rw [hnprod]

/-- A product of factors each equal to `M` (when `p < B`) or `1` (otherwise) is at most `M ^ B`. -/
lemma prod_ite_lt_le_pow {M : ℝ} (hM : 1 ≤ M) (B : ℕ) (s : Finset ℕ) :
    ∏ p ∈ s, (if p < B then M else (1 : ℝ)) ≤ M ^ B := by
  have heq : ∏ p ∈ s, (if p < B then M else (1 : ℝ)) = M ^ (s.filter (· < B)).card := by
    rw [Finset.prod_ite, Finset.prod_const, Finset.prod_const_one, mul_one]
  rw [heq]
  apply pow_le_pow_right₀ hM
  have hsub : s.filter (· < B) ⊆ Finset.range B := by
    intro x hx
    simp only [Finset.mem_filter, Finset.mem_range] at *
    exact hx.2
  calc (s.filter (· < B)).card ≤ (Finset.range B).card := Finset.card_le_card hsub
    _ = B := Finset.card_range B

/-- Core estimate: given the small-prime constant `M` and large-prime threshold `B`, the `k`-fold
divisor function satisfies `d_k(n) ≤ M ^ B * n ^ δ` for `n ≠ 0`. -/
lemma dk_le_of_bounds {k : ℕ} (hk : 0 < k) {δ : ℝ} (hδ : 0 < δ) {M : ℝ} (hM : 1 ≤ M) {B : ℕ}
    (hsmall : ∀ a : ℕ, ((a + k - 1).choose (k - 1) : ℝ) ≤ M * (2 : ℝ) ^ ((a : ℝ) * δ))
    (hlarge : ∀ p a : ℕ, B ≤ p → 2 ≤ p →
      ((a + k - 1).choose (k - 1) : ℝ) ≤ (p : ℝ) ^ ((a : ℝ) * δ))
    {n : ℕ} (hn : n ≠ 0) :
    (d k n : ℝ) ≤ M ^ B * (n : ℝ) ^ δ := by
  rw [d_apply hk hn, Nat.cast_prod]
  have hkey : ∀ p ∈ n.primeFactors,
      ((n.factorization p + k - 1).choose (k - 1) : ℝ)
        ≤ (if p < B then M else 1) * (p : ℝ) ^ ((n.factorization p : ℝ) * δ) := by
    intro p hp
    have hp2 : 2 ≤ p := (Nat.prime_of_mem_primeFactors hp).two_le
    set a := n.factorization p with ha
    by_cases hPB : p < B
    · rw [if_pos hPB]
      have h2p : (2 : ℝ) ^ ((a : ℝ) * δ) ≤ (p : ℝ) ^ ((a : ℝ) * δ) := by
        apply Real.rpow_le_rpow (by norm_num) (by exact_mod_cast hp2)
        positivity
      calc ((a + k - 1).choose (k - 1) : ℝ)
          ≤ M * (2 : ℝ) ^ ((a : ℝ) * δ) := hsmall a
        _ ≤ M * (p : ℝ) ^ ((a : ℝ) * δ) := mul_le_mul_of_nonneg_left h2p (by linarith)
    · rw [if_neg hPB, one_mul]
      exact hlarge p a (not_lt.mp hPB) hp2
  calc ∏ p ∈ n.primeFactors, ((n.factorization p + k - 1).choose (k - 1) : ℝ)
      ≤ ∏ p ∈ n.primeFactors,
          (if p < B then M else 1) * (p : ℝ) ^ ((n.factorization p : ℝ) * δ) :=
        Finset.prod_le_prod (fun p hp => by positivity) hkey
    _ = (∏ p ∈ n.primeFactors, (if p < B then M else (1 : ℝ)))
          * ∏ p ∈ n.primeFactors, (p : ℝ) ^ ((n.factorization p : ℝ) * δ) :=
        Finset.prod_mul_distrib
    _ = (∏ p ∈ n.primeFactors, (if p < B then M else (1 : ℝ))) * (n : ℝ) ^ δ := by
        rw [prod_primeFactors_rpow hn]
    _ ≤ M ^ B * (n : ℝ) ^ δ :=
        mul_le_mul_of_nonneg_right (prod_ite_lt_le_pow hM B _) (by positivity)

/--
Iwaniec-Kowalski Theorem 2.11:
For every k ≥ 1 and every δ > 0, there exists a constant C(δ, k) such that
the k-fold divisor function is bounded by C * n^δ for all n.
-/
lemma IK_2_11 (k : ℕ) (δ : ℝ) (hδ : 0 < δ) :
    ∃ C : ℝ, ∀ n : ℕ, (d k n : ℝ) ≤ C * (n : ℝ) ^ δ := by
  rcases Nat.eq_zero_or_pos k with hk | hk
  · subst hk
    refine ⟨1, fun n => ?_⟩
    rcases eq_or_ne n 0 with rfl | hn
    · simp [Real.zero_rpow hδ.ne']
    · rw [d_zero, one_mul]
      have h1 : ((1 : ArithmeticFunction ℕ) n : ℝ) ≤ 1 := by
        rw [ArithmeticFunction.one_apply]; split <;> simp
      have hge : (1 : ℝ) ≤ (n : ℝ) ^ δ := by
        rw [show (1 : ℝ) = (1 : ℝ) ^ δ from (Real.one_rpow δ).symm]
        exact Real.rpow_le_rpow (by norm_num)
          (by exact_mod_cast Nat.one_le_iff_ne_zero.mpr hn) hδ.le
      exact le_trans h1 hge
  · obtain ⟨M, hM1, hMbound⟩ := exists_pow_le_const_mul_rpow (k - 1) hδ
    obtain ⟨B, hB⟩ := exists_prime_pow_threshold k hδ
    refine ⟨M ^ B, fun n => ?_⟩
    rcases eq_or_ne n 0 with rfl | hn
    · simp [Real.zero_rpow hδ.ne']
    · refine dk_le_of_bounds hk hδ hM1 (fun a => ?_) hB hn
      calc ((a + k - 1).choose (k - 1) : ℝ)
          ≤ ((a + 1 : ℝ)) ^ (k - 1) := by exact_mod_cast choose_add_sub_le_pow k a
        _ ≤ M * (2 : ℝ) ^ ((a : ℝ) * δ) := hMbound a

/-- τ grows subpolynomially -/
lemma tau_subpoly_growth (δ : ℝ) (hδ : 0 < δ) :
    ∃ C : ℝ, ∀ n : ℕ, (tau n : ℝ) ≤ C * (n : ℝ) ^ δ := by
  obtain ⟨C, hC⟩ := IK_2_11 2 δ hδ
  refine ⟨C, fun n => ?_⟩
  have hn := hC n
  rwa [d_two] at hn

end ArithmeticFunction

namespace PoissonCRT

-- Subpolynomial growth of the multi-divisor function (the blueprint name),
-- obtained directly from `IK_2_11`.
lemma divisor_bound (k : ℕ) (ε : ℝ) (hε : 0 < ε) :
    ∃ C : ℝ, ∀ n : ℕ, (ArithmeticFunction.d k) n ≤ C * (n : ℝ) ^ ε :=
  ArithmeticFunction.IK_2_11 k ε hε

/-
Convergence of the Euler product for strictly positive exponents
-/
lemma euler_product_converges (c : ℝ) (ε : ℝ) (hε : 0 < ε) :
  ∃ M : ℝ, ∀ T : Finset ℕ, (∀ p ∈ T, p.Prime) →
    ∏ p ∈ T, (1 + c / (p : ℝ) ^ (1 + ε)) ≤ M := by
  -- Set `M := exp(|c| * S)`, where `S := ∑' n : ℕ, (1 : ℝ) / (n : ℝ) ^ (1 + ε)`.
  set S := ∑' n : ℕ, (1 : ℝ) / (n : ℝ) ^ (1 + ε)
  set M := Real.exp (|c| * S);
  use M;
  intro T hT
  have h_prod_le_exp : ∏ p ∈ T, |1 + c / (p : ℝ) ^ (1 + ε)| ≤ Real.exp (|c| * ∑ p ∈ T, (1 : ℝ) / (p : ℝ) ^ (1 + ε)) := by
    have h_prod_le_exp : ∀ p ∈ T, |1 + c / (p : ℝ) ^ (1 + ε)| ≤ Real.exp (|c| / (p : ℝ) ^ (1 + ε)) := by
      intro p hp; rw [ abs_le ] ; constructor <;> cases abs_cases c <;> nlinarith [ Real.add_one_le_exp ( |c| / ( p : ℝ ) ^ ( 1 + ε ) ), show ( p : ℝ ) ^ ( 1 + ε ) > 0 by exact Real.rpow_pos_of_pos ( Nat.cast_pos.mpr <| Nat.Prime.pos <| hT p hp ) _, div_mul_cancel₀ ( |c| : ℝ ) <| ne_of_gt <| Real.rpow_pos_of_pos ( Nat.cast_pos.mpr <| Nat.Prime.pos <| hT p hp ) <| 1 + ε, div_mul_cancel₀ ( c : ℝ ) <| ne_of_gt <| Real.rpow_pos_of_pos ( Nat.cast_pos.mpr <| Nat.Prime.pos <| hT p hp ) <| 1 + ε ] ;
    convert Finset.prod_le_prod ( fun _ _ => abs_nonneg _ ) h_prod_le_exp using 1 ; norm_num [ div_eq_mul_inv, Finset.mul_sum _ _ _, Real.exp_sum ];
  refine' le_trans _ ( h_prod_le_exp.trans _ );
  · exact le_of_abs_le ( by rw [ Finset.abs_prod ] );
  · refine' Real.exp_le_exp.mpr ( mul_le_mul_of_nonneg_left ( Summable.sum_le_tsum _ _ _ ) ( abs_nonneg _ ) );
    · exact fun _ _ => by positivity;
    · exact Real.summable_one_div_nat_rpow.2 ( by linarith )

end PoissonCRT
