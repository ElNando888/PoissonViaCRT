/-
Helper: algebraic cancellation S · (1/s)^n ≤ V + C given S ≤ (V + C) · s^n.
-/
private lemma box_card_ratio_cancel (S V C s : ℝ) (n : ℕ)
    (hVC : 0 ≤ V + C) (hs : 0 < s)
