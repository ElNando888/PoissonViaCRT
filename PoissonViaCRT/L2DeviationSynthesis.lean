/-! ## 1. Cauchy-Schwarz for Finite Sums -/

/-- **Cauchy-Schwarz for finite sums (absolute value form).**
`|∑_{i ∈ s} f(i)| ≤ √|s| · √(∑_{i ∈ s} f(i)²)`. -/
theorem deviation_L1_le_L2 {ι : Type*} (s : Finset ι) (f : ι → ℝ) :
    |∑ i ∈ s, f i| ≤ Real.sqrt s.card * Real.sqrt (∑ i ∈ s, f i ^ 2) := by
  rw [← Real.sqrt_mul (Nat.cast_nonneg _), ← Real.sqrt_sq_eq_abs]
  exact Real.sqrt_le_sqrt (mod_cast sq_sum_le_card_mul_sum_sq)

/-! ## 2. Per-Prime Variance Bound -/

/-- The sum of `|N_p(0,r) − μ_p|` over all residue tuples `r ∈ (ZMod p)^{k−1}`
is at most `p^{k−1} · cEW_p · μ_p`, directly from the `WellDistributed` second
component. -/
lemma sum_abs_localDeviation_le (ε : ℝ) (p : ℕ) (hp : Nat.Prime p) (k : ℕ)
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hWD : @WellDistributed ε p ⟨hp⟩ (Ω p) k) :
    haveI : NeZero p := ⟨hp.ne_zero⟩
    ∑ r : Fin (k - 1) → ZMod p,
      |(tupleCount (Ω p) (Fin.cons 0 r) : ℝ) - (Ω p).card ^ k / (p : ℝ) ^ (k - 1)| ≤
    (p : ℝ) ^ (k - 1) * (1 - (Ω p).card / (p : ℝ)) * (p : ℝ) ^ (-ε) *
      ((Ω p).card ^ k / (p : ℝ) ^ (k - 1)) :=
  hWD.2

/-! ## 3. Mean-Zero Property -/

/-
**Mean-zero property of local deviations.**
The sum of `N_k(0,r,Ω_p) − μ_p` over all residue tuples `r ∈ (ZMod p)^{k−1}` is
zero. This is a double-counting argument: `∑_r N_k(0,r) = |Ω_p|^k = p^{k−1} · μ_p`,
so `∑_r (N_k − μ_p) = 0`.
-/
lemma mean_zero_local_deviation (p : ℕ) [NeZero p] (Ω : Finset (ZMod p)) (k : ℕ) (hk : 1 ≤ k) :
    ∑ r : Fin (k - 1) → ZMod p,
      ((tupleCount Ω (Fin.cons 0 r) : ℝ) - (Ω.card : ℝ) ^ k / (p : ℝ) ^ (k - 1)) = 0 := by
  -- For each $t \in \Omega$, the number of $r$ such that $t + r_i \in \Omega$ for all $i$ is $|\Omega|^{k-1}$.
  have h_card : ∀ t ∈ Ω, ∑ r : Fin (k - 1) → ZMod p, (if ∀ i, t + r i ∈ Ω then 1 else 0) = (Ω.card : ℝ) ^ (k - 1) := by
    intro t ht
    have h_card : ∑ r : Fin (k - 1) → ZMod p, (if ∀ i, t + r i ∈ Ω then 1 else 0) = ∏ i : Fin (k - 1), (∑ r : ZMod p, (if t + r ∈ Ω then 1 else 0)) := by
      rw [ Finset.prod_sum ];
      refine' Finset.sum_bij ( fun r _ => fun i _ => r i ) _ _ _ _ <;> simp +decide;
      · simp +decide [ funext_iff ];
      · exact fun b => ⟨ fun i => b i ( Finset.mem_univ i ), rfl ⟩;
      · intro a; split_ifs <;> simp_all +decide [ Finset.prod_ite ] ;
    simp_all +decide;
    rw [ show ( Finset.filter ( fun x => t + x ∈ Ω ) Finset.univ : Finset ( ZMod p ) ) = Finset.image ( fun x => x - t ) Ω from ?_, Finset.card_image_of_injective _ ( sub_left_injective ) ] ; aesop;
  -- By Fubini's theorem, we can interchange the order of summation.
  have h_fubini : ∑ r : Fin (k - 1) → ZMod p, (Finset.card (Finset.filter (fun t => ∀ i, t + r i ∈ Ω) Ω) : ℝ) = ∑ t ∈ Ω, ∑ r : Fin (k - 1) → ZMod p, (if ∀ i, t + r i ∈ Ω then 1 else 0) := by
    rw [ Finset.sum_comm, Finset.sum_congr rfl ] ; aesop;
  simp_all +decide [ Finset.sum_sub_distrib, tupleCount ];
  convert sub_eq_zero_of_eq h_fubini using 2 <;> norm_num [ Fin.forall_fin_succ ];
  · simp +decide only [filter_and];
    rcongr x ; aesop;
  · rw [ mul_div_cancel₀ _ ( by norm_cast; exact pow_ne_zero _ ( NeZero.ne p ) ), ← pow_succ', Nat.sub_add_cancel hk ]

/-! ## 4. All-Large-Prime Per-T Bound -/

/-- Per-prime Weil bound reformulated with `k` instead of `n+1`.  Wraps
`localCount_deviation_weil` handling the `k - 1 + 1 = k` conversion. -/
private lemma per_prime_large_bound (ε : ℝ) (k : ℕ) (hk : 2 ≤ k)
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hWD : ∀ (p : ℕ) [Fact p.Prime], WellDistributed ε p (Ω p) k)
    (q : ℕ) [NeZero q]
    (X : Box (k - 1))
    (s : ℝ) (hs : 0 < s)
    (p : ℕ) (hp_prime : Nat.Prime p) (hp_factor : p ∈ q.primeFactors)
    (hp_large : (⌈s * ∑ i, X.sides i⌉₊ : ℕ) < p)
    (h : Fin (k - 1) → ℤ)
    (hbox : inScaledBox X s (fun _ => 0) h) :
    |localCount Ω q (Fin.cons (0 : ZMod q) (fun i => (h i : ZMod q))) p -
      localMean k Ω p| ≤
    combinedEulerWeight ε k Ω p * localMean k Ω p := by
  have hk_eq : k - 1 + 1 = k := Nat.sub_add_cancel (by omega)
  have hWD' : @WellDistributed ε p ⟨hp_prime⟩ (Ω p) (k - 1 + 1) := hk_eq ▸ @hWD p ⟨hp_prime⟩
  have h1 := localCount_deviation_weil ε (show 1 ≤ k - 1 by omega) Ω q X s hs p hp_prime hp_factor hp_large hWD' h hbox
  simp only [hk_eq] at h1
  unfold combinedEulerWeight
  exact h1

/-
Helper: pointwise bound on |∏_T (localCount - localMean)| when all primes in T are large.
Uses `per_prime_large_bound` for each p, then assembles via Finset.prod_le_prod.
