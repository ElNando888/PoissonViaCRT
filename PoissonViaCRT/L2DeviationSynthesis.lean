/-!
# Second Moment Method for Large Divisors (L2 Deviation Synthesis)

This file implements the second-moment/Cauchy-Schwarz bounds needed to control the
large-divisor tail in the error term of the Granville–Kurlberg theorem (GK08 §3.1).

## Strategy

For each nonempty subset `T ⊆ primeFactors(q)`, we bound the per-T
inclusion-exclusion contribution by `C · ∏_{p ∈ T} combinedEulerWeight`. The
proof decomposes into two cases:

### Case 1: All primes in T are large (p > B_max)

The box lattice points give injective tuples mod p (by `fin_cons_castHom_injective`),
so the `WellDistributed` first component yields `|N_p(h) − μ_p| ≤ cEW_p · μ_p`
pointwise. Summing over h and absorbing the prefactor gives the bound directly.

### Case 2: T contains at least one small prime

The key insight is the **mean-zero cancellation**: for each prime p,
`∑_{r_p} (N_p(r_p) − μ_p) = 0` (the local count has exact mean μ_p over all
residue classes). By CRT, the product `∑_r ∏_T g_p(r_p) = 0` over complete
residue systems. The lattice-point sum differs from zero only by a boundary
error controlled by `C_lp`.

## Main Results

* `deviation_L1_le_L2` — Cauchy-Schwarz for finite sums.
* `mean_zero_local_deviation` — Mean-zero property of local deviations.
* `all_large_per_T_bound` — Per-T bound when all primes in T are large.
* `per_T_deviation_le_combinedEulerWeight` — The complete per-T bound.
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ## 1. Cauchy-Schwarz for Finite Sums -/

/-- **Cauchy-Schwarz for finite sums (absolute value form).**
`|∑_{i ∈ s} f(i)| ≤ √|s| · √(∑_{i ∈ s} f(i)²)`. -/
theorem deviation_L1_le_L2 {ι : Type*} (s : Finset ι) (f : ι → ℝ) :
    |∑ i ∈ s, f i| ≤ Real.sqrt s.card * Real.sqrt (∑ i ∈ s, f i ^ 2) := by
  rw [← Real.sqrt_mul (Nat.cast_nonneg _), ← Real.sqrt_sq_eq_abs]
  exact Real.sqrt_le_sqrt (mod_cast sq_sum_le_card_mul_sum_sq)

/-! ## 2. Per-Prime Variance Bound -/

/-- The sum of `|N_p(0,r) − μ_p|` over all residue tuples `r ∈ (ZMod p)^{k−1}`
is at most `p^{k−1} · cEW_p · μ_p`, directly from the `WellDistributed` second
component. -/
lemma sum_abs_localDeviation_le (ε : ℝ) (p : ℕ) (hp : Nat.Prime p) (k : ℕ)
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hWD : @WellDistributed ε p ⟨hp⟩ (Ω p) k) :
    haveI : NeZero p := ⟨hp.ne_zero⟩
    ∑ r : Fin (k - 1) → ZMod p,
      |(tupleCount (Ω p) (Fin.cons 0 r) : ℝ) - (Ω p).card ^ k / (p : ℝ) ^ (k - 1)| ≤
    (p : ℝ) ^ (k - 1) * (1 - (Ω p).card / (p : ℝ)) * (p : ℝ) ^ (-ε) *
      ((Ω p).card ^ k / (p : ℝ) ^ (k - 1)) :=
  hWD.2

/-! ## 3. Mean-Zero Property -/

/-
**Mean-zero property of local deviations.**
The sum of `N_k(0,r,Ω_p) − μ_p` over all residue tuples `r ∈ (ZMod p)^{k−1}` is
zero. This is a double-counting argument: `∑_r N_k(0,r) = |Ω_p|^k = p^{k−1} · μ_p`,
so `∑_r (N_k − μ_p) = 0`.
-/
lemma mean_zero_local_deviation (p : ℕ) [NeZero p] (Ω : Finset (ZMod p)) (k : ℕ) (hk : 1 ≤ k) :
    ∑ r : Fin (k - 1) → ZMod p,
      ((tupleCount Ω (Fin.cons 0 r) : ℝ) - (Ω.card : ℝ) ^ k / (p : ℝ) ^ (k - 1)) = 0 := by
  -- For each $t \in \Omega$, the number of $r$ such that $t + r_i \in \Omega$ for all $i$ is $|\Omega|^{k-1}$.
  have h_card : ∀ t ∈ Ω, ∑ r : Fin (k - 1) → ZMod p, (if ∀ i, t + r i ∈ Ω then 1 else 0) = (Ω.card : ℝ) ^ (k - 1) := by
    intro t ht
    have h_card : ∑ r : Fin (k - 1) → ZMod p, (if ∀ i, t + r i ∈ Ω then 1 else 0) = ∏ i : Fin (k - 1), (∑ r : ZMod p, (if t + r ∈ Ω then 1 else 0)) := by
      rw [ Finset.prod_sum ];
      refine' Finset.sum_bij ( fun r _ => fun i _ => r i ) _ _ _ _ <;> simp +decide;
      · simp +decide [ funext_iff ];
      · exact fun b => ⟨ fun i => b i ( Finset.mem_univ i ), rfl ⟩;
      · intro a; split_ifs <;> simp_all +decide [ Finset.prod_ite ] ;
    simp_all +decide;
    rw [ show ( Finset.filter ( fun x => t + x ∈ Ω ) Finset.univ : Finset ( ZMod p ) ) = Finset.image ( fun x => x - t ) Ω from ?_, Finset.card_image_of_injective _ ( sub_left_injective ) ] ; aesop;
  -- By Fubini's theorem, we can interchange the order of summation.
  have h_fubini : ∑ r : Fin (k - 1) → ZMod p, (Finset.card (Finset.filter (fun t => ∀ i, t + r i ∈ Ω) Ω) : ℝ) = ∑ t ∈ Ω, ∑ r : Fin (k - 1) → ZMod p, (if ∀ i, t + r i ∈ Ω then 1 else 0) := by
    rw [ Finset.sum_comm, Finset.sum_congr rfl ] ; aesop;
  simp_all +decide [ Finset.sum_sub_distrib, tupleCount ];
  convert sub_eq_zero_of_eq h_fubini using 2 <;> norm_num [ Fin.forall_fin_succ ];
  · simp +decide only [filter_and];
    rcongr x ; aesop;
  · rw [ mul_div_cancel₀ _ ( by norm_cast; exact pow_ne_zero _ ( NeZero.ne p ) ), ← pow_succ', Nat.sub_add_cancel hk ]

/-! ## 4. All-Large-Prime Per-T Bound -/

/-- When every prime `p ∈ T` satisfies `p > B_max`, the per-T deviation bound follows
from the pointwise `WellDistributed` first component.

For each box lattice point `h`, the tuple `Fin.cons 0 h` is injective modulo every
`p ∈ T` (by `fin_cons_castHom_injective`), so:
`|∏_{p∈T} (N_p(h) − μ_p)| ≤ ∏_T |N_p − μ_p| ≤ ∏_T (cEW_p · μ_p)`

Summing over `h` and using the prefactor absorption:
`|inner_T| ≤ (|S|/|Ω_q|) · ∏_T cEW · ∏_q μ ≤ (vol + C_lp) · ∏_T cEW` -/
lemma all_large_per_T_bound (ε : ℝ) (hε : 0 < ε) (k : ℕ) (hk : 2 ≤ k)
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hΩ : ∀ p, p.Prime → (Ω p).Nonempty)
    (hWD : ∀ (p : ℕ) [Fact p.Prime], WellDistributed ε p (Ω p) k)
    (hsp : ∀ (p : ℕ), p.Prime →
      (p : ℝ) / (Ω p).card ≤ (p : ℝ) ^ (lambdaExponent k - ε))
    (hrp : ∀ (p : ℕ), p.Prime → 1 - (Ω p).card / (p : ℝ) ≤ k / (p : ℝ))
    (hε_lt : ε < lambdaExponent k)
    (X : Box (k - 1))
    (C_lp : ℝ) (hC_lp_pos : 0 < C_lp)
    (hC_lp : ∀ (v : Fin (k - 1) → ℝ), (∀ i, 0 ≤ v i ∧ v i ≤ 1) → ∀ (s : ℝ), 1 ≤ s →
      |(((Fintype.piFinset fun _ : Fin (k - 1) =>
          Finset.Icc (1 : ℤ) ⌈s * ∑ i, X.sides i⌉).filter
        (fun h => inScaledBox X s v h)).card : ℝ) - s ^ (k - 1 : ℕ) * X.volume| ≤
        C_lp * s ^ (((k - 1 : ℕ) : ℤ) - 1))
    (q : ℕ) [NeZero q] (hq_sq : Squarefree q)
    (T : Finset ℕ) (hT : T ∈ q.primeFactors.powerset.filter (· ≠ ∅))
    -- All primes in T are large:
    (hT_large : ∀ p ∈ T,
      (⌈(q : ℝ) / (crtSubset q Ω).card * ∑ i, X.sides i⌉₊ : ℕ) < p) :
    let Ω_q := crtSubset q Ω
    let s := (q : ℝ) / Ω_q.card
    |∑ h ∈ ((Fintype.piFinset fun _ : Fin (k - 1) =>
          Finset.Icc (1 : ℤ) ⌈s * ∑ i, X.sides i⌉).filter
        (fun h => inScaledBox X s (fun _ => 0) h)),
      (1 / (Ω_q.card : ℝ)) *
        ((∏ p ∈ T, (localCount Ω q
            (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p -
            localMean k Ω p)) *
          ∏ p ∈ q.primeFactors \ T, localMean k Ω p)| ≤
    (X.volume + C_lp) * ∏ p ∈ T, combinedEulerWeight ε k Ω p := by
  sorry

/-! ## 5. Per-T Deviation Bound (Complete) -/

/-- **Per-T deviation bound.**
For any nonempty `T ⊆ primeFactors(q)`, the absolute value of the per-T
inclusion-exclusion contribution is bounded by
`C · ∏_{p ∈ T} combinedEulerWeight ε k Ω p`,
where `C` depends on `X`, `C_lp`, `k`, `ε` but not on `q` or `T`.

The proof splits into two cases:
- **All-large T**: every `p ∈ T` has `p > B_max`; use `all_large_per_T_bound`.
- **Mixed T**: at least one `p ∈ T` has `p ≤ B_max`; use the mean-zero
  cancellation + CRT variance decomposition + Cauchy-Schwarz. -/
public lemma per_T_deviation_le_combinedEulerWeight (ε : ℝ) (hε : 0 < ε) (k : ℕ) (hk : 2 ≤ k)
    (Ω : ∀ p : ℕ, Finset (ZMod p))
    (hΩ : ∀ p, p.Prime → (Ω p).Nonempty)
    (hWD : ∀ (p : ℕ) [Fact p.Prime], WellDistributed ε p (Ω p) k)
    (hsp : ∀ (p : ℕ), p.Prime →
      (p : ℝ) / (Ω p).card ≤ (p : ℝ) ^ (lambdaExponent k - ε))
    (hrp : ∀ (p : ℕ), p.Prime → 1 - (Ω p).card / (p : ℝ) ≤ k / (p : ℝ))
    (hε_lt : ε < lambdaExponent k)
    (X : Box (k - 1))
    (C_lp : ℝ) (hC_lp_pos : 0 < C_lp)
    (hC_lp : ∀ (v : Fin (k - 1) → ℝ), (∀ i, 0 ≤ v i ∧ v i ≤ 1) → ∀ (s : ℝ), 1 ≤ s →
      |(((Fintype.piFinset fun _ : Fin (k - 1) =>
          Finset.Icc (1 : ℤ) ⌈s * ∑ i, X.sides i⌉).filter
        (fun h => inScaledBox X s v h)).card : ℝ) - s ^ (k - 1 : ℕ) * X.volume| ≤
        C_lp * s ^ (((k - 1 : ℕ) : ℤ) - 1)) :
    ∃ C_T : ℝ, 0 < C_T ∧ ∀ (q : ℕ) [NeZero q] (_ : Squarefree q)
      (T : Finset ℕ) (_ : T ∈ q.primeFactors.powerset.filter (· ≠ ∅)),
      let Ω_q := crtSubset q Ω
      let s := (q : ℝ) / Ω_q.card
      |∑ h ∈ ((Fintype.piFinset fun _ : Fin (k - 1) =>
            Finset.Icc (1 : ℤ) ⌈s * ∑ i, X.sides i⌉).filter
          (fun h => inScaledBox X s (fun _ => 0) h)),
        (1 / (Ω_q.card : ℝ)) *
          ((∏ p ∈ T, (localCount Ω q
              (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p -
              localMean k Ω p)) *
            ∏ p ∈ q.primeFactors \ T, localMean k Ω p)| ≤
      C_T * ∏ p ∈ T, combinedEulerWeight ε k Ω p := by
  sorry

