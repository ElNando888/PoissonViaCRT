import PoissonViaCRT.CRTMultiplicativity
import PoissonViaCRT.FluctuationHelpers
import PoissonViaCRT.IteratedCancellation

/-!
# Period Pullback via the Chinese Remainder Theorem

This file formalizes the translation between the spatial period of a squarefree modulus `d`
and the algebraic CRT product space `‚àè_{p | d} (‚Ñ§/p‚Ñ§)^k`. It bridges the geometric
picture (lattice points in a complete period modulo `d`) with the algebraic factorization
that enables iterated cancellation.

## Main Results

* `PoissonCRT.box_period_equiv` : For squarefree `d`, the `k`‚Äëtuples `(Fin k ‚Üí ZMod d)` are
  in canonical bijection with the CRT product space `‚àè_{p | d} (Fin k ‚Üí ZMod p)`.
  The construction composes the pointwise CRT ring isomorphism with argument transposition.

* `PoissonCRT.deviation_sum_pullback` : The sum of the product of local deviation functions
  over the CRT product space `‚àè_{p | d} (ZMod p)^k` vanishes. The statement is in the exact
  syntactic form required by `zero_sum_implies_pi_sum_zero` from `IteratedCancellation`.

## References

* [A. Granville, P. Kurlberg, *Poisson statistics via the Chinese remainder theorem*],
  ¬ß1, ¬ß3
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ### Auxiliary instance -/

/-- Every element of `d.primeFactors` is a positive natural number, hence nonzero. -/
public instance neZero_of_mem_primeFactors {d : ‚Ñï} (p : d.primeFactors) : NeZero p.val :=
  ‚ü®(Nat.pos_of_mem_primeFactors p.2).ne'‚ü©

/-! ### 1. The CRT period equivalence -/

/-- **CRT period equivalence.** For squarefree `d`, the `k`‚Äëtuples `(Fin k ‚Üí ZMod d)` are in
canonical bijection with the CRT product space `‚àè_{p | d} (Fin k ‚Üí ZMod p)`.

The construction composes two standard equivalences:
1. **Pointwise CRT**: Apply `crtRingEquiv d hd` to each coordinate, giving
   `(Fin k ‚Üí ZMod d) ‚âÉ (Fin k ‚Üí ‚àè_{p | d} ZMod p)`.
2. **Argument transposition**: Swap the quantifier order via `Equiv.piComm`, giving
   `(Fin k ‚Üí ‚àè_{p | d} ZMod p) ‚âÉ ‚àè_{p | d} (Fin k ‚Üí ZMod p)`. -/
@[expose]
public noncomputable def box_period_equiv (d : ‚Ñï) [NeZero d] (hd : Squarefree d) :
    (Fin k ‚Üí ZMod d) ‚âÉ ((p : d.primeFactors) ‚Üí Fin k ‚Üí ZMod ‚Üëp) :=
  (Equiv.piCongrRight fun _ => (crtRingEquiv d hd).toEquiv).trans
    (Equiv.piComm fun _ _ => _)

/-- Each component of `box_period_equiv` acts as the CRT projection composed with
evaluation at the given coordinate. -/
public theorem box_period_equiv_apply (d : ‚Ñï) [NeZero d] (hd : Squarefree d)
    (g : Fin k ‚Üí ZMod d) (p : d.primeFactors) (i : Fin k) :
    box_period_equiv d hd g p i = crtRingEquiv d hd (g i) p := rfl

/-- `box_period_equiv` at each component agrees with `ZMod.castHom`, the canonical
reduction modulo `p`. -/
public theorem box_period_equiv_apply_eq_castHom (d : ‚Ñï) [NeZero d] (hd : Squarefree d)
    (g : Fin k ‚Üí ZMod d) (p : d.primeFactors) (i : Fin k) :
    box_period_equiv d hd g p i =
      ZMod.castHom (Nat.dvd_of_mem_primeFactors p.2) (ZMod ‚Üëp) (g i) := by
  rw [box_period_equiv_apply, crtRingEquiv_apply_eq_castHom]

/-! ### 2. The local deviation function -/

/-- The local deviation function at a prime `p`: for a `k`‚Äëtuple `g : (ZMod p)^k`,
$$\delta_p(g) \;=\; N_{k+1}\!\bigl((0, g_1, \dots, g_k),\, \Omega_p\bigr)
  \;-\; \frac{|\Omega_p|^{k+1}}{p^k}.$$
The sum `‚àë_g Œ¥_p(g) = 0` for every prime `p`
(by `tupleCount_cons_deviation_sum_zero`). -/
@[expose]
public noncomputable def localDeviation (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (k : ‚Ñï)
    (p : ‚Ñï) [NeZero p] (g : Fin k ‚Üí ZMod p) : ‚Ñù :=
  (tupleCount (Œ© p) (Fin.cons 0 g) : ‚Ñù) - (Œ© p).card ^ (k + 1) / (p : ‚Ñù) ^ k

/-- The local deviation sums to zero over all `g : (ZMod p)^k`. This is a direct
consequence of `tupleCount_cons_deviation_sum_zero`. -/
public theorem localDeviation_sum_zero (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (k : ‚Ñï)
    (p : ‚Ñï) [NeZero p] :
    ‚àë g : Fin k ‚Üí ZMod p, localDeviation Œ© k p g = 0 :=
  tupleCount_cons_deviation_sum_zero (Œ© p) k

/-! ### 3. Deviation sum pullback -/

/-- **Deviation sum pullback.** The sum of the product of local deviation functions over the
CRT product space `‚àè_{p | d} (ZMod p)^k` vanishes:

$$\sum_{x \,\in\, \prod_{p \mid d} (\mathbb{Z}/p\mathbb{Z})^k}
  \;\prod_{p \mid d}\; \delta_p(x_p) \;=\; 0.$$

The statement is in the exact syntactic form required by `zero_sum_implies_pi_sum_zero`
(the iterated cancellation lemma from `IteratedCancellation`): the index type is
`d.primeFactors`, the fiber types are `Fin k ‚Üí ZMod ‚Üëp`, and the integrand is the product
of local deviations `localDeviation Œ© k p (x p)` over all prime factors `p | d`.

We need `d` to have at least one prime factor (equivalently, `1 < d`) so that there exists
a coordinate whose marginal sum vanishes, enabling the application of
`zero_sum_implies_pi_sum_zero`. -/
public theorem deviation_sum_pullback (d : ‚Ñï) [NeZero d] (hd_pos : 0 < d.primeFactors.card)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (k : ‚Ñï) :
    ‚àë x : ((p : d.primeFactors) ‚Üí Fin k ‚Üí ZMod ‚Üëp),
      ‚àè p : d.primeFactors, localDeviation Œ© k ‚Üëp (x p) = 0 := by
  obtain ‚ü®j, hj‚ü© := Finset.card_pos.mp hd_pos
  haveI : NeZero j := ‚ü®(Nat.pos_of_mem_primeFactors hj).ne'‚ü©
  exact sum_prod_pi_eq_zero
    (fun (p : d.primeFactors) (g : Fin k ‚Üí ZMod ‚Üëp) => localDeviation Œ© k ‚Üëp g)
    (j := ‚ü®j, hj‚ü©)
    (localDeviation_sum_zero Œ© k j)

end PoissonCRT
