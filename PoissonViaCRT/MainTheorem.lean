  refine' РЪе 1, zero_lt_one, fun q hq d hd hd' => _ РЪЕ;
  rw [ Finset.abs_prod ];
  refine Finset.prod_le_one ?_ ?_ <;> norm_num;
  ┬и exact fun _ _ _ _ => by positivity;
  ┬и intro p pp dp _; rw [ abs_of_nonneg ( Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) ] ; rw [ abs_of_nonneg ] <;> norm_num;
    ┬и exact le_trans ( mul_le_of_le_one_left ( by positivity ) ( sub_le_self _ ( by positivity ) ) ) ( by simpa using Real.rpow_le_rpow_of_exponent_le ( mod_cast pp.one_lt.le ) ( neg_nonpos.mpr h╬х.le ) );
    ┬и rw [ div_le_iffРѓђ ] <;> norm_cast <;> haveI := Fact.mk pp <;> simp_all;
      ┬и haveI := Fact.mk pp; exact le_trans ( Finset.card_le_univ _ ) ( by norm_num ) ;
      ┬и exact pp.pos

/-
**Complete period cancellation application**: For a divisor `d > 1` of `q`,
the sum of the error product `e_k(h, d) = РѕЈ_{p|d} ╬х_k(h, p)` over lattice
points `h` in the scaled box `sX` is bounded using the cancellation from
`tupleCount_cons_deviation_sum_zero`. The key insight is that complete periods
cancel, and only boundary terms of size `O(s^{k-2})` remain.

Combining the lattice point box bound, the Euler product convergence, and the
period cancellation, the overall error is bounded by `C / s_q`.

Decompose kCorrelation into main term + deviation:

kCorrelation ╬Е_q X = (1/|╬Е_q|) * РѕЉ_h tupleCount(0::h)

Split tupleCount into expected ╬╝ = |╬Е_q|^k / q^{k-1} plus deviation:
= (1/|╬Е_q|) * [|box| * ╬╝ + РѕЉ_h (tupleCount - ╬╝)]
= (╬╝/|╬Е_q|) * |box| + deviation_sum
= s^{-(k-1)} * |box| + deviation_sum

where s^{-(k-1)} = (|╬Е_q|/q)^{k-1} = ╬╝/|╬Е_q|.

By the triangle inequality:
|kCorrelation - vol(X)| РЅц |s^{-(k-1)} * |box| - vol(X)| + |deviation_sum|

For the first term: s^{-(k-1)} * ||box| - s^{k-1} * vol(X)| РЅц s^{-(k-1)} * C_lp * s^{(k-1)-1} = C_lp * s^{-1}.
This uses h_lp_q.

For the second term: |deviation_sum| РЅц C_dev * s^{-1}.
This is exactly h_dev_q.

So: |kCorrelation - vol| РЅц C_lp * s^{-1} + C_dev * s^{-1} = (C_lp + C_dev) * s^{-1} РЅц (C_lp + C_dev + 1) * s^{-1}.

Key steps: unfold kCorrelation, use Finset.sum_sub_distrib to split the sum, convert the main term to s^{-(k-1)} * |box| using algebra, apply the triangle inequality, use h_lp_q and h_dev_q, and combine.
-/
-- set_option maxHeartbeats 800000 in
lemma complete_period_cancellation_apply
    (╬х : РёЮ) (h╬х : 0 < ╬х) (k : РёЋ) (hk : 2 РЅц k)
    (╬Е : Рѕђ p : РёЋ, Finset (ZMod p))
    (h╬Е : Рѕђ p, p.Prime Рєњ (╬Е p).Nonempty)
    (hWD : Рѕђ (p : РёЋ) [Fact p.Prime], WellDistributed ╬х p (╬Е p) k)
    (hsp : Рѕђ (p : РёЋ), p.Prime Рєњ
      (p : РёЮ) / (╬Е p).card РЅц (p : РёЮ) ^ (lambdaExponent k - ╬х))
    (h_lp : Рѕђ (X : Box (k - 1)), РѕЃ C : РёЮ, 0 < C РѕД Рѕђ (v : Fin (k - 1) Рєњ РёЮ), (Рѕђ i, 0 РЅц v i РѕД v i РЅц 1) Рєњ
      Рѕђ (s : РёЮ), 1 РЅц s Рєњ
      |(((Fintype.piFinset fun _ : Fin (k - 1) =>
          Finset.Icc (1 : Рёц) Рїѕs * РѕЉ i, X.sides iРїЅ).filter
        (fun h => inScaledBox X s v h)).card : РёЮ) - s ^ (k - 1 : РёЋ) * X.volume| РЅц
        C * s ^ (((k - 1 : РёЋ) : Рёц) - 1))
    (h_ep : РѕЃ C : РёЮ, 0 < C РѕД Рѕђ (q : РёЋ) [NeZero q],
      Рѕђ (d : РёЋ), d РѕБ q Рєњ 1 < d Рєњ
        |РѕЈ p Рѕѕ d.primeFactors,
          ((1 : РёЮ) - (╬Е p).card / p) * (p : РёЮ) ^ (-╬х)| РЅц C) :
    РѕЃ ╬┤ : РёЮ, 0 < ╬┤ РѕД Рѕђ (X : Box (k - 1)), РѕЃ C : РёЮ, 0 < C РѕД
      Рѕђ (q : РёЋ) [NeZero q] (_hq_sq : Squarefree q),
        |kCorrelation (crtSubset q ╬Е) X - X.volume| РЅц
          C * ((q : РёЮ) / (crtSubset q ╬Е).card) ^ (-╬┤) := by
  -- The deviation synthesis now returns РѕЃ ╬┤ > 0, and we propagate this ╬┤ through
  -- the cancellation argument. The key change: the old bound was O(s^{-1}), now
  -- it is O(s^{-╬┤}) for some ╬┤ > 0 that may be < 1 when k = 2.
  -- TODO: Adapt the algebraic cancellation proof to the general s^{-╬┤} form.
  -- For now, this is sorry'd pending the k=2 Cauchy-Schwarz completion.
  sorry

/-- **Fluctuation bound** (core of Proposition 3.6): Under the well-distribution hypothesis,
the error `|R_k(X) - vol(X)|` is bounded by `C ┬и s_q^{-╬┤}` for some `╬┤ > 0`.

This is the core mathematical content of Proposition 3.6 from GranvilleРђЊKurlberg
(arXiv:math/0412135v2, ┬Д3.2). The proof combines:
1. **Lattice point box bound** (`lattice_point_box_bound`): approximation of lattice
   point counts in scaled boxes.
2. **Euler product convergence** (`euler_product_convergence`): boundedness of the
   multiplicative error product under WD.
3. **Complete period cancellation** (`complete_period_cancellation_apply`): cancellation
   from `tupleCount_cons_deviation_sum_zero` applied to box sums. -/
private lemma fluctuation_bound
    (╬х : РёЮ) (h╬х : 0 < ╬х) (k : РёЋ) (hk : 2 РЅц k)
    (╬Е : Рѕђ p : РёЋ, Finset (ZMod p))
    (h╬Е : Рѕђ p, p.Prime Рєњ (╬Е p).Nonempty)
    (hWD : Рѕђ (p : РёЋ) [Fact p.Prime], WellDistributed ╬х p (╬Е p) k)
    (hsp : Рѕђ (p : РёЋ), p.Prime Рєњ
      (p : РёЮ) / (╬Е p).card РЅц (p : РёЮ) ^ (lambdaExponent k - ╬х)) :
    РѕЃ ╬┤ : РёЮ, 0 < ╬┤ РѕД Рѕђ (X : Box (k - 1)), РѕЃ C : РёЮ, 0 < C РѕД
      Рѕђ (q : РёЋ) [NeZero q] (_hq_sq : Squarefree q),
        |kCorrelation (crtSubset q ╬Е) X - X.volume| РЅц
          C * ((q : РёЮ) / (crtSubset q ╬Е).card) ^ (-╬┤) := by
  -- Step 1: Obtain the lattice point box bound
  have h_lp : Рѕђ (X : Box (k - 1)), _ := fun X => lattice_point_box_bound (k - 1) X
  -- Step 2: Obtain the Euler product convergence bound
  have h_ep := euler_product_convergence ╬х h╬х k hk ╬Е h╬Е hWD hsp
  -- Step 3: Apply the complete period cancellation to combine these bounds.
  -- The ╬┤ now comes from the deviation synthesis, not hardcoded to 1.
  obtain РЪе╬┤, h╬┤_pos, h_cpcРЪЕ := complete_period_cancellation_apply ╬х h╬х k hk ╬Е h╬Е hWD hsp h_lp h_ep
  exact РЪе╬┤, h╬┤_pos, h_cpcРЪЕ

/-- **Proposition 3.6** (simplified form): Under the well-distribution hypothesis (1) with
parameter `╬х`, the error in the `k`-level correlation is bounded by `C ┬и s_q^{-╬┤}` for
some `╬┤ > 0` depending on `╬х`, and some constant `C > 0` depending on the box `X`.

Note: The original formalization had issues that have been corrected:
1. `kCorrelation` now filters by `inScaledBox` (matching the paper's definition)
2. The bound includes a box-dependent constant `C`
3. Non-emptiness of `╬Е p` for primes `p` is explicitly required -/
theorem error_bound_simplified
    (╬х : РёЮ) (h╬х : 0 < ╬х) (k : РёЋ) (hk : 2 РЅц k)
    (╬Е : Рѕђ p : РёЋ, Finset (ZMod p))
    (h╬Е : Рѕђ p, p.Prime Рєњ (╬Е p).Nonempty)
    (hWD : Рѕђ (p : РёЋ) [Fact p.Prime], WellDistributed ╬х p (╬Е p) k)
    (hsp : Рѕђ (p : РёЋ), p.Prime Рєњ
      (p : РёЮ) / (╬Е p).card РЅц (p : РёЮ) ^ (lambdaExponent k - ╬х)) :
    РѕЃ ╬┤ : РёЮ, 0 < ╬┤ РѕД Рѕђ (X : Box (k - 1)), РѕЃ C : РёЮ, 0 < C РѕД
      Рѕђ (q : РёЋ) [NeZero q] (_hq_sq : Squarefree q),
        |kCorrelation (crtSubset q ╬Е) X - X.volume| РЅц
          C * ((q : РёЮ) / (crtSubset q ╬Е).card) ^ (-╬┤) := by
  exact fluctuation_bound ╬х h╬х k hk ╬Е h╬Е hWD hsp

/-! ### Theorem 3.7 (= Theorem 1.1, precise version) -/

/-
**Theorem 3.7** (Theorem 1.1, precise version): Fix `╬х > 0` and integer `K`.
Suppose subsets `╬Е_p Ріє Рёц/pРёц` satisfy:
1. `s_p РЅц p^{╬╗_K - ╬х}` for all primes `p`,
2. Hypothesis (1) holds for all `k РЅц K` with distinct `h` mod `p`.

Then for `k РЅц K` and any box `X`, the `k`-level correlation satisfies
`R_k(X, ╬Е_q) = vol(X) + o_{X,k}(1)` as `s_q Рєњ Рѕъ`.

This follows from Proposition 3.6 and the lemma below.
-/
theorem mainTheorem_precise
    (╬х : РёЮ) (h╬х : 0 < ╬х) (K : РёЋ) (hK : 2 РЅц K)
    (╬Е : Рѕђ p : РёЋ, Finset (ZMod p))
    (h╬Е : Рѕђ p, p.Prime Рєњ (╬Е p).Nonempty)
    (hWD : Рѕђ (p : РёЋ) [Fact p.Prime] (k : РёЋ), k РЅц K Рєњ
      WellDistributed ╬х p (╬Е p) k)
    (hsp : Рѕђ (p : РёЋ), p.Prime Рєњ
      (p : РёЮ) / (╬Е p).card РЅц (p : РёЮ) ^ (lambdaExponent K - ╬х)) :
    Рѕђ (k : РёЋ), 2 РЅц k Рєњ k РЅц K Рєњ Рѕђ (X : Box (k - 1)),
      РѕЃ ╬┤ : РёЮ, 0 < ╬┤ РѕД РѕЃ C : РёЮ, 0 < C РѕД Рѕђ (q : РёЋ) [NeZero q] (_hq_sq : Squarefree q),
        |kCorrelation (crtSubset q ╬Е) X - X.volume| РЅц
          C * ((q : РёЮ) / (crtSubset q ╬Е).card) ^ (-╬┤) := by
  intro k hk2 hk_le X
  have h_lam : lambdaExponent K РЅц lambdaExponent k := by
    unfold lambdaExponent; split_ifs ;
    any_goals linarith;
    any_goals rw [ div_le_div_iffРѓђ ] <;> nlinarith [ Real.sqrt_nonneg 17, Real.sq_sqrt ( show 0 РЅц 17 by norm_num ), show ( k : РёЮ ) РЅЦ 2 by norm_cast, show ( K : РёЮ ) РЅЦ k by norm_cast ];
    ┬и omega;
    ┬и omega;
    ┬и rw [ div_le_div_iffРѓђ ] <;> nlinarith [ Real.sqrt_nonneg 17, Real.sq_sqrt ( show 0 РЅц 17 by norm_num ), show ( K : РёЮ ) РЅЦ 4 by norm_cast; omega ];
    ┬и rw [ div_le_div_iffРѓђ ] <;> linarith [ show ( K : РёЮ ) РЅЦ 4 by norm_cast; omega ]
  have hsp_k : Рѕђ (p : РёЋ), p.Prime Рєњ (p : РёЮ) / (╬Е p).card РЅц (p : РёЮ) ^ (lambdaExponent k - ╬х) := by
    intro p hp
    have h_base := hsp p hp
    have h_pow : (p : РёЮ) ^ (lambdaExponent K - ╬х) РЅц (p : РёЮ) ^ (lambdaExponent k - ╬х) := by
      apply Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast hp.one_le)
      linarith
    exact le_trans h_base h_pow
  have := error_bound_simplified ╬х h╬х k hk2 ╬Е h╬Е (fun p _ => hWD p k hk_le) hsp_k
  exact РЪеthis.choose, this.choose_spec.1, this.choose_spec.2 XРЪЕ

/-
**Lemma following Theorem 3.7**: Under the well-distribution hypothesis with suitable
bounds on `s_p`, the `p`-th factor in each Euler product is `s_p^{o(1)}`, so each
Euler product is `s_q^{o(1)}` and `Error РЅц s_q^{-╬┤}` for some `╬┤ > 0`.

Choose ╬┤ = ╬х (positive by h╬х). Then for any prime p, subset ╬Е, assuming WellDistributed ╬х p ╬Е k, the spacing bound, and given injective h:

Case 1: If ╬Е.card = 0, then epsilonError = 0 by the if-then-else in the definition, and |0| = 0 РЅц RHS (since RHS = (1 - 0) * p^(-╬х) РЅЦ 0, because p^(-╬х) РЅЦ 0).

Case 2: If ╬Е.card > 0: WellDistributed gives |tupleCount ╬Е h - expected| РЅц (1 - |╬Е|/p) * p^(-╬х) * expected, where expected = |╬Е|^k / p^(k-1) > 0.

epsilonError = tupleCount/expected - 1, so |epsilonError| = |tupleCount/expected - 1| = |tupleCount - expected| / expected (using the fact that for b > 0, |a/b - 1| = |a - b| / b).

From WellDistributed: |tupleCount - expected| / expected РЅц (1 - |╬Е|/p) * p^(-╬х).

Key steps:
1. refine РЪе╬х, h╬х, fun p _ ╬Е hWD _ h hInj => ?_РЪЕ
2. Unfold epsilonError, split on ╬Е.card = 0.
3. If ╬Е.card = 0: simp.
4. If ╬Е.card РЅа 0: let E := expected, show E > 0, then rewrite |.../E - 1| as |... - E|/E, then apply div_le_iff and use WellDistributed.
-/
theorem error_from_euler_products
    (╬х : РёЮ) (h╬х : 0 < ╬х) (k : РёЋ) (_ : 2 РЅц k) :
    РѕЃ ╬┤ : РёЮ, 0 < ╬┤ РѕД Рѕђ (p : РёЋ) [Fact p.Prime] (╬Е : Finset (ZMod p)),
      WellDistributed ╬х p ╬Е k Рєњ
      (p : РёЮ) / ╬Е.card РЅц (p : РёЮ) ^ (lambdaExponent k - 2 * ╬х) Рєњ
        Рѕђ (h : Fin k Рєњ ZMod p), Function.Injective h Рєњ
          |epsilonError ╬Е h| РЅц (1 - ╬Е.card / p : РёЮ) * (p : РёЮ) ^ (-╬х) := by
  refine' РЪе ╬х, h╬х, _ РЪЕ;
  intro p hp ╬Е hWD hsp h hInj
  unfold epsilonError
  simp +decide;
  split_ifs <;> simp_all +decide [ WellDistributed ];
  ┬и positivity;
  ┬и convert div_le_div_of_nonneg_right ( hWD.1 h hInj ) ( show 0 РЅц ( ( ╬Е.card : РёЮ ) ^ k / p ^ ( k - 1 ) ) by positivity ) using 1;
    ┬и rw [ div_sub_one, abs_div ] <;> norm_num [ show ( ╬Е.card : РёЮ ) РЅа 0 by exact Nat.cast_ne_zero.mpr <| ne_of_gt <| Finset.card_pos.mpr <| Finset.nonempty_iff_ne_empty.mpr Рђ╣_Рђ║ ];
      ┬и rw [ abs_of_nonneg ( by positivity : 0 РЅц ( ╬Е.card : РёЮ ) ^ k / p ^ ( k - 1 ) ) ];
      ┬и exact fun h => absurd h hp.1.ne_zero;
    ┬и rw [ mul_div_cancel_rightРѓђ _ ( ne_of_gt ( div_pos ( pow_pos ( Nat.cast_pos.mpr ( Finset.card_pos.mpr ( Finset.nonempty_of_ne_empty Рђ╣_Рђ║ ) ) ) _ ) ( pow_pos ( Nat.cast_pos.mpr hp.1.pos ) _ ) ) ) ]

