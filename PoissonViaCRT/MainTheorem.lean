/-! ### Special case: Hooley's theorem (integers coprime to q) -/

/-- **Hooley's theorem** (recovered from Theorem 1.1): For `╬Е_p = {x Рѕѕ Рёц/pРёц : x РЅа 0}`
(integers coprime to `p`), the tuple counting function satisfies
`N_k(h, ╬Е_p) = p - k` for injective `h`. -/
theorem coprime_tupleCount (p : РёЋ) [hp : Fact p.Prime] (k : РёЋ)
    (h : Fin k Рєњ ZMod p) (hh : Function.Injective h) :
    tupleCount (univ.filter (┬и РЅа (0 : ZMod p))) h = p - k := by
  by_contra h_contra
  have h_set : Finset.filter (fun t : ZMod p => Рѕђ i, t + h i РЅа 0) Finset.univ =
      Finset.univ \ Finset.image (fun i => -h i) Finset.univ := by
    grind
  unfold tupleCount at h_contra
  simp_all +decide [Finset.card_sdiff]
  exact h_contra (by
    rw [Finset.card_image_of_injective _ fun i j hij => by simpa [hh.eq_iff] using hij]
    simp +decide)

