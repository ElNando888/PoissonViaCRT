          Prime.factorization, Finsupp.coe_add, Pi.add_apply, Finsupp.single_eq_same, reduceAdd,
          _root_.mul_eq_zero, or_self, Nat.add_eq_zero_iff, and_false, and_self,
          le_add_iff_nonneg_right]
