  intro d m hd hm
  induction d generalizing m
  case zero => contradiction
  case succ d ih =>
    induction hm <;> simp_all +decide only [le_add_iff_nonneg_left, _root_.zero_le, Nat.pow_succ']
    case refl =>
      refine Nat.recOn d ?_ ?_ <;> simp_all +decide [ Nat.stirlingSecond, Nat.choose ]
      grind +suggestions
    case step m hm ih =>
      by_cases hd : 1 ≤ d
      · simp_all +decide only [forall_const, le_eq, succ_eq_add_one]
        have h_combined : (m + 2 + d).choose 2 ^ (d + 1)
          ≥ (m + 1) * (m + 1 + d).choose 2 ^ d + (m + 1 + d).choose 2 ^ (d + 1) := by
          have h_combined : (m + 2 + d).choose 2 ^ (d + 1)
            ≥ ((m + 1 + d).choose 2 + (m + 1)) * (m + 1 + d).choose 2 ^ d := by
            rw [ show m + 2 + d = m + 1 + d + 1 by ring, Nat.choose_two_succ ]
            rw [ pow_succ' ]
            exact Nat.mul_le_mul ( by linarith ) ( Nat.pow_le_pow_left ( by linarith ) _ )
          grind
        have h_combined : (m + 1) * (m + 1 + d).stirlingSecond (m + 1)
          + (m + 1 + d).stirlingSecond m
          ≤ (m + 1) * (m + 1 + d).choose 2 ^ d + (m + 1 + d).choose 2 ^ (d + 1) := by
          apply Nat.add_le_add
          · exact Nat.mul_le_mul_left _ ( by
              simpa only [ add_comm, add_left_comm, add_assoc ]
                using ‹∀ m : ℕ, 1 ≤ m → ( m + d ).stirlingSecond m
                  ≤ ( m + d ).choose 2 ^ d› ( m + 1 ) ( by linarith ) )
          · grind
        convert h_combined.trans ‹_› using 1
        ring_nf
      · simp_all +decide [ Nat.stirlingSecond_succ_succ, Nat.choose_two_succ ]
        simp +decide [ Nat.stirlingSecond_eq_zero_of_lt ]
        simp_all +arith +decide [ Nat.stirlingSecond_self ]

/-- Apply a permutation `σ` of `{0, …, k-1}` to a Gamma
structure. The permuted structure has
`γ^(σ)_{i,j} = γ_{σ(i), σ(j)}`. -/
def GammaStructure.permute (Γ : GammaStructure k)
    (σ : Equiv.Perm (Fin k)) : GammaStructure k where
  gamma i j := Γ.gamma (σ i) (σ j)
  symm i j := Γ.symm (σ i) (σ j)
  pos i j hij := Γ.pos (σ i) (σ j)
    (fun h => hij (σ.injective h))
  sqfree i j hij := Γ.sqfree (σ i) (σ j)
    (fun h => hij (σ.injective h))
  compat i j l hij hjl hil := Γ.compat (σ i) (σ j) (σ l)
    (fun h => hij (σ.injective h))
    (fun h => hjl (σ.injective h))
    (fun h => hil (σ.injective h))
  diag i := Γ.diag (σ i)

