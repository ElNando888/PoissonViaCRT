lemma GammaStructure.gammaRow_squarefree
    (Γ : GammaStructure k) (j : Fin k) :
    Squarefree (Γ.gammaRow j) := by
  have h_lcm_sqfree : ∀ {S : Finset ℕ},
      (∀ s ∈ S, Squarefree s) →
        Squarefree (Finset.lcm S id) := by
