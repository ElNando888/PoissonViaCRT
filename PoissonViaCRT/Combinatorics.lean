          ⟨Finset.mem_univ _, hrefl₁ j₁⟩⟩ := by aesop
    obtain ⟨j₂, hj₂⟩ : ∃ j₂, a₂ = Finset.min'
        (Finset.univ.filter fun i => R₁ i j₂)
        ⟨j₂, Finset.mem_filter.mpr
          ⟨Finset.mem_univ _, hrefl₁ j₂⟩⟩ := by
      rw [Finset.mem_image] at ha₂
      obtain ⟨j₂, _, rfl⟩ := ha₂; exact ⟨j₂, rfl⟩
