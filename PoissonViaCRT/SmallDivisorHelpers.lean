    (d : ℕ) [NeZero d] (r : Fin k → ZMod d) (b : Fin k → ℤ) :
    let r_1 : Fin k → ℤ := fun i =>
      if (ZMod.val (r i) : ℤ) = 0 then (d : ℤ) else (ZMod.val (r i) : ℤ)
