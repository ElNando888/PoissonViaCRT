/-!
# τ-Optimization from §3.2 of Granville–Kurlberg

This file formalizes the core combinatorial definitions and abstract summation bound
from Section 3.2 of "Poisson statistics via the Chinese remainder theorem" by
Granville and Kurlberg (arXiv:math/0412135v2).

The τ-optimization partitions the prime factors of a squarefree integer `q` into
"active" and "inactive" primes. Each subset `T` of the prime factors contributes
a weight `2^{|T|} · ∏_{p ∈ T} p^{-ε}` to the total error bound. The key insight
is that this sum factorizes as a product over individual primes, allowing a
uniform bound independent of `q`.

## Main Definitions

* `PoissonCRT.tauLocalWeight ε p`: The local weight `2 · p^{-ε}` for a prime `p`.
* `PoissonCRT.tauPartitionSum ε S`: The sum over all subsets `T ⊆ S` of
  `∏_{p ∈ T} (2 · p^{-ε})`.
* `PoissonCRT.tauDimension`: The number `|T|` of active primes.
* `PoissonCRT.tauWeight ε T`: The accumulated savings `∑_{p ∈ T} p^{-ε}`.
* `PoissonCRT.tauBoundConstant ε`: The convergent constant
  `C(ε) = exp(∑' n, 2 · n^{-ε})` bounding the partition sum for all `q`.

## Main Results

* `PoissonCRT.tauPartitionSum_eq_prod`: The partition sum factorizes as
  `∏_{p ∈ S} (1 + 2 · p^{-ε})`.
* `PoissonCRT.tauPartitionSum_le_exp`: The partition sum is bounded by
  `exp(∑_{p ∈ S} 2 · p^{-ε})`.
* `PoissonCRT.tauPartitionSum_le_bound`: For `ε > 1`, the partition sum over any
  finset is at most `C(ε)`, a convergent constant independent of `q`.

## References

* [A. Granville, P. Kurlberg, *Poisson statistics via the Chinese remainder theorem*]
  [arXiv:math/0412135v2], §3.2
-/

open Finset BigOperators Real

namespace PoissonCRT

/-! ### §3.2 Partition Definitions -/

/-- The local weight for a natural number `p` with savings exponent `ε`:
`tauLocalWeight ε p = 2 * p ^ (-ε)`.

In the context of §3.2 of Granville–Kurlberg, when a prime `p` is "activated"
in a τ-partition, it contributes this weight to the optimization bound. -/
@[expose]
public noncomputable def tauLocalWeight (ε : ℝ) (p : ℕ) : ℝ :=
  2 * (p : ℝ) ^ (-ε)

/-- The dimension `v(τ)` of a τ-partition is the cardinality of the active set `T`.
This counts the number of primes contributing to the well-distribution savings. -/
def tauDimension (T : Finset ℕ) : ℕ := T.card

/-- The weight `w(τ, ε)` of a τ-partition: the accumulated savings
`∑_{p ∈ T} p^{-ε}` from the active primes. -/
noncomputable def tauWeight (ε : ℝ) (T : Finset ℕ) : ℝ :=
  ∑ p ∈ T, (p : ℝ) ^ (-ε)

/-- The partition sum over a finset `S`:
`tauPartitionSum ε S = ∑_{T ⊆ S} ∏_{p ∈ T} tauLocalWeight ε p`.

This is the total optimization weight from §3.2, summing over all possible
τ-partitions (subsets of the prime factor set). -/
@[expose]
public noncomputable def tauPartitionSum (ε : ℝ) (S : Finset ℕ) : ℝ :=
  ∑ T ∈ S.powerset, ∏ p ∈ T, tauLocalWeight ε p

/-- The convergent bound constant `C(ε) = exp(∑' n, tauLocalWeight ε n)`.
For `ε > 1`, this is a finite positive constant that bounds the partition sum
for all finsets `S`. -/
@[expose]
public noncomputable def tauBoundConstant (ε : ℝ) : ℝ :=
  exp (∑' n : ℕ, tauLocalWeight ε n)

/-! ### Basic Properties -/

/-- The local weight is nonneg for any `ε` and `p : ℕ`. -/
public theorem tauLocalWeight_nonneg (ε : ℝ) (p : ℕ) : 0 ≤ tauLocalWeight ε p :=
  mul_nonneg (by norm_num) (rpow_nonneg (Nat.cast_nonneg p) (-ε))

/-- The partition sum is nonneg. -/
theorem tauPartitionSum_nonneg (ε : ℝ) (S : Finset ℕ) : 0 ≤ tauPartitionSum ε S :=
  Finset.sum_nonneg fun _ _ =>
    Finset.prod_nonneg fun p _ => tauLocalWeight_nonneg ε p

/-! ### The Factorization Identity -/

/-- **Factorization identity**: The partition sum factors as a product over primes:
`∑_{T ⊆ S} ∏_{p ∈ T} (2 · p^{-ε}) = ∏_{p ∈ S} (1 + 2 · p^{-ε})`.

This is the combinatorial heart of the §3.2 optimization, reducing the sum over
exponentially many partitions to a product over individual primes. -/
theorem tauPartitionSum_eq_prod (ε : ℝ) (S : Finset ℕ) :
    tauPartitionSum ε S = ∏ p ∈ S, (1 + tauLocalWeight ε p) :=
  (Finset.prod_one_add S).symm

/-! ### Exponential Bound -/

/-- Each factor `1 + tauLocalWeight ε p ≥ 0`. -/
private theorem one_add_tauLocalWeight_nonneg (ε : ℝ) (p : ℕ) :
    0 ≤ 1 + tauLocalWeight ε p :=
  le_trans zero_le_one (le_add_of_nonneg_right (tauLocalWeight_nonneg ε p))

/-- **Exponential bound on the partition sum**:
`tauPartitionSum ε S ≤ exp(∑_{p ∈ S} tauLocalWeight ε p)`.

Since `1 + x ≤ exp(x)` for all real `x`, each factor in the product is bounded
by the corresponding exponential, giving a product-to-exp comparison. -/
theorem tauPartitionSum_le_exp (ε : ℝ) (S : Finset ℕ) :
    tauPartitionSum ε S ≤ exp (∑ p ∈ S, tauLocalWeight ε p) := by
  rw [tauPartitionSum_eq_prod, exp_sum]
  exact Finset.prod_le_prod
    (fun i _ => one_add_tauLocalWeight_nonneg ε i)
    (fun i _ => by linarith [add_one_le_exp (tauLocalWeight ε i)])

/-! ### Summability and Convergence -/

/-
For `ε > 1`, the function `n ↦ (n : ℝ) ^ (-ε)` is summable over `ℕ`.
-/
private theorem summable_natCast_rpow_neg {ε : ℝ} (hε : 1 < ε) :
    Summable (fun n : ℕ => (n : ℝ) ^ (-ε)) := by
  convert Real.summable_nat_rpow_inv.mpr hε using 1;
  simp +contextual [ Real.rpow_neg ]

/-
For `ε > 1`, the local weight function is summable over `ℕ`.
-/
theorem tauLocalWeight_summable {ε : ℝ} (hε : 1 < ε) :
    Summable (fun n : ℕ => tauLocalWeight ε n) := by
  exact Summable.mul_left _ <| Real.summable_nat_rpow.2 <| by linarith;

/-- For `ε > 1`, the bound constant `C(ε)` is positive. -/
theorem tauBoundConstant_pos (ε : ℝ) : 0 < tauBoundConstant ε :=
  exp_pos _

/-- The finite sum of local weights over any finset is bounded by the tsum
when the series converges. -/
private theorem sum_le_tsum_tauLocalWeight (ε : ℝ) (S : Finset ℕ)
    (hs : Summable (fun n : ℕ => tauLocalWeight ε n)) :
    ∑ p ∈ S, tauLocalWeight ε p ≤ ∑' n, tauLocalWeight ε n :=
  hs.sum_le_tsum S (fun i _ => tauLocalWeight_nonneg ε i)

/-! ### The Main Bound -/

/-- **The q-independent bound**: For `ε > 1`, the partition sum
`∑_{T ⊆ S} ∏_{p ∈ T} (2 · p^{-ε})`
is bounded above by the convergent constant
`C(ε) = exp(∑' n, 2 · n^{-ε})`
for ALL finsets `S` (and in particular for `S = primeFactors(q)` for any `q`).

This is the abstract form of the main result of §3.2: the optimization sum
converges uniformly over all squarefree integers. -/
public theorem tauPartitionSum_le_bound {ε : ℝ} (hε : 1 < ε) (S : Finset ℕ) :
    tauPartitionSum ε S ≤ tauBoundConstant ε :=
  calc tauPartitionSum ε S
      ≤ exp (∑ p ∈ S, tauLocalWeight ε p) := tauPartitionSum_le_exp ε S
    _ ≤ exp (∑' n, tauLocalWeight ε n) :=
        exp_le_exp.mpr (sum_le_tsum_tauLocalWeight ε S (tauLocalWeight_summable hε))
    _ = tauBoundConstant ε := rfl

/-- **Strict bound**: For `ε > 1`, the partition sum is strictly less than
`C(ε) + 1`. -/
theorem tauPartitionSum_lt_bound_add_one {ε : ℝ} (hε : 1 < ε) (S : Finset ℕ) :
    tauPartitionSum ε S < tauBoundConstant ε + 1 :=
  lt_of_le_of_lt (tauPartitionSum_le_bound hε S) (lt_add_one _)

/-! ### Specialization to Prime Factors -/

/-- For a squarefree integer `q`, the partition sum over its prime factors
is bounded by `C(ε)`. -/
theorem tauPartitionSum_primeFactors_le {ε : ℝ} (hε : 1 < ε) (q : ℕ) :
    tauPartitionSum ε q.primeFactors ≤ tauBoundConstant ε :=
  tauPartitionSum_le_bound hε q.primeFactors

/-! ### Monotonicity -/

/-
The partition sum is monotone in the finset: if `S ⊆ S'`, then
`tauPartitionSum ε S ≤ tauPartitionSum ε S'`.

This reflects the fact that enlarging the set of prime factors (increasing `q`)
can only increase the optimization sum.
-/
theorem tauPartitionSum_mono (ε : ℝ) {S S' : Finset ℕ} (h : S ⊆ S') :
    tauPartitionSum ε S ≤ tauPartitionSum ε S' := by
  rw [tauPartitionSum_eq_prod, tauPartitionSum_eq_prod, ← Finset.prod_sdiff h]
  exact le_mul_of_one_le_left
    (Finset.prod_nonneg fun _ _ =>
      add_nonneg zero_le_one (tauLocalWeight_nonneg _ _))
    (le_trans (by norm_num)
      (Finset.prod_le_prod (fun _ _ => by norm_num)
        fun _ _ => le_add_of_nonneg_right (tauLocalWeight_nonneg _ _)))

/-! ### Simple Evaluations -/

/-- The partition sum of the empty set is 1. -/
@[simp]
theorem tauPartitionSum_empty (ε : ℝ) : tauPartitionSum ε ∅ = 1 := by
  simp [tauPartitionSum]

/-- The partition sum of a singleton `{p}` is `1 + 2 · p^{-ε}`. -/
@[simp]
theorem tauPartitionSum_singleton (ε : ℝ) (p : ℕ) :
    tauPartitionSum ε {p} = 1 + tauLocalWeight ε p := by
  rw [tauPartitionSum_eq_prod, Finset.prod_singleton]

end PoissonCRT
