/-!
# Divisor Sum Glue Lemmas

Helper lemmas for the Fourier → divisor sum bound in `MobiusSynthesis.lean`.
These handle the divisor-sum algebraic manipulation for `divisor_sum_uniform_bound`.
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ## Logarithmic bound -/

/-
log(d) + 1 ≤ C * d^δ for all d ≥ 1 and δ > 0.
    Proof: log(x) ≤ x^δ/δ for x ≥ 1 (since e^t ≥ 1+t), so
    log(d) + 1 ≤ d^δ/δ + 1 ≤ (1/δ + 1) * d^δ (using d^δ ≥ 1).
-/
lemma log_add_one_le_rpow (δ : ℝ) (hδ : 0 < δ) :
    ∃ C : ℝ, 0 < C ∧ ∀ (d : ℕ), 1 ≤ d → Real.log (d : ℝ) + 1 ≤ C * (d : ℝ) ^ δ := by
  use 1 / δ + 1, by positivity, fun d hd => ?_;
  have := Real.log_le_sub_one_of_pos ( by positivity : 0 < ( d : ℝ ) ^ δ );
  rw [ Real.log_rpow ( by positivity ) ] at this; ring_nf at this ⊢; nlinarith [ inv_pos.mpr hδ, mul_inv_cancel₀ hδ.ne', show ( 1 : ℝ ) ≤ d ^ δ by exact Real.one_le_rpow ( mod_cast hd ) hδ.le ] ;

/-! ## Divisor swap trick -/

/-
The divisor-swap trick: for squarefree q, ∑_{d|q} d^{1-δ}/q = q^{-δ} ∑_{d|q} d^{δ-1}.
    The substitution d' = q/d is a bijection on divisors of squarefree q.
-/
lemma divisor_swap (q : ℕ) [NeZero q] (hq : Squarefree q) (δ : ℝ) :
    ∑ d ∈ q.divisors, (d : ℝ) ^ (1 - δ) / (q : ℝ) =
    (q : ℝ) ^ (-δ) * ∑ d ∈ q.divisors, (d : ℝ) ^ (δ - 1) := by
  rw [ Finset.mul_sum, ← Nat.sum_div_divisors ];
  refine Finset.sum_congr rfl fun x hx => ?_;
  rw [ Nat.cast_div ( Nat.dvd_of_mem_divisors hx ) ( by aesop ) ];
  rw [ Real.div_rpow ( by positivity ) ( by positivity ) ] ; ring;
  rw [ show ( -δ : ℝ ) = ( 1 - δ ) - 1 by ring, show ( -1 + δ : ℝ ) = - ( 1 - δ ) by ring, Real.rpow_sub_one, Real.rpow_neg ] <;> ring <;> aesop

/-! ## Euler product convergence -/

/-
For squarefree q, ∑_{d|q} d^{δ-1} = ∏_{p|q} (1 + p^{δ-1}).
    Since q is squarefree, its divisors are products of distinct primes.
-/
lemma divisor_sum_eq_euler_product (q : ℕ) [NeZero q] (hq : Squarefree q) (δ : ℝ) :
    ∑ d ∈ q.divisors, (d : ℝ) ^ (δ - 1) =
    ∏ p ∈ q.primeFactors, (1 + (p : ℝ) ^ (δ - 1)) := by
  -- Since $q$ is squarefree, its divisors are exactly the products of distinct primes dividing $q$.
  have h_divisors : q.divisors = Finset.image (fun s => ∏ p ∈ s, p) (Finset.powerset q.primeFactors) := by
    ext d;
    constructor;
    · intro hd; use Finset.mem_image.mpr ⟨ Nat.primeFactors d, Finset.mem_powerset.mpr <| Nat.primeFactors_mono ( Nat.dvd_of_mem_divisors hd ) <| by aesop, ?_ ⟩ ;
      rw [ Nat.prod_primeFactors_of_squarefree ( hq.squarefree_of_dvd <| Nat.dvd_of_mem_divisors hd ) ];
    · simp +zetaDelta at *;
      rintro x hx rfl; exact ⟨ Nat.prod_primeFactors_dvd q |> dvd_trans ( by rw [ ← Finset.prod_sdiff hx ] ; aesop ), NeZero.ne q ⟩ ;
  rw [ h_divisors, Finset.sum_image ];
  · simp +decide [ add_comm ( 1 : ℝ ), Finset.prod_add, Real.finset_prod_rpow _ _ fun x hx => Nat.cast_nonneg _ ];
  · intro s hs t ht h_eq; apply_fun fun x => x.primeFactors at h_eq; simp_all +decide [ Finset.subset_iff, Nat.primeFactors_prod ] ;

/-- The Euler product ∏_{p|q} (1 + p^{δ-1}) is bounded by a global constant
    when δ - 1 < -1/2, i.e., the series ∑ p^{δ-1} converges.
    We bound each factor by exp(p^{δ-1}) and the product by exp(∑ p^{δ-1}).
    For δ < 1/2, we have δ - 1 < -1/2, so p^{δ-1} ≤ p^{-1/2} ≤ 2^{-1/2},
    and the sum over primes converges. -/
lemma euler_product_convergent_bound (δ : ℝ) (hδ : 0 < δ) (hδ1 : δ < 1/2) :
    ∃ C : ℝ, 0 < C ∧ ∀ (q : ℕ) [NeZero q], Squarefree q →
      ∏ p ∈ q.primeFactors, (1 + (p : ℝ) ^ (δ - 1)) ≤ C := by
  sorry

/-! ## Monotonicity of rpow -/

/-
For s ≤ q with both positive and α > 0, q^(-α) ≤ s^(-α).
-/
lemma rpow_neg_le_of_le (q : ℝ) (s : ℝ) (α : ℝ) (hα : 0 < α)
    (hq : 0 < q) (hs : 0 < s) (h : s ≤ q) :
    q ^ (-α) ≤ s ^ (-α) := by
  rw [ Real.rpow_le_rpow_iff_of_neg ] <;> linarith

