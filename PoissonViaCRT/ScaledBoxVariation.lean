import PoissonViaCRT.HardCaseSynthesis
import PoissonViaCRT.LatticePointBound

/-!
# Scaled Box Variation Bound

This file bridges the gap between the abstract geometric boundary bounds
(`prod_floor_approx`, `count_inScaledBox_eq_prod_floor`) and the concrete
`inScaledBox` predicate, establishing the `O(s^{k-2}/d^{k-2})` lattice point
discrepancy bound needed by the Möbius synthesis.

## Main Results

* `PoissonCRT.scaled_box_count_approx`: The lattice point count in a scaled box
  `s · X` deviates from `s^m · vol(X)` by at most `C · s^{m-1}`, where `C`
  depends only on `X`.

* `PoissonCRT.scaled_box_variation_bound`: The lattice point discrepancy for
  the `inScaledBox` predicate modulo `d` satisfies a boundary bound of order
  `O(s^{k-2} / d^{k-2})`, suitable for feeding into `divisor_boundary_bound`.

## Proof Strategy

1. Relate the predicate `inScaledBox X s` to the product of floors via
   `count_inScaledBox_eq_prod_floor`.
2. Apply `prod_floor_approx` to bound the product-of-floors error.
3. For the modular version, substitute `s / d` for `s` and extract the
   `d`-dependent decay.
4. Apply `divisor_boundary_bound` to obtain the weighted deviation bound.

## References

* [A. Granville, P. Kurlberg, *Poisson statistics via the Chinese remainder theorem*],
  §3.2, Proposition 3.6.
-/

open Finset BigOperators Classical

namespace PoissonCRT

/-! ### 1. Basic Lattice Point Count Approximation -/

/-- **Lattice point count approximation.** The number of integer points
`h : Fin m → ℤ` satisfying `inScaledBox X s h` (within the bounding
`piFinset`) deviates from `s^m · vol(X)` by at most `C · s^{m-1}`.

This composes `count_inScaledBox_eq_prod_floor` (which rewrites the count
as `∏ᵢ ⌊s · bᵢ⌋`) with `prod_floor_approx` (which bounds the product-of-floors
error). -/
theorem scaled_box_count_approx (m : ℕ) (X : Box m) :
    ∃ C : ℝ, 0 < C ∧ ∀ (s : ℝ), 1 ≤ s →
      |(((Fintype.piFinset fun _ : Fin m =>
          Finset.Icc (1 : ℤ) ⌈s * ∑ i, X.sides i⌉).filter
        (fun h => inScaledBox X s h)).card : ℝ) - s ^ m * X.volume| ≤
        C * s ^ ((m : ℤ) - 1) := by
  obtain ⟨C, hC, hbound⟩ := prod_floor_approx m X.sides X.sides_pos
  exact ⟨C, hC, fun s hs => by
    rw [count_inScaledBox_eq_prod_floor m X s hs]
    simp only [Box.volume]
    push_cast
    exact hbound s hs⟩

/-! ### 2. Modular Lattice Point Discrepancy -/

/-- **Scaled box variation bound (modular version).** For a box `X` in
`ℝ^{k-1}`, a real scaling factor `s ≥ d`, and a positive integer `d`,
the product-of-floors approximation at scale `s / d` satisfies

  `|∏ᵢ ⌊(s / d) · bᵢ⌋₊ − (s / d)^{k-1} · vol(X)| ≤ C · s^{k-2} / d^{k-2}`

where `C` depends only on `X`. This captures the `O(s^{k-2} / d^{k-2})`
boundary variation arising when lattice points in `s · X` are decomposed
by residue class modulo `d`. -/
theorem scaled_box_variation_bound (k : ℕ) (hk : 2 ≤ k) (X : Box (k - 1))
    (d : ℕ) (hd : 0 < d) :
    ∃ C : ℝ, 0 < C ∧ ∀ (s : ℝ), 1 ≤ s → (d : ℝ) ≤ s →
      |(∏ i : Fin (k - 1), (⌊s / d * X.sides i⌋₊ : ℝ)) -
          (s / d) ^ (k - 1 : ℕ) * X.volume| ≤
        C * s ^ ((k : ℤ) - 2) / (d : ℝ) ^ ((k : ℤ) - 2) := by
  obtain ⟨C, hC, hbound⟩ := prod_floor_approx (k - 1) X.sides X.sides_pos
  refine ⟨C, hC, fun s hs hds => ?_⟩
  have hd_pos : (0 : ℝ) < (d : ℝ) := Nat.cast_pos.mpr hd
  have hs_d : 1 ≤ s / d := le_div_iff₀ hd_pos |>.mpr (by linarith)
  have h := hbound (s / d) hs_d
  have hk1 : 1 ≤ k - 1 := by omega
  have hexp : ((k - 1 : ℕ) : ℤ) - 1 = (k : ℤ) - 2 := by omega
  rw [hexp] at h
  calc |(∏ i : Fin (k - 1), (⌊s / ↑d * X.sides i⌋₊ : ℝ)) -
          (s / ↑d) ^ (k - 1) * X.volume|
      _ ≤ C * (s / d) ^ ((k : ℤ) - 2) := h
      _ = C * (s ^ ((k : ℤ) - 2) / (d : ℝ) ^ ((k : ℤ) - 2)) := by
            congr 1
            rw [div_zpow]
      _ = C * s ^ ((k : ℤ) - 2) / (d : ℝ) ^ ((k : ℤ) - 2) := by ring

/-! ### 3. Connection to `divisor_boundary_bound`

The lattice point discrepancy established above controls the total variation
of weights across residue classes modulo `d`. When combined with
`divisor_boundary_bound`, this yields bounds on weighted deviation sums
in the Möbius decomposition. -/

/-- **Weighted deviation bound via scaled box variation.** Given a subset
`Ω ⊆ ZMod d` with `0 < |Ω| ≤ d`, for the indicator weights `w` of
the `(s/d)`-scaled box with baseline `c` and total variation `TV`,
the weighted sum of counting deviations is bounded by `TV · 2|Ω|`.

This specializes `divisor_boundary_bound` to the scaled box setting,
showing how the `O(s^{k-2}/d^{k-2})` lattice point discrepancy propagates
through to the final deviation bound. -/
theorem scaled_box_weighted_deviation_bound
    (d : ℕ) [NeZero d]
    (Ω : Finset (ZMod d))
    (hcard : 0 < Ω.card) (hle : (Ω.card : ℝ) ≤ (d : ℝ))
    (m : ℕ) (w : (Fin m → ZMod d) → ℝ)
    (c : ℝ) (TV : ℝ)
    (hTV : ∑ g : Fin m → ZMod d, |w g - c| ≤ TV) :
    |∑ g : Fin m → ZMod d, w g *
      ((tupleCount Ω (Fin.cons (0 : ZMod d) g) : ℝ) -
        (Ω.card : ℝ) ^ (m + 1) / (d : ℝ) ^ m)| ≤
    TV * (2 * Ω.card) :=
  divisor_boundary_bound d Ω hcard hle m w c TV hTV

end PoissonCRT
