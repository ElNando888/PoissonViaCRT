/-!
# Module 2: SimultaneousCongruences

## Goal
Extend the Chinese Remainder Theorem to arbitrary `Finset`s of pairwise coprime moduli over `ÔäĄ`,
using the Mathlib isomorphism `ZMod.prodEquivPi`.

## Main results

* `LatticeCounting.crt_finset`: Given pairwise coprime moduli `M i` indexed by a `Finset U` and
  target residues `a i`, there exists a simultaneous solution `A`, unique modulo `ÔłĆ i Ôłł U, M i`.
* `LatticeCounting.crt_finset_dvd`: If `x` satisfies all individual congruences, then
  `(ÔłĆ i Ôłł U, M i) Ôłú (x - A)` for the CRT solution `A`.
* `LatticeCounting.crt_partition`: A system of congruences over a finset `U` that is partitioned
  by a map `c : ╬▒ Ôćĺ ╬▓` factors into independent congruences modulo the block products.
-/

namespace LatticeCounting

variable {╬▒ : Type*} [DecidableEq ╬▒]

/-! ### Pairwise coprimality helpers -/

omit [DecidableEq ╬▒] in
/-- Pairwise coprimality on a `Finset` lifts to `Pairwise` on the membership subtype. -/
theorem pairwise_coprime_subtype (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j))) :
    Pairwise (Function.onFun Nat.Coprime (fun (i : U) => M i)) := by
  intro i j hij
  convert hcop i.2 j.2 ( Subtype.coe_injective.ne hij ) using 1

omit [DecidableEq ╬▒] in
/-- Pairwise coprimality on `ÔäĽ` implies pairwise `IsCoprime` on `ÔäĄ` casts. -/
theorem pairwise_coprime_intCast (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j))) :
    (U : Set ╬▒).Pairwise (fun i j => IsCoprime ((M i : ÔäĄ)) ((M j : ÔäĄ))) := by
  exact fun i hi j hj hij => Int.isCoprime_iff_nat_coprime.mpr ( hcop hi hj hij )

/-! ### The CRT isomorphism applied to `Finset`s -/

omit [DecidableEq ╬▒] in
private theorem prod_subtype_eq (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ) :
    ÔłĆ i Ôłł U, M i = ÔłĆ i : U, M i := by
  convert Finset.prod_attach U M
  exact Finset.prod_bij ( fun i hi ÔćŽ ÔčĘ i, by aesop Ôčę ) (by aesop) (by aesop) (by aesop) (by aesop)
  convert Finset.prod_attach U M using 1

/-- The `ZMod.prodEquivPi` isomorphism reindexed over a `Finset`. -/
private noncomputable def crt_equiv (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j))) :
    ZMod (ÔłĆ i Ôłł U, M i) Ôëâ+* ((i : U) Ôćĺ ZMod (M i)) :=
  (ZMod.ringEquivCongr (prod_subtype_eq U M)).trans
    (ZMod.prodEquivPi (fun (i : U) => M i) (pairwise_coprime_subtype U M hcop))

omit [DecidableEq ╬▒] in
private theorem crt_equiv_intCast (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j)))
    (a : ÔäĄ) (i : U) :
    crt_equiv U M hcop (a : ZMod (ÔłĆ j Ôłł U, M j)) i = (a : ZMod (M i)) := by
  simp +decide

/-! ### Main CRT theorem -/

/-- **Chinese Remainder Theorem for `Finset`s over `ÔäĄ`.**
Given a `Finset U` of indices with pairwise coprime moduli `M i` and target residues `a i`,
there exists `A : ÔäĄ` satisfying all congruences `A Ôëí a i [ZMOD M i]` simultaneously,
and any other such solution is congruent to `A` modulo `ÔłĆ i Ôłł U, M i`. -/
public theorem crt_finset (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j)))
    (a : ╬▒ Ôćĺ ÔäĄ) :
    Ôłâ A : ÔäĄ, (ÔłÇ i Ôłł U, A Ôëí a i [ZMOD (M i)]) Ôłž
      ÔłÇ B : ÔäĄ, (ÔłÇ i Ôłł U, B Ôëí a i [ZMOD (M i)]) Ôćĺ
        B Ôëí A [ZMOD (ÔłĆ i Ôłł U, M i)] := by
  -- By the Chinese Remainder Theorem, there exists an integer $A$ such that
  -- $A \equiv a_i \pmod{M_i}$ for all $i \in U$.
  obtain ÔčĘA, hAÔčę : Ôłâ A : ÔäĄ, ÔłÇ i Ôłł U, A Ôëí a i [ZMOD M i] := by
    -- By the properties of the Chinese Remainder Theorem, such an $A$ exists.
    have h_crt : ÔłÇ i Ôłł U, Ôłâ x : ÔäĄ, x Ôëí a i [ZMOD (M i)] Ôłž ÔłÇ j Ôłł U, j Ôëá i Ôćĺ x Ôëí 0 [ZMOD (M j)] := by
      -- For each $i \in U$, let $y_i$ be the multiplicative inverse of
      -- $\prod_{j \neq i} M_j$ modulo $M_i$.
      intro i hi
      obtain ÔčĘy_i, hy_iÔčę : Ôłâ y_i : ÔäĄ, y_i * (ÔłĆ j Ôłł U \ {i}, (M j : ÔäĄ)) Ôëí 1 [ZMOD (M i : ÔäĄ)] := by
        have h_coprime : Nat.Coprime (ÔłĆ j Ôłł U \ {i}, (M j)) (M i) := by
          exact Nat.Coprime.prod_left fun j hj => hcop ( Finset.mem_sdiff.mp hj |>.1 ) hi (by aesop)
        have := Nat.gcd_eq_gcd_ab ( ÔłĆ j Ôłł U \ { i }, M j ) ( M i )
        exact ÔčĘ Nat.gcdA ( ÔłĆ j Ôłł U \ { i }, M j ) ( M i ),
          Int.modEq_iff_dvd.mpr ÔčĘ Nat.gcdB ( ÔłĆ j Ôłł U \ { i }, M j ) ( M i ),
            by push_cast at *; linarith Ôčę Ôčę
      use y_i * (ÔłĆ j Ôłł U \ {i}, (M j : ÔäĄ)) * (a i)
      exact ÔčĘ by simpa using hy_i.mul_right _, fun j hj hij =>
        Int.modEq_zero_iff_dvd.mpr <|
          dvd_mul_of_dvd_left ( dvd_mul_of_dvd_right ( Finset.dvd_prod_of_mem _ <| by aesop) _) _Ôčę
    choose! x hxÔéü hxÔéé using h_crt
    use ÔłĹ i Ôłł U, x i
    intro i hi; simp_all +decide only [Int.ModEq]
    rw [ Finset.sum_int_mod, Finset.sum_eq_single i ] <;> aesop
  refine' ÔčĘ A, hA, fun B hB => _ Ôčę
  simp_all +decide [ Int.modEq_iff_dvd ]
  convert Finset.prod_dvd_of_coprime _ _ <;> simp_all +decide [ dvd_sub_comm ]
  ┬Ě exact pairwise_coprime_intCast U M hcop
  ┬Ě exact fun i hi => by simpa using dvd_sub ( hA i hi ) ( hB i hi )

/-- **Divisibility form of CRT.** If `x` satisfies `x Ôëí a i [ZMOD M i]` for all `i Ôłł U` with
pairwise coprime moduli, then `(ÔłĆ i Ôłł U, ÔćĹ(M i)) Ôłú (x - A)` where `A` is the CRT solution. -/
public theorem crt_finset_dvd (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j)))
    (a : ╬▒ Ôćĺ ÔäĄ) (x : ÔäĄ) (hx : ÔłÇ i Ôłł U, x Ôëí a i [ZMOD (M i)]) :
    Ôłâ A : ÔäĄ, (ÔłÇ i Ôłł U, A Ôëí a i [ZMOD (M i)]) Ôłž
      (ÔłĆ i Ôłł U, (M i : ÔäĄ)) Ôłú (x - A) := by
  -- Apply the Chinese Remainder Theorem to obtain the existence of such an A.
  obtain ÔčĘA, hAÔčę := crt_finset U M hcop a
  exact ÔčĘ A, hA.1, Int.modEq_iff_dvd.mp ( hA.2 x hx |> Int.ModEq.symm ) Ôčę

/-! ### Partition factoring -/

omit [DecidableEq ╬▒] in
/-- **CRT partition.** If a `Finset U` is partitioned by `c : ╬▒ Ôćĺ ╬▓` into blocks
`U.filter (c ┬Ě = j)`, and all moduli in `U` are pairwise coprime, then
`x` satisfies all individual congruences if and only if `x` satisfies the combined
congruence modulo `ÔłĆ i Ôłł U.filter (c ┬Ě = j), M i` for each block `j Ôłł c '' U`. -/
public theorem crt_partition {╬▓ : Type*} [DecidableEq ╬▓] (U : Finset ╬▒) (M : ╬▒ Ôćĺ ÔäĽ)
    (_hcop : (U : Set ╬▒).Pairwise (fun i j => Nat.Coprime (M i) (M j)))
    (a : ╬▒ Ôćĺ ÔäĄ) (c : ╬▒ Ôćĺ ╬▓) (x : ÔäĄ) :
    (ÔłÇ i Ôłł U, x Ôëí a i [ZMOD (M i)]) Ôćö
      ÔłÇ j Ôłł U.image c,
        Ôłâ Aj : ÔäĄ, (ÔłÇ i Ôłł U.filter (c ┬Ě = j), Aj Ôëí a i [ZMOD (M i)]) Ôłž
          x Ôëí Aj [ZMOD (ÔłĆ i Ôłł U.filter (c ┬Ě = j), M i)] := by
  refine' ÔčĘ _, _ Ôčę <;> intro h
  ┬Ě aesop
  ┬Ě intro i hi
    specialize h ( c i ) ( Finset.mem_image_of_mem c hi )
    obtain ÔčĘ Aj, hAjÔéü, hAjÔéé Ôčę := h
    have := hAjÔéé.of_dvd ( Finset.dvd_prod_of_mem _ ( by aesop ) :
      ( M i : ÔäĄ ) Ôłú ÔłĆ i Ôłł Finset.filter ( fun x => c x = c i ) U, ( M i : ÔäĄ ) )
    simp_all +decide [ Int.ModEq ]

end LatticeCounting
