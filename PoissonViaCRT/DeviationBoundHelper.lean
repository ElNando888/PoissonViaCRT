import PoissonViaCRT.Defs
import PoissonViaCRT.ConvergentEulerBound

/-!
# Deviation Bound Helpers

Helper lemmas for closing the final `calc` step in `deviation_bound_k_ge_3`.

The partition bounds here bound subset sums by the **finite** Euler product
`ÔłĆ_{p Ôłł Q} (1 + w(p))` rather than by an infinite constant, aligning with the
GranvilleÔÇôKurlberg `s^╬Ě`-trick (arXiv:math/0412135v1, ┬ž3).

## Main Results

* `PoissonCRT.small_partition_bound`: The small-divisor partition sum is bounded by
  `C * convergentEulerPartitionSum ╬Á ╬ę Q`.
* `PoissonCRT.one_le_prod_primes`: The product of primes in a nonempty set is at least 1.
* `PoissonCRT.large_divisor_per_term_bound`: Per-term bound for the large-divisor case.
* `PoissonCRT.large_partition_bound`: The large-divisor partition sum is bounded by
  `C * largeEulerPartitionSum ╬Á ╬ę Q`.
* `PoissonCRT.localMean`: The local expected value `╬╝_p = |╬ę_p|^k / p^{k-1}`.
* `PoissonCRT.localCount`: The local counting function at prime `p`.
* `PoissonCRT.abs_localCount_sub_localMean_le`: Uniform bound
  `|localCount - localMean| ÔëĄ p ^ k` for `k Ôëą 1`.
-/

set_option linter.unusedVariables false

open Finset BigOperators Classical

namespace PoissonCRT

/-! ## Local deviation definitions and bounds -/

/-- The local expected value (mean) for the counting function at prime `p`:
`╬╝_p = |╬ę_p|^k / p^{k-1}`. -/
@[expose]
public noncomputable def localMean (k : ÔäĽ) (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)) (p : ÔäĽ) : ÔäŁ :=
  ((╬ę p).card : ÔäŁ) ^ k / (p : ÔäŁ) ^ (k - 1)

/-- The local counting function value at prime `p`, projected from `ZMod q`.
For `p Ôłł q.primeFactors`, this is `N_k(h mod p, ╬ę_p)`.
For `p Ôłë q.primeFactors`, this is defined as `1` (a neutral element for products). -/
@[expose]
public noncomputable def localCount {m : ÔäĽ} (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p))
    (q : ÔäĽ) [NeZero q] (h : Fin m Ôćĺ ZMod q) (p : ÔäĽ) : ÔäŁ :=
  if hp : p Ôłł q.primeFactors then
    haveI : NeZero p := ÔčĘ(Nat.mem_primeFactors.mp hp).1.ne_zeroÔčę
    (tupleCount (╬ę p)
      (fun i => ZMod.castHom (Nat.dvd_of_mem_primeFactors hp) (ZMod p) (h i)) : ÔäŁ)
  else 1

/-- `localCount` is nonneg (it is a natural number cast to `ÔäŁ`). -/
public lemma localCount_nonneg {╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)} {q : ÔäĽ} [NeZero q]
    {h : Fin k Ôćĺ ZMod q} {p : ÔäĽ} :
    0 ÔëĄ localCount ╬ę q h p := by
  unfold localCount; split_ifs <;> norm_cast
  exact Nat.zero_le _

/-- `localCount` at a prime factor is at most `p`. -/
public lemma localCount_le {q : ÔäĽ} [NeZero q]
    (p : ÔäĽ) (hp : p Ôłł q.primeFactors) (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p))
    (h : Fin k Ôćĺ ZMod q) :
    localCount ╬ę q h p ÔëĄ (p : ÔäŁ) := by
  unfold localCount
  simp +zetaDelta at *
  split_ifs
  haveI := Fact.mk hp.1; exact_mod_cast le_trans ( Finset.card_filter_le _ _ ) ( by norm_num )

/-- `localMean` is nonneg. -/
public lemma localMean_nonneg (k : ÔäĽ) (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)) (p : ÔäĽ) :
    0 ÔëĄ localMean k ╬ę p := by
  exact div_nonneg ( pow_nonneg ( Nat.cast_nonneg _ ) _ ) ( pow_nonneg ( Nat.cast_nonneg _ ) _ )

/-- `localMean` is at most `p` when `k Ôëą 1` and `p` is prime. -/
public lemma localMean_le (k : ÔäĽ) (hk : 1 ÔëĄ k) (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)) (p : ÔäĽ)
    (hp : p.Prime) :
    localMean k ╬ę p ÔëĄ (p : ÔäŁ) := by
  unfold localMean
  rcases p with ( _ | _ | p ) <;> norm_num at *
  rw [ div_le_iffÔéÇ ] <;> norm_cast <;> norm_num
  exact le_trans ( Nat.pow_le_pow_left ( show Finset.card ( ╬ę ( p + 1 + 1 ) ) ÔëĄ p + 1 + 1 from
    le_trans ( Finset.card_le_univ _ ) ( by norm_num ) ) _ )
    ( by cases k <;> simp_all +decide [ pow_succ' ] )

/-- Uniform bound on the absolute local deviation: `|N_k(h mod p, ╬ę_p) - ╬╝_p| ÔëĄ p ^ k`.

The bound follows from the triangle inequality. Both `localCount` and `localMean` lie
in `[0, p]`:
- `localCount` is a `tupleCount`, hence a natural number at most `p`
  (it counts a subset of `ZMod p`).
- `localMean = |╬ę_p|^k / p^{k-1} ÔëĄ p^k / p^{k-1} = p`.

Thus `|localCount - localMean| ÔëĄ p ÔëĄ p ^ k` (for `k Ôëą 1` and `p Ôëą 2`). -/
public lemma abs_localCount_sub_localMean_le_p {k : ÔäĽ} (hk : 1 ÔëĄ k) (q : ÔäĽ) [NeZero q]
    (p : ÔäĽ) (hp : p Ôłł q.primeFactors) (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p))
    (h : Fin k Ôćĺ ZMod q) :
    |localCount ╬ę q h p - localMean k ╬ę p| ÔëĄ (p : ÔäŁ) := by
  apply abs_sub_le_iff.mpr _
  constructor
  ┬Ě apply le_trans ( sub_le_self _ <| localMean_nonneg _ _ _ ) _
    exact localCount_le _ hp _ _
  ┬Ě apply le_trans ( sub_le_self _ ( localCount_nonneg ) ) _
    exact localMean_le k hk ╬ę p ( Nat.prime_of_mem_primeFactors hp )

lemma abs_localCount_sub_localMean_le {k : ÔäĽ} (hk : 1 ÔëĄ k) (q : ÔäĽ) [NeZero q]
    (p : ÔäĽ) (hp : p Ôłł q.primeFactors) (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p))
    (h : Fin k Ôćĺ ZMod q) :
    |localCount ╬ę q h p - localMean k ╬ę p| ÔëĄ (p : ÔäŁ) ^ k := by
  exact le_trans ( abs_localCount_sub_localMean_le_p hk q p hp ╬ę h )
    ( mod_cast Nat.le_self_pow ( by linarith ) _ )

end PoissonCRT
