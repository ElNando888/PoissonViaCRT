import PoissonViaCRT.Defs
import PoissonViaCRT.ConvergentEulerBound

/-!
# Deviation Bound Helpers

Helper lemmas for closing the final `calc` step in `deviation_bound_k_ge_3`.

The partition bounds here bound subset sums by the **finite** Euler product
`ÔêÅ_{p Ôêê Q} (1 + w(p))` rather than by an infinite constant, aligning with the
GranvilleÔÇôKurlberg `s^╬À`-trick (arXiv:math/0412135v1, ┬º3).

## Main Results

* `PoissonCRT.small_partition_bound`: The small-divisor partition sum is bounded by
  `C * convergentEulerPartitionSum ╬Á ╬® Q`.
* `PoissonCRT.one_le_prod_primes`: The product of primes in a nonempty set is at least 1.
* `PoissonCRT.large_divisor_per_term_bound`: Per-term bound for the large-divisor case.
* `PoissonCRT.large_partition_bound`: The large-divisor partition sum is bounded by
  `C * largeEulerPartitionSum ╬Á ╬® Q`.
* `PoissonCRT.localMean`: The local expected value `╬╝_p = |╬®_p|^k / p^{k-1}`.
* `PoissonCRT.localCount`: The local counting function at prime `p`.
* `PoissonCRT.abs_localCount_sub_localMean_le`: Uniform bound
  `|localCount - localMean| Ôëñ p ^ k` for `k ÔëÑ 1`.
-/

set_option linter.unusedVariables false

open Finset BigOperators Classical

namespace PoissonCRT

/-! ## Local deviation definitions and bounds -/

/-- The local expected value (mean) for the counting function at prime `p`:
`╬╝_p = |╬®_p|^k / p^{k-1}`. -/
@[expose]
public noncomputable def localMean (k : Ôäò) (╬® : ÔêÇ p : Ôäò, Finset (ZMod p)) (p : Ôäò) : ÔäØ :=
  ((╬® p).card : ÔäØ) ^ k / (p : ÔäØ) ^ (k - 1)

/-- The local counting function value at prime `p`, projected from `ZMod q`.
For `p Ôêê q.primeFactors`, this is `N_k(h mod p, ╬®_p)`.
For `p Ôêë q.primeFactors`, this is defined as `1` (a neutral element for products). -/
@[expose]
public noncomputable def localCount {m : Ôäò} (╬® : ÔêÇ p : Ôäò, Finset (ZMod p))
    (q : Ôäò) [NeZero q] (h : Fin m ÔåÆ ZMod q) (p : Ôäò) : ÔäØ :=
  if hp : p Ôêê q.primeFactors then
    haveI : NeZero p := Ôƒ¿(Nat.mem_primeFactors.mp hp).1.ne_zeroÔƒ®
    (tupleCount (╬® p)
      (fun i => ZMod.castHom (Nat.dvd_of_mem_primeFactors hp) (ZMod p) (h i)) : ÔäØ)
  else 1

/-- `localCount` is nonneg (it is a natural number cast to `ÔäØ`). -/
public lemma localCount_nonneg {╬® : ÔêÇ p : Ôäò, Finset (ZMod p)} {q : Ôäò} [NeZero q]
    {h : Fin k ÔåÆ ZMod q} {p : Ôäò} :
    0 Ôëñ localCount ╬® q h p := by
  unfold localCount; split_ifs <;> norm_cast
  exact Nat.zero_le _

/-- `localCount` at a prime factor is at most `p`. -/
public lemma localCount_le {q : Ôäò} [NeZero q]
    (p : Ôäò) (hp : p Ôêê q.primeFactors) (╬® : ÔêÇ p : Ôäò, Finset (ZMod p))
    (h : Fin k ÔåÆ ZMod q) :
    localCount ╬® q h p Ôëñ (p : ÔäØ) := by
  unfold localCount
  simp +zetaDelta only [Nat.mem_primeFactors, ne_eq, ZMod.castHom_apply] at *
  split_ifs
  haveI := Fact.mk hp.1; exact_mod_cast le_trans ( Finset.card_filter_le _ _ ) ( by norm_num )

/-- `localMean` is nonneg. -/
public lemma localMean_nonneg (k : Ôäò) (╬® : ÔêÇ p : Ôäò, Finset (ZMod p)) (p : Ôäò) :
    0 Ôëñ localMean k ╬® p := by
  exact div_nonneg ( pow_nonneg ( Nat.cast_nonneg _ ) _ ) ( pow_nonneg ( Nat.cast_nonneg _ ) _ )

/-- `localMean` is at most `p` when `k ÔëÑ 1` and `p` is prime. -/
public lemma localMean_le (k : Ôäò) (hk : 1 Ôëñ k) (╬® : ÔêÇ p : Ôäò, Finset (ZMod p)) (p : Ôäò)
    (hp : p.Prime) :
    localMean k ╬® p Ôëñ (p : ÔäØ) := by
  unfold localMean
  rcases p with ( _ | _ | p ) <;> norm_num at *
  rw [ div_le_iffÔéÇ ] <;> norm_cast <;> norm_num
  exact le_trans ( Nat.pow_le_pow_left ( show Finset.card ( ╬® ( p + 1 + 1 ) ) Ôëñ p + 1 + 1 from
    le_trans ( Finset.card_le_univ _ ) ( by norm_num ) ) _ )
    ( by cases k <;> simp_all +decide [ pow_succ' ] )

/-- Uniform bound on the absolute local deviation: `|N_k(h mod p, ╬®_p) - ╬╝_p| Ôëñ p ^ k`.

The bound follows from the triangle inequality. Both `localCount` and `localMean` lie
in `[0, p]`:
- `localCount` is a `tupleCount`, hence a natural number at most `p`
  (it counts a subset of `ZMod p`).
- `localMean = |╬®_p|^k / p^{k-1} Ôëñ p^k / p^{k-1} = p`.

Thus `|localCount - localMean| Ôëñ p Ôëñ p ^ k` (for `k ÔëÑ 1` and `p ÔëÑ 2`). -/
public lemma abs_localCount_sub_localMean_le_p {k : Ôäò} (hk : 1 Ôëñ k) (q : Ôäò) [NeZero q]
    (p : Ôäò) (hp : p Ôêê q.primeFactors) (╬® : ÔêÇ p : Ôäò, Finset (ZMod p))
    (h : Fin k ÔåÆ ZMod q) :
    |localCount ╬® q h p - localMean k ╬® p| Ôëñ (p : ÔäØ) := by
  apply abs_sub_le_iff.mpr _
  constructor
  ┬À apply le_trans ( sub_le_self _ <| localMean_nonneg _ _ _ ) _
    exact localCount_le _ hp _ _
  ┬À apply le_trans ( sub_le_self _ ( localCount_nonneg ) ) _
    exact localMean_le k hk ╬® p ( Nat.prime_of_mem_primeFactors hp )

lemma abs_localCount_sub_localMean_le {k : Ôäò} (hk : 1 Ôëñ k) (q : Ôäò) [NeZero q]
    (p : Ôäò) (hp : p Ôêê q.primeFactors) (╬® : ÔêÇ p : Ôäò, Finset (ZMod p))
    (h : Fin k ÔåÆ ZMod q) :
    |localCount ╬® q h p - localMean k ╬® p| Ôëñ (p : ÔäØ) ^ k := by
  exact le_trans ( abs_localCount_sub_localMean_le_p hk q p hp ╬® h )
    ( mod_cast Nat.le_self_pow ( by linarith ) _ )

end PoissonCRT
