/-!
# Fourier ANOVA for the Deviation Bound

This file scaffolds the **Fourier ANOVA** (Analysis of Variance) machinery for proving
the uniform deviation bound in Proposition 3.6 of Granville‚ÄìKurlberg
(arXiv:math/0412135v2, ¬ß3.2).

Instead of the combinatorial Gamma-structure decomposition, we expand the deviation
$N_k(h, \Omega_q) - \mu$ in terms of the discrete Fourier transform on the finite
abelian group $G = (\mathbb{Z}/q\mathbb{Z})^{k-1}$, factor the Fourier coefficients
via CRT, and bound the resulting sum using exponential-sum estimates from the
`WellDistributed` hypothesis.

## Main Definitions

* `PoissonCRT.rootOfUnity`: The primitive $q$-th root of unity $e^{2\pi i / q}$.
* `PoissonCRT.character`: The additive character
  $\chi_\xi(x) = e^{2\pi i \langle \xi, x \rangle / q}$.
* `PoissonCRT.dft`: The discrete Fourier transform on $(\mathbb{Z}/q\mathbb{Z})^m$.
* `PoissonCRT.fourierLocalDeviation`: The local deviation function
  $\operatorname{dev}_p(h) = N_k(h, \Omega_p) - \mu_p$.
* `PoissonCRT.boxIndicator`: The indicator function of the scaled box $s \cdot X$
  in $(\mathbb{Z}/q\mathbb{Z})^m$.

## Main Results (stubbed)

* `PoissonCRT.character_orthogonality`: Orthogonality of additive characters.
* `PoissonCRT.plancherel_identity`: Plancherel / Parseval identity on $G$.
* `PoissonCRT.dft_inversion`: Fourier inversion formula.
* `PoissonCRT.fourierLocalDeviation_dft_zero`: The Fourier transform of the local deviation
  vanishes at the zero frequency.
* `PoissonCRT.local_deviation_fourier_bound`: $L^\infty$ bound on the local
  deviation Fourier coefficients using `WellDistributed`.
* `PoissonCRT.box_fourier_l1_bound`: The $L^1$-norm of the box indicator Fourier
  transform is $O((\log q)^{k-1})$.

## References

* [A. Granville, P. Kurlberg, *Poisson statistics via the Chinese remainder theorem*]
  [arXiv:math/0412135v2], ¬ß3.2
* See `docs/fourier_anova_blueprint.md` for the full mathematical blueprint.
-/

open Finset BigOperators Classical Complex

namespace PoissonCRT

/-! ### Additive characters on `ZMod q` -/

/-- The primitive `q`-th root of unity $\omega_q = e^{2\pi i / q}$. -/
noncomputable def rootOfUnity (q : ‚Ñï) [NeZero q] : ‚ÑÇ :=
  Complex.exp (2 * Real.pi * Complex.I / (q : ‚ÑÇ))

/-- The additive character $\chi_a(x) = \omega_q^{a \cdot x}$ on `ZMod q`.
Here `a` and `x` are elements of `ZMod q`, and we lift the product `a * x` to `‚Ñ§`
via `ZMod.val` before exponentiating. -/
noncomputable def additiveChar (q : ‚Ñï) [NeZero q] (a : ZMod q) (x : ZMod q) : ‚ÑÇ :=
  Complex.exp (2 * Real.pi * Complex.I * ((a * x).val : ‚ÑÇ) / (q : ‚ÑÇ))

/-- The product character on `(ZMod q)^m`. Given a frequency vector `Œæ : Fin m ‚Üí ZMod q`
and a point `x : Fin m ‚Üí ZMod q`, the character is
$\chi_\xi(x) = \prod_j \chi_{\xi_j}(x_j) = e^{2\pi i \langle \xi, x \rangle / q}$. -/
noncomputable def character (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (Œæ x : Fin m ‚Üí ZMod q) : ‚ÑÇ :=
  ‚àè j : Fin m, additiveChar q (Œæ j) (x j)

/-! ### Discrete Fourier Transform -/

/-- The **discrete Fourier transform** of `f : (ZMod q)^m ‚Üí ‚ÑÇ`.

$$\widehat{f}(\xi) = \frac{1}{q^m} \sum_{x \in (\mathbb{Z}/q\mathbb{Z})^m}
  f(x) \cdot \overline{\chi_\xi(x)}.$$ -/
noncomputable def dft (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (f : (Fin m ‚Üí ZMod q) ‚Üí ‚ÑÇ) (Œæ : Fin m ‚Üí ZMod q) : ‚ÑÇ :=
  (1 / (q : ‚ÑÇ) ^ m) * ‚àë x : Fin m ‚Üí ZMod q, f x * starRingEnd ‚ÑÇ (character q m Œæ x)

/-! ### Character properties -/

/-
`additiveChar q a x` can be written as a power of the primitive root
`exp(2œÄi¬∑a.val/q)` raised to `x.val`.
-/
lemma additiveChar_eq_exp_pow (q : ‚Ñï) [NeZero q] (a x : ZMod q) :
    additiveChar q a x =
      Complex.exp (2 * Real.pi * Complex.I * (a.val : ‚ÑÇ) / (q : ‚ÑÇ)) ^ x.val := by
  rw [ ‚Üê Complex.exp_nat_mul ] ; ring_nf;
  convert Complex.exp_eq_exp_iff_exists_int.mpr ?_ using 2 ; ring_nf;
  use -((a.val * x.val) / q);
  rw [ ZMod.val_mul ];
  rw [ Nat.mod_def ] ; ring_nf;
  rw [ Nat.cast_sub ( Nat.mul_div_le _ _ ) ] ; push_cast ; ring_nf;
  norm_cast ; simp +decide [ mul_assoc, mul_comm, mul_left_comm, NeZero.ne ]

/-
The `additiveChar` at `a = 0` is identically `1`.
-/
@[simp]
lemma additiveChar_zero (q : ‚Ñï) [NeZero q] (x : ZMod q) :
    additiveChar q 0 x = 1 := by
  -- By definition of additiveChar, we have additiveChar q 0 x = Complex.exp (2 * Real.pi * Complex.I * (0 * x).val / (q : ‚ÑÇ)).
  simp [additiveChar]

/-
The primitive `q`-th root of unity raised to `q` equals `1`.
-/
lemma exp_two_pi_I_val_pow_eq_one (q : ‚Ñï) [NeZero q] (a : ZMod q) :
    Complex.exp (2 * Real.pi * Complex.I * (a.val : ‚ÑÇ) / (q : ‚ÑÇ)) ^ q = 1 := by
  rw [ ‚Üê Complex.exp_nat_mul, mul_comm, Complex.exp_eq_one_iff ];
  exact ‚ü® a.val, by rw [ div_mul_cancel‚ÇÄ _ ( NeZero.ne _ ) ] ; push_cast; ring ‚ü©

/-
For `a ‚âÝ 0` in `ZMod q`, the primitive root `exp(2œÄi¬∑a.val/q) ‚âÝ 1`.
-/
lemma exp_two_pi_I_val_ne_one (q : ‚Ñï) [NeZero q] (a : ZMod q) (ha : a ‚âÝ 0) :
    Complex.exp (2 * Real.pi * Complex.I * (a.val : ‚ÑÇ) / (q : ‚ÑÇ)) ‚âÝ 1 := by
  contrapose! ha;
  rw [ Complex.exp_eq_one_iff ] at ha;
  -- By simplifying, we can see that this implies $a.val = nq$ for some integer $n$.
  obtain ‚ü®n, hn‚ü© := ha
  have h_eq : a.val = n * q := by
    rw [ div_eq_iff ] at hn;
    ¬∑ exact_mod_cast ( mul_left_cancel‚ÇÄ ( Complex.two_pi_I_ne_zero ) <| by linear_combination' hn : ( a.val : ‚ÑÇ ) = n * q );
    ¬∑ exact Nat.cast_ne_zero.mpr <| NeZero.ne q;
  replace h_eq := congr_arg ( ( ‚Üë ) : ‚Ñ§ ‚Üí ZMod q ) h_eq ; simp_all +decide

/-
**1D orthogonality of additive characters.**
$$\sum_{x \in \mathbb{Z}/q\mathbb{Z}} \chi_a(x) =
  \begin{cases} q & \text{if } a = 0, \\ 0 & \text{if } a \neq 0. \end{cases}$$
-/
lemma additiveChar_sum_eq_ite (q : ‚Ñï) [NeZero q] (a : ZMod q) :
    ‚àë x : ZMod q, additiveChar q a x = if a = 0 then (q : ‚ÑÇ) else 0 := by
  split_ifs with ha;
  ¬∑ aesop;
  ¬∑ -- Rewrite each term using `additiveChar_eq_exp_pow` to get `‚àë x, r^(x.val)` where `r = exp(2œÄi a.val/q)`.
    have h_exp : ‚àë x : ZMod q, additiveChar q a x = ‚àë x ‚àà Finset.range q, (Complex.exp (2 * Real.pi * Complex.I * (a.val : ‚ÑÇ) / (q : ‚ÑÇ))) ^ x := by
      refine' Finset.sum_bij ( fun x _ => x.val ) _ _ _ _ <;> simp +decide [ additiveChar_eq_exp_pow ];
      ¬∑ exact fun x => ZMod.val_lt x;
      ¬∑ exact fun x y h => by simpa [ ZMod.natCast_zmod_val ] using congr_arg ( fun x : ‚Ñï => x : ‚Ñï ‚Üí ZMod q ) h;
      ¬∑ exact fun b hb => ‚ü® b, ZMod.val_cast_of_lt hb ‚ü©;
    rw [ h_exp, geom_sum_eq ] <;> norm_num [ ha ];
    ¬∑ exact Or.inl ( by rw [ sub_eq_zero, ‚Üê Complex.exp_nat_mul, mul_comm, Complex.exp_eq_one_iff ] ; use a.val; push_cast; ring_nf; norm_num [ NeZero.ne ] );
    ¬∑ convert exp_two_pi_I_val_ne_one q a ha using 1;
      cases q <;> aesop

/-
The conjugate of `additiveChar q a x` equals `additiveChar q (-a) x`.
-/
lemma starRingEnd_additiveChar (q : ‚Ñï) [NeZero q] (a x : ZMod q) :
    starRingEnd ‚ÑÇ (additiveChar q a x) = additiveChar q (-a) x := by
  -- Apply the property of the conjugate of the exponential.
  have h_conj_exp : (starRingEnd ‚ÑÇ) (Complex.exp (2 * Real.pi * Complex.I * ((a * x).val : ‚ÑÇ) / (q : ‚ÑÇ))) = Complex.exp (2 * Real.pi * Complex.I * (q - (a * x).val : ‚Ñ§) / (q : ‚ÑÇ)) := by
    norm_num [ Complex.ext_iff, Complex.exp_re, Complex.exp_im ];
    norm_num [ sub_div, mul_sub, NeZero.ne ];
    erw [ ZMod.cast_eq_val ] ; norm_cast ; aesop;
  unfold additiveChar;
  cases eq_or_ne ( a * x ) 0 <;> simp_all +decide [ ZMod.neg_val ];
  rw [ Nat.cast_sub ];
  ¬∑ cases q <;> aesop;
  ¬∑ exact Nat.le_of_lt ( ZMod.val_lt _ )

/-
The product of characters satisfies `œá_Œæ(x) ¬∑ conj(œá_Œ∑(x)) = œá_{Œæ-Œ∑}(x)`.
-/
lemma character_mul_conj (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (Œæ Œ∑ x : Fin m ‚Üí ZMod q) :
    character q m Œæ x * starRingEnd ‚ÑÇ (character q m Œ∑ x) =
      character q m (Œæ - Œ∑) x := by
  unfold character;
  rw [ map_prod, ‚Üê Finset.prod_mul_distrib ];
  refine' Finset.prod_congr rfl fun j _ => _;
  rw [ starRingEnd_additiveChar ];
  unfold additiveChar;
  rw [ ‚Üê Complex.exp_add ];
  rw [ Complex.exp_eq_exp_iff_exists_int ];
  use ((Œæ j * x j).val + (-Œ∑ j * x j).val - ((Œæ j - Œ∑ j) * x j).val) / q;
  rw [ Int.cast_div ] <;> norm_num;
  ¬∑ ring;
  ¬∑ simp +decide [ sub_mul, ‚Üê ZMod.intCast_zmod_eq_zero_iff_dvd ];
  ¬∑ exact NeZero.ne q

/-
**Orthogonality of additive characters.** The sum of a non-trivial character over the
full group vanishes, and the sum of the trivial character is the group order:

$$\sum_{x \in G} \chi_\xi(x) \overline{\chi_\eta(x)} = |G| \cdot \delta_{\xi, \eta}.$$
-/
theorem character_orthogonality (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (Œæ Œ∑ : Fin m ‚Üí ZMod q) :
    ‚àë x : Fin m ‚Üí ZMod q, character q m Œæ x * starRingEnd ‚ÑÇ (character q m Œ∑ x) =
      if Œæ = Œ∑ then ((q : ‚ÑÇ) ^ m) else 0 := by
  -- By Fubini's theorem, we can interchange the order of summation.
  have h_fubini : ‚àë x : Fin m ‚Üí ZMod q, character q m (Œæ - Œ∑) x = ‚àè j : Fin m, ‚àë x : ZMod q, additiveChar q ((Œæ - Œ∑) j) x := by
    rw [ Finset.prod_sum ];
    refine' Finset.sum_bij ( fun x _ => fun i _ => x i ) _ _ _ _ <;> simp +decide [ character ];
    ¬∑ simp +decide [ funext_iff ];
    ¬∑ exact fun b => ‚ü® fun i => b i ( Finset.mem_univ i ), funext fun i => funext fun _ => rfl ‚ü©;
  split_ifs with h <;> simp_all +decide [ character_mul_conj ];
  exact Finset.prod_eq_zero ( Finset.mem_univ ( Classical.choose ( Function.ne_iff.mp h ) ) ) ( by rw [ additiveChar_sum_eq_ite ] ; simp +decide [ sub_eq_zero, Classical.choose_spec ( Function.ne_iff.mp h ) ] )

/-
**Fourier inversion formula.**
$f(x) = \sum_{\xi \in G} \widehat{f}(\xi) \cdot \chi_\xi(x)$.
-/
theorem dft_inversion (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (f : (Fin m ‚Üí ZMod q) ‚Üí ‚ÑÇ) (x : Fin m ‚Üí ZMod q) :
    f x = ‚àë Œæ : Fin m ‚Üí ZMod q, dft q m f Œæ * character q m Œæ x := by
  simp +decide [ dft, Finset.mul_sum _ _ _, mul_comm, mul_left_comm ];
  -- By the orthogonality of the characters, the inner sum over Œæ is q^m if x = y and 0 otherwise.
  have h_orthogonality : ‚àÄ y : Fin m ‚Üí ZMod q, ‚àë Œæ : Fin m ‚Üí ZMod q, (character q m Œæ x) * (starRingEnd ‚ÑÇ (character q m Œæ y)) = if x = y then (q : ‚ÑÇ) ^ m else 0 := by
    convert character_orthogonality q m x using 1;
    unfold character; ring_nf;
    unfold additiveChar; simp +decide [ mul_comm ] ;
  rw [ Finset.sum_comm ];
  simp_all +decide [ ‚Üê Finset.mul_sum _ _ _ ]

/-! ### Plancherel / Parseval identity -/

/-
**Plancherel identity** on $(\mathbb{Z}/q\mathbb{Z})^m$:

$$\frac{1}{q^m} \sum_{x \in G} f(x) \cdot \overline{g(x)}
  = \sum_{\xi \in G} \widehat{f}(\xi) \cdot \overline{\widehat{g}(\xi)}.$$
-/
theorem plancherel_identity (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (f g : (Fin m ‚Üí ZMod q) ‚Üí ‚ÑÇ) :
    (1 / (q : ‚ÑÇ) ^ m) * ‚àë x : Fin m ‚Üí ZMod q, f x * starRingEnd ‚ÑÇ (g x) =
      ‚àë Œæ : Fin m ‚Üí ZMod q, dft q m f Œæ * starRingEnd ‚ÑÇ (dft q m g Œæ) := by
  unfold dft; simp +decide [ mul_assoc, Finset.mul_sum _ _ _, Finset.sum_mul ] ;
  -- By the orthogonality of the characters, the inner sum over Œæ is zero unless x = y.
  have h_inner : ‚àÄ x y : Fin m ‚Üí ZMod q, ‚àë Œæ : Fin m ‚Üí ZMod q, character q m Œæ x * starRingEnd ‚ÑÇ (character q m Œæ y) = if x = y then (q : ‚ÑÇ) ^ m else 0 := by
    intro x y;
    have := character_orthogonality q m;
    convert this x y using 1;
    unfold character; simp +decide
    unfold additiveChar; simp +decide [ mul_comm ] ;
  simp +decide only [mul_left_comm];
  rw [ Finset.sum_comm, Finset.sum_congr rfl ] ; intros ; rw [ Finset.sum_comm ] ; simp +decide [ ‚Üê Finset.mul_sum _ _ _ ] ; ring_nf;
  simp_all +decide [ mul_assoc, mul_comm, mul_left_comm, pow_mul ];
  simp +decide [ sq, mul_assoc, NeZero.ne ]

/-! ### Local deviation function -/

/-- The **local deviation function** at prime `p`:
$\operatorname{dev}_p(h) = N_k((0, h_1, \ldots, h_{k-1}), \Omega_p) - \mu_p$,
where $\mu_p = |\Omega_p|^k / p^{k-1}$ is the local expected value. -/
noncomputable def fourierLocalDeviation (k : ‚Ñï) (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (p : ‚Ñï) [NeZero p] (h : Fin (k - 1) ‚Üí ZMod p) : ‚ÑÇ :=
  (tupleCount (Œ© p) (Fin.cons 0 h) : ‚ÑÇ) - (((Œ© p).card : ‚Ñù) ^ k / (p : ‚Ñù) ^ (k - 1) : ‚Ñù)

/-
For any `t : ZMod p` and `S : Finset (ZMod p)`, the number of `h : ZMod p` with
`t + h ‚àà S` equals `|S|`. This is because `h ‚Ü¶ t + h` is a bijection on `ZMod p`.
-/
lemma card_filter_add_mem (p : ‚Ñï) [NeZero p] (t : ZMod p) (S : Finset (ZMod p)) :
    (Finset.univ.filter fun h : ZMod p => t + h ‚àà S).card = S.card := by
  -- The function h ‚Ü¶ t + h is a bijection from ZMod p to ZMod p, so the cardinality of the preimage of S under this function is equal to the cardinality of S.
  have h_bij : Finset.image (fun h => t + h) (Finset.univ.filter (fun h => t + h ‚àà S)) = S := by
    ext x; aesop;
  rw [ ‚Üê h_bij, Finset.card_image_of_injective _ ( add_right_injective t ) ];
  aesop

/-
Summing `tupleCount (Œ© p) (Fin.cons 0 h)` over all `h` in `‚Ñï` form:
`‚àë h, tupleCount (Œ© p) (Fin.cons 0 h) = (Œ© p).card ^ k`.
-/
theorem sum_tupleCount_eq_card_pow_nat (k : ‚Ñï) (hk : 1 ‚â§ k) (p : ‚Ñï) [NeZero p]
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
    (‚àë h : Fin (k - 1) ‚Üí ZMod p, tupleCount (Œ© p) (Fin.cons 0 h)) =
      (Œ© p).card ^ k := by
  unfold tupleCount;
  rcases k with ( _ | k ) <;> simp_all +decide [ Fin.forall_fin_succ ];
  -- For each fixed t ‚àà Œ© p, the number of h such that ‚àÄ i, t + h i ‚àà Œ© p is exactly |Œ© p|^k.
  have h_count : ‚àÄ t ‚àà Œ© p, (Finset.univ.filter fun h : Fin k ‚Üí ZMod p => ‚àÄ i, t + h i ‚àà Œ© p).card = (Œ© p).card ^ k := by
    intro t ht
    have h_count : (Finset.univ.filter fun h : Fin k ‚Üí ZMod p => ‚àÄ i, t + h i ‚àà Œ© p).card = (Finset.pi Finset.univ fun _ : Fin k => Finset.univ.filter fun h : ZMod p => t + h ‚àà Œ© p).card := by
      refine' Finset.card_bij ( fun h hh => fun i _ => h i ) _ _ _ <;> simp +decide [ funext_iff ];
      exact fun b hb => ‚ü® fun i => b i ( Finset.mem_univ i ), hb, fun i => rfl ‚ü©;
    simp_all +decide [ Finset.card_univ ];
    exact congr_arg ( ¬∑ ^ k ) ( by rw [ show Finset.filter ( fun h => t + h ‚àà Œ© p ) Finset.univ = Finset.image ( fun h => h - t ) ( Œ© p ) by ext; aesop ] ; rw [ Finset.card_image_of_injective _ ( sub_left_injective ) ] );
  -- By Fubini's theorem, we can interchange the order of summation.
  have h_fubini : ‚àë x : Fin k ‚Üí ZMod p, (Finset.univ.filter fun t : ZMod p => t ‚àà Œ© p ‚àß ‚àÄ i, t + x i ‚àà Œ© p).card = ‚àë t ‚àà Œ© p, (Finset.univ.filter fun x : Fin k ‚Üí ZMod p => ‚àÄ i, t + x i ‚àà Œ© p).card := by
    simp +decide only [card_filter];
    rw [ Finset.sum_comm ];
    rw [ ‚Üê Finset.sum_subset ( Finset.subset_univ ( Œ© p ) ) ] <;> aesop;
  rw [ h_fubini, Finset.sum_congr rfl h_count, Finset.sum_const, Finset.card_eq_sum_ones, smul_eq_mul, mul_comm ] ; ring

/-- Summing `tupleCount (Œ© p) (Fin.cons 0 h)` over all `h : Fin (k-1) ‚Üí ZMod p`
yields `(Œ© p).card ^ k`. The key idea: swap the sum over `h` and `t`, then for
each fixed `t ‚àà Œ© p`, the sum over each coordinate `h_i` of the indicator
`[t + h_i ‚àà Œ© p]` equals `|Œ© p|` (as `h_i` ranges over all of `ZMod p`). -/
theorem sum_tupleCount_eq_card_pow (k : ‚Ñï) (hk : 1 ‚â§ k) (p : ‚Ñï) [NeZero p]
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
    (‚àë h : Fin (k - 1) ‚Üí ZMod p, (tupleCount (Œ© p) (Fin.cons 0 h) : ‚ÑÇ)) =
      ((Œ© p).card : ‚ÑÇ) ^ k := by
  exact_mod_cast sum_tupleCount_eq_card_pow_nat k hk p Œ©

/- The original statement of `fourierLocalDeviation_sum_zero` omitted the hypothesis `1 ‚â§ k`.
   It is false when `k = 0`: ‚Ñï subtraction gives `k - 1 = 0`, so `Fin.cons 0 h` has type
   `Fin 1 ‚Üí ZMod p`, making the tuple count equal to `|Œ© p|` while the mean term is
   `|Œ© p|^0 / p^0 = 1`.  The corrected version below adds `(hk : 1 ‚â§ k)`. -/
-- theorem fourierLocalDeviation_sum_zero (k : ‚Ñï) (p : ‚Ñï) [NeZero p]
--     (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
--     ‚àë h : Fin (k - 1) ‚Üí ZMod p, fourierLocalDeviation k Œ© p h = 0 := by
--   sorry

/-- The sum of the local deviation over all elements of $(\mathbb{Z}/p\mathbb{Z})^{k-1}$
is zero (the deviations from the mean cancel).

*Corrected*: requires `1 ‚â§ k`; the original statement is false for `k = 0`. -/
theorem fourierLocalDeviation_sum_zero (k : ‚Ñï) (hk : 1 ‚â§ k) (p : ‚Ñï) [NeZero p]
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
    ‚àë h : Fin (k - 1) ‚Üí ZMod p, fourierLocalDeviation k Œ© p h = 0 := by
  unfold fourierLocalDeviation
  simp +decide [Finset.sum_sub_distrib]
  rw [mul_div_cancel‚ÇÄ]
  ¬∑ exact sub_eq_zero_of_eq <| mod_cast sum_tupleCount_eq_card_pow k hk p Œ©
  ¬∑ exact pow_ne_zero _ (Nat.cast_ne_zero.mpr <| NeZero.ne p)

/- The original statement of `fourierLocalDeviation_dft_zero` omitted `1 ‚â§ k`; it inherits
   the same issue from `fourierLocalDeviation_sum_zero`. -/
-- theorem fourierLocalDeviation_dft_zero (k : ‚Ñï) (p : ‚Ñï) [NeZero p]
--     (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
--     dft p (k - 1) (fourierLocalDeviation k Œ© p) 0 = 0 := by
--   sorry

/-- The Fourier transform of the local deviation vanishes at the zero frequency:
$\widehat{\operatorname{dev}}_p(0) = 0$. This is immediate from `fourierLocalDeviation_sum_zero`
and the definition of `dft`.

*Corrected*: requires `1 ‚â§ k`; see `fourierLocalDeviation_sum_zero`. -/
theorem fourierLocalDeviation_dft_zero (k : ‚Ñï) (hk : 1 ‚â§ k) (p : ‚Ñï) [NeZero p]
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
    dft p (k - 1) (fourierLocalDeviation k Œ© p) 0 = 0 := by
  unfold dft; simp +decide
  unfold character; simp +decide [additiveChar_zero]
  exact Or.inr (fourierLocalDeviation_sum_zero k hk p Œ©)

/-! ### Box indicator function -/

/-- The **box indicator function** on $(\mathbb{Z}/q\mathbb{Z})^m$. Given a box `B`
with side lengths $b_1, \ldots, b_m$ and a scaling parameter `s > 0`, the indicator
$I_S(x) = 1$ if $x$ lies in the scaled box $\{1, \ldots, \lfloor s b_j \rfloor\}^m$
(identified with elements of `ZMod q` via their canonical representatives), and
$I_S(x) = 0$ otherwise. -/
noncomputable def boxIndicator (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (B : Box m) (s : ‚Ñù) (x : Fin m ‚Üí ZMod q) : ‚ÑÇ :=
  if ‚àÄ j : Fin m, (x j).val ‚àà Finset.Icc 1 ‚åäs * B.sides j‚åã‚Çä then 1 else 0

/-! ### Exponential sum bounds from `WellDistributed` -/

/-- The Fourier-analytic analogue of `WellDistributed` from ¬ß3.2.
This hypothesis directly asserts the necessary $L^\\infty$ decay on the non-zero Fourier
coefficients of the local deviation function, bypassing the lossy spatial bound.
Specifically, it asserts that for $\\xi \\neq 0$, the Fourier coefficient is bounded by
$p^{-\\varepsilon} |\\Omega_p| / p^{k-1}$, which is necessary to offset the dual group volume. -/
def WellDistributedFourier (Œµ : ‚Ñù) (p : ‚Ñï) [Fact p.Prime] (Œ© : Finset (ZMod p)) (k : ‚Ñï) : Prop :=
  ‚àÄ (Œæ : Fin (k - 1) ‚Üí ZMod p), Œæ ‚âÝ 0 ‚Üí
    ‚Äñdft p (k - 1) (fun h => (tupleCount Œ© (Fin.cons 0 h) : ‚ÑÇ)) Œæ‚Äñ ‚â§
    (p : ‚Ñù) ^ (-Œµ) * ((Œ©.card : ‚Ñù) ^ k / (p : ‚Ñù) ^ (k - 1))

/-! ### Helper lemmas for the WD ‚Üí WDF bridge -/

/-- The norm of `additiveChar q a x` is 1. -/
lemma norm_additiveChar (q : ‚Ñï) [NeZero q] (a x : ZMod q) :
    ‚ÄñadditiveChar q a x‚Äñ = 1 := by
  unfold additiveChar
  have h : 2 * ‚ÜëReal.pi * I * ‚Üë(a * x).val / (‚Üëq : ‚ÑÇ) =
      ‚Üë(2 * Real.pi * ‚Üë(a * x).val / (‚Üëq : ‚Ñù)) * I := by
    push_cast; ring
  rw [h, Complex.norm_exp_ofReal_mul_I]

/-- The norm of `character q m Œæ x` is 1. -/
lemma norm_character (q : ‚Ñï) [NeZero q] (m : ‚Ñï) (Œæ x : Fin m ‚Üí ZMod q) :
    ‚Äñcharacter q m Œæ x‚Äñ = 1 := by
  unfold character
  induction m with
  | zero => simp
  | succ n ih =>
    rw [Fin.prod_univ_castSucc, norm_mul]
    rw [ih (fun j => Œæ j.castSucc) (fun j => x j.castSucc)]
    rw [norm_additiveChar]
    ring

/-- For Œæ ‚âÝ 0, the sum of conjugate characters vanishes. -/
lemma sum_star_character_eq_zero (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (Œæ : Fin m ‚Üí ZMod q) (hŒæ : Œæ ‚âÝ 0) :
    ‚àë x : Fin m ‚Üí ZMod q, starRingEnd ‚ÑÇ (character q m Œæ x) = 0 := by
  have h := character_orthogonality q m 0 Œæ
  simp only [character, Pi.zero_apply, additiveChar_zero, Finset.prod_const_one, one_mul] at h
  rw [if_neg (Ne.symm hŒæ)] at h
  convert h using 1

lemma WellDistributed_implies_WellDistributedFourier
    (Œµ : ‚Ñù) (p : ‚Ñï) [Fact p.Prime] (Œ© : Finset (ZMod p)) (k : ‚Ñï)
    (hWD : WellDistributed Œµ p Œ© k) :
    WellDistributedFourier Œµ p Œ© k := by
  intro ŒæŒæ hŒæ_ne_zero
  have h_sum_zero : ‚àë r : Fin (k - 1) ‚Üí ZMod p, starRingEnd ‚ÑÇ (character p (k - 1) ŒæŒæ r) = 0 := by
    convert sum_star_character_eq_zero p ( k - 1 ) ŒæŒæ hŒæ_ne_zero using 1;
  -- Apply the triangle inequality to the sum.
  have h_triangle : ‚Äñ(1 / (p : ‚ÑÇ) ^ (k - 1)) * ‚àë r : Fin (k - 1) ‚Üí ZMod p, (tupleCount Œ© (Fin.cons 0 r) - ((Œ©.card : ‚ÑÇ) ^ k / (p : ‚ÑÇ) ^ (k - 1))) * starRingEnd ‚ÑÇ (character p (k - 1) ŒæŒæ r)‚Äñ ‚â§ (1 / (p : ‚Ñù) ^ (k - 1)) * ‚àë r : Fin (k - 1) ‚Üí ZMod p, |(tupleCount Œ© (Fin.cons 0 r) : ‚Ñù) - ((Œ©.card : ‚Ñù) ^ k / (p : ‚Ñù) ^ (k - 1))| := by
    have h_triangle : ‚àÄ r : Fin (k - 1) ‚Üí ZMod p, ‚Äñ(tupleCount Œ© (Fin.cons 0 r) - ((Œ©.card : ‚ÑÇ) ^ k / (p : ‚ÑÇ) ^ (k - 1))) * starRingEnd ‚ÑÇ (character p (k - 1) ŒæŒæ r)‚Äñ ‚â§ |(tupleCount Œ© (Fin.cons 0 r) : ‚Ñù) - ((Œ©.card : ‚Ñù) ^ k / (p : ‚Ñù) ^ (k - 1))| := by
      intro r
      simp [norm_character];
      convert Complex.norm_real _ |> le_of_eq using 1;
      norm_num [ Complex.normSq, Complex.norm_def ];
    rw [ norm_mul, norm_div ];
    gcongr;
    ¬∑ exact_mod_cast pow_pos ( Nat.Prime.pos Fact.out ) _;
    ¬∑ norm_num;
    ¬∑ norm_num [ Complex.norm_pow ];
    ¬∑ exact le_trans ( norm_sum_le _ _ ) ( Finset.sum_le_sum fun _ _ => h_triangle _ );
  refine le_trans ?_ ( h_triangle.trans ?_ );
  ¬∑ unfold dft; simp +decide [ sub_mul ] ;
    simp_all +decide [ ‚Üê Finset.mul_sum _ _ _ ];
  ¬∑ have := hWD.2;
    rw [ div_mul_eq_mul_div, div_le_iff‚ÇÄ ] <;> norm_cast at * <;> simp_all +decide only [Nat.cast_pow,
      one_div, Complex.norm_mul, norm_inv, norm_pow, RCLike.norm_natCast, one_mul];
    ¬∑ exact this.trans ( by nlinarith [ show 0 ‚â§ ( p : ‚Ñù ) ^ ( k - 1 ) * ( p : ‚Ñù ) ^ ( -Œµ ) * ( ( #Œ© : ‚Ñù ) ^ k / p ^ ( k - 1 ) ) by positivity, show ( 1 - ( #Œ© : ‚Ñù ) / p ) ‚â§ 1 by exact sub_le_self _ <| by positivity ] );
    ¬∑ exact pow_pos ( Nat.Prime.pos Fact.out ) _

/-
**$L^\\infty$ bound on local deviation Fourier coefficients.** Under the `WellDistributedFourier`
hypothesis (which encodes the Weil bound cancellation from the convolution structure),
the Fourier transform of the local deviation function is bounded pointwise.

Note: by definition, `dft(deviation)(0) = 0`. For $\\xi \\neq 0$, the deviation FT equals
the FT of `tupleCount`, which is bounded by `WellDistributedFourier`.
-/
theorem local_deviation_fourier_bound (Œµ : ‚Ñù) (_hŒµ : 0 < Œµ)
    (p : ‚Ñï) [hp : Fact p.Prime] (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (k : ‚Ñï) (hk : 1 ‚â§ k)
    (hwd : WellDistributedFourier Œµ p (Œ© p) k)
    (Œæ : Fin (k - 1) ‚Üí ZMod p) :
    ‚Äñdft p (k - 1) (fourierLocalDeviation k Œ© p) Œæ‚Äñ ‚â§
      (p : ‚Ñù) ^ (-Œµ) * ((Œ© p).card : ‚Ñù) ^ k / (p : ‚Ñù) ^ (k - 1) := by
  unfold WellDistributedFourier at hwd;
  unfold dft fourierLocalDeviation;
  by_cases hŒæ : Œæ = 0 <;> simp_all +decide [ div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm ];
  ¬∑ simp_all +decide [ Finset.sum_sub_distrib, mul_comm, mul_left_comm, character ];
    rw [ show ( ‚àë x : Fin ( k - 1 ) ‚Üí ZMod p, ( tupleCount ( Œ© p ) ( Fin.cons 0 x ) : ‚ÑÇ ) ) = ( # ( Œ© p ) : ‚ÑÇ ) ^ k from ?_ ] ; norm_num;
    ¬∑ positivity;
    ¬∑ convert sum_tupleCount_eq_card_pow k hk p Œ© using 1;
  ¬∑ simp_all +decide [ mul_sub, mul_assoc, mul_comm, Finset.mul_sum _ _ _, dft ];
    simp_all +decide [ ‚Üê Finset.mul_sum _ _ _ ];
    rw [ show ( ‚àë i : Fin ( k - 1 ) ‚Üí ZMod p, ( starRingEnd ‚ÑÇ ) ( character p ( k - 1 ) Œæ i ) ) = 0 from ?_ ] ; aesop;
    have := character_orthogonality p ( k - 1 ) Œæ 0; simp_all +decide only [‚ÜìreduceIte] ;
    convert congr_arg Star.star this using 1;
    ¬∑ simp +decide [ character ];
    ¬∑ norm_num

/-! ### Box Fourier transform decay -/

/-
The box indicator factors as a product of coordinate-wise 1D indicators:
`boxIndicator q m B s x = ‚àè j, if (x j).val ‚àà Icc 1 ‚åäs * B.sides j‚åã‚Çä then 1 else 0`.
This follows from the equivalence of `‚àÄ j, P j` with the product of `if P j then 1 else 0`.
-/
lemma boxIndicator_eq_prod (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (B : Box m) (s : ‚Ñù) (x : Fin m ‚Üí ZMod q) :
    boxIndicator q m B s x = ‚àè j : Fin m,
      if (x j).val ‚àà Finset.Icc 1 ‚åäs * B.sides j‚åã‚Çä then (1 : ‚ÑÇ) else 0 := by
  unfold boxIndicator; split_ifs <;> simp_all +decide [ Finset.prod_ite ] ;

/-
The DFT of the box indicator factors as a product of 1D DFTs.
This relies on `boxIndicator_eq_prod` to factor the function and the fact that
`character q m Œæ x = ‚àè j, additiveChar q (Œæ j) (x j)` factors over coordinates.
The sum over `x : Fin m ‚Üí ZMod q` of the product then splits via `Fintype.prod_sum`.
-/
lemma dft_boxIndicator_eq_prod (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (B : Box m) (s : ‚Ñù) (Œæ : Fin m ‚Üí ZMod q) :
    dft q m (boxIndicator q m B s) Œæ =
      ‚àè j : Fin m, dft q 1
        (fun x => if (x 0).val ‚àà Finset.Icc 1 ‚åäs * B.sides j‚åã‚Çä then (1 : ‚ÑÇ) else 0)
        (fun _ => Œæ j) := by
  unfold dft;
  nontriviality;
  simp +decide [ boxIndicator_eq_prod, Finset.prod_mul_distrib, Finset.prod_const ];
  rw [ Finset.prod_sum ];
  refine' Or.inl ( Finset.sum_bij ( fun x _ => fun i _ => fun _ => x i ) _ _ _ _ ) <;> simp +decide [ character ];
  ¬∑ simp +decide [ funext_iff ];
  ¬∑ exact fun b => ‚ü® fun i => b i ( Finset.mem_univ i ) 0, funext fun i => funext fun _ => funext fun _ => by simp +decide [ Fin.eq_zero ] ‚ü©;
  ¬∑ exact fun a => by rw [ ‚Üê Finset.prod_mul_distrib ] ; exact Finset.prod_congr rfl fun _ _ => by split_ifs <;> ring;

/-! ### CRT frequency equivalence -/

/-
For squarefree `q` and prime factor `p ‚à£ q`, the cofactor `q / p` is nonzero in `ZMod p`.
This holds because `q` is squarefree, so `p ‚à§ q / p`, hence `(q / p : ‚Ñï)` has nonzero
image in `ZMod p`.
-/
lemma natCast_div_prime_ne_zero (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (p : q.primeFactors) :
    ((q / p : ‚Ñï) : ZMod p) ‚âÝ 0 := by
  rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ];
  rw [ Nat.dvd_div_iff_mul_dvd ] <;> norm_num [ Nat.mem_primeFactors.mp p.2 ];
  exact fun h => absurd ( hq.squarefree_of_dvd h ) ( by rw [ Nat.squarefree_mul_iff ] ; aesop )

/-- The **CRT frequency equivalence**: maps a global frequency `Œæ ‚àà ZMod q` to its
local frequency components for the additive character splitting.

For each prime factor `p ‚à£ q`, the local frequency is
`(Œæ mod p) ¬∑ (q/p)‚Åª¬π mod p`, where `(q/p)‚Åª¬π` is the modular inverse of the cofactor
`q/p` in `ZMod p`. This correction factor arises from the CRT idempotents:
if `e‚Çö` is the idempotent satisfying `e‚Çö ‚â° 1 (mod p)` and `e‚Çö ‚â° 0 (mod p')`
for `p' ‚âÝ p`, then `e‚Çö = (q/p) ¬∑ (q/p)‚Åª¬π`, and the additive character
`exp(2œÄi a/q)` decomposes as `‚àè‚Çö exp(2œÄi (a mod p ¬∑ (q/p)‚Åª¬π) / p)`. -/
noncomputable def crtFrequencyEquiv (q : ‚Ñï) [NeZero q] (hq : Squarefree q) :
    ZMod q ‚âÉ ((p : q.primeFactors) ‚Üí ZMod (p : ‚Ñï)) where
  toFun Œæ p :=
    haveI : NeZero p.val := ‚ü®(Nat.mem_primeFactors.mp p.prop).1.ne_zero‚ü©
    crtRingEquiv q hq Œæ p * ((q / p : ‚Ñï) : ZMod p)‚Åª¬π
  invFun f :=
    (crtRingEquiv q hq).symm fun p =>
      haveI : NeZero p.val := ‚ü®(Nat.mem_primeFactors.mp p.prop).1.ne_zero‚ü©
      f p * ((q / p : ‚Ñï) : ZMod p)
  left_inv Œæ := by
    simp only
    conv_rhs => rw [‚Üê (crtRingEquiv q hq).symm_apply_apply Œæ]
    congr 1; funext p
    haveI : NeZero p.val := ‚ü®(Nat.mem_primeFactors.mp p.prop).1.ne_zero‚ü©
    haveI : Fact p.val.Prime := ‚ü®(Nat.mem_primeFactors.mp p.prop).1‚ü©
    rw [mul_assoc, inv_mul_cancel‚ÇÄ (natCast_div_prime_ne_zero q hq p), mul_one]
  right_inv f := by
    funext p; simp only
    haveI : NeZero p.val := ‚ü®(Nat.mem_primeFactors.mp p.prop).1.ne_zero‚ü©
    haveI : Fact p.val.Prime := ‚ü®(Nat.mem_primeFactors.mp p.prop).1‚ü©
    rw [(crtRingEquiv q hq).apply_symm_apply]
    rw [mul_assoc, mul_inv_cancel‚ÇÄ (natCast_div_prime_ne_zero q hq p), mul_one]

/-
**Additive character CRT splitting.** For squarefree `q`, the additive character
`exp(2œÄi (Œæ ¬∑ x).val / q)` decomposes as a product over the prime factors of `q`:
$\chi_\xi(x) = \prod_{p \mid q} \chi_{\xi_p}(x_p),$
where `Œæ_p = crtFrequencyEquiv q hq Œæ p` is the corrected local frequency and
`x_p = crtRingEquiv q hq x p` is the CRT projection of `x`.
-/
set_option maxHeartbeats 1600000 in
lemma additiveChar_crt_split (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (Œæ x : ZMod q) :
    additiveChar q Œæ x =
      ‚àè p ‚àà q.primeFactors.attach, (
        haveI : NeZero p.val := ‚ü®(Nat.mem_primeFactors.mp p.prop).1.ne_zero‚ü©
        additiveChar p.val
          (crtFrequencyEquiv q hq Œæ p)
          (crtRingEquiv q hq x p)
      ) := by
  unfold additiveChar; simp +decide [ mul_comm ] ;
  rw [ ‚Üê Complex.exp_sum ];
  -- By the properties of the exponential function and the definition of `crtFrequencyEquiv`, we can rewrite the right-hand side of the equation.
  have h_exp : (Œæ * x).cast / (q : ‚ÑÇ) - ‚àë p ‚àà q.primeFactors.attach, ((crtFrequencyEquiv q hq) Œæ p * (crtRingEquiv q hq) x p).val / (p : ‚ÑÇ) ‚àà Set.range (fun n : ‚Ñ§ => (n : ‚ÑÇ)) := by
    -- By the properties of the Chinese Remainder Theorem, we know that
    have h_crt : (Œæ * x).val ‚â° ‚àë p ‚àà q.primeFactors.attach, ((crtFrequencyEquiv q hq) Œæ p * (crtRingEquiv q hq) x p).val * (q / p : ‚Ñï) [MOD q] := by
      have h_crt : ‚àÄ p ‚àà q.primeFactors.attach, (Œæ * x).val ‚â° ((crtFrequencyEquiv q hq Œæ p) * (crtRingEquiv q hq x p)).val * (q / p : ‚Ñï) [MOD p] := by
        intro p hp
        have h_crt : (Œæ * x).val ‚â° ((crtRingEquiv q hq (Œæ * x) p).val) * (q / p : ‚Ñï) * ((q / p : ‚Ñï)‚Åª¬π : ZMod p).val [MOD p] := by
          have h_crt : (q / p : ‚Ñï) * ((q / p : ‚Ñï)‚Åª¬π : ZMod p).val ‚â° 1 [MOD p] := by
            haveI := Fact.mk ( Nat.prime_of_mem_primeFactors p.2 ) ; simp +decide [ ‚Üê ZMod.natCast_eq_natCast_iff ] ;
            rw [ ZMod.mul_inv_of_unit ];
            rw [ isUnit_iff_ne_zero ];
            rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ];
            rw [ Nat.dvd_div_iff_mul_dvd ];
            ¬∑ exact fun h => absurd ( hq.squarefree_of_dvd h ) ( by rw [ Nat.squarefree_mul_iff ] ; aesop );
            ¬∑ exact Nat.dvd_of_mem_primeFactors p.2;
          simp_all +decide [ ‚Üê ZMod.natCast_eq_natCast_iff, mul_assoc ];
          have h_crt : (Œæ * x).cast = ((crtRingEquiv q hq (Œæ * x) p).val : ZMod p) := by
            convert rfl;
            convert ZMod.natCast_zmod_val _;
            ¬∑ convert rfl;
              convert crtRingEquiv_apply_eq_castHom q hq ( Œæ * x ) p using 1;
            ¬∑ exact ‚ü® Nat.ne_of_gt ( Nat.pos_of_mem_primeFactors p.2 ) ‚ü©;
          aesop;
        simp_all +decide [ ‚Üê ZMod.natCast_eq_natCast_iff, mul_assoc ];
        simp +decide [ mul_assoc, mul_comm, mul_left_comm, crtFrequencyEquiv ];
        haveI := Fact.mk ( Nat.prime_of_mem_primeFactors p.2 ) ; simp +decide [ ‚Üê mul_assoc ] ;
      have h_crt : ‚àÄ p ‚àà q.primeFactors.attach, (Œæ * x).val ‚â° ‚àë p ‚àà q.primeFactors.attach, ((crtFrequencyEquiv q hq Œæ p) * (crtRingEquiv q hq x p)).val * (q / p : ‚Ñï) [MOD p] := by
        intro p hp
        have h_crt : ‚àë p ‚àà q.primeFactors.attach, ((crtFrequencyEquiv q hq Œæ p) * (crtRingEquiv q hq x p)).val * (q / p : ‚Ñï) ‚â° ((crtFrequencyEquiv q hq Œæ p) * (crtRingEquiv q hq x p)).val * (q / p : ‚Ñï) [MOD p] := by
          simp +decide [ ‚Üê ZMod.natCast_eq_natCast_iff ];
          rw [ Finset.sum_eq_single p ] <;> simp_all +decide [ Nat.ModEq ];
          intro a ha ha' ha'' ha'''; have := Nat.dvd_div_of_mul_dvd ( show a * p.val ‚à£ q from Nat.Coprime.mul_dvd_of_dvd_of_dvd ( by have := Nat.coprime_primes ha ( Nat.prime_of_mem_primeFactors p.2 ) ; aesop ) ha' ( Nat.dvd_of_mem_primeFactors p.2 ) ) ; simp_all +decide [ Nat.dvd_iff_mod_eq_zero ] ;
          simp_all +decide [ ‚Üê ZMod.val_natCast, Nat.dvd_iff_mod_eq_zero ];
        exact Eq.trans ( by solve_by_elim ) h_crt.symm;
      rw [ Nat.modEq_iff_dvd ] at *;
      have h_crt : (‚àè p ‚àà q.primeFactors.attach, (p : ‚Ñ§)) ‚à£ (‚àë p ‚àà q.primeFactors.attach, ((crtFrequencyEquiv q hq Œæ p) * (crtRingEquiv q hq x p)).val * (q / p : ‚Ñï)) - (Œæ * x).val := by
        convert Finset.prod_dvd_of_coprime _ _;
        ¬∑ intros p hp q hq hpq; exact (by
          have := Nat.coprime_primes ( Nat.prime_of_mem_primeFactors p.2 ) ( Nat.prime_of_mem_primeFactors q.2 ) ; aesop;);
        ¬∑ exact fun p hp => by simpa using h_crt p hp |> Nat.ModEq.dvd;
      convert h_crt using 1;
      rw [ ‚Üê Nat.cast_prod ] ; norm_cast ; rw [ ‚Üê Nat.prod_primeFactors_of_squarefree hq ] ;
      refine' Finset.prod_bij ( fun p hp => ‚ü® p, _ ‚ü© ) _ _ _ _ <;> simp_all +decide [ Nat.primeFactors_prod ];
    obtain ‚ü® k, hk ‚ü© := h_crt.symm.dvd;
    use k;
    simp_all +decide [ ‚Üê @Int.cast_inj ‚ÑÇ ];
    rw [ div_sub', eq_div_iff ] <;> norm_cast at * <;> simp_all +decide [ NeZero.ne ];
    convert hk.symm using 1 ; ring;
    rw [ Finset.mul_sum _ _ _ ] ; refine' congr_arg _ ( Finset.sum_congr rfl fun p hp => _ ) ; rw [ Nat.cast_div ( Nat.dvd_of_mem_primeFactors p.2 ) ( Nat.cast_ne_zero.mpr <| Nat.ne_of_gt <| Nat.pos_of_mem_primeFactors p.2 ) ] ; ring;
  obtain ‚ü® n, hn ‚ü© := h_exp; simp_all +decide [ Complex.exp_eq_exp_iff_exists_int, mul_div_assoc, mul_assoc, mul_comm, mul_left_comm ] ;
  exact ‚ü® n, by rw [ hn ] ; simp [ Finset.mul_sum _ _ _, mul_sub, mul_comm ] ‚ü©

/-! ### CRT factorization of Fourier coefficients -/

/-
**CRT factorization of the deviation DFT.** For squarefree `q`, the Fourier transform
of the global counting function factors as a product of local Fourier transforms over
the prime factors of `q`. This is the frequency-domain manifestation of
`counting_function_multiplicative`.
-/
theorem dft_crt_factorization (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (Œæ : Fin (k - 1) ‚Üí ZMod q) :
    dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ)) Œæ =
      ‚àè p ‚àà q.primeFactors.attach, (
        haveI : NeZero p.val := ‚ü®(Nat.mem_primeFactors.mp p.prop).1.ne_zero‚ü©
        dft p.val (k - 1) (fun h_p => (tupleCount (Œ© p.val) (Fin.cons 0 h_p) : ‚ÑÇ))
          (fun j => crtFrequencyEquiv q hq (Œæ j) p)) := by
  -- `hk` is not used in the proof but is retained for specification purposes.
  unfold dft; simp +decide [ Finset.prod_mul_distrib ] ;
  rw [ Finset.prod_sum ];
  refine' congrArg‚ÇÇ _ _ _;
  ¬∑ rw [ Finset.prod_pow, ‚Üê Nat.cast_prod ];
    convert rfl;
    convert prod_primeFactors_eq q hq |> Eq.symm;
  ¬∑ refine' Finset.sum_bij _ _ _ _ _;
    use fun a _ p _ j => crtRingEquiv q hq ( a j ) p;
    ¬∑ aesop;
    ¬∑ simp +decide [funext_iff];
      intro a‚ÇÅ a‚ÇÇ h x; exact (crtRingEquiv q hq).injective (by
      ext p; specialize h p.val ( Nat.prime_of_mem_primeFactors p.prop ) ( Nat.dvd_of_mem_primeFactors p.prop ) ( NeZero.ne q ) x; aesop;);
    ¬∑ intro b hb; use fun j => (crtRingEquiv q hq).symm (fun p => b p (by
      exact Finset.mem_attach _ p) j); simp +decide;
    ¬∑ intro a ha; rw [ Finset.prod_mul_distrib ] ; simp +decide [ character ] ;
      congr! 1;
      ¬∑ convert congr_arg ( ( ‚Üë ) : ‚Ñï ‚Üí ‚ÑÇ ) ( counting_function_multiplicative q hq Œ© ( Fin.cons 0 a ) ) using 1;
        simp +decide [ crtRingEquiv_apply_eq_castHom ];
        refine' Finset.prod_bij ( fun x _ => x.val ) _ _ _ _ <;> simp +decide [ Fin.cons ];
        intro p hp hp' hq; congr; ext i; induction i using Fin.inductionOn <;> aesop;
      ¬∑ rw [ Finset.prod_comm ];
        refine' Finset.prod_congr rfl fun x _ => _;
        rw [ additiveChar_crt_split q hq ];
        rw [ map_prod ];
        refine' Finset.prod_bij ( fun p hp => ‚ü® p, hp ‚ü© ) _ _ _ _ <;> aesop

/-! ### Fourier synthesis helper lemmas -/

/-
The sum of `‚Äñdft I_S (-Œæ)‚Äñ` over all `Œæ` equals the sum of `‚Äñdft I_S Œæ‚Äñ` by reindexing
(`Œæ ‚Ü¶ -Œæ` is a bijection on the group).
-/
lemma sum_norm_dft_neg_eq (q : ‚Ñï) [NeZero q] (m : ‚Ñï) (f : (Fin m ‚Üí ZMod q) ‚Üí ‚ÑÇ) :
    ‚àë Œæ : Fin m ‚Üí ZMod q, ‚Äñdft q m f (-Œæ)‚Äñ =
    ‚àë Œæ : Fin m ‚Üí ZMod q, ‚Äñdft q m f Œæ‚Äñ := by
  apply Finset.sum_bij (fun Œæ _ => -Œæ);
  ¬∑ exact fun _ _ => Finset.mem_univ _;
  ¬∑ aesop;
  ¬∑ exact fun b _ => ‚ü® -b, Finset.mem_univ _, neg_neg b ‚ü©;
  ¬∑ grind

/-
**Spatial ‚Üí Frequency swap.** Using DFT inversion on `f_dev` and swapping sums
(Fubini), we obtain
`‚àë h, I_S(h) * f(h) = ‚àë Œæ, q^m * dft(f)(Œæ) * dft(I_S)(-Œæ)`.
-/
lemma spatial_to_frequency_swap (q : ‚Ñï) [NeZero q] (m : ‚Ñï)
    (f g : (Fin m ‚Üí ZMod q) ‚Üí ‚ÑÇ) :
    ‚àë h, g h * f h =
      ‚àë Œæ : Fin m ‚Üí ZMod q,
        ((q : ‚ÑÇ) ^ m) * dft q m f Œæ * dft q m g (-Œæ) := by
  -- By Fubini's theorem, we can interchange the order of summation.
  have h_fubini : ‚àë h : Fin m ‚Üí ZMod q, g h * (‚àë Œæ : Fin m ‚Üí ZMod q, dft q m f Œæ * character q m Œæ h) = ‚àë Œæ : Fin m ‚Üí ZMod q, dft q m f Œæ * (‚àë h : Fin m ‚Üí ZMod q, g h * character q m Œæ h) := by
    simpa only [ mul_assoc, mul_left_comm, Finset.mul_sum _ _ _ ] using Finset.sum_comm;
  convert h_fubini using 2;
  ¬∑ exact congrArg _ ( dft_inversion q m f _ );
  ¬∑ unfold dft;
    field_simp;
    unfold character; congr! 2; simp +decide [ starRingEnd_additiveChar ] ;

/-
The sum of the global counting function over all `h` equals
`q^(k-1) * ‚àè_p Œº_p` (or equivalently, `‚àè_p |Œ©_p|^k`).
-/
lemma sum_global_tupleCount (k : ‚Ñï) (hk : 2 ‚â§ k)
    (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
    (‚àë h : Fin (k - 1) ‚Üí ZMod q,
      (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ)) =
      ‚Üë(q : ‚Ñù) ^ (k - 1 : ‚Ñï) * ‚Üë(‚àè p ‚àà q.primeFactors, localMean k Œ© p) := by
  have := @dft_crt_factorization;
  specialize this q hq Œ© k hk 0;
  convert congr_arg ( fun x : ‚ÑÇ => ( q : ‚ÑÇ ) ^ ( k - 1 ) * x ) this using 1;
  ¬∑ unfold dft; norm_num;
    unfold character; norm_num [ NeZero.ne ] ;
  ¬∑ simp +decide [ localMean, dft ];
    rw [ ‚Üê Finset.prod_div_distrib ];
    rw [ ‚Üê Finset.prod_attach ];
    refine Or.inl <| Finset.prod_congr rfl fun p hp => ?_;
    rw [ show ( crtFrequencyEquiv q hq ) 0 p = 0 from _ ];
    ¬∑ simp +decide [ character, additiveChar ];
      rw [ inv_mul_eq_div, sum_tupleCount_eq_card_pow ];
      linarith;
    ¬∑ simp +decide [ crtFrequencyEquiv ]

/-
The DFT of the global counting function at `Œæ = 0` equals `Œº_q = ‚àè_p Œº_p`.
This is a consequence of the definition of `dft`, `sum_tupleCount_eq_card_pow`,
and `counting_function_multiplicative`.
-/
lemma dft_tupleCount_zero (k : ‚Ñï) (hk : 2 ‚â§ k)
    (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) :
    dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ)) 0 =
      ‚Üë(‚àè p ‚àà q.primeFactors, localMean k Œ© p) := by
  unfold dft;
  -- The sum of the counting function over the entire domain is independent of the phase factor `e^(iŒ∏)`. It is equal to the product of the means times `q^(k-1)` by `sum_global_tupleCount`.
  have h_sum_nonzero : ‚àë h : Fin (k - 1) ‚Üí ZMod q, (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ) = (q : ‚Ñù) ^ (k - 1 : ‚Ñï) * (‚àè p ‚àà q.primeFactors, localMean k Œ© p) := by
    exact sum_global_tupleCount k hk q hq Œ©;
  simp_all +decide [ character ];
  rw [ ‚Üê mul_assoc, inv_mul_cancel‚ÇÄ ( pow_ne_zero _ ( Nat.cast_ne_zero.mpr <| NeZero.ne q ) ), one_mul ]

/-
The DFT of a constant function at `Œæ ‚âÝ 0` vanishes.
This follows from character orthogonality.
-/
lemma dft_const_nonzero (q : ‚Ñï) [NeZero q] (m : ‚Ñï) (c : ‚ÑÇ)
    (Œæ : Fin m ‚Üí ZMod q) (hŒæ : Œæ ‚âÝ 0) :
    dft q m (fun _ => c) Œæ = 0 := by
  unfold dft;
  have := character_orthogonality q m Œæ 0; simp_all +decide [ Finset.mul_sum _ _ _, mul_left_comm ] ;
  convert congr_arg ( fun x : ‚ÑÇ => c * ( ( q ^ m : ‚ÑÇ ) ‚Åª¬π * starRingEnd ‚ÑÇ x ) ) this using 1 ; simp +decide [ Finset.mul_sum _ _ _, character ] ; ring_nf;
  norm_num

lemma dft_tupleCount_norm_le_localMean (k : ‚Ñï) (hk : 2 ‚â§ k) (Œµ : ‚Ñù) (hŒµ : 0 < Œµ)
    (p : ‚Ñï) [hp : Fact p.Prime] (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (hwd : WellDistributedFourier Œµ p (Œ© p) k)
    (Œæ : Fin (k - 1) ‚Üí ZMod p) :
    ‚Äñdft p (k - 1) (fun h => (tupleCount (Œ© p) (Fin.cons 0 h) : ‚ÑÇ)) Œæ‚Äñ ‚â§
      localMean k Œ© p := by
  by_cases hŒæ : Œæ = 0;
  ¬∑ -- By definition of $dft$, we have:
    have h_dft_zero : dft p (k - 1) (fun h => ‚Üë(tupleCount (Œ© p) (Fin.cons 0 h))) 0 = (p : ‚Ñù) ^ (-(k - 1) : ‚Ñ§) * ((Œ© p).card : ‚Ñù) ^ k := by
      have := @sum_tupleCount_eq_card_pow;
      rcases k with ( _ | _ | k ) <;> simp_all +decide [ dft ];
      simp_all +decide [ character ];
      convert congr_arg ( fun x : ‚ÑÇ => ( p ^ ( k + 1 ) : ‚ÑÇ ) ‚Åª¬π * x ) ( this ( k + 2 ) ( by linarith ) p Œ© ) using 1 ; group;
    rcases k with ( _ | _ | k ) <;> simp_all +decide [ localMean ];
    norm_num [ zpow_add‚ÇÄ, hp.1.ne_zero ] ; ring_nf ; norm_num;
  ¬∑ refine' le_trans ( hwd Œæ hŒæ ) _;
    simp only [localMean];
    rw [mul_div];
    exact div_le_div_of_nonneg_right
      (mul_le_of_le_one_left (by positivity)
        (by simpa using Real.rpow_le_rpow_of_exponent_le (mod_cast hp.1.one_lt.le) (neg_nonpos.mpr hŒµ.le)))
      (by positivity)

lemma dft_tupleCount_norm_le_decay (k : ‚Ñï) (hk : 2 ‚â§ k) (Œµ : ‚Ñù) (hŒµ : 0 < Œµ)
    (p : ‚Ñï) [hp : Fact p.Prime] (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (hwd : WellDistributedFourier Œµ p (Œ© p) k)
    (Œæ : Fin (k - 1) ‚Üí ZMod p) (hŒæ : Œæ ‚âÝ 0) :
    ‚Äñdft p (k - 1) (fun h => (tupleCount (Œ© p) (Fin.cons 0 h) : ‚ÑÇ)) Œæ‚Äñ ‚â§
      (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p := by
  have := hwd Œæ hŒæ
  unfold localMean
  exact this

/-! ### Fourier synthesis: the uniform deviation bound -/

lemma deviation_dft_prod_bound (k : ‚Ñï) (hk : 2 ‚â§ k) (Œµ : ‚Ñù) (hŒµ : 0 < Œµ)
    (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (hwd : ‚àÄ p, (hp : p ‚àà q.primeFactors) ‚Üí haveI : Fact p.Prime :=
      ‚ü®(Nat.mem_primeFactors.mp hp).1‚ü©;
      WellDistributedFourier Œµ p (Œ© p) k)
    (Œæ : Fin (k - 1) ‚Üí ZMod q) :
    ‚Äñdft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ) -
      ‚Üë(‚àè p ‚àà q.primeFactors, localMean k Œ© p)) Œæ‚Äñ ‚â§
      ‚àè p ‚àà q.primeFactors, localMean k Œ© p := by
  by_cases hŒæ : Œæ = 0;
  ¬∑ -- By definition of $dft$, we know that
    have h_dft_zero : dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ) - (‚àè p ‚àà q.primeFactors, localMean k Œ© p) : (Fin (k - 1) ‚Üí ZMod q) ‚Üí ‚ÑÇ) 0 = 0 := by
      have h_dft_zero : dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ)) 0 = (‚àè p ‚àà q.primeFactors, localMean k Œ© p) := by
        convert dft_tupleCount_zero k hk q hq Œ© using 1;
      convert congr_arg ( fun x : ‚ÑÇ => x - dft q ( k - 1 ) ( fun _ => ( ‚àè p ‚àà q.primeFactors, localMean k Œ© p : ‚ÑÇ ) ) 0 ) h_dft_zero using 1;
      ¬∑ unfold dft; norm_num [ Finset.sum_sub_distrib, sub_mul ] ;
        rw [ mul_sub ];
      ¬∑ unfold dft; norm_num [ Finset.card_univ ] ;
        unfold character; norm_num [ Finset.card_univ ] ;
        rw [ ‚Üê mul_assoc, inv_mul_cancel‚ÇÄ ( pow_ne_zero _ ( NeZero.ne _ ) ), one_mul, sub_self ];
    rw [ hŒæ, h_dft_zero ];
    exact le_trans ( by norm_num ) ( Finset.prod_nonneg fun p hp => div_nonneg ( pow_nonneg ( Nat.cast_nonneg _ ) _ ) ( pow_nonneg ( Nat.cast_nonneg _ ) _ ) );
  ¬∑ -- By linearity of the DFT, we have:
    have h_dft_linear : dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ) - (‚àè p ‚àà q.primeFactors, localMean k Œ© p)) Œæ = dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ)) Œæ := by
      unfold dft; simp +decide [ *, Finset.sum_sub_distrib, sub_mul ] ;
      rw [ ‚Üê Finset.mul_sum _ _ _, show ‚àë x : Fin ( k - 1 ) ‚Üí ZMod q, ( starRingEnd ‚ÑÇ ) ( character q ( k - 1 ) Œæ x ) = 0 from ?_ ] ; aesop;
      convert congr_arg ( fun x : ‚ÑÇ => starRingEnd ‚ÑÇ x ) ( character_orthogonality q ( k - 1 ) Œæ 0 ) using 1 <;> norm_num [ character ];
      aesop;
    rw [ h_dft_linear, dft_crt_factorization q hq Œ© k hk Œæ ];
    rw [ norm_prod ];
    refine' le_trans ( Finset.prod_le_prod _ fun p hp => _ ) _;
    use fun p => localMean k Œ© p;
    ¬∑ exact fun _ _ => norm_nonneg _;
    ¬∑ convert dft_tupleCount_norm_le_localMean k hk Œµ hŒµ p ( Œ© ) ( hwd p p.2 ) _ using 1;
    ¬∑ conv_rhs => rw [ ‚Üê Finset.prod_attach ] ;

/-- The support of a frequency Œæ modulo q is the set of prime factors p of q where Œæ mod p ‚âÝ 0. -/
def freqSupport (q m : ‚Ñï) [NeZero q] (Œæ : Fin m ‚Üí ZMod q) : Finset ‚Ñï :=
  q.primeFactors.filter (fun p =>
    if hp : p ‚àà q.primeFactors then
      (fun i => ZMod.castHom (Nat.dvd_of_mem_primeFactors hp) (ZMod p) (Œæ i)) ‚âÝ 0
    else False)

lemma deviation_dft_q1_q2_bound (k : ‚Ñï) (hk : 2 ‚â§ k) (Œµ : ‚Ñù) (hŒµ : 0 < Œµ)
    (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (hwd : ‚àÄ p, (hp : p ‚àà q.primeFactors) ‚Üí haveI : Fact p.Prime :=
      ‚ü®(Nat.mem_primeFactors.mp hp).1‚ü©;
      WellDistributedFourier Œµ p (Œ© p) k)
    (Œæ : Fin (k - 1) ‚Üí ZMod q) (hŒæ : Œæ ‚âÝ 0) :
    ‚Äñdft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ) -
      ‚Üë(‚àè p ‚àà q.primeFactors, localMean k Œ© p)) Œæ‚Äñ ‚â§
      (‚àè p ‚àà freqSupport q (k - 1) Œæ, (p : ‚Ñù) ^ (-Œµ)) * ‚àè p ‚àà q.primeFactors, localMean k Œ© p := by
  -- By the linearity of the DFT and the orthogonality of the characters, we can express the DFT of the deviation in terms of the DFT of the tuple count and the constant term.
  have h_dft_linear : dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ) - ‚Üë(‚àè p ‚àà q.primeFactors, localMean k Œ© p)) Œæ = dft q (k - 1) (fun h => (tupleCount (crtSubset q Œ©) (Fin.cons 0 h) : ‚ÑÇ)) Œæ := by
    unfold dft;
    simp +decide [ sub_mul ];
    rw [ ‚Üê Finset.mul_sum _ _ _ ];
    exact Or.inl <| mul_eq_zero_of_right _ <| sum_star_character_eq_zero q ( k - 1 ) Œæ hŒæ;
  rw [ h_dft_linear, dft_crt_factorization ];
  rotate_left;
  grind;
  ¬∑ linarith;
  ¬∑ rw [ norm_prod, ‚Üê Finset.prod_attach ];
    refine' le_trans ( Finset.prod_le_prod _ fun x hx => _ ) _;
    use fun x => if x.val.val ‚àà freqSupport q ( k - 1 ) Œæ then ( x.val.val : ‚Ñù ) ^ ( -Œµ ) * localMean k Œ© x.val.val else localMean k Œ© x.val.val;
    ¬∑ exact fun _ _ => norm_nonneg _;
    ¬∑ split_ifs with h;
      ¬∑ convert dft_tupleCount_norm_le_decay k hk Œµ hŒµ x.val.val _ _ _ _ using 1;
        exact ‚ü® Nat.prime_of_mem_primeFactors x.1.2 ‚ü©;
        ¬∑ exact hwd _ ( by aesop );
        ¬∑ intro H; simp_all +decide [ funext_iff, freqSupport ] ;
          obtain ‚ü® i, hi ‚ü© := h.2; specialize H i; simp_all +decide [ crtFrequencyEquiv ] ;
          haveI := Fact.mk h.1.1; simp_all +decide [ ZMod.natCast_eq_zero_iff ] ;
          exact absurd ( H.resolve_left ( by rw [ crtRingEquiv_apply_eq_castHom ] ; exact hi ) ) ( by intro h; exact absurd ( hq.squarefree_of_dvd h ) ( by rw [ Nat.squarefree_mul_iff ] ; aesop ) );
      ¬∑ convert dft_tupleCount_norm_le_localMean k hk Œµ hŒµ x.val.val _ _ _ using 1;
        grind;
        exact hwd _ ( by simp );
    ¬∑ simp +decide [ Finset.prod_ite, Finset.prod_mul_distrib ];
      rw [ mul_assoc, ‚Üê Finset.prod_union ];
      ¬∑ refine' mul_le_mul _ _ _ _;
        ¬∑ refine' le_of_eq _;
          refine' Finset.prod_bij ( fun x hx => x.val.val ) _ _ _ _ <;> simp +decide [ freqSupport ];
          exact fun p hp hpq hq h => ‚ü® ‚ü® hp, hpq, hq ‚ü©, h ‚ü©;
        ¬∑ refine' le_of_eq _;
          refine' Finset.prod_bij ( fun x hx => x.val.val ) _ _ _ _ <;> simp +decide [ freqSupport ];
          exact fun p hp hpq hq => ‚ü® ‚ü® hp, hpq, hq ‚ü©, by tauto ‚ü©;
        ¬∑ exact Finset.prod_nonneg fun _ _ => localMean_nonneg _ _ _;
        ¬∑ exact Finset.prod_nonneg fun _ _ => Real.rpow_nonneg ( Nat.cast_nonneg _ ) _;
      ¬∑ exact Finset.disjoint_filter.mpr fun _ _ _ _ => by tauto;

lemma dft_interval_l1_bound (q : ‚Ñï) [NeZero q] (L : ‚Ñï) :
    ‚àë Œæ : ZMod q, ‚Äñdft q 1 (fun x => if (x 0).val ‚àà Finset.Icc 1 L then (1 : ‚ÑÇ) else 0) (fun _ => Œæ)‚Äñ ‚â§
      Real.log (q : ‚Ñù) + 2 := by
