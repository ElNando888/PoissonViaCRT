    have hH_pos : 0 < H := by
      apply Nat.ceil_pos.mpr
      exact mul_pos (by linarith) (Finset.sum_pos (fun _ _ => X.sides_pos _)
        ‚ü®‚ü®0, by omega‚ü©, Finset.mem_univ _‚ü©)
    have hkk : (k - 1 + 1) * (k - 1 + 1) ‚â§ k * k := by
      rw [Nat.sub_add_cancel (by omega : 1 ‚â§ k)]
    calc gammaProdOfBoxPoint T h
        ‚â§ H ^ ((k - 1 + 1) * (k - 1 + 1)) := by
          apply gammaProdOfBoxPoint_le T H hH_pos h
          ¬∑ exact natAbs_diff_le_H H h hh_mem
          ¬∑ exact fin_cons_zero_diff_pos (by omega) X s h hbox
      _ ‚â§ H ^ (k * k) := Nat.pow_le_pow_right hH_pos hkk

/-
**Prime factors of a gamma product are in `T`.** Every prime dividing
`gammaProdOfBoxPoint T h` lies in `T`. This is because `gammaProdOfBoxPoint T h`
is a product of `lcm`s of values `gcd(‚àè_{p‚ààT} p, ¬∑)`, each of which divides
`‚àè_{p‚ààT} p`; hence the whole product divides a power of `‚àè_{p‚ààT} p`, whose
prime factors are exactly `T` (when `T` consists of primes).

This justifies restricting the gamma summation domain to those `Œ≥` with
`Œ≥.primeFactors ‚äÜ T`: the box-point fibres are empty outside this set.
-/
lemma gammaProdOfBoxPoint_primeFactors_subset {n : ‚Ñï} (T : Finset ‚Ñï)
    (hT_prime : ‚àÄ p ‚àà T, Nat.Prime p) (h : Fin n ‚Üí ‚Ñ§) :
    (gammaProdOfBoxPoint T h).primeFactors ‚äÜ T := by
  -- By definition of gammaProdOfBoxPoint, we know that every prime factor of gammaProdOfBoxPoint T h divides c.
  have h_divides_c : gammaProdOfBoxPoint T h ‚à£ (‚àè p ‚àà T, p) ^ (n + 1) := by
    convert Finset.prod_dvd_prod_of_dvd _ _ _;
    rotate_left;
    exact fun _ => ‚àè p ‚àà T, p;
    ¬∑ exact fun i _ => Finset.lcm_dvd fun j hj => Nat.gcd_dvd_left _ _;
    ¬∑ norm_num;
  grind +suggestions

/-! ## 3. Deviation sum bounded by gamma sum -/

/-- **Deviation-sum ‚â§ gamma-sum (per-T bound).**

For a nonempty subset `T ‚äÜ q.primeFactors`, the sum over box lattice
points `h` of the absolute deviation product `|‚àè_{p ‚àà T} (N_p(h) ‚àí Œº_p)|`
is bounded by a sum over gamma values `Œ≥ ‚àà [1, H^{k^2}]` of the per-gamma
deviation weight times the tuple count `M_Œ≥(H)`.

The proof proceeds by:
1. Applying `Finset.sum_fiberwise_of_maps_to` with the fibering function
   `gammaProdOfBoxPoint T` to partition the sum by gamma value.
2. Bounding each fiber sum using the pointwise bound
   `deviation_prod_le_perGammaWeight`.
3. Bounding each fiber cardinality using
   `fiber_card_le_countTuplesWithGammaProd`. -/
lemma deviation_sum_le_gamma_sum (Œµ : ‚Ñù) (hŒµ : 0 < Œµ) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (hŒ© : ‚àÄ p, p.Prime ‚Üí (Œ© p).Nonempty)
    (hWD : ‚àÄ (p : ‚Ñï) [Fact p.Prime], WellDistributed Œµ p (Œ© p) k)
    (X : Box (k - 1)) (s : ‚Ñù) (hs : 1 ‚â§ s)
    (T : Finset ‚Ñï) (hT : T ‚äÜ q.primeFactors) (hT_ne : T.Nonempty) :
    let H := ‚åàs * ‚àë i, X.sides i‚åâ‚Çä
    ‚àë h ‚àà ((Fintype.piFinset fun _ : Fin (k - 1) =>
        Finset.Icc (1 : ‚Ñ§) ‚ÜëH).filter
      (fun h => inScaledBox X s (fun _ => 0) h)),
      |‚àè p ‚àà T, (localCount Œ© q
          (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p -
          localMean k Œ© p)| ‚â§
    ‚àë Œ≥ ‚àà (Finset.Icc 1 (H ^ (k * k))).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
      perGammaDeviationWeight Œµ k Œ© T Œ≥ *
        (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) := by
  -- Introduce the let-binding and set up notation
  set H := ‚åàs * ‚àë i, X.sides i‚åâ‚Çä with H_def
  -- Eliminate the trivial let-binding left in the goal
  change ‚àë h ‚àà ((Fintype.piFinset fun _ : Fin (k - 1) =>
      Finset.Icc (1 : ‚Ñ§) ‚ÜëH).filter
    (fun h => inScaledBox X s (fun _ => 0) h)),
    |‚àè p ‚àà T, (localCount Œ© q
        (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p -
        localMean k Œ© p)| ‚â§
    ‚àë Œ≥ ‚àà (Finset.Icc 1 (H ^ (k * k))).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
      perGammaDeviationWeight Œµ k Œ© T Œ≥ *
        (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù)
  set S := ((Fintype.piFinset fun _ : Fin (k - 1) =>
      Finset.Icc (1 : ‚Ñ§) ‚ÜëH).filter
    (fun h => inScaledBox X s (fun _ => 0) h)) with S_def
  set f := fun h : Fin (k - 1) ‚Üí ‚Ñ§ =>
    |‚àè p ‚àà T, (localCount Œ© q
        (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p -
        localMean k Œ© p)| with f_def
  set g := fun h : Fin (k - 1) ‚Üí ‚Ñ§ => gammaProdOfBoxPoint T h with g_def
  set w := fun Œ≥ => perGammaDeviationWeight Œµ k Œ© T Œ≥ with w_def
  -- Step 1: Show g maps S into Icc 1 (H^k)
  have hg : ‚àÄ h ‚àà S, g h ‚àà (Finset.Icc 1 (H ^ (k * k))).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T) := by
    intro h hh
    simp only [S_def, Finset.mem_filter] at hh
    refine Finset.mem_filter.mpr ‚ü®gammaProdOfBoxPoint_mem_Icc k hk T hT_ne q hq hT X s hs h hh.1 hh.2,
      gammaProdOfBoxPoint_primeFactors_subset T
        (fun p hp => Nat.prime_of_mem_primeFactors (hT hp)) h‚ü©
  -- Step 2: Apply fiberwise decomposition (rewrite LHS into grouped form)
  have fiber_eq : ‚àë h ‚àà S, f h =
      ‚àë Œ≥ ‚àà (Finset.Icc 1 (H ^ (k * k))).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T), ‚àë h ‚àà S.filter (fun h => g h = Œ≥), f h :=
    (Finset.sum_fiberwise_of_maps_to hg f).symm
  rw [show ‚àë h ‚àà S, f h
           = ‚àë Œ≥ ‚àà (Finset.Icc 1 (H ^ (k * k))).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T), ‚àë h ‚àà S.filter (fun h => g h = Œ≥), f h from fiber_eq]
  -- Step 3: Bound each fiber sum
  apply Finset.sum_le_sum
  intro Œ≥ _hŒ≥
  -- Step 3a: Pointwise bound on each summand in the fiber
  have h_pointwise : ‚àÄ h ‚àà S.filter (fun h => g h = Œ≥), f h ‚â§ w Œ≥ := by
    intro h hh
    have hh_S : h ‚àà S := (Finset.mem_filter.mp hh).1
    have hh_Œ≥ : g h = Œ≥ := (Finset.mem_filter.mp hh).2
    have hh_pi : h ‚àà Fintype.piFinset fun _ : Fin (k - 1) => Finset.Icc (1 : ‚Ñ§) ‚ÜëH :=
      (Finset.mem_filter.mp hh_S).1
    have hh_box : inScaledBox X s (fun _ => 0) h := (Finset.mem_filter.mp hh_S).2
    have h_bound := deviation_prod_le_perGammaWeight Œµ hŒµ k hk Œ© q hq hŒ© hWD X s hs T hT hT_ne h
      hh_pi hh_box
    simp only [f_def, w_def, g_def] at *
    rw [‚Üê hh_Œ≥]
    exact h_bound
  -- Step 3b: Bound fiber sum by w(Œ≥) * |fiber|
  have h_fiber_sum : ‚àë h ‚àà S.filter (fun h => g h = Œ≥), f h ‚â§
      w Œ≥ * ((S.filter (fun h => g h = Œ≥)).card : ‚Ñù) := by
    have h_le := Finset.sum_le_card_nsmul _ _ (w Œ≥) h_pointwise
    rw [nsmul_eq_mul] at h_le
    linarith
  -- Step 3c: Bound fiber cardinality
  have h_fiber_card : ((S.filter (fun h => g h = Œ≥)).card : ‚Ñù) ‚â§
      (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) := by
    exact_mod_cast fiber_card_le_countTuplesWithGammaProd k hk T q hq hT X s hs Œ≥
  -- Step 3d: Combine
  calc ‚àë h ‚àà S.filter (fun h => g h = Œ≥), f h
      ‚â§ w Œ≥ * ((S.filter (fun h => g h = Œ≥)).card : ‚Ñù) := h_fiber_sum
    _ ‚â§ w Œ≥ * (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) := by
        exact mul_le_mul_of_nonneg_left h_fiber_card
          (perGammaDeviationWeight_nonneg Œµ k Œ© q T hT Œ≥)

/-! ## 4. Auxiliary lemmas for the gamma-weighted series bound -/

/--
**Euler product expansion.** The product `‚àè_{p ‚àà S} (1 + 1/p)` equals
the sum over all subsets `A ‚äÜ S` of `‚àè_{p ‚àà A} (1/p)`. This follows
from `Finset.prod_add` with `f = 1/p`, `g = 1`.
-/
lemma euler_product_one_add_inv (S : Finset ‚Ñï) :
    ‚àè p ‚àà S, (1 + 1 / (p : ‚Ñù)) =
    ‚àë A ‚àà S.powerset, ‚àè p ‚àà A, (1 / (p : ‚Ñù)) := by
  simp +decide [ add_comm, Finset.prod_add ]

/--
For squarefree `Œ≥` divisible by `d = ‚àè T` (where `T` consists of primes),
we have `T ‚äÜ Œ≥.primeFactors` and
`Œ≥ = (‚àè p ‚àà T, p) * ‚àè p ‚àà Œ≥.primeFactors \ T, p`.
-/
lemma squarefree_prod_primeFactors_sdiff (T : Finset ‚Ñï) (hT : ‚àÄ p ‚àà T, Nat.Prime p)
    (Œ≥ : ‚Ñï) (hŒ≥ : Squarefree Œ≥) (hdvd : (‚àè p ‚àà T, p) ‚à£ Œ≥) :
    Œ≥ = (‚àè p ‚àà T, p) * ‚àè p ‚àà Œ≥.primeFactors \ T, p := by
  convert Nat.prod_primeFactors_of_squarefree hŒ≥ |> Eq.symm |> Eq.trans <| ?_ using 1
  rw [ ‚Üê Finset.prod_union ( Finset.disjoint_sdiff ), Finset.union_sdiff_of_subset ]
  have h_prime_factors : T ‚äÜ Œ≥.primeFactors := by
    have h_div : ‚àè p ‚àà T, p ‚à£ Œ≥ := hdvd
    have h_prime : ‚àÄ p ‚àà T, Nat.Prime p := hT
    exact fun p hp =>
      Nat.mem_primeFactors.mpr ‚ü® h_prime p hp, Nat.dvd_trans ( Finset.dvd_prod_of_mem _ hp ) h_div,
        by aesop ‚ü©
  assumption

/--
For squarefree `Œ≥ ‚àà [1, N]`, the set `Œ≥.primeFactors \ T` lies in
the powerset of `S = {primes p ‚àà [2,N], p ‚àâ T}`.
-/
lemma primeFactors_sdiff_mem_powerset (T : Finset ‚Ñï) (hT : ‚àÄ p ‚àà T, Nat.Prime p)
    (N Œ≥ : ‚Ñï) (hŒ≥_sq : Squarefree Œ≥) (hŒ≥_range : Œ≥ ‚àà Finset.Icc 1 N) :
    Œ≥.primeFactors \ T ‚àà
      ((Finset.Icc 2 N).filter (fun p => Nat.Prime p ‚àß p ‚àâ T)).powerset := by
  simp +zetaDelta only [mem_Icc, mem_powerset] at *
  intro p hp
  simp_all +decide only [mem_sdiff, Nat.mem_primeFactors, ne_eq, mem_filter, mem_Icc,
    not_false_eq_true, and_self, and_true]
  exact ‚ü® hp.1.1.two_le, Nat.le_trans ( Nat.le_of_dvd hŒ≥_range.1 hp.1.2.1 ) hŒ≥_range.2 ‚ü©

/--
The map `Œ≥ ‚Ü¶ Œ≥.primeFactors \ T` is injective on squarefree multiples
of `d = ‚àè T`. This is because squarefree `Œ≥` is determined by its prime
factors, and `T ‚äÜ Œ≥.primeFactors` (so the sdiff determines all of
`Œ≥.primeFactors`).
-/
lemma primeFactors_sdiff_injOn (T : Finset ‚Ñï) (hT : ‚àÄ p ‚àà T, Nat.Prime p) (N : ‚Ñï) :
    Set.InjOn (fun Œ≥ : ‚Ñï => Œ≥.primeFactors \ T)
      ((Finset.Icc 1 N).filter (fun Œ≥ => Squarefree Œ≥ ‚àß (‚àè p ‚àà T, p) ‚à£ Œ≥) : Finset ‚Ñï) := by
  intros Œ≥‚ÇÅ hŒ≥‚ÇÅ Œ≥‚ÇÇ hŒ≥‚ÇÇ h_eq
  simp_all +decide only [coe_filter, mem_Icc, Set.mem_setOf_eq, Finset.ext_iff, mem_sdiff,
    Nat.mem_primeFactors, ne_eq, and_congr_left_iff, and_congr_right_iff]
  -- Since Œ≥‚ÇÅ and Œ≥‚ÇÇ are squarefree and divisible by d, their prime factors are exactly T and
  -- the prime factors of Œ≥‚ÇÅ and Œ≥‚ÇÇ that are not in T.
  have h_prime_factors :
      Œ≥‚ÇÅ.primeFactors = T ‚à™ (Œ≥‚ÇÅ.primeFactors \ T)
      ‚àß Œ≥‚ÇÇ.primeFactors = T ‚à™ (Œ≥‚ÇÇ.primeFactors \ T) := by
    have h_prime_factors : T ‚äÜ Œ≥‚ÇÅ.primeFactors ‚àß T ‚äÜ Œ≥‚ÇÇ.primeFactors := by
      exact ‚ü® fun p hp => Nat.mem_primeFactors.mpr ‚ü® hT p hp,
          Nat.dvd_trans ( Finset.dvd_prod_of_mem _ hp ) hŒ≥‚ÇÅ.2.2, by linarith ‚ü©,
        fun p hp => Nat.mem_primeFactors.mpr ‚ü® hT p hp,
          Nat.dvd_trans ( Finset.dvd_prod_of_mem _ hp ) hŒ≥‚ÇÇ.2.2, by linarith ‚ü© ‚ü©
    generalize_proofs at *; (
    exact ‚ü® by rw [ Finset.union_sdiff_of_subset h_prime_factors.1 ],
      by rw [ Finset.union_sdiff_of_subset h_prime_factors.2 ] ‚ü©)
  generalize_proofs at *; (
  -- Since Œ≥‚ÇÅ and Œ≥‚ÇÇ are squarefree and have the same prime factors, they must be equal.
  have h_eq_prime_factors : Œ≥‚ÇÅ.primeFactors = Œ≥‚ÇÇ.primeFactors := by
    grind +ring
  generalize_proofs at *; (
  exact Nat.prod_primeFactors_of_squarefree hŒ≥‚ÇÅ.2.1 ‚ñ∏ Nat.prod_primeFactors_of_squarefree hŒ≥‚ÇÇ.2.1 ‚ñ∏
    by rw [ h_eq_prime_factors ] ))



/-- **Tail Euler weight.** The combined Euler weight multiplied by `p^{Œµ/2}`,
used in the Rankin trick. With the spacing hypothesis, this is
`O(k ¬∑ p^{-1-Œµ/2})`, which is summable. -/
noncomputable def tailEulerWeight (Œµ : ‚Ñù) (k : ‚Ñï) (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (p : ‚Ñï) : ‚Ñù :=
  combinedEulerWeight Œµ k Œ© p * (p : ‚Ñù) ^ (Œµ / 2)



/-! ## 5. Gamma-weighted series bound -/

/--
If `p` is prime and divides `radical Œ≥`, then `p ‚â§ Œ≥`.
-/
lemma prime_dvd_radical_le_self (p Œ≥ : ‚Ñï) (hp : p.Prime) (h : p ‚à£ radical Œ≥) : p ‚â§ Œ≥ := by
  by_cases hg : Œ≥ = 0 <;> simp_all +decide only [radical, Nat.primeFactors_zero, prod_empty,
    Nat.dvd_one, nonpos_iff_eq_zero]
  simp_all +decide only [Nat.Prime.dvd_iff_not_coprime hp, Nat.coprime_prod_right_iff,
    Nat.mem_primeFactors, ne_eq, not_false_eq_true, and_true, and_imp, not_forall]
  obtain ‚ü® q, hq‚ÇÅ, hq‚ÇÇ, hq‚ÇÉ ‚ü© := h
  have := Nat.gcd_dvd_left p q
  have := Nat.gcd_dvd_right p q
  simp_all +decide only [Nat.dvd_prime, false_or, ge_iff_le, Nat.gcd_self]
  exact Nat.le_of_dvd ( Nat.pos_of_ne_zero hg ) hq‚ÇÇ

/--
The Weil weight `(1 ‚àí |Œ©_p|/p) ¬∑ p^{‚àíŒµ} ¬∑ localMean k Œ© p` is at most `p`
for any prime `p` and `Œµ ‚â• 0`.
-/
lemma weil_weight_le_prime (Œµ : ‚Ñù) (hŒµ : 0 ‚â§ Œµ) (k : ‚Ñï) (hk : 1 ‚â§ k)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (p : ‚Ñï) (hp : p.Prime) :
    (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p ‚â§ (p : ‚Ñù) := by
  have h_weil_weight_le_p :
      (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p
      ‚â§ (1 : ‚Ñù) * (p : ‚Ñù) ^ (-Œµ) * p := by
    gcongr <;> norm_num [ localMean ]
    ¬∑ positivity
    ¬∑ positivity
    ¬∑ have h_card_le_p : (Œ© p).card ‚â§ p := by
        haveI := Fact.mk hp
        exact le_trans ( Finset.card_le_univ _ ) ( by norm_num )
      generalize_proofs at *; (
      rcases k with ( _ | k ) <;> simp_all +decide only [le_add_iff_nonneg_left, zero_le, pow_succ,
        add_tsub_cancel_right, ge_iff_le]
      exact div_le_of_le_mul‚ÇÄ ( by positivity ) ( by positivity ) ( by
        norm_cast
        nlinarith [ pow_pos ( Nat.pos_of_ne_zero hp.ne_zero ) k,
          pow_le_pow_left' h_card_le_p k ] ))
  exact h_weil_weight_le_p.trans ( by
    rw [ one_mul ]
    exact mul_le_of_le_one_left ( Nat.cast_nonneg _ ) ( by
      simpa using Real.rpow_le_rpow_of_exponent_le ( Nat.one_le_cast.mpr hp.pos )
        ( neg_nonpos.mpr hŒµ ) ) )

/--
**Prefactor absorption inequality.**
`(1/|Œ©_q|) ¬∑ ‚àè_{q.pf ‚àñ T} Œº_p ‚â§ ‚àè_T Œº_p‚Åª¬π`.
-/
private lemma prefactor_le_inv_prod_localMean (k : ‚Ñï) (hk : 2 ‚â§ k)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (hŒ© : ‚àÄ p, p.Prime ‚Üí (Œ© p).Nonempty)
    (T : Finset ‚Ñï) (hT : T ‚äÜ q.primeFactors) :
    (1 / (crtSubset q Œ©).card : ‚Ñù) *
      ‚àè p ‚àà q.primeFactors \ T, localMean k Œ© p ‚â§
    ‚àè p ‚àà T, (localMean k Œ© p)‚Åª¬π := by
  -- By definition of cardinality, we know that
  -- $(crtSubset q).card ÔøΩ =ÔøΩ \prod_{p \in q.primeFactors} (Œ© p).card$.
  have h_card : ((crtSubset q Œ©).card : ‚Ñù) = (‚àè p ‚àà q.primeFactors, (Œ© p).card : ‚Ñù) := by
    convert globalMean_eq_prod_localMean 1 q hq Œ© using 1
    ¬∑ norm_num
    ¬∑ unfold localMean; norm_num
  rw [ h_card, div_mul_eq_mul_div, div_le_iff‚ÇÄ ]
  ¬∑ rw [ ‚Üê Finset.prod_sdiff hT ]
    simp +decide [localMean, mul_assoc, mul_comm]
    field_simp
    rw [ div_le_div_iff‚ÇÄ ] <;> norm_cast <;> norm_num [ Finset.prod_eq_zero_iff, Nat.Prime.ne_zero ]
    ¬∑ have h_prod_le : ‚àÄ p ‚àà q.primeFactors, (Œ© p).card ^ k ‚â§ p ^ (k - 1) * (Œ© p).card := by
        intro p hp
        have h_card_le : (Œ© p).card ‚â§ p := by
          haveI := Fact.mk ( Nat.prime_of_mem_primeFactors hp )
          exact le_trans ( Finset.card_le_univ _ ) ( by norm_num )
        exact le_trans ( by rw [ ‚Üê pow_succ, Nat.sub_add_cancel ( by linarith ) ] )
          ( Nat.mul_le_mul_right _ ( Nat.pow_le_pow_left h_card_le _ ) )
      apply le_trans ( Nat.mul_le_mul ( Finset.prod_le_prod' fun p hp =>
          h_prod_le p <| Finset.mem_sdiff.mp hp |>.1 )
        ( Finset.prod_le_prod' fun p hp => h_prod_le p <| hT hp ) ) _
      simp +decide [ mul_assoc, mul_comm, mul_left_comm, Finset.prod_mul_distrib ]
    ¬∑ exact fun p hp _ _ _ => pow_pos hp.pos _
    ¬∑ exact fun p hp =>
        pow_pos ( Finset.card_pos.mpr ( hŒ© p ( Nat.prime_of_mem_primeFactors ( hT hp ) ) ) ) _
  ¬∑ exact Finset.prod_pos fun p hp =>
      Nat.cast_pos.mpr ( Finset.card_pos.mpr ( hŒ© p ( Nat.prime_of_mem_primeFactors hp ) ) )

/-
**Tuple count universal bound.** `M_Œ≥(H) ‚â§ (H+1)^k` since the
counting set is a subset of all tuples in `[0, H]^{k+1}`.
-/
lemma countTuplesWithGammaProd_le_pow (k Œ≥ H : ‚Ñï) :
    (countTuplesWithGammaProd k Œ≥ H : ‚Ñù) ‚â§ ((H : ‚Ñù) + 1) ^ k := by
  norm_cast;
  refine' le_trans ( Set.ncard_le_ncard <| show { h : Fin ( k + 1 ) ‚Üí ‚Ñ§ | h 0 = 0 ‚àß ( ‚àÄ i j : Fin ( k + 1 ), ¬¨i = j ‚Üí ¬¨h i = h j ) ‚àß ( ‚àÄ i : Fin ( k + 1 ), 0 ‚â§ h i ‚àß h i ‚â§ H ) ‚àß ‚àÉ Œì : GammaStructure ( k + 1 ), Œì.gammaProd = Œ≥ ‚àß ‚àÄ i j : Fin ( k + 1 ), ¬¨i = j ‚Üí Œì.sqfreepart.gcd ( h j - h i |> Int.natAbs ) = Œì.gamma i j } ‚äÜ Set.image ( fun x : Fin k ‚Üí ‚Ñ§ => Fin.cons 0 x ) ( Set.Icc ( 0 : Fin k ‚Üí ‚Ñ§ ) ( fun _ => H ) ) from _ ) _;
  ¬∑ intro h hh;
    use fun i => h i.succ;
    exact ‚ü® ‚ü® fun i => hh.2.2.1 _ |>.1, fun i => hh.2.2.1 _ |>.2 ‚ü©, by ext i; induction i using Fin.inductionOn <;> aesop ‚ü©;
  ¬∑ rw [ Set.ncard_image_of_injective, Set.ncard_eq_toFinset_card' ] <;> norm_num [ Function.Injective ];
    erw [ Finset.card_map, Finset.card_pi ] ; norm_num

/-
**Pointwise bound on `perGammaDeviationWeight`.**
For each `Œ≥`, the weight is at most `‚àè_T (k¬∑p¬∑(1‚àír_p) + weil_p)` since each prime
contributes either the collision factor `k¬∑p¬∑(1‚àír_p)` or `weil_p`, both bounded by
their sum (all summands nonnegative).
-/
lemma perGammaDeviationWeight_le_prod_add (Œµ : ‚Ñù) (k : ‚Ñï)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (hŒ©le : ‚àÄ p, p.Prime ‚Üí (Œ© p).card ‚â§ p)
    (T : Finset ‚Ñï) (hT_prime : ‚àÄ p ‚àà T, Nat.Prime p) (Œ≥ : ‚Ñï) :
    perGammaDeviationWeight Œµ k Œ© T Œ≥ ‚â§
    ‚àè p ‚àà T, ((k : ‚Ñù) * (p : ‚Ñù) * (1 - (Œ© p).card / (p : ‚Ñù)) +
      (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p) := by
  rw [ ‚Üê Finset.prod_filter_mul_prod_filter_not T ( fun p => p ‚à£ radical Œ≥ ) ];
  refine' mul_le_mul _ _ _ _;
  ¬∑ refine' Finset.prod_le_prod _ _;
    ¬∑ exact fun p hp => mul_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( sub_nonneg.2 <| div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p <| hT_prime p <| Finset.filter_subset _ _ hp ) <| Nat.cast_nonneg _ );
    ¬∑ intro p hp; refine' le_add_of_nonneg_right _; refine' mul_nonneg ( mul_nonneg _ _ ) _ <;> norm_num;
      ¬∑ exact div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p ( Finset.filter_subset _ _ hp ) ) ) ( Nat.cast_nonneg _ );
      ¬∑ positivity;
      ¬∑ exact localMean_nonneg k Œ© p;
  ¬∑ gcongr;
    ¬∑ intro p hp; refine' mul_nonneg _ _;
      ¬∑ exact mul_nonneg ( sub_nonneg.2 <| div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p <| hT_prime p <| Finset.filter_subset _ _ hp ) <| Nat.cast_nonneg _ ) <| Real.rpow_nonneg ( Nat.cast_nonneg _ ) _;
      ¬∑ refine' mul_nonneg _ _ <;> norm_num;
    ¬∑ exact le_add_of_nonneg_left ( mul_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( sub_nonneg.mpr ( div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le _ ( hT_prime _ ( Finset.mem_filter.mp ‚Äπ_‚Ä∫ |>.1 ) ) ) ( Nat.cast_nonneg _ ) ) ) );
  ¬∑ refine' Finset.prod_nonneg fun p hp => mul_nonneg ( mul_nonneg _ _ ) _;
    ¬∑ exact sub_nonneg_of_le ( div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p ( Finset.filter_subset _ _ hp ) ) ) ( Nat.cast_nonneg _ ) );
    ¬∑ positivity;
    ¬∑ apply_rules [ localMean_nonneg ];
  ¬∑ refine' Finset.prod_nonneg fun p hp => add_nonneg _ _;
    ¬∑ exact mul_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( sub_nonneg.2 ( div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p ( Finset.filter_subset _ _ hp ) ) ) ( Nat.cast_nonneg _ ) ) );
    ¬∑ refine' mul_nonneg ( mul_nonneg _ _ ) _;
      ¬∑ exact sub_nonneg_of_le ( div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p ( Finset.filter_subset _ _ hp ) ) ) ( Nat.cast_nonneg _ ) );
      ¬∑ positivity;
      ¬∑ apply localMean_nonneg

/-- **Prefactor absorption identity.**
The `q`-dependent prefactor `(q^{k-1}/|Œ©_q|^k) ‚àè_{q \ T} Œº_p`
simplifies algebraically to exactly `‚àè_{p ‚àà T} Œº_p‚Åª¬π`. -/
lemma prefactor_absorption (k : ‚Ñï) (hk : 2 ‚â§ k) (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (hŒ© : ‚àÄ p, p.Prime ‚Üí (Œ© p).Nonempty)
    (T : Finset ‚Ñï) (hT : T ‚äÜ q.primeFactors) :
    ((q : ‚Ñù) ^ (k - 1) / ((crtSubset q Œ©).card : ‚Ñù) ^ k) *
    (‚àè p ‚àà q.primeFactors \ T, localMean k Œ© p) =
    ‚àè p ‚àà T, (localMean k Œ© p)‚Åª¬π := by
  have hlm_pos : ‚àÄ p ‚àà q.primeFactors, 0 < localMean k Œ© p := by
    intro p hp; unfold localMean
    exact div_pos (pow_pos (Nat.cast_pos.mpr (Finset.Nonempty.card_pos (hŒ© p (Nat.prime_of_mem_primeFactors hp)))) _)
      (pow_pos (Nat.cast_pos.mpr (Nat.pos_of_mem_primeFactors hp)) _)
  have hgm := globalMean_eq_prod_localMean k q hq Œ©
  have h_inv : (q : ‚Ñù) ^ (k - 1) / ((crtSubset q Œ©).card : ‚Ñù) ^ k =
    (‚àè p ‚àà q.primeFactors, localMean k Œ© p)‚Åª¬π := by
    rw [‚Üê hgm, inv_div]
  rw [h_inv]
  have h_split := (Finset.prod_sdiff hT (f := fun p => localMean k Œ© p)).symm
  rw [h_split, mul_inv_rev, mul_assoc,
    inv_mul_cancel‚ÇÄ (ne_of_gt (Finset.prod_pos (fun p hp => hlm_pos p (Finset.sdiff_subset hp)))),
    mul_one, Finset.prod_inv_distrib]

/-
**Weight as radical times Euler tail.** For `Œ≥` whose prime factors lie in `T`,
the per-gamma weight factorises as `(rad Œ≥) ¬∑ ‚àè_{p ‚àà T \ pf Œ≥} weil_p`, where
`weil_p = (1 - |Œ©_p|/p) ¬∑ p^{-Œµ} ¬∑ Œº_p`.  The collision primes (`p ‚à£ rad Œ≥`) are
exactly `Œ≥.primeFactors` (as `Œ≥.primeFactors ‚äÜ T`), contributing `‚àè_{p ‚àà pf Œ≥} p = rad Œ≥`.
-/
lemma perGammaDeviationWeight_eq_of_subset (Œµ : ‚Ñù) (k : ‚Ñï)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (T : Finset ‚Ñï) (hT_prime : ‚àÄ p ‚àà T, Nat.Prime p) (Œ≥ : ‚Ñï)
    (hŒ≥ : Œ≥.primeFactors ‚äÜ T) :
    perGammaDeviationWeight Œµ k Œ© T Œ≥ =
    (‚àè p ‚àà Œ≥.primeFactors, (k : ‚Ñù) * (p : ‚Ñù) * (1 - (Œ© p).card / (p : ‚Ñù))) *
      ‚àè p ‚àà T \ Œ≥.primeFactors,
        (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p := by
  by_cases hŒ≥_zero : Œ≥ = 0 <;> simp_all +decide [ perGammaDeviationWeight ];
  ¬∑ simp +decide [ radical, Finset.prod_filter ];
    split_ifs <;> simp_all +decide [ Finset.prod_ite, Finset.filter_ne' ];
    exact absurd ( hT_prime 1 ‚Äπ_‚Ä∫ ) ( by norm_num );
  ¬∑ congr! 1;
    ¬∑ refine' Finset.prod_subset _ _ <;> simp_all +decide [ Finset.subset_iff ];
      ¬∑ exact fun p hp hp' => dvd_trans hp' ( Nat.prod_primeFactors_dvd _ );
      ¬∑ exact fun p pp dp dp' => False.elim <| dp' <| Nat.dvd_trans ( dvd_refl p ) <| Finset.dvd_prod_of_mem _ <| Nat.mem_primeFactors.mpr ‚ü® pp, dp, hŒ≥_zero ‚ü©;
    ¬∑ congr! 1;
      ext p; simp [radical];
      intro hp; simp_all +decide [ Nat.Prime.dvd_iff_not_coprime, Nat.coprime_prod_right_iff, Nat.coprime_primes ] ;

/-- **Collision factor radical bound.** For `Œ≥` with `Œ≥.primeFactors ‚äÜ T`, the
per-gamma weight is bounded by `k^{œâ(Œ≥)} ¬∑ (radical Œ≥) ¬∑ ‚àè_{T \ pf Œ≥} weil_p`,
obtained from `perGammaDeviationWeight_eq_of_subset` by bounding each collision
factor `k¬∑p¬∑(1‚àír_p) ‚â§ k¬∑p` (i.e. `‚àè_{pf Œ≥}(1‚àír_p) ‚â§ 1`). -/
lemma perGammaDeviationWeight_le_radical_form (Œµ : ‚Ñù) (k : ‚Ñï)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p))
    (hŒ©le : ‚àÄ p, p.Prime ‚Üí (Œ© p).card ‚â§ p)
    (T : Finset ‚Ñï) (hT_prime : ‚àÄ p ‚àà T, Nat.Prime p) (Œ≥ : ‚Ñï)
    (hŒ≥ : Œ≥.primeFactors ‚äÜ T) :
    perGammaDeviationWeight Œµ k Œ© T Œ≥ ‚â§
    (k : ‚Ñù) ^ Œ≥.primeFactors.card * (radical Œ≥ : ‚Ñù) *
      ‚àè p ‚àà T \ Œ≥.primeFactors,
        (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p := by
  rw [perGammaDeviationWeight_eq_of_subset Œµ k Œ© T hT_prime Œ≥ hŒ≥]
  refine mul_le_mul_of_nonneg_right ?_ ?_
  ¬∑ -- ‚àè (k*p*(1-r_p)) = k^œâ * radical Œ≥ * ‚àè(1-r_p) ‚â§ k^œâ * radical Œ≥
    have hcol : (‚àè p ‚àà Œ≥.primeFactors, (k : ‚Ñù) * (p : ‚Ñù) * (1 - (Œ© p).card / (p : ‚Ñù)))
        = (k : ‚Ñù) ^ Œ≥.primeFactors.card * (radical Œ≥ : ‚Ñù) *
          ‚àè p ‚àà Œ≥.primeFactors, (1 - (Œ© p).card / (p : ‚Ñù)) := by
      rw [show (radical Œ≥ : ‚Ñù) = ‚àè p ‚àà Œ≥.primeFactors, (p : ‚Ñù) by
            unfold radical; rw [Nat.cast_prod]]
      rw [Finset.prod_mul_distrib, Finset.prod_mul_distrib, Finset.prod_const]
    rw [hcol]
    refine mul_le_of_le_one_right (by positivity) ?_
    refine Finset.prod_le_one (fun p hp => ?_) (fun p hp => ?_)
    ¬∑ exact sub_nonneg.2 (div_le_one_of_le‚ÇÄ (mod_cast hŒ©le p (Nat.prime_of_mem_primeFactors hp))
        (Nat.cast_nonneg _))
    ¬∑ exact sub_le_self _ (div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _))
  ¬∑ exact Finset.prod_nonneg fun p hp => mul_nonneg (mul_nonneg
      (sub_nonneg.2 (div_le_one_of_le‚ÇÄ (mod_cast hŒ©le p (hT_prime p (Finset.mem_sdiff.mp hp).1))
        (Nat.cast_nonneg _))) (Real.rpow_nonneg (Nat.cast_nonneg _) _)) (localMean_nonneg k Œ© p)

/-- Numeric per-prime constant bound used in `gamma_sum_le_euler_factor_small_gamma`:
`2¬∑(2^{C(k,2)}¬∑k) + w ‚â§ 2^{k+C(k,2)}¬∑(1+w)` for `k ‚â• 2`, `w ‚â• 0`.  The key fact is
`2¬∑k ‚â§ 2^k` for `k ‚â• 2`, which lets `k¬∑2^{C(k,2)+1} ‚â§ 2^{k+C(k,2)}`. -/
lemma small_gamma_perprime_const (k : ‚Ñï) (hk : 2 ‚â§ k) (w : ‚Ñù) (hw : 0 ‚â§ w) :
    2 * ((2 : ‚Ñù) ^ (Nat.choose k 2) * k) + w ‚â§
      (2 : ‚Ñù) ^ (k + Nat.choose k 2) * (1 + w) := by
  have h2k : 2 * k ‚â§ 2 ^ k := by
    induction k with
    | zero => omega
    | succ n ih =>
      rcases Nat.lt_or_ge n 2 with hn | hn
      ¬∑ interval_cases n <;> simp_all
      ¬∑ have := ih (by omega)
        simp only [pow_succ]
        omega
  have h2kR : (2 : ‚Ñù) * k ‚â§ 2 ^ k := by exact_mod_cast h2k
  have hpow : (2 : ‚Ñù) ^ (k + Nat.choose k 2) = 2 ^ k * 2 ^ (Nat.choose k 2) := by
    rw [pow_add]
  have hCpos : (0 : ‚Ñù) < 2 ^ (Nat.choose k 2) := by positivity
  have hkey : 2 * ((2 : ‚Ñù) ^ (Nat.choose k 2) * k) ‚â§ 2 ^ (k + Nat.choose k 2) := by
    rw [hpow]; nlinarith [hCpos, h2kR]
  have hone : (1 : ‚Ñù) ‚â§ 2 ^ (k + Nat.choose k 2) := one_le_pow‚ÇÄ (by norm_num)
  nlinarith [hkey, hone, hw]

/-
**Full-range Œ≥-sum bound with the vanishing collision weight (crude-count route).**
Over the full GK Œ≥-window `Icc 1 (H^{k*k})`, the deviation Œ≥-sum is bounded by feeding the
*crude* tuple count `M_Œ≥(H) ‚â§ (H+1)^{k-1}` through `insert_gamma_denominator` (to extract a
genuine `1/Œ≥^Œ±` saving) and the per-prime fractional Euler engine
`core_gamma_euler_sum_frac_perprime` with the vanishing collision multiplier
`c_p = k¬∑(1 ‚àí r_p)`.  Each resulting Euler factor therefore carries the `(1 ‚àí r_p)` factor.
-/
lemma gamma_sum_frac_le (Œµ : ‚Ñù) (hŒµ : 0 < Œµ) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (hŒ©le : ‚àÄ p, p.Prime ‚Üí (Œ© p).card ‚â§ p)
    (T : Finset ‚Ñï) (hT_prime : ‚àÄ p ‚àà T, Nat.Prime p) (H : ‚Ñï) (hH : 1 < H)
    (Œ± : ‚Ñù) (hŒ±0 : 0 < Œ±) (hŒ±1 : Œ± ‚â§ 1) :
    ‚àë Œ≥ ‚àà (Finset.Icc 1 (H ^ (k * k))).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
      perGammaDeviationWeight Œµ k Œ© T Œ≥ * (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) ‚â§
    ((H : ‚Ñù) + 1) ^ (((k - 1 : ‚Ñï) : ‚Ñù) + Œ± * (k * k)) *
      ‚àè p ‚àà T, ((1 / (1 - (2:‚Ñù) ^ (-Œ±))) * ((k : ‚Ñù) * (1 - (Œ© p).card / (p : ‚Ñù))) *
          (p : ‚Ñù) ^ (1 - Œ±) +
        (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p) := by
  refine' le_trans ( Finset.sum_le_sum fun Œ≥ hŒ≥ => _ ) _;
  use fun Œ≥ => ( perGammaDeviationWeight Œµ k Œ© T Œ≥ / ( Œ≥ : ‚Ñù ) ^ Œ± ) * ( H + 1 ) ^ ( ( k - 1 : ‚Ñï ) + Œ± * ( k * k ) );
  ¬∑ rw [ div_mul_eq_mul_div, le_div_iff‚ÇÄ ];
    ¬∑ rw [ mul_assoc ];
      gcongr;
      ¬∑ apply_rules [ mul_nonneg, Finset.prod_nonneg ];
        ¬∑ exact fun p hp => mul_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( sub_nonneg.2 <| div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p <| hT_prime p <| Finset.mem_filter.mp hp |>.1 ) <| Nat.cast_nonneg _ );
        ¬∑ intro p hp; refine' mul_nonneg ( mul_nonneg _ _ ) _ <;> norm_num;
          ¬∑ exact div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p ( Finset.mem_filter.mp hp |>.1 ) ) ) ( Nat.cast_nonneg _ );
          ¬∑ positivity;
          ¬∑ exact div_nonneg ( pow_nonneg ( Nat.cast_nonneg _ ) _ ) ( pow_nonneg ( Nat.cast_nonneg _ ) _ );
      ¬∑ refine' le_trans ( mul_le_mul_of_nonneg_right ( countTuplesWithGammaProd_le_pow _ _ _ ) ( by positivity ) ) _;
        rw [ Real.rpow_add ( by positivity ), Real.rpow_mul ( by positivity ) ] ; norm_cast ; ring_nf ; norm_num;
        gcongr;
        rw [ ‚Üê Real.rpow_natCast, ‚Üê Real.rpow_mul ( by positivity ), mul_comm, Real.rpow_mul ( by positivity ), Real.rpow_natCast ];
        gcongr;
        exact le_trans ( Nat.cast_le.mpr <| Finset.mem_Icc.mp ( Finset.mem_filter.mp hŒ≥ |>.1 ) |>.2 ) <| by norm_cast; rw [ pow_two ] ; exact Nat.pow_le_pow_left ( by linarith ) _ |> le_trans <| Nat.pow_le_pow_right ( by linarith ) <| by nlinarith;
    ¬∑ exact Real.rpow_pos_of_pos ( Nat.cast_pos.mpr ( Finset.mem_Icc.mp ( Finset.mem_filter.mp hŒ≥ |>.1 ) |>.1 ) ) _;
  ¬∑ rw [ ‚Üê Finset.sum_mul _ _ _ ];
    rw [ mul_comm ];
    gcongr;
    convert core_gamma_euler_sum_frac_perprime T hT_prime ( H ^ ( k * k ) ) Œ± hŒ±0 hŒ±1 ( fun p => k * ( 1 - ( Œ© p |> Finset.card : ‚Ñù ) / p ) ) ( fun p hp => ?_ ) ( fun p => ( 1 - ( Œ© p |> Finset.card : ‚Ñù ) / p ) * p ^ ( -Œµ ) * localMean k Œ© p ) ( fun p hp => ?_ ) using 1;
    ¬∑ refine' Finset.sum_congr rfl fun x hx => _;
      rw [ perGammaDeviationWeight_eq_of_subset ];
      ¬∑ unfold radical; norm_num [ Finset.prod_mul_distrib, mul_assoc, mul_comm, mul_left_comm ] ;
        ring;
      ¬∑ assumption;
      ¬∑ grind;
    ¬∑ exact mul_nonneg ( Nat.cast_nonneg _ ) ( sub_nonneg.2 <| div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p <| hT_prime p hp ) <| Nat.cast_nonneg _ );
    ¬∑ refine' mul_nonneg ( mul_nonneg _ _ ) _ <;> norm_num;
      ¬∑ exact div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p hp ) ) ( Nat.cast_nonneg _ );
      ¬∑ positivity;
      ¬∑ exact div_nonneg ( pow_nonneg ( Nat.cast_nonneg _ ) _ ) ( pow_nonneg ( Nat.cast_nonneg _ ) _ )

/-
**Per-band crude-count fractional Œ≥-sum engine (Step 8.1).**

This is the band-localized generalization of `gamma_sum_frac_le`: instead of
inserting the denominator over the *full* range `Œ≥ ‚â§ H^{k¬∑k}` (insertion cost
`(H+1)^{Œ±¬∑k¬≤}`), it bounds the Œ≥-sum restricted to the band `Œ≥ ‚â§ H^W` with a
*band-tailored* insertion cost `(H+1)^{(k-1)+Œ±¬∑W}`.  The crude tuple count
`M_Œ≥(H) ‚â§ (H+1)^{k-1}` is multiplied by `1 ‚â§ (H^W/Œ≥)^Œ±` (`insert_gamma_denominator`)
to extract the genuine `1/Œ≥^Œ±` decay, which is then fed ‚Äî together with the
vanishing collision multiplier `c_p = k¬∑(1 ‚àí r_p)` ‚Äî into the per-prime fractional
Euler engine `core_gamma_euler_sum_frac_perprime`.  Each resulting Euler factor
therefore carries the `(1 ‚àí r_p)` factor and the `p^{1-Œ±}` collision weight.
-/
lemma gamma_sum_frac_le_upper (Œµ : ‚Ñù) (hŒµ : 0 < Œµ) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (hŒ©le : ‚àÄ p, p.Prime ‚Üí (Œ© p).card ‚â§ p)
    (T : Finset ‚Ñï) (hT_prime : ‚àÄ p ‚àà T, Nat.Prime p) (H : ‚Ñï) (hH : 1 < H)
    (Œ± : ‚Ñù) (hŒ±0 : 0 < Œ±) (hŒ±1 : Œ± ‚â§ 1) (W : ‚Ñù) (hW : 0 ‚â§ W) :
    ‚àë Œ≥ ‚àà (Finset.Icc 1 (H ^ (k * k))).filter
        (fun Œ≥ : ‚Ñï => Œ≥.primeFactors ‚äÜ T ‚àß (Œ≥ : ‚Ñù) ‚â§ (H : ‚Ñù) ^ W),
      perGammaDeviationWeight Œµ k Œ© T Œ≥ * (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) ‚â§
    ((H : ‚Ñù) + 1) ^ (((k - 1 : ‚Ñï) : ‚Ñù) + Œ± * W) *
      ‚àè p ‚àà T, ((1 / (1 - (2:‚Ñù) ^ (-Œ±))) * ((k : ‚Ñù) * (1 - (Œ© p).card / (p : ‚Ñù))) *
          (p : ‚Ñù) ^ (1 - Œ±) +
        (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p) := by
  refine' le_trans ( Finset.sum_le_sum fun x hx => _ ) _;
  use fun x => ( perGammaDeviationWeight Œµ k Œ© T x / ( x : ‚Ñù ) ^ Œ± ) * ( H + 1 ) ^ ( ( k - 1 : ‚Ñï ) + Œ± * W );
  ¬∑ rw [ div_mul_eq_mul_div, le_div_iff‚ÇÄ ];
    ¬∑ rw [ mul_assoc ];
      gcongr;
      ¬∑ apply_rules [ mul_nonneg, Finset.prod_nonneg ];
        ¬∑ exact fun p hp => mul_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( sub_nonneg.2 <| div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p <| hT_prime p <| Finset.filter_subset _ _ hp ) <| Nat.cast_nonneg _ );
        ¬∑ intro p hp; refine' mul_nonneg ( mul_nonneg _ _ ) _ <;> norm_num;
          ¬∑ exact div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( hT_prime p ( Finset.mem_filter.mp hp |>.1 ) ) ) ( Nat.cast_nonneg _ );
          ¬∑ positivity;
          ¬∑ refine' mul_nonneg _ _ <;> norm_num;
      ¬∑ refine' le_trans ( mul_le_mul_of_nonneg_right ( countTuplesWithGammaProd_le_pow _ _ _ ) ( by positivity ) ) _;
        rw [ Real.rpow_add ( by positivity ), Real.rpow_mul ( by positivity ) ];
        gcongr;
        ¬∑ norm_cast;
        ¬∑ rw [ ‚Üê Real.rpow_mul ( by positivity ), mul_comm, Real.rpow_mul ( by positivity ) ];
          gcongr;
          exact le_trans ( Finset.mem_filter.mp hx |>.2.2 ) ( Real.rpow_le_rpow ( by positivity ) ( by linarith ) ( by positivity ) );
    ¬∑ exact Real.rpow_pos_of_pos ( Nat.cast_pos.mpr ( Finset.mem_Icc.mp ( Finset.mem_filter.mp hx |>.1 ) |>.1 ) ) _;
  ¬∑ have := @core_gamma_euler_sum_frac_perprime;
