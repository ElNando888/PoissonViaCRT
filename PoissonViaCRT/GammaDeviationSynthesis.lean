/- The sharp-count "band" engines (`gamma_band_euler_factor`,
`gamma_band_euler_factor_low`) used the large-gamma sharp tuple count
(`countTuplesWithGammaProd_large_gamma_sharp`).  The re-architecture of the
large-divisor regime (see `MobiusSynthesis.deviation_large_divisors`) abandons the
sharp-count band approach in favour of the crude counts plus the vanishing
collision weight, so these engines are retired here. -/

/-- The per-band exponent `Œ±(n, œÑ)`, the *clamped* square-root choice
`min 1 (sqrt(2 / w(œÑ)))`, where `w(œÑ) = tupleBoundWeight n œÑ`.

**Faithfulness correction.**  The bare choice `sqrt(2 / w(œÑ))` (as originally
proposed) does *not* satisfy `Œ± ‚â§ 1`: whenever `w(œÑ) < 2` (e.g. `n = 1`, `œÑ = 0`,
where `w = 1` and `sqrt 2 > 1`) it exceeds `1`.  Since the band engine
`gamma_band_euler_factor` simultaneously requires `Œ± ‚â§ 1` *and* the band
constraint `w(œÑ) ‚â§ 2 / Œ±¬≤`, the genuine per-band choice must clamp at `1`.  The
clamp keeps the band constraint as an (almost) equality ‚Äî exact when `w(œÑ) ‚â• 2`
(so `sqrt(2/w) ‚â§ 1`), and `w(œÑ) < 2 ‚â§ 2/1¬≤` otherwise. -/
noncomputable def alphaOf (n œÑ : ‚Ñï) : ‚Ñù := min 1 (Real.sqrt (2 / tupleBoundWeight n œÑ))

/-- The per-band exponent `alphaOf n œÑ` is positive (for `n ‚â• 1`, which is the
relevant regime `n = k - 1` with `k ‚â• 2`).  The hypothesis `1 ‚â§ n` is necessary:
`tupleBoundWeight 0 0 = 0`, forcing `alphaOf 0 0 = 0`. -/
lemma alphaOf_pos (n œÑ : ‚Ñï) (hn : 1 ‚â§ n) : 0 < alphaOf n œÑ := by
  unfold alphaOf tupleBoundWeight
  apply lt_min
  ¬∑ norm_num
  ¬∑ apply Real.sqrt_pos.mpr
    have h1 : (1:‚Ñù) ‚â§ (n:‚Ñù) := by exact_mod_cast hn
    have hwpos : (0:‚Ñù) < (n:‚Ñù) + 1 - 9/8 + ((œÑ:‚Ñù) - 1/2)^2 / 2 := by
      nlinarith [sq_nonneg ((œÑ:‚Ñù) - 1/2)]
    exact _root_.div_pos (by norm_num) hwpos

/-- The per-band exponent `alphaOf n œÑ` is at most `1` (immediate from the clamp). -/
lemma alphaOf_le_one (n œÑ : ‚Ñï) : alphaOf n œÑ ‚â§ 1 := by
  unfold alphaOf; exact min_le_left _ _

/-- The band constraint holds for `alphaOf n œÑ`: `w(œÑ) ‚â§ 2 / Œ±(n,œÑ)¬≤`, with equality
when `w(œÑ) ‚â• 2` and the harmless slack `w(œÑ) < 2 ‚â§ 2/1¬≤` otherwise. -/
lemma alphaOf_band_ok (n œÑ : ‚Ñï) : tupleBoundWeight n œÑ ‚â§ 2 / (alphaOf n œÑ) ^ 2 := by
  unfold alphaOf
  set w := tupleBoundWeight n œÑ with hw
  have hnn : 0 ‚â§ w := by
    rw [hw]; unfold tupleBoundWeight
    have h : (1:‚Ñù)/4 ‚â§ ((œÑ:‚Ñù) - 1/2)^2 := by
      have h : (0:‚Ñù) ‚â§ (œÑ:‚Ñù) * ((œÑ:‚Ñù) - 1) := by
        rcases Nat.eq_zero_or_pos œÑ with h | h
        ¬∑ simp [h]
        ¬∑ have h1 : (1:‚Ñù) ‚â§ (œÑ:‚Ñù) := by exact_mod_cast h
          nlinarith [Nat.cast_nonneg (Œ± := ‚Ñù) œÑ]
      nlinarith
    have hn : (0:‚Ñù) ‚â§ (n:‚Ñù) := by positivity
    linarith
  rcases eq_or_lt_of_le hnn with h0 | hpos
  ¬∑ rw [‚Üê h0]; simp
  ¬∑ have hs : Real.sqrt (2 / w) ^ 2 = 2 / w := Real.sq_sqrt (by positivity)
    rcases le_total (Real.sqrt (2 / w)) 1 with hle | hge
    ¬∑ rw [min_eq_right hle, hs, div_div_eq_mul_div]; linarith
    ¬∑ rw [min_eq_left hge]
      simp only [one_pow, div_one]
      have h2 : (1:‚Ñù) ‚â§ 2 / w := by nlinarith [hs, hge, Real.sqrt_nonneg (2/w)]
      rw [le_div_iff‚ÇÄ hpos] at h2
      linarith


/-- Per-prime simplification: `localMean k Œ© p / |Œ©_p| = (|Œ©_p|/p)^{k-1}` (needs `k ‚â• 1`
and `|Œ©_p| ‚âÝ 0`). -/
lemma localMean_mul_inv_card (k : ‚Ñï) (hk : 1 ‚â§ k) (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (p : ‚Ñï)
    (hp : ((Œ© p).card : ‚Ñù) ‚âÝ 0) :
    (localMean k Œ© p : ‚Ñù) * (1 / ((Œ© p).card : ‚Ñù)) = ((Œ© p).card / (p : ‚Ñù)) ^ (k - 1) := by
  unfold localMean
  have hpow : ((Œ© p).card : ‚Ñù) ^ k = ((Œ© p).card : ‚Ñù) ^ (k - 1) * ((Œ© p).card : ‚Ñù) := by
    rw [‚Üê pow_succ, Nat.sub_add_cancel hk]
  rw [hpow, div_pow]
  field_simp

/-! ## 6. Regime-splitting architecture for Granville‚ÄìKurlberg Proposition 4.2

The uniform Rankin trick used in the (now retired) ¬ß3.2 sketch applies the same
weight to the whole collision constraint `‚àè_{p ‚àà T} p > s`, which makes the
resulting series over `Œ≥` diverge.  Following **Proposition 4.2** of
Granville‚ÄìKurlberg, the sum over the squarefree divisor `d = ‚àè_{p ‚àà T} p` of `q`
(equivalently, over subsets `T ‚äÜ q.primeFactors`) is instead split at the
threshold `d = s_q ^ R` into a *small-divisor* regime (`d ‚â§ s_q ^ R`, handled by
the uniform bound) and a *large-divisor* regime (`d > s_q ^ R`, where the Rankin
trick is applied selectively).  See `artifacts/GK_PROPOSITION_4_2_BLUEPRINT.md`. -/

/-- **Divisor-sum splitting (Step A).**
The sum of a real weight `f` over all subsets `T ‚äÜ q.primeFactors` (equivalently,
over all squarefree divisors `d = ‚àè_{p ‚àà T} p` of `q`) splits as the sum over the
*small-divisor* regime `‚àè_{p ‚àà T} p ‚â§ s ^ R` plus the sum over the *large-divisor*
regime `s ^ R < ‚àè_{p ‚àà T} p`. -/
lemma split_divisor_sum (q : ‚Ñï) (s R : ‚Ñù) (f : Finset ‚Ñï ‚Üí ‚Ñù) :
    ‚àë T ‚àà q.primeFactors.powerset, f T =
      (‚àë T ‚àà q.primeFactors.powerset.filter
          (fun T : Finset ‚Ñï => (‚àè p ‚àà T, (p : ‚Ñù)) ‚â§ s ^ R), f T) +
      (‚àë T ‚àà q.primeFactors.powerset.filter
          (fun T : Finset ‚Ñï => s ^ R < (‚àè p ‚àà T, (p : ‚Ñù))), f T) := by
  rw [‚Üê Finset.sum_filter_add_sum_filter_not q.primeFactors.powerset
        (fun T : Finset ‚Ñï => (‚àè p ‚àà T, (p : ‚Ñù)) ‚â§ s ^ R) f]
  congr 1
  refine Finset.sum_congr ?_ (fun _ _ => rfl)
  exact Finset.filter_congr (fun T _ => by rw [not_le])

/- RETIRED (large-divisor re-architecture).
The GK Proposition 4.2 small-gamma reassembly (`gk08_prop42_large_divisors`,
`gk08_prop42_small_divisors`, `gk08_proposition_4_2`) was built on the lossy
collision weight `‚àè_{p ‚à£ rad Œ≥} p`.  With the vanishing collision weight
`k¬∑p¬∑(1 ‚àí r_p)` the fixed per-prime constant `2^(k+C(k,2))` no longer dominates
for small `|T|`, and this disconnected chain is superseded by the direct
`MobiusSynthesis.deviation_large_divisors` route.  It is retired (commented out)
rather than deleted.
/-
**Large-divisor regime (Step B, Rankin trick).**

The part of the divisor sum restricted to the *large-divisor* regime
`s_q ^ R < ‚àè_{p ‚àà T} p` is bounded by Line 2 of GK Proposition 4.2.

Mathematically this is the *selective* Rankin trick: on this regime one has
`1 ‚â§ (‚àè_{p‚ààT} p / s_q ^ R) ^ Œ≤‚ÇÅ`, which extracts the global factor `s_q ^ (‚àíŒ≤‚ÇÅ R)`
and attaches a `p ^ Œ≤‚ÇÅ` weight to each prime of `T`; summing the resulting weighted
product over all subsets `T ‚äÜ q.primeFactors` decouples (via `Finset.prod_add`) into
the Euler product over the primes dividing `q`.

**Uniformity of the constant.**  Unlike the earlier draft, the constant `C` here is
quantified *before* `Œ©`, `q`, and `H`, so it is genuinely independent of those data
(it depends only on `Œµ, k, R, Œ±‚ÇÅ, Œ≤‚ÇÅ`; concretely one may take
`C = 2 ^ (k + Nat.choose k 2)`).  This is the mathematically correct reading of the
big-`O` constant in Proposition 4.2.

**Faithfulness corrections to the right-hand side.**  Two changes were necessary to
turn this into a statement that is *true* with a `q`- and `H`-independent constant
`C`:

* an explicit box-volume factor `((H : ‚Ñù) + 1) ^ (k - 1)` is included.  The
  per-fibre count `countTuplesWithGammaProd (k-1) Œ≥ H` grows like `H ^ (k-1)`, so the
  left-hand side is genuinely of size `H ^ (k-1)`; without this factor no constant
  independent of `H` could bound it.  (In Granville‚ÄìKurlberg this is the box volume
  carried implicitly throughout ¬ß4.)
* each per-prime Euler factor uses `1 + C ¬∑ p ^ Œ≤‚ÇÅ ¬∑ (1 + A_p)` rather than
  `1 + C ¬∑ p ^ Œ≤‚ÇÅ ¬∑ A_p`, where `A_p = combinedEulerWeight Œµ k Œ© p ¬∑ localMean k Œ© p`.
  The honest output of the available radical-regrouping engine
  (`core_gamma_euler_sum`, via `gamma_sum_le_euler_factor_small_gamma`) is a per-prime
  weight of the shape `B ¬∑ (1 + A_p)` with a bare constant `B`; the collision primes
  contribute this bare constant (their `radical Œ≥` factor is compensated by the count,
  not by `A_p`), so the `+1` cannot be dropped while keeping `C` independent of `q`.

The hypothesis `hŒ©` (each `Œ© p` nonempty for primes `p`) is used to guarantee
`s_q = q / |Œ©_q| ‚â• 1` (and in particular `s_q > 0`), which is what makes the Rankin
factor `(‚àè_{p‚ààT} p / s_q ^ R) ^ Œ≤‚ÇÅ ‚â• 1` and the absorption `s_q ^ (‚àíŒ≤‚ÇÅ R) ‚â§
s_q ^ (Œ±‚ÇÅ ‚àí Œ≤‚ÇÅ R)` valid.
-/
lemma gk08_prop42_large_divisors (Œµ : ‚Ñù) (hŒµ : 0 < Œµ) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (R Œ±‚ÇÅ Œ≤‚ÇÅ : ‚Ñù) (hR‚ÇÄ : 0 ‚â§ R) (hR‚ÇÅ : R ‚â§ 1) (hŒ±‚ÇÅ : 0 < Œ±‚ÇÅ) (hŒ≤‚ÇÅ : 0 < Œ≤‚ÇÅ) :
    ‚àÉ C : ‚Ñù, 0 < C ‚àß
      ‚àÄ (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (hŒ©le : ‚àÄ p, p.Prime ‚Üí (Œ© p).card ‚â§ p)
        (hŒ© : ‚àÄ p, p.Prime ‚Üí (Œ© p).Nonempty)
        (q : ‚Ñï) [NeZero q] (hq : Squarefree q) (H : ‚Ñï),
      ‚àë T ‚àà q.primeFactors.powerset.filter
          (fun T : Finset ‚Ñï =>
            ((q : ‚Ñù) / (crtSubset q Œ©).card) ^ R < (‚àè p ‚àà T, (p : ‚Ñù))),
        ‚àë Œ≥ ‚àà (Finset.Icc 1 H).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
          perGammaDeviationWeight Œµ k Œ© T Œ≥ *
            (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) ‚â§
      C * ((H : ‚Ñù) + 1) ^ (k - 1) *
          ((q : ‚Ñù) / (crtSubset q Œ©).card) ^ (Œ±‚ÇÅ - Œ≤‚ÇÅ * R) *
          (‚àè p ‚àà q.primeFactors,
            (1 + C * (p : ‚Ñù) ^ Œ≤‚ÇÅ *
              (1 + combinedEulerWeight Œµ k Œ© p * localMean k Œ© p))) := by
  refine' ‚ü® 2 ^ ( k + Nat.choose k 2 ), by positivity, _ ‚ü©;
  intro Œ© hŒ©le hŒ© q _ hq H
  set s := (q : ‚Ñù) / (crtSubset q Œ©).card
  have hcard_eq : (crtSubset q Œ©).card = ‚àè p ‚àà q.primeFactors, (Œ© p).card := by
    convert globalMean_eq_prod_localMean 1 q hq Œ© using 1
    unfold localMean; norm_num
    norm_cast
  have hcard_pos : 0 < (crtSubset q Œ©).card := by
    rw [hcard_eq]
    exact Finset.prod_pos fun p hp =>
      Finset.card_pos.mpr (hŒ© p (Nat.prime_of_mem_primeFactors hp))
  have hs_pos : 0 < s := div_pos (Nat.cast_pos.mpr (NeZero.pos q)) (Nat.cast_pos.mpr hcard_pos)
  have hs_ge_one : 1 ‚â§ s := by
    have h_card_le_q : (crtSubset q Œ©).card ‚â§ q :=
      hcard_eq ‚ñ∏ le_trans
        (Finset.prod_le_prod' fun p hp => hŒ©le p (Nat.prime_of_mem_primeFactors hp))
        (by rw [Nat.prod_primeFactors_of_squarefree hq])
    exact (one_le_div (Nat.cast_pos.mpr hcard_pos)).2 (mod_cast h_card_le_q)
  -- Apply the per-T bound from the small-Œ≥ Euler engine + Rankin.
  have h_per_T_bound : ‚àÄ T ‚àà q.primeFactors.powerset, s ^ R < (‚àè p ‚àà T, (p : ‚Ñù)) ‚Üí
    ‚àë Œ≥ ‚àà (Finset.Icc 1 H).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
      perGammaDeviationWeight Œµ k Œ© T Œ≥ * (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) ‚â§
    ((H : ‚Ñù) + 1) ^ (k - 1) * s ^ (-Œ≤‚ÇÅ * R) *
      (‚àè p ‚àà T, (2 ^ (k + Nat.choose k 2) * (p : ‚Ñù) ^ Œ≤‚ÇÅ * (1 + combinedEulerWeight Œµ k Œ© p * localMean k Œ© p))) := by
        intro T hT hT_large
        have h_per_T_bound : ‚àë Œ≥ ‚àà (Finset.Icc 1 H).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
          perGammaDeviationWeight Œµ k Œ© T Œ≥ * (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) ‚â§
          ((H : ‚Ñù) + 1) ^ (k - 1) *
            (‚àè p ‚àà T, (2 ^ (k + Nat.choose k 2) * (1 + combinedEulerWeight Œµ k Œ© p * localMean k Œ© p))) := by
              convert gamma_sum_le_euler_factor_small_gamma Œµ hŒµ k hk Œ© hŒ©le T ( fun p hp => Nat.prime_of_mem_primeFactors ( Finset.mem_powerset.mp hT hp ) ) H using 1;
        refine le_trans h_per_T_bound ?_;
        rw [ mul_assoc ];
        gcongr;
        refine' le_trans _ ( mul_le_mul_of_nonneg_right ( show s ^ ( -Œ≤‚ÇÅ * R ) ‚â• 1 / ( ‚àè p ‚àà T, ( p : ‚Ñù ) ) ^ Œ≤‚ÇÅ from _ ) <| Finset.prod_nonneg fun _ _ => _ );
        ¬∑ rw [ div_mul_eq_mul_div, le_div_iff‚ÇÄ ];
          ¬∑ norm_num [ mul_assoc, mul_comm, mul_left_comm, Finset.prod_mul_distrib ];
            rw [ Real.finsetProd_rpow _ _ fun x hx => Nat.cast_nonneg x ] ; ring_nf ; norm_num;
          ¬∑ exact Real.rpow_pos_of_pos ( lt_of_le_of_lt ( by positivity ) hT_large ) _;
        ¬∑ rw [ one_div, ‚Üê Real.rpow_neg ( Finset.prod_nonneg fun _ _ => Nat.cast_nonneg _ ) ];
          rw [ neg_mul, Real.rpow_neg ( by positivity ), Real.rpow_neg ( by exact Finset.prod_nonneg fun _ _ => Nat.cast_nonneg _ ) ];
          exact inv_anti‚ÇÄ ( Real.rpow_pos_of_pos hs_pos _ ) ( by exact le_trans ( by rw [ ‚Üê Real.rpow_mul ( by positivity ), mul_comm ] ) ( Real.rpow_le_rpow ( by positivity ) hT_large.le ( by positivity ) ) );
        ¬∑ refine' mul_nonneg ( mul_nonneg ( by positivity ) ( by positivity ) ) ( add_nonneg zero_le_one ( mul_nonneg _ _ ) );
          ¬∑ apply combinedEulerWeight_nonneg;
            exact Nat.prime_of_mem_primeFactors <| Finset.mem_powerset.mp hT ‚Äπ_‚Ä∫;
          ¬∑ exact localMean_nonneg _ _ _;
  refine' le_trans ( Finset.sum_le_sum fun T hT => h_per_T_bound T ( Finset.mem_filter.mp hT |>.1 ) ( Finset.mem_filter.mp hT |>.2 ) ) _;
  refine' le_trans _ ( mul_le_mul_of_nonneg_right _ _ );
  rotate_left;
  exact ( H + 1 ) ^ ( k - 1 ) * s ^ ( -Œ≤‚ÇÅ * R );
  ¬∑ refine' le_trans _ ( mul_le_mul_of_nonneg_right ( le_mul_of_one_le_left ( by positivity ) ( one_le_pow‚ÇÄ ( by norm_num ) ) ) ( by positivity ) );
    exact mul_le_mul_of_nonneg_left ( Real.rpow_le_rpow_of_exponent_le hs_ge_one ( by linarith ) ) ( by positivity );
  ¬∑ refine' Finset.prod_nonneg fun p hp => add_nonneg zero_le_one _;
    refine' mul_nonneg ( mul_nonneg ( pow_nonneg zero_le_two _ ) ( Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) ) ( add_nonneg zero_le_one _ );
    refine' mul_nonneg _ _;
    ¬∑ grind +suggestions;
    ¬∑ apply_rules [ localMean_nonneg ];
  ¬∑ refine' le_trans ( Finset.sum_le_sum_of_subset_of_nonneg _ _ ) _;
    exact q.primeFactors.powerset;
    ¬∑ exact Finset.filter_subset _ _;
    ¬∑ intro T hT hT'; refine' mul_nonneg ( mul_nonneg ( pow_nonneg ( by positivity ) _ ) ( Real.rpow_nonneg hs_pos.le _ ) ) ( Finset.prod_nonneg fun p hp => mul_nonneg ( mul_nonneg ( by positivity ) ( Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) ) ( add_nonneg zero_le_one ( mul_nonneg ( _ ) ( _ ) ) ) ) ;
      ¬∑ grind +suggestions;
      ¬∑ grind +suggestions;
    ¬∑ rw [ ‚Üê Finset.mul_sum _ _ _ ];
      rw [ Finset.prod_add ];
      rw [ ‚Üê Finset.sum_bij ( fun T _ => q.primeFactors \ T ) ];
      ¬∑ simp +contextual [ Finset.subset_iff ];
      ¬∑ simp +contextual [ Finset.ext_iff ];
        grind;
      ¬∑ exact fun T hT => ‚ü® q.primeFactors \ T, by aesop ‚ü©;
      ¬∑ norm_num

/- The sharp-count per-band aggregation lemmas `gk08_band_perT` and
`gk08_band_large_d` (GK Proposition 4.2, Line 3) were built on the now-retired
sharp band engines and are not used by `gk08_proposition_4_2`; they are retired as
part of the large-divisor re-architecture. -/

/-
**Small-divisor regime (Step C/D).**

The part of the divisor sum restricted to the *small-divisor* regime
`‚àè_{p ‚àà T} p ‚â§ s_q ^ R` is bounded by Line 1 of GK Proposition 4.2.  (The previous
version of this lemma also carried a nonnegative Line-3 slack term; that term is now
supplied by the dedicated band lemma `gk08_band_large_d`, so it has been dropped here
and this lemma yields Line 1 alone.)  As in `gk08_prop42_large_divisors`, the constant
`C` is quantified *before* `Œ©`, `q`, `H` (so it is independent of those data), the
box-volume factor `((H : ‚Ñù) + 1) ^ (k - 1)` is made explicit, and each per-prime Euler
factor carries the bare-constant `+1`.

**Faithfulness correction to the Line-1 exponent (`Œ±‚ÇÄ R` instead of `Œ±‚ÇÄ R ‚àí 1`).**
The textual exponent of GK Proposition 4.2, Line 1, is `s_q ^ (Œ±‚ÇÄ R ‚àí 1)`.  That
exponent refers to the *normalised* (relative) deviation sum, in which the whole
left-hand side is divided by the main term `s_q`.  The left-hand side formalised
here is *not* normalised: `perGammaDeviationWeight` carries the bare collision
factor `‚àè_{p ‚à£ rad Œ≥} p` with no compensating `1 / s_q`.  Consequently the honest
provable exponent is one higher, `s_q ^ (Œ±‚ÇÄ R)`, matching the factor `s_q ^ (Œ±‚ÇÄ R)`
produced by the small-divisor Rankin inequality `1 ‚â§ (s_q ^ R / ‚àè_{p‚ààT} p) ^ Œ±‚ÇÄ`.
With the textual `Œ±‚ÇÄ R ‚àí 1` the statement is in fact *false*: taking `Œ±‚ÇÄ = 1/2`,
`Œ± ‚â° Œ≤ ‚â° 100`, `R = 1/2` and `q` a product of many small primes with each
`Œ©_p` a singleton (so `s_q = q`), the left-hand side grows like `œâ(q) ¬∑ H^{k-1}`
(indeed `inner {p} ‚â• p ¬∑ M_p(H) ‚âç H` for every `p ‚à£ q`), whereas every term on the
right-hand side decays in `q`.  Raising the Line-1 exponent to `Œ±‚ÇÄ R` repairs this.

The proof bounds each inner `Œ≥`-sum by `gamma_sum_le_euler_factor_small_gamma`,
applies the small-divisor Rankin trick with exponent `max 0 (Œ±‚ÇÄ ‚àí 1)`, decouples
via `Finset.prod_add`, and absorbs the residual `s_q`-power using `s_q ‚â• 1`.
-/
lemma gk08_prop42_small_divisors (Œµ : ‚Ñù) (hŒµ : 0 < Œµ) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (R Œ±‚ÇÄ : ‚Ñù) (hR‚ÇÄ : 0 ‚â§ R) (hR‚ÇÅ : R ‚â§ 1) (hŒ±‚ÇÄ : 0 < Œ±‚ÇÄ)
    (Œ± Œ≤ : ‚Ñï ‚Üí ‚Ñù) (hŒ± : ‚àÄ œÑ, 0 < Œ± œÑ) (hŒ≤ : ‚àÄ œÑ, 0 ‚â§ Œ≤ œÑ) :
    ‚àÉ C : ‚Ñù, 0 < C ‚àß
      ‚àÄ (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (hŒ©le : ‚àÄ p, p.Prime ‚Üí (Œ© p).card ‚â§ p)
        (hŒ© : ‚àÄ p, p.Prime ‚Üí (Œ© p).Nonempty)
        (q : ‚Ñï) [NeZero q] (hq : Squarefree q) (H : ‚Ñï),
      ‚àë T ‚àà q.primeFactors.powerset.filter
          (fun T : Finset ‚Ñï => (‚àè p ‚àà T, (p : ‚Ñù)) ‚â§ ((q : ‚Ñù) / (crtSubset q Œ©).card) ^ R),
        ‚àë Œ≥ ‚àà (Finset.Icc 1 H).filter (fun Œ≥ => Œ≥.primeFactors ‚äÜ T),
          perGammaDeviationWeight Œµ k Œ© T Œ≥ *
            (countTuplesWithGammaProd (k - 1) Œ≥ H : ‚Ñù) ‚â§
      -- Line 1: small-divisor uniform term.
      C * ((H : ‚Ñù) + 1) ^ (k - 1) *
          ((q : ‚Ñù) / (crtSubset q Œ©).card) ^ (Œ±‚ÇÄ * R) *
          (‚àè p ‚àà q.primeFactors,
            (1 + C * (p : ‚Ñù) ^ (1 - Œ±‚ÇÄ) *
              (1 + combinedEulerWeight Œµ k Œ© p * localMean k Œ© p))) := by
  refine' ‚ü® 2 ^ ( k + Nat.choose k 2 ), _, _ ‚ü©;
  ¬∑ positivity;
  ¬∑ intro Œ© hŒ©le hŒ© q _ hq H;
    ¬∑ refine' le_trans ( Finset.sum_le_sum fun T hT => _ ) _;
      use fun T => ( H + 1 ) ^ ( k - 1 ) * ( q / ( crtSubset q Œ© |> Finset.card : ‚Ñù ) ) ^ ( max 0 ( Œ±‚ÇÄ - 1 ) * R ) * ‚àè p ‚àà T, ( 2 ^ ( k + Nat.choose k 2 ) * ( p : ‚Ñù ) ^ ( -max 0 ( Œ±‚ÇÄ - 1 ) ) * ( 1 + combinedEulerWeight Œµ k Œ© p * localMean k Œ© p ) );
      ¬∑ refine' le_trans ( gamma_sum_le_euler_factor_small_gamma Œµ hŒµ k hk Œ© hŒ©le T ( fun p hp => Nat.prime_of_mem_primeFactors ( Finset.mem_powerset.mp ( Finset.mem_filter.mp hT |>.1 ) hp ) ) H ) _;
        -- Apply the inequality term by term to the product.
        have h_prod_ineq : (‚àè p ‚àà T, (p : ‚Ñù) ^ (max 0 (Œ±‚ÇÄ - 1))) ‚â§ (q / (crtSubset q Œ©).card : ‚Ñù) ^ (max 0 (Œ±‚ÇÄ - 1) * R) := by
          rw [ Real.finsetProd_rpow _ _ fun p hp => Nat.cast_nonneg _ ];
          rw [ mul_comm, Real.rpow_mul ];
          ¬∑ exact Real.rpow_le_rpow ( Finset.prod_nonneg fun _ _ => Nat.cast_nonneg _ ) ( Finset.mem_filter.mp hT |>.2 ) ( by positivity );
          ¬∑ positivity;
        rw [ mul_assoc ];
        gcongr;
        refine' le_trans _ ( mul_le_mul_of_nonneg_right h_prod_ineq _ );
        ¬∑ rw [ ‚Üê Finset.prod_mul_distrib ];
          refine' Finset.prod_le_prod _ _;
          ¬∑ intro p hp; refine' mul_nonneg ( by positivity ) ( add_nonneg zero_le_one _ ) ;
            refine' mul_nonneg ( mul_nonneg _ _ ) _;
            ¬∑ exact sub_nonneg_of_le ( div_le_one_of_le‚ÇÄ ( mod_cast hŒ©le p ( Nat.prime_of_mem_primeFactors ( Finset.mem_powerset.mp ( Finset.mem_filter.mp hT |>.1 ) hp ) ) ) ( Nat.cast_nonneg _ ) );
            ¬∑ positivity;
            ¬∑ exact localMean_nonneg _ _ _;
          ¬∑ intro p hp; rw [ mul_left_comm ] ; ring_nf;
            norm_num [ mul_assoc, ‚Üê Real.rpow_add ( Nat.cast_pos.mpr <| Nat.Prime.pos <| Nat.prime_of_mem_primeFactors <| Finset.mem_powerset.mp ( Finset.mem_filter.mp hT |>.1 ) hp ) ];
            unfold combinedEulerWeight; ring_nf; norm_num;
        ¬∑ refine' Finset.prod_nonneg fun p hp => mul_nonneg ( mul_nonneg ( by positivity ) ( Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) ) ( add_nonneg zero_le_one ( mul_nonneg _ _ ) );
          ¬∑ exact combinedEulerWeight_nonneg Œµ k Œ© p ( Nat.prime_of_mem_primeFactors ( Finset.mem_powerset.mp ( Finset.mem_filter.mp hT |>.1 ) hp ) );
          ¬∑ exact localMean_nonneg _ _ _;
      ¬∑ refine' le_trans ( Finset.sum_le_sum_of_subset_of_nonneg _ _ ) _;
        exact q.primeFactors.powerset;
        ¬∑ exact Finset.filter_subset _ _;
        ¬∑ intro T hT hT'; refine' mul_nonneg ( mul_nonneg ( pow_nonneg ( by positivity ) _ ) ( Real.rpow_nonneg ( by positivity ) _ ) ) ( Finset.prod_nonneg fun p hp => mul_nonneg ( mul_nonneg ( by positivity ) ( Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) ) ( add_nonneg zero_le_one ( mul_nonneg ( _ ) ( _ ) ) ) ) ;
          ¬∑ exact combinedEulerWeight_nonneg Œµ k Œ© p ( Nat.prime_of_mem_primeFactors ( Finset.mem_powerset.mp hT hp ) );
          ¬∑ exact localMean_nonneg _ _ _;
        ¬∑ rw [ ‚Üê Finset.mul_sum _ _ _ ];
          refine' le_trans ( mul_le_mul_of_nonneg_left ( _ : _ ‚â§ _ ) ( by positivity ) ) _;
          exact ‚àè p ‚àà q.primeFactors, ( 1 + 2 ^ ( k + k.choose 2 ) * ( p : ‚Ñù ) ^ ( -max 0 ( Œ±‚ÇÄ - 1 ) ) * ( 1 + combinedEulerWeight Œµ k Œ© p * localMean k Œ© p ) );
          ¬∑ simp +decide [ add_comm ( 1 : ‚Ñù ), Finset.prod_add ];
          ¬∑ refine' mul_le_mul _ _ _ _;
            ¬∑ refine' le_trans _ ( mul_le_mul_of_nonneg_right ( le_mul_of_one_le_left ( by positivity ) ( one_le_pow‚ÇÄ ( by norm_num ) ) ) ( by positivity ) );
              gcongr;
              ¬∑ rw [ one_le_div ] <;> norm_cast;
                ¬∑ exact le_trans ( Finset.card_le_univ _ ) ( by norm_num );
                ¬∑ exact crtSubset_card_pos_aux Œ© hŒ© q;
              ¬∑ grind;
            ¬∑ gcongr;
              ¬∑ intro p hp; refine' add_nonneg zero_le_one _; refine' mul_nonneg _ _;
                ¬∑ positivity;
                ¬∑ refine' add_nonneg zero_le_one ( mul_nonneg _ _ );
                  ¬∑ exact combinedEulerWeight_nonneg Œµ k Œ© p ( Nat.prime_of_mem_primeFactors hp );
                  ¬∑ exact localMean_nonneg _ _ _;
              ¬∑ refine' add_nonneg zero_le_one ( mul_nonneg _ _ );
                ¬∑ exact combinedEulerWeight_nonneg Œµ k Œ© _ ( Nat.prime_of_mem_primeFactors ‚Äπ_‚Ä∫ );
                ¬∑ exact localMean_nonneg _ _ _;
              ¬∑ exact_mod_cast Nat.Prime.pos ( Nat.prime_of_mem_primeFactors ‚Äπ_‚Ä∫ );
              ¬∑ cases max_cases ( 0 : ‚Ñù ) ( Œ±‚ÇÄ - 1 ) <;> linarith;
            ¬∑ refine' Finset.prod_nonneg fun p hp => add_nonneg zero_le_one _;
              refine' mul_nonneg ( mul_nonneg ( pow_nonneg zero_le_two _ ) ( Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) ) ( add_nonneg zero_le_one ( mul_nonneg _ _ ) );
              ¬∑ exact combinedEulerWeight_nonneg Œµ k Œ© p ( Nat.prime_of_mem_primeFactors hp );
              ¬∑ exact localMean_nonneg _ _ _;
