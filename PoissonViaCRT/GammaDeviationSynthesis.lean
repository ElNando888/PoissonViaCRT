  · apply sub_nonneg_of_le _
    apply div_le_one_of_le₀ _ ( Nat.cast_nonneg _ )
    haveI := Fact.mk ( Nat.prime_of_mem_primeFactors ( hT ( Finset.mem_filter.mp hp |>.1 ) ) )
    exact_mod_cast le_trans ( Finset.card_le_univ _ ) ( by norm_num )
  · apply sub_nonneg_of_le _
    apply div_le_one_of_le₀ _ ( Nat.cast_nonneg _ )
    haveI := Fact.mk ( Nat.prime_of_mem_primeFactors ( hT ( Finset.mem_filter.mp hp |>.1 ) ) )
