    convert mul_le_mul_of_nonneg_left h_bound ( show 0 ‚â§ perGammaDeviationWeight Œµ k Œ© T Œ≥ from ?_ ) using 1;
    ¬∑ rw [ perGammaDeviationWeight_eq_of_subset ];
