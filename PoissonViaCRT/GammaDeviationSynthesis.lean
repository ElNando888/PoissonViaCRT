        (fun p => (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p) (fun p hp => ?_)
      exact mul_nonneg (mul_nonneg (sub_nonneg.2 <| div_le_one_of_le‚ÇÄ
        (mod_cast hŒ©le p <| hT_prime p hp) <| Nat.cast_nonneg _) <|
