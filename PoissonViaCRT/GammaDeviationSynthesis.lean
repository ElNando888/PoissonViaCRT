lemma deviation_prod_le_perGammaWeight (Œµ : ‚Ñù) (hŒµ : 0 < Œµ) (k : ‚Ñï) (hk : 2 ‚â§ k)
    (Œ© : ‚àÄ p : ‚Ñï, Finset (ZMod p)) (q : ‚Ñï) [NeZero q] (hq : Squarefree q)
    (hŒ© : ‚àÄ p, p.Prime ‚Üí (Œ© p).Nonempty)
    (hWD : ‚àÄ (p : ‚Ñï) [Fact p.Prime], WellDistributed Œµ p (Œ© p) k)
    (X : Box (k - 1)) (s : ‚Ñù) (hs : 1 ‚â§ s)
    (T : Finset ‚Ñï) (hT : T ‚äÜ q.primeFactors) (hT_ne : T.Nonempty)
    (h : Fin (k - 1) ‚Üí ‚Ñ§)
    (hh_mem : h ‚àà (Fintype.piFinset fun _ : Fin (k - 1) =>
        Finset.Icc (1 : ‚Ñ§) ‚Üë(‚åàs * ‚àë i, X.sides i‚åâ‚Çä)))
    (hbox : inScaledBox X s (fun _ => 0) h) :
    |‚àè p ‚àà T, (localCount Œ© q
        (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p -
        localMean k Œ© p)| ‚â§
    perGammaDeviationWeight Œµ k Œ© T (gammaProdOfBoxPoint T h) := by
  -- For each prime $p \in T$, we can split the product into two parts: one where $p$ divides
  -- the radical of $\gamma$ and one where it does not.
  have h_split : ‚àÄ p ‚àà T,
      |localCount Œ© q (Fin.cons 0 (fun i => ((h i : ‚Ñ§) : ZMod q))) p - localMean k Œ© p|
      ‚â§ if p ‚à£ radical (gammaProdOfBoxPoint T h) then
          (k : ‚Ñù) * (p : ‚Ñù) * (1 - (Œ© p).card / (p : ‚Ñù))
      else (1 - (Œ© p).card / (p : ‚Ñù)) * (p : ‚Ñù) ^ (-Œµ) * localMean k Œ© p := by
    intro p hp
    split_ifs
    ¬∑ -- Collision prime: sharp union bound `|N_p ‚àí Œº_p| ‚â§ k¬∑p¬∑(1 ‚àí r_p)`.
      have hp_prime := Nat.prime_of_mem_primeFactors (hT hp)
      have hp_pos : (0 : ‚Ñù) < (p : ‚Ñù) := by exact_mod_cast hp_prime.pos
      have h_collision := localCount_sub_localMean_abs_le_collision k hk Œ© q p (hT hp) h
      refine h_collision.trans (le_of_eq ?_)
      field_simp
    ¬∑ convert localCount_deviation_of_injective ( show 1 ‚â§ k - 1 from
        Nat.le_sub_one_of_lt hk ) Œ© q p ( Nat.prime_of_mem_primeFactors ( hT hp ) )
          ( hT hp ) _ h _ using 1
      any_goals rw [ Nat.sub_add_cancel ( by linarith ) ]
      ¬∑ grind
      ¬∑ convert hWD p using 1
      ¬∑ convert not_dvd_radical_gammaProd_imp_injective
          ( show 1 ‚â§ k - 1 from Nat.le_sub_one_of_lt hk ) T q hT p
          ( Nat.prime_of_mem_primeFactors ( hT hp ) ) hp h ‚Äπ_‚Ä∫ using 1
  convert Finset.prod_le_prod ?_ h_split using 1
  ¬∑ rw [ Finset.abs_prod ]
  ¬∑ unfold perGammaDeviationWeight; simp +decide [ Finset.prod_ite ]
  ¬∑ exact fun _ _ => abs_nonneg _

