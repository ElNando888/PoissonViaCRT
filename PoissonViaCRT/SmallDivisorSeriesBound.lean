/-! ### Step 1: Per-term product bound for squarefree d -/

/--
For any squarefree `d ‚Č• 1` and `őĶ > 0`, the product
`‚ąŹ_{p ‚ą£ d} (k ¬∑ p^{-őĶ/2})` is bounded by a constant depending
only on `k` and `őĶ`. Specifically, for primes `p ‚Č• k^{2/őĶ}` the
factor `k ¬∑ p^{-őĶ/2} ‚Č§ 1`, so only finitely many "small" primes
contribute factors larger than 1.
-/
public lemma prod_kp_half_le_const (őĶ : ‚ĄĚ) (hőĶ : 0 < őĶ) (k : ‚Ąē) :
    ‚ąÉ M : ‚ĄĚ, 0 < M ‚ąß ‚ąÄ (d : ‚Ąē), Squarefree d ‚Üí
      ‚ąŹ p ‚ąą d.primeFactors, ((k : ‚ĄĚ) * (p : ‚ĄĚ) ^ (-őĶ / 2)) ‚Č§ M := by
  by_cases hk : 0 < k
  ¬∑ -- Let N‚āÄ be the number ÔŅĹ ofÔŅĹ primesÔŅĹ less than k^{2/őĶ}.
    set N‚āÄ := Finset.card
      (Finset.filter Nat.Prime (Finset.range (Nat.ceil ((k : ‚ĄĚ) ^ (2 / őĶ)) + 1))) with hN‚āÄ_def
    refine ‚ü® ( k : ‚ĄĚ ) ^ N‚āÄ, by positivity, fun d hd => ?_ ‚ü©
    -- For each prime p in the prime factors of d, if p is less than k^{2/őĶ},
    -- then k * p^{-őĶ/2} ‚Č§ k. Otherwise, k * p^{-őĶ/2} ‚Č§ 1.
    have h_prime_factors : ‚ąÄ p ‚ąą d.primeFactors,
        (k : ‚ĄĚ) * p ^ (-őĶ / 2) ‚Č§ if p < Nat.ceil ((k : ‚ĄĚ) ^ (2 / őĶ)) then (k : ‚ĄĚ) else 1 := by
      intro p hp; split_ifs <;> simp_all +decide only [Nat.mem_primeFactors, ne_eq, neg_div,
        Nat.cast_nonneg, Real.rpow_neg, Nat.cast_pos, mul_le_iff_le_one_right, not_lt, Nat.ceil_le]
      ¬∑ exact inv_le_one_of_one_le‚āÄ ( Real.one_le_rpow ( mod_cast hp.1.pos ) ( by positivity ) )
      ¬∑ rw [ ‚Üź div_eq_mul_inv, div_le_one ( Real.rpow_pos_of_pos ( Nat.cast_pos.mpr hp.1.pos ) _ ) ]
        exact le_trans ( by
          rw [ ‚Üź Real.rpow_mul ( Nat.cast_nonneg _ ), mul_comm ]
          ring_nf
          norm_num [ hőĶ.ne' ] )
          ( Real.rpow_le_rpow ( by positivity ) ‚ÄĻ ( k : ‚ĄĚ ) ^ ( 2 / őĶ ) ‚Č§ p ‚Äļ ( by positivity ) )
    apply le_trans ( Finset.prod_le_prod ( fun _ _ => by positivity ) h_prime_factors ) _
    simp +decide only [ prod_ite, prod_const, not_lt ]
    simp only [Nat.ceil_le, one_pow, mul_one]
    exact pow_le_pow_right‚āÄ ( mod_cast hk )
      ( Finset.card_le_card <| fun x hx =>
        Finset.mem_filter.mpr ‚ü® Finset.mem_range.mpr <| Nat.lt_succ_of_lt <|
          Finset.mem_filter.mp hx |>.2.trans_le <| Nat.le_of_lt_succ <| Nat.lt_succ_self _,
      Nat.prime_of_mem_primeFactors <| Finset.mem_filter.mp hx |>.1 ‚ü© )
  ¬∑ refine ‚ü® 1, zero_lt_one, fun d hd => ?_ ‚ü©
    by_cases hd1 : d = 1
    ¬∑ simp [hd1]
    ¬∑ have hk0 : k = 0 := by omega
      have hne : d.primeFactors.Nonempty := by
        rw [Finset.nonempty_iff_ne_empty]
        simp only [ne_eq, Nat.primeFactors_eq_empty, not_or]
        exact ‚ü®hd.ne_zero, hd1‚ü©
      obtain ‚ü®p, hp‚ü© := hne
      have h0 : (k : ‚ĄĚ) * (p : ‚ĄĚ) ^ (-őĶ / 2) = 0 := by rw [hk0]; simp
      rw [Finset.prod_eq_zero hp h0]; exact zero_le_one

/--
For squarefree `d > 0`, the product `‚ąŹ_{p ‚ą£ d} p^őĪ` equals
`d^őĪ`, since `‚ąŹ_{p ‚ą£ d} p = d` for squarefree numbers.
-/
public lemma prod_rpow_eq_rpow_of_squarefree (d : ‚Ąē) (hd : Squarefree d) (hd0 : d ‚Č† 0)
    (őĪ : ‚ĄĚ) :
    ‚ąŹ p ‚ąą d.primeFactors, ((p : ‚ĄĚ) ^ őĪ) = (d : ‚ĄĚ) ^ őĪ := by
  rw [ Real.finsetProd_rpow ]
  ¬∑ rw [ ‚Üź Nat.cast_prod, Nat.prod_primeFactors_of_squarefree hd ]
  ¬∑ aesop

/--
The per-term bound: for squarefree `d > 0`,
`‚ąŹ_{p ‚ą£ d} k ¬∑ p^{-őĶ} ‚Č§ M ¬∑ d^{-őĶ/2}`.
-/
public lemma prod_kp_eps_le_const_mul_rpow (őĶ : ‚ĄĚ) (hőĶ : 0 < őĶ) (k : ‚Ąē) :
    ‚ąÉ M : ‚ĄĚ, 0 < M ‚ąß ‚ąÄ (d : ‚Ąē), Squarefree d ‚Üí d ‚Č† 0 ‚Üí
      ‚ąŹ p ‚ąą d.primeFactors, ((k : ‚ĄĚ) * (p : ‚ĄĚ) ^ (-őĶ)) ‚Č§
        M * (d : ‚ĄĚ) ^ (-őĶ / 2) := by
  obtain ‚ü®M, hM_pos, hM‚ü© := prod_kp_half_le_const őĶ hőĶ k
  refine ‚ü®M, hM_pos, fun d hd hd0 => ?_‚ü©
  -- Split the product:_{p | d} k * p^{-őĶ} =_{p | d} k * p^{-őĶ/2}) * (‚ąŹ_{p | d} p^{-őĶ/2}).
  have h_split :
      (‚ąŹ p ‚ąą d.primeFactors, ((k : ‚ĄĚ) * (p : ‚ĄĚ) ^ (-őĶ)))
      = (‚ąŹ p ‚ąą d.primeFactors, ((k : ‚ĄĚ) * (p : ‚ĄĚ) ^ (-őĶ / 2)))
        * (‚ąŹ p ‚ąą d.primeFactors, ((p : ‚ĄĚ) ^ (-őĶ / 2))) := by
    rw [ ‚Üź Finset.prod_mul_distrib ] ; congr ; ext ; ring_nf
    rw [ ‚Üź Real.rpow_natCast _ 2, ‚Üź Real.rpow_mul ( Nat.cast_nonneg _ ) ] ; ring_nf
  rw [ h_split, prod_rpow_eq_rpow_of_squarefree d hd hd0 ] ; gcongr ; aesop

/-! ### Step 2: Sum of d^{-őĪ} bound -/

/--
For `0 < őĪ < 1` and integer `N ‚Č• 1`, the sum
`‚ąĎ_{d=1}^{N} d^{-őĪ} ‚Č§ N^{1-őĪ} / (1 - őĪ)`.

This follows from the integral comparison: each term `d^{-őĪ}` for
`d ‚Č• 1` is at most `‚ąę_{d-1}^{d} x^{-őĪ} dx` (since `x^{-őĪ}` is
decreasing), and these integrals telescope to `‚ąę_0^N x^{-őĪ} dx =
N^{1-őĪ}/(1-őĪ)`.
-/
public lemma sum_rpow_le_rpow_div (őĪ : ‚ĄĚ) (hőĪ0 : 0 < őĪ) (hőĪ1 : őĪ < 1) (N : ‚Ąē) (hN : 1 ‚Č§ N) :
    ‚ąĎ d ‚ąą Finset.range N, ((d : ‚ĄĚ) + 1) ^ (-őĪ) ‚Č§
      (N : ‚ĄĚ) ^ (1 - őĪ) / (1 - őĪ) := by
  induction hN <;> norm_num [ Finset.sum_range_succ ]
  ¬∑ bound
  ¬∑ -- By the Mean Value Theorem, there ÔŅĹ existsÔŅĹ some $c \in (m, m+1)$ such that
    -- $(m+1)^{1-\alpha} - m^{1-\alpha} = (1-\alpha)c^{-\alpha}$.
    have h_mean_value : ‚ąÄ m : ‚Ąē, 1 ‚Č§ m ‚Üí ‚ąÉ c ‚ąą Set.Ioo (m : ‚ĄĚ) (m + 1),
        (m + 1 : ‚ĄĚ) ^ (1 - őĪ) - m ^ (1 - őĪ) = (1 - őĪ) * c ^ (-őĪ) := by
      intro m hm
      have := exists_deriv_eq_slope ( f := fun x => x ^ ( 1 - őĪ ) )
        ( show ( m : ‚ĄĚ ) < m + 1 by norm_num )
      exact this ( by
        exact continuousOn_of_forall_continuousAt fun x hx => by
          exact ContinuousAt.rpow ( continuousAt_id ) continuousAt_const <| Or.inr <| by
            linarith ) ( by
              exact fun x hx => by
                exact DifferentiableAt.differentiableWithinAt <| by
                  apply_rules [ DifferentiableAt.rpow ] <;> norm_num
                  linarith [ hx.1, hx.2 ] ) |> fun ‚ü® c, hc1, hc2 ‚ü© =>
                    ‚ü® c, hc1, by
                      norm_num [ show c ‚Č† 0 by linarith [ hc1.1 ] ] at hc2 ‚äĘ ; linarith ‚ü©
    rename_i k hk ih
    obtain ‚ü® c, ‚ü® hc1, hc2 ‚ü©, hc3 ‚ü© := h_mean_value k hk
    rw [ le_div_iff‚āÄ ] at * <;> try linarith
    nlinarith [ show ( k + 1 : ‚ĄĚ ) ^ ( -őĪ ) ‚Č§ c ^ ( -őĪ ) by
      rw [ Real.rpow_le_rpow_iff_of_neg ] <;> linarith ]

/-! ### Step 3: Main bound -/

/--
**Small-divisor series bound** (for squarefree `q`).
The sum `‚ąĎ_{d ‚Č§ s, d ‚ą£ q, d > 1} ‚ąŹ_{p ‚ą£ d} k ¬∑ p^{‚ąíőĶ}`
is bounded by `K ¬∑ s^{1‚ąíőĶ/2}`, uniformly in squarefree `q`.
-/
public theorem small_divisor_series_bound (őĶ : ‚ĄĚ) (hőĶ : 0 < őĶ) (hőĶ2 : őĶ < 2)
    (k : ‚Ąē) :
    ‚ąÉ K_series : ‚ĄĚ, 0 < K_series ‚ąß
      ‚ąÄ (q : ‚Ąē), Squarefree q ‚Üí
        ‚ąÄ (s : ‚ĄĚ), 1 ‚Č§ s ‚Üí
          ‚ąĎ d ‚ąą (q.divisors.filter (1 < ¬∑)).filter
                (fun (d : ‚Ąē) => (d : ‚ĄĚ) ‚Č§ s),
            (‚ąŹ p ‚ąą d.primeFactors, (k : ‚ĄĚ) * (p : ‚ĄĚ) ^ (-őĶ)) ‚Č§
              K_series * s ^ (1 - őĶ / 2) := by
  -- Use `prod_kp_eps_le_const_mul_r ÔŅĹpowÔŅĹ` to get a constant M such that for all squarefree d > 0,
  -- ‚ąŹ_{p|d} k * p^{-őĶ} ‚Č§ M * d^{-őĶ/2}.
  obtain ‚ü®M, hM_pos, hM‚ü© := prod_kp_eps_le_const_mul_rpow őĶ hőĶ k
  -- Use `sum_rpow_le_rpow_div` to bound the sum $\sum_{d=1}^{‚Ćäs‚Ćč} d^{-őĶ/2}$.
  have h_sum_bound : ‚ąÄ s : ‚ĄĚ, 1 ‚Č§ s ‚Üí ‚ąĎ d ‚ąą Finset.filter (fun d : ‚Ąē => d ‚Č§ s)
    (Finset.range (Nat.floor s + 1)), (d : ‚ĄĚ) ^ (-őĶ / 2) ‚Č§ (s : ‚ĄĚ) ^ (1 - őĶ / 2) / (1 - őĶ / 2) := by
    intro s hs
    have h_sum_bound : ‚ąĎ d ‚ąą Finset.range (Nat.floor s + 1),
        (d : ‚ĄĚ) ^ (-őĶ / 2) ‚Č§ (s : ‚ĄĚ) ^ (1 - őĶ / 2) / (1 - őĶ / 2) := by
      have := sum_rpow_le_rpow_div ( őĶ / 2 ) ( by linarith ) ( by linarith ) ( Nat.floor s )
        ( Nat.floor_pos.mpr hs )
      simp_all +decide only [ne_eq, sum_range_succ', Nat.cast_add, Nat.cast_one, CharP.cast_eq_zero,
        ge_iff_le]
      norm_num [ neg_div, hőĶ.ne' ] at *
      exact le_trans this ( div_le_div_of_nonneg_right ( Real.rpow_le_rpow ( Nat.cast_nonneg _ )
        ( Nat.floor_le ( by positivity ) ) ( by linarith ) ) ( by linarith ) )
    exact le_trans ( Finset.sum_le_sum_of_subset_of_nonneg ( fun x hx => by aesop ) fun _ _ _ =>
      Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) h_sum_bound
  refine ‚ü® M / ( 1 - őĶ / 2 ), div_pos hM_pos ( by linarith ), fun q hq s hs => ?_ ‚ü©
  refine le_trans ( Finset.sum_le_sum fun x hx => hM x ?_ ?_ ) ?_
  ¬∑ exact hq.squarefree_of_dvd <| Nat.dvd_of_mem_divisors <|
      Finset.mem_filter.mp ( Finset.mem_filter.mp hx |>.1 ) |>.1
  ¬∑ aesop
  ¬∑ rw [ ‚Üź Finset.mul_sum _ _ _ ]
    rw [ div_mul_eq_mul_div, mul_div_assoc ]
    apply mul_le_mul_of_nonneg_left ( le_trans ( Finset.sum_le_sum_of_subset_of_nonneg _ _ )
      ( h_sum_bound s hs ) ) hM_pos.le
    ¬∑ simp +contextual only [subset_iff, mem_filter, Nat.mem_divisors, ne_eq, mem_range,
      Order.lt_add_one_iff, and_true, and_imp]
      exact fun x hx‚āĀ hx‚āā hx hx => Nat.le_floor hx
    ¬∑ exact fun _ _ _ => Real.rpow_nonneg ( Nat.cast_nonneg _ ) _

end SmallDivisorSeriesBound
