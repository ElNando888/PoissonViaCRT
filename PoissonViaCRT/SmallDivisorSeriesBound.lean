import Mathlib.Algebra.Squarefree.Basic
import Mathlib.Analysis.SpecialFunctions.Pow.Deriv
import Mathlib.Analysis.SpecialFunctions.Pow.Real
import Mathlib.Data.Real.StarOrdered
import Mathlib.Tactic

/-!
# Small-divisor series bound

This file proves the bound
`∑_{d ≤ s, d ∣ q, d > 1} ∏_{p ∣ d} k · p^{−ε} ≤ K · s^{1 − ε/2}`
for squarefree `q`, using the **elementary factorization path**:

1. For primes `p ≥ k^{2/ε}`, we have `k · p^{−ε/2} ≤ 1`.
2. The multiplicative function `f(d) = ∏_{p∣d} (k · p^{−ε/2})` is bounded
   by a constant `M(k,ε)` (the product over the finitely many primes
   `p < k^{2/ε}`).
3. This gives `∏_{p∣d} k · p^{−ε} ≤ M · d^{−ε/2}` for squarefree `d`.
4. Summing `d^{−ε/2}` up to `s` and comparing to `∫₁ˢ x^{−ε/2} dx`
   yields `O(s^{1−ε/2})`.
-/

set_option linter.unusedVariables false

open Finset BigOperators

namespace SmallDivisorSeriesBound

/-! ### Step 1: Per-term product bound for squarefree d -/

/--
For any squarefree `d ≥ 1` and `ε > 0`, the product
`∏_{p ∣ d} (k · p^{-ε/2})` is bounded by a constant depending
only on `k` and `ε`. Specifically, for primes `p ≥ k^{2/ε}` the
factor `k · p^{-ε/2} ≤ 1`, so only finitely many "small" primes
contribute factors larger than 1.
-/
public lemma prod_kp_half_le_const (ε : ℝ) (hε : 0 < ε) (k : ℕ) :
    ∃ M : ℝ, 0 < M ∧ ∀ (d : ℕ), Squarefree d →
      ∏ p ∈ d.primeFactors, ((k : ℝ) * (p : ℝ) ^ (-ε / 2)) ≤ M := by
  by_cases hk : 0 < k
  · -- Let N₀ be the number � of� primes� less than k^{2/ε}.
    set N₀ := Finset.card
      (Finset.filter Nat.Prime (Finset.range (Nat.ceil ((k : ℝ) ^ (2 / ε)) + 1))) with hN₀_def
    refine' ⟨ ( k : ℝ ) ^ N₀, by positivity, fun d hd => _ ⟩
    -- For each prime p in the prime factors of d, if p is less than k^{2/ε},
    -- then k * p^{-ε/2} ≤ k. Otherwise, k * p^{-ε/2} ≤ 1.
    have h_prime_factors : ∀ p ∈ d.primeFactors,
        (k : ℝ) * p ^ (-ε / 2) ≤ if p < Nat.ceil ((k : ℝ) ^ (2 / ε)) then (k : ℝ) else 1 := by
      intro p hp; split_ifs <;> simp_all +decide [ neg_div, Real.rpow_neg ]
      · exact inv_le_one_of_one_le₀ ( Real.one_le_rpow ( mod_cast hp.1.pos ) ( by positivity ) )
      · rw [ ← div_eq_mul_inv, div_le_one ( Real.rpow_pos_of_pos ( Nat.cast_pos.mpr hp.1.pos ) _ ) ]
        exact le_trans ( by
          rw [ ← Real.rpow_mul ( Nat.cast_nonneg _ ), mul_comm ]
          ring_nf
          norm_num [ hε.ne' ] )
          ( Real.rpow_le_rpow ( by positivity ) ‹ ( k : ℝ ) ^ ( 2 / ε ) ≤ p › ( by positivity ) )
    refine' le_trans ( Finset.prod_le_prod ( fun _ _ => by positivity ) h_prime_factors ) _
    simp +decide [ Finset.prod_ite ]
    exact pow_le_pow_right₀ ( mod_cast hk )
      ( Finset.card_le_card <| fun x hx =>
        Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr <| Nat.lt_succ_of_lt <|
          Finset.mem_filter.mp hx |>.2.trans_le <| Nat.le_of_lt_succ <| Nat.lt_succ_self _,
      Nat.prime_of_mem_primeFactors <| Finset.mem_filter.mp hx |>.1 ⟩ )
  · refine' ⟨ 1, zero_lt_one, fun d hd => _ ⟩
    by_cases hd1 : d = 1
    · simp [hd1]
    · have hk0 : k = 0 := by omega
      have hne : d.primeFactors.Nonempty := by
        rw [Finset.nonempty_iff_ne_empty]; simp [Nat.primeFactors_eq_empty]
        exact ⟨hd.ne_zero, hd1⟩
      obtain ⟨p, hp⟩ := hne
      have h0 : (k : ℝ) * (p : ℝ) ^ (-ε / 2) = 0 := by rw [hk0]; simp
      rw [Finset.prod_eq_zero hp h0]; exact zero_le_one

/--
For squarefree `d > 0`, the product `∏_{p ∣ d} p^α` equals
`d^α`, since `∏_{p ∣ d} p = d` for squarefree numbers.
-/
public lemma prod_rpow_eq_rpow_of_squarefree (d : ℕ) (hd : Squarefree d) (hd0 : d ≠ 0)
    (α : ℝ) :
    ∏ p ∈ d.primeFactors, ((p : ℝ) ^ α) = (d : ℝ) ^ α := by
  rw [ Real.finset_prod_rpow ]
  · rw [ ← Nat.cast_prod, Nat.prod_primeFactors_of_squarefree hd ]
  · aesop

/--
The per-term bound: for squarefree `d > 0`,
`∏_{p ∣ d} k · p^{-ε} ≤ M · d^{-ε/2}`.
-/
public lemma prod_kp_eps_le_const_mul_rpow (ε : ℝ) (hε : 0 < ε) (k : ℕ) :
    ∃ M : ℝ, 0 < M ∧ ∀ (d : ℕ), Squarefree d → d ≠ 0 →
      ∏ p ∈ d.primeFactors, ((k : ℝ) * (p : ℝ) ^ (-ε)) ≤
        M * (d : ℝ) ^ (-ε / 2) := by
  obtain ⟨M, hM_pos, hM⟩ := prod_kp_half_le_const ε hε k
  refine ⟨M, hM_pos, fun d hd hd0 => ?_⟩
  -- Split the product:_{p | d} k * p^{-ε} =_{p | d} k * p^{-ε/2}) * (∏_{p | d} p^{-ε/2}).
  have h_split :
      (∏ p ∈ d.primeFactors, ((k : ℝ) * (p : ℝ) ^ (-ε)))
      = (∏ p ∈ d.primeFactors, ((k : ℝ) * (p : ℝ) ^ (-ε / 2)))
        * (∏ p ∈ d.primeFactors, ((p : ℝ) ^ (-ε / 2))) := by
    rw [ ← Finset.prod_mul_distrib ] ; congr ; ext ; ring_nf
    rw [ ← Real.rpow_natCast _ 2, ← Real.rpow_mul ( Nat.cast_nonneg _ ) ] ; ring_nf
  rw [ h_split, prod_rpow_eq_rpow_of_squarefree d hd hd0 ] ; gcongr ; aesop

/-! ### Step 2: Sum of d^{-α} bound -/

/--
For `0 < α < 1` and integer `N ≥ 1`, the sum
`∑_{d=1}^{N} d^{-α} ≤ N^{1-α} / (1 - α)`.

This follows from the integral comparison: each term `d^{-α}` for
`d ≥ 1` is at most `∫_{d-1}^{d} x^{-α} dx` (since `x^{-α}` is
decreasing), and these integrals telescope to `∫_0^N x^{-α} dx =
N^{1-α}/(1-α)`.
-/
public lemma sum_rpow_le_rpow_div (α : ℝ) (hα0 : 0 < α) (hα1 : α < 1) (N : ℕ) (hN : 1 ≤ N) :
    ∑ d ∈ Finset.range N, ((d : ℝ) + 1) ^ (-α) ≤
      (N : ℝ) ^ (1 - α) / (1 - α) := by
  induction hN <;> norm_num [ Finset.sum_range_succ ]
  · bound
  · -- By the Mean Value Theorem, there � exists� some $c \in (m, m+1)$ such that
    -- $(m+1)^{1-\alpha} - m^{1-\alpha} = (1-\alpha)c^{-\alpha}$.
    have h_mean_value : ∀ m : ℕ, 1 ≤ m → ∃ c ∈ Set.Ioo (m : ℝ) (m + 1),
        (m + 1 : ℝ) ^ (1 - α) - m ^ (1 - α) = (1 - α) * c ^ (-α) := by
      intro m hm
      have := exists_deriv_eq_slope ( f := fun x => x ^ ( 1 - α ) )
        ( show ( m : ℝ ) < m + 1 by norm_num )
      exact this ( by
        exact continuousOn_of_forall_continuousAt fun x hx => by
          exact ContinuousAt.rpow ( continuousAt_id ) continuousAt_const <| Or.inr <| by
            linarith ) ( by
              exact fun x hx => by
                exact DifferentiableAt.differentiableWithinAt <| by
                  apply_rules [ DifferentiableAt.rpow ] <;> norm_num
                  linarith [ hx.1, hx.2 ] ) |> fun ⟨ c, hc1, hc2 ⟩ =>
                    ⟨ c, hc1, by
                      norm_num [ show c ≠ 0 by linarith [ hc1.1 ] ] at hc2 ⊢ ; linarith ⟩
    rename_i k hk ih
    obtain ⟨ c, ⟨ hc1, hc2 ⟩, hc3 ⟩ := h_mean_value k hk
    rw [ le_div_iff₀ ] at * <;> try linarith
    nlinarith [ show ( k + 1 : ℝ ) ^ ( -α ) ≤ c ^ ( -α ) by
      rw [ Real.rpow_le_rpow_iff_of_neg ] <;> linarith ]

/-! ### Step 3: Main bound -/

/--
**Small-divisor series bound** (for squarefree `q`).
The sum `∑_{d ≤ s, d ∣ q, d > 1} ∏_{p ∣ d} k · p^{−ε}`
is bounded by `K · s^{1−ε/2}`, uniformly in squarefree `q`.
-/
public theorem small_divisor_series_bound (ε : ℝ) (hε : 0 < ε) (hε2 : ε < 2)
    (k : ℕ) :
    ∃ K_series : ℝ, 0 < K_series ∧
      ∀ (q : ℕ), Squarefree q →
        ∀ (s : ℝ), 1 ≤ s →
          ∑ d ∈ (q.divisors.filter (1 < ·)).filter
                (fun (d : ℕ) => (d : ℝ) ≤ s),
            (∏ p ∈ d.primeFactors, (k : ℝ) * (p : ℝ) ^ (-ε)) ≤
              K_series * s ^ (1 - ε / 2) := by
  -- Use `prod_kp_eps_le_const_mul_r �pow�` to get a constant M such that for all squarefree d > 0,
  -- ∏_{p|d} k * p^{-ε} ≤ M * d^{-ε/2}.
  obtain ⟨M, hM_pos, hM⟩ := prod_kp_eps_le_const_mul_rpow ε hε k
  -- Use `sum_rpow_le_rpow_div` to bound the sum $\sum_{d=1}^{⌊s⌋} d^{-ε/2}$.
  have h_sum_bound : ∀ s : ℝ, 1 ≤ s → ∑ d ∈ Finset.filter (fun d : ℕ => d ≤ s)
    (Finset.range (Nat.floor s + 1)), (d : ℝ) ^ (-ε / 2) ≤ (s : ℝ) ^ (1 - ε / 2) / (1 - ε / 2) := by
    intro s hs
    have h_sum_bound : ∑ d ∈ Finset.range (Nat.floor s + 1),
        (d : ℝ) ^ (-ε / 2) ≤ (s : ℝ) ^ (1 - ε / 2) / (1 - ε / 2) := by
      have := sum_rpow_le_rpow_div ( ε / 2 ) ( by linarith ) ( by linarith ) ( Nat.floor s )
        ( Nat.floor_pos.mpr hs )
      simp_all +decide [ Finset.sum_range_succ' ]
      norm_num [ neg_div, hε.ne' ] at *
      exact le_trans this ( div_le_div_of_nonneg_right ( Real.rpow_le_rpow ( Nat.cast_nonneg _ )
        ( Nat.floor_le ( by positivity ) ) ( by linarith ) ) ( by linarith ) )
    exact le_trans ( Finset.sum_le_sum_of_subset_of_nonneg ( fun x hx => by aesop ) fun _ _ _ =>
      Real.rpow_nonneg ( Nat.cast_nonneg _ ) _ ) h_sum_bound
  refine' ⟨ M / ( 1 - ε / 2 ), div_pos hM_pos ( by linarith ), fun q hq s hs => _ ⟩
  refine' le_trans ( Finset.sum_le_sum fun x hx => hM x _ _ ) _
  · exact hq.squarefree_of_dvd <| Nat.dvd_of_mem_divisors <|
      Finset.mem_filter.mp ( Finset.mem_filter.mp hx |>.1 ) |>.1
  · aesop
  · rw [ ← Finset.mul_sum _ _ _ ]
    rw [ div_mul_eq_mul_div, mul_div_assoc ]
    refine' mul_le_mul_of_nonneg_left ( le_trans ( Finset.sum_le_sum_of_subset_of_nonneg _ _ )
      ( h_sum_bound s hs ) ) hM_pos.le
    · simp +contextual [ Finset.subset_iff ]
      exact fun x hx₁ hx₂ hx hx => Nat.le_floor hx
    · exact fun _ _ _ => Real.rpow_nonneg ( Nat.cast_nonneg _ ) _

end SmallDivisorSeriesBound
