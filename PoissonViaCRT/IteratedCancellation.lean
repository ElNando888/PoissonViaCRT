import Mathlib.Algebra.BigOperators.Ring.Finset
import Mathlib.Data.Fintype.Pi

/-!
# Iterated Cancellation over Product Spaces

This file proves that a sum over a multidimensional Cartesian product of a product of functions
collapses to zero if the sum over any single coordinate is zero.

## Main results

* `sum_prod_pi` : The sum of a product of functions over a pi type equals the product of the
  individual sums: `∑ x, ∏ i, f i (x i) = ∏ i, ∑ y, f i y`.
* `sum_prod_pi_eq_zero` : If there exists an index `j` such that `∑ y, f j y = 0`, then
  `∑ x, ∏ i, f i (x i) = 0`.
-/

open Finset

variable {ι : Type*} {α : ι → Type*} {R : Type*}

section SumProdPi

variable [Fintype ι] [DecidableEq ι] [(i : ι) → Fintype (α i)] [CommSemiring R]

/-- The sum of a product of functions over a pi type equals the product of the individual sums.
This is a restatement of `Fintype.prod_sum` with the equality reversed for readability. -/
theorem sum_prod_pi (f : (i : ι) → α i → R) :
    ∑ x : (i : ι) → α i, ∏ i, f i (x i) = ∏ i, ∑ y, f i y :=
  (Fintype.prod_sum f).symm

/-- **Iterated Cancellation Lemma.** If the sum of `f j` over the fiber `α j` is zero for some
index `j`, then the total sum of the product over the entire pi type is zero. -/
theorem sum_prod_pi_eq_zero (f : (i : ι) → α i → R) {j : ι} (hj : ∑ y, f j y = 0) :
    ∑ x : (i : ι) → α i, ∏ i, f i (x i) = 0 := by
  rw [sum_prod_pi]
  exact Finset.prod_eq_zero (Finset.mem_univ j) hj

end SumProdPi

-- Provide the names requested in the instructions as aliases.
/-- Alias of `sum_prod_pi` with the name requested by the specification. -/
theorem sum_mul_sum_pi {ι : Type*} {α : ι → Type*} {R : Type*}
    [Fintype ι] [DecidableEq ι] [(i : ι) → Fintype (α i)] [CommSemiring R]
    (f : (i : ι) → α i → R) :
    ∑ x : (i : ι) → α i, ∏ i, f i (x i) = ∏ i, ∑ y, f i y :=
  sum_prod_pi f

/-- Alias of `sum_prod_pi_eq_zero` with the name requested by the specification. -/
theorem zero_sum_implies_pi_sum_zero {ι : Type*} {α : ι → Type*} {R : Type*}
    [Fintype ι] [DecidableEq ι] [(i : ι) → Fintype (α i)] [CommSemiring R]
    (f : (i : ι) → α i → R) {j : ι} (hj : ∑ y, f j y = 0) :
    ∑ x : (i : ι) → α i, ∏ i, f i (x i) = 0 :=
  sum_prod_pi_eq_zero f hj
