  obtain ⟨ C, hC₀, hC ⟩ := h_bound; use C; refine ⟨ hC₀, fun p hp ↦ ?_ ⟩ ; specialize hC p hp; rw [ localMean ] ; simp_all +decide [div_pow] ;
