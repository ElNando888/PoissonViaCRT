      rw [ div_le_iff₀ ] <;> nlinarith [ show ( k : ℝ ) ≥ 2 by norm_cast, show ( p : ℝ ) ≥ 2 * k by norm_cast, show ( ( Ω p |> Finset.card ) : ℝ ) ≥ 1 by exact_mod_cast Finset.card_pos.mpr ( hΩ p hp ) ];
