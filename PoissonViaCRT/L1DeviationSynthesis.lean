          Finset.Icc (1 : ℤ) ⌈s * ∑ i, X.sides i⌉).filter
        (fun h => inScaledBox X s (fun _ => 0) h)),
      ∏ p ∈ T, |localCount Ω q
          (Fin.cons (0 : ZMod q) fun i => (h i : ZMod q)) p - localMean k Ω p| ≤
    C_box * s ^ (k - 1) *
        ∏ p ∈ T, (combinedEulerWeight ε k Ω p * localMean k Ω p + (k : ℝ)^2 * (C_γ / (p : ℝ))) +
