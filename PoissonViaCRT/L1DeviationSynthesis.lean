      intro p hp hp'
      specialize hrp p hp
      rw [ sub_div', div_le_div_iff₀ ] at hrp <;> norm_num at * <;> try linarith [ hp.two_le ]
      rw [ div_le_iff₀ ] <;> nlinarith [ show ( k : ℝ ) ≥ 2 by norm_cast,
        show ( p : ℝ ) ≥ 2 * k by norm_cast,
        show ( ( Ω p |> Finset.card ) : ℝ ) ≥ 1 by exact_mod_cast Finset.card_pos.mpr ( hΩ p hp ) ]
    -- For primes $p < 2k$, we have $|Ω_p| \geq 1$, so $p/|Ω_p| \leq p < 2k$.
