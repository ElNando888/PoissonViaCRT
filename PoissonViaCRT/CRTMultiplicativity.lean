/-! ### The CRT ring isomorphism for squarefree moduli -/

/-- The prime factors of a squarefree number are pairwise coprime (as a `Pairwise` condition
on the subtype `q.primeFactors`). -/
public theorem primeFactors_pairwise_coprime (q : ÔäĽ) :
    Pairwise (Function.onFun Nat.Coprime
      (fun (p : q.primeFactors) => (p : ÔäĽ))) := by
  intro ÔčĘa, haÔčę ÔčĘb, hbÔčę hab
  simp only [Function.onFun]
  have ha' := (Nat.mem_primeFactors.mp ha).1
  have hb' := (Nat.mem_primeFactors.mp hb).1
  exact (ha'.coprime_iff_not_dvd).mpr fun h =>
    hab (Subtype.ext (hb'.eq_one_or_self_of_dvd a h |>.resolve_left ha'.one_lt.ne'))

/-- A squarefree natural number equals the product of its prime factors. -/
public theorem prod_primeFactors_eq (q : ÔäĽ) (hq : Squarefree q) :
    q = ÔłĆ p : q.primeFactors, (p : ÔäĽ) := by
  rw [Finset.prod_coe_sort q.primeFactors (fun p => p)]
  exact (Nat.prod_primeFactors_of_squarefree hq).symm

/-- The CRT ring isomorphism: for squarefree `q`,
`ZMod q Ôëâ+* ÔłĆ_{p Ôłł q.primeFactors} ZMod p`. -/
@[expose]
public noncomputable def crtRingEquiv (q : ÔäĽ) [NeZero q] (hq : Squarefree q) :
    ZMod q Ôëâ+* ((p : q.primeFactors) Ôćĺ ZMod (p : ÔäĽ)) :=
  (ZMod.ringEquivCongr (prod_primeFactors_eq q hq)).trans
    (ZMod.prodEquivPi _ (primeFactors_pairwise_coprime q))

/-! ### Projection lemma -/

/-- Each component of the CRT equivalence agrees with the canonical `ZMod.castHom`
projection. This follows from the uniqueness of ring homomorphisms out of `ZMod q`
(`RingHom.ext_zmod`). -/
public theorem crtRingEquiv_apply_eq_castHom (q : ÔäĽ) [NeZero q] (hq : Squarefree q)
    (x : ZMod q) (p : q.primeFactors) :
    crtRingEquiv q hq x p =
      ZMod.castHom (Nat.dvd_of_mem_primeFactors p.2) (ZMod p) x := by
  have : (Pi.evalRingHom (fun p : q.primeFactors => ZMod (p : ÔäĽ)) p).comp
      (crtRingEquiv q hq).toRingHom =
      ZMod.castHom (Nat.dvd_of_mem_primeFactors p.2) (ZMod p) :=
    RingHom.ext_zmod _ _
  exact RingHom.congr_fun this x

/-! ### Domain equivalence -/

/-- Membership in the CRT subset, restated using the CRT equivalence:
`x Ôłł ╬ę_q Ôćö ÔłÇ p | q, (CRT projection of x to ZMod p) Ôłł ╬ę_p`. -/
public theorem mem_crtSubset_iff_crtEquiv (q : ÔäĽ) [NeZero q] (hq : Squarefree q)
    (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)) (x : ZMod q) :
    x Ôłł crtSubset q ╬ę Ôćö
      ÔłÇ p : q.primeFactors, crtRingEquiv q hq x p Ôłł ╬ę p := by
  simp only [mem_crtSubset_iff, crtRingEquiv_apply_eq_castHom]
  exact ÔčĘfun h p => h p.val p.prop, fun h p hp => h ÔčĘp, hpÔčęÔčę

/-- The CRT domain equivalence: for squarefree `q`, the CRT subset `╬ę_q ÔŐć ZMod q`
is in bijection with the Cartesian product `ÔłĆ_{p | q} ╬ę_p`. -/
@[expose]
public noncomputable def crtDomainEquiv (q : ÔäĽ) [NeZero q] (hq : Squarefree q)
    (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)) :
    Ôćą(crtSubset q ╬ę) Ôëâ ((p : q.primeFactors) Ôćĺ Ôćą(╬ę p.val)) := by
  refine Equiv.ofBijective
    (fun ÔčĘx, hxÔčę p => ÔčĘcrtRingEquiv q hq x p,
      (mem_crtSubset_iff_crtEquiv q hq ╬ę x).mp hx pÔčę) ÔčĘ?_, ?_Ôčę
  ┬Ě intro ÔčĘx, hxÔčę ÔčĘy, hyÔčę heq
    simp only [Subtype.mk.injEq]
    apply (crtRingEquiv q hq).injective
    funext p
    have h1 := congr_fun heq p
    exact congrArg Subtype.val h1
  ┬Ě intro f
    let y : (p : q.primeFactors) Ôćĺ ZMod (p : ÔäĽ) := fun p => (f p).val
    refine ÔčĘÔčĘ(crtRingEquiv q hq).symm y, ?_Ôčę, ?_Ôčę
    ┬Ě rw [mem_crtSubset_iff_crtEquiv q hq]
      intro p
