/-! ### Counting function multiplicativity -/

/-- **CRT multiplicativity of the counting function**: For squarefree `q`, the counting
function `N_k(h, ╬ę_q)` factors as a product over the prime divisors of `q`:

$N_k(h, \Omega_q) = \prod_{p \mid q} N_k(h \bmod p, \Omega_p).$

The proof uses the CRT ring isomorphism to transfer the count from `ZMod q` to the
product type `ÔłĆ_{p | q} ZMod p`, where the filter condition factors componentwise. -/
public theorem counting_function_multiplicative {k : ÔäĽ} (q : ÔäĽ) [NeZero q] (hq : Squarefree q)
    (╬ę : ÔłÇ p : ÔäĽ, Finset (ZMod p)) (h : Fin k Ôćĺ ZMod q) :
    tupleCount (crtSubset q ╬ę) h =
      ÔłĆ p : q.primeFactors,
        (letI : NeZero (p : ÔäĽ) := ÔčĘ(Nat.mem_primeFactors.mp p.2).1.ne_zeroÔčę
         tupleCount (╬ę p.val)
          (fun i => ZMod.castHom (Nat.dvd_of_mem_primeFactors p.2) (ZMod p) (h i))) := by
  unfold tupleCount
  rw [ ÔćÉ Fintype.card_piFinset ]
  fapply Finset.card_bij
  use fun a ha p => crtRingEquiv q hq a p
  ┬Ě simp +contextual [ crtRingEquiv_apply_eq_castHom ]
  ┬Ě exact fun aÔéü haÔéü aÔéé haÔéé h => by
      simpa using crtRingEquiv q hq |>.injective <| funext fun p => congr_fun h p
  ┬Ě intro b hb
    refine ÔčĘ ( crtRingEquiv q hq ).symm b, ?_, ?_ Ôčę <;> simp_all +decide [ Fintype.mem_piFinset ]
    intro i p hp hpq hq; specialize hb p hp hpq hq i; convert hb using 1
    have := crtRingEquiv_apply_eq_castHom q ÔÇ╣_ÔÇ║ ( ( crtRingEquiv q ÔÇ╣_ÔÇ║ ).symm b ) ÔčĘ p, by aesop Ôčę
    simp_all only [RingEquiv.apply_symm_apply, ZMod.castHom_apply]

