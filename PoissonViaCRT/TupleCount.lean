/-! ### Basic properties -/

/-- `N_{k+1}(h, ╬ę) ÔëĄ |╬ę|`, since each valid `t` satisfies `t + h 0 Ôłł ╬ę`, and the map
`t ÔćŽ t + h 0` is injective. -/
public theorem tupleCount_le_card (╬ę : Finset (ZMod q)) (h : Fin (k + 1) Ôćĺ ZMod q) :
    tupleCount ╬ę h ÔëĄ ╬ę.card := by
  refine le_trans ?_ (Finset.card_le_card <| show Finset.image (fun t : ZMod q => t + h 0)
    (Finset.filter (fun t : ZMod q => ÔłÇ i, t + h i Ôłł ╬ę) Finset.univ) ÔŐć ╬ę from ?_)
  ┬Ě rw [Finset.card_image_of_injective _ (add_left_injective _)]; rfl
  ┬Ě grind

/-- When `k = 0`, `N_0(h, ╬ę)` counts all elements of `ÔäĄ/qÔäĄ`, i.e., equals `q`. -/
theorem tupleCount_zero (╬ę : Finset (ZMod q)) (h : Fin 0 Ôćĺ ZMod q) :
    tupleCount ╬ę h = q := by
  unfold tupleCount
  simp_all only [IsEmpty.forall_iff, filter_true, card_univ, ZMod.card]

/-- Shifting all offsets by a constant doesn't change `N_k`. -/
