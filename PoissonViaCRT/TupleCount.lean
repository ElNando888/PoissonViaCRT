  ┬Ě exact fun _ _ => Finset.mem_univ _
  ┬Ě intro aÔéü haÔéü aÔéé haÔéé a
    simp_all only [mem_univ, add_left_inj]
  ┬Ě exact fun b _ => ÔčĘb - c, Finset.mem_univ _, sub_add_cancel _ _Ôčę
  ┬Ě simp +decide only [add_comm, add_left_comm]
    tauto

/-! ### The sum formula

The fundamental identity `ÔłĹ_h N_k(h, ╬ę) = q ┬Ě |╬ę|^k` is established by exchanging the order
of summation. Each `t Ôłł ÔäĄ/qÔäĄ` contributes `|╬ę|^k` to the sum (by independence of coordinates).

The paper uses the variant with `hÔéÇ = 0` fixed (Lemma 3.5): summing over `g : Fin k Ôćĺ ÔäĄ/qÔäĄ`,
we have `ÔłĹ_g N_{k+1}(0 :: g, ╬ę) = |╬ę|^{k+1}`. The condition `t + 0 Ôłł ╬ę` restricts `t` to
`╬ę`, giving `|╬ę|` choices of `t`, each contributing `|╬ę|^k` from the remaining coordinates.
-/

/-- **Sum formula for `N_k`**: `ÔłĹ_h N_k(h, ╬ę) = q ┬Ě |╬ę|^k`. -/
public theorem tupleCount_sum_eq (╬ę : Finset (ZMod q)) :
    ÔłĹ h : Fin k Ôćĺ ZMod q, tupleCount ╬ę h = q * ╬ę.card ^ k := by
  have h_fubini : ÔłĹ h : Fin k Ôćĺ ZMod q, (Finset.univ.filter fun t : ZMod q =>
      ÔłÇ i, t + h i Ôłł ╬ę).card =
      ÔłĹ t : ZMod q, ÔłĹ h : Fin k Ôćĺ ZMod q, if ÔłÇ i, t + h i Ôłł ╬ę then 1 else 0 := by
    rw [Finset.sum_comm, Finset.sum_congr rfl]; aesop
  have h_inner_sum : ÔłÇ t : ZMod q, ÔłĹ h : Fin k Ôćĺ ZMod q,
      (if ÔłÇ i, t + h i Ôłł ╬ę then 1 else 0) = ╬ę.card ^ k := by
    intro t
    have : ÔłĹ h : Fin k Ôćĺ ZMod q, (if ÔłÇ i, t + h i Ôłł ╬ę then 1 else 0) =
        ÔłĆ i : Fin k, ÔłĹ h_i : ZMod q, (if t + h_i Ôłł ╬ę then 1 else 0) := by
      rw [Finset.prod_sum]
      refine Finset.sum_bij (fun h _ => fun i _ => h i) ?_ ?_ ?_ ?_ <;>
        simp +decide [Finset.prod_ite]
      ┬Ě simp +decide [funext_iff]
      ┬Ě exact fun b => ÔčĘfun i => b i (Finset.mem_univ i), funext fun i => rflÔčę
      ┬Ě intro a; split_ifs <;> simp_all +decide [Finset.ext_iff]
    simp_all +decide
    rw [show Finset.filter (fun x => t + x Ôłł ╬ę) Finset.univ =
        Finset.image (fun x => x - t) ╬ę from ?_,
      Finset.card_image_of_injective _ fun x y hxy => by simpa using hxy]
    aesop
  simp_all +decide [Finset.card_univ]
  convert h_fubini using 1

/-- **Sum formula with `hÔéÇ = 0` fixed** (Lemma 3.5 identity):
`ÔłĹ_g N_{k+1}(Fin.cons 0 g, ╬ę) = |╬ę|^{k+1}`. -/
public theorem tupleCount_sum_cons_eq (╬ę : Finset (ZMod q)) :
    ÔłĹ g : Fin k Ôćĺ ZMod q, tupleCount ╬ę (Fin.cons 0 g) = ╬ę.card ^ (k + 1) := by
  unfold tupleCount
  simp +decide only [card_filter]
  rw [Finset.sum_comm]
  have h_inner : ÔłÇ t Ôłł ╬ę, ÔłĹ g : Fin k Ôćĺ ZMod q,
      (if ÔłÇ j, t + g j Ôłł ╬ę then 1 else 0) = ╬ę.card ^ k := by
    intro t ht
    have : (ÔłĹ g : Fin k Ôćĺ ZMod q, if ÔłÇ j : Fin k, t + g j Ôłł ╬ę then 1 else 0) =
        (ÔłĆ j : Fin k, (ÔłĹ g : ZMod q, if t + g Ôłł ╬ę then 1 else 0)) := by
      rw [Finset.prod_sum]
      refine Finset.sum_bij (fun g _ => fun j _ => g j) ?_ ?_ ?_ ?_ <;> simp +decide
      ┬Ě simp +decide [funext_iff]
      ┬Ě exact fun b => ÔčĘfun j => b j (Finset.mem_univ j), funext fun j => rflÔčę
      ┬Ě intro a; split_ifs <;> simp_all +decide [Finset.prod_ite]
    simp_all +decide
    rw [show Finset.filter (fun x => t + x Ôłł ╬ę) Finset.univ =
        Finset.image (fun x => x - t) ╬ę from ?_,
      Finset.card_image_of_injective _ sub_left_injective]
    grind
  convert Finset.sum_congr rfl h_inner using 1
  ┬Ě simp +decide [Fin.forall_fin_succ]
    rw [ÔćÉ Finset.sum_subset (Finset.subset_univ ╬ę)]
    simp_all only [sum_boole, Nat.cast_id, true_and, sum_const, smul_eq_mul]
    simp +contextual
  ┬Ě norm_num [pow_succ']

