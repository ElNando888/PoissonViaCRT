import Mathlib.Algebra.BigOperators.Ring.Finset
import Mathlib.Analysis.Complex.Exponential
import Mathlib.Analysis.PSeries
import Mathlib.Analysis.SpecialFunctions.Pow.Real

/-!
# П„-Optimization from В§3.2 of GranvilleвҖ“Kurlberg

This file formalizes the core combinatorial definitions and abstract summation bound
from Section 3.2 of "Poisson statistics via the Chinese remainder theorem" by
Granville and Kurlberg (arXiv:math/0412135v2).

The П„-optimization partitions the prime factors of a squarefree integer `q` into
"active" and "inactive" primes. Each subset `T` of the prime factors contributes
a weight `2^{|T|} В· вҲҸ_{p вҲҲ T} p^{-Оө}` to the total error bound. The key insight
is that this sum factorizes as a product over individual primes, allowing a
uniform bound independent of `q`.

## Main Definitions

* `PoissonCRT.tauLocalWeight Оө p`: The local weight `2 В· p^{-Оө}` for a prime `p`.
* `PoissonCRT.tauPartitionSum Оө S`: The sum over all subsets `T вҠҶ S` of
  `вҲҸ_{p вҲҲ T} (2 В· p^{-Оө})`.
* `PoissonCRT.tauDimension`: The number `|T|` of active primes.
* `PoissonCRT.tauWeight Оө T`: The accumulated savings `вҲ‘_{p вҲҲ T} p^{-Оө}`.
* `PoissonCRT.tauBoundConstant Оө`: The convergent constant
  `C(Оө) = exp(вҲ‘' n, 2 В· n^{-Оө})` bounding the partition sum for all `q`.

## Main Results

* `PoissonCRT.tauPartitionSum_eq_prod`: The partition sum factorizes as
  `вҲҸ_{p вҲҲ S} (1 + 2 В· p^{-Оө})`.
* `PoissonCRT.tauPartitionSum_le_exp`: The partition sum is bounded by
  `exp(вҲ‘_{p вҲҲ S} 2 В· p^{-Оө})`.
* `PoissonCRT.tauPartitionSum_le_bound`: For `Оө > 1`, the partition sum over any
  finset is at most `C(Оө)`, a convergent constant independent of `q`.

## References

* [A. Granville, P. Kurlberg, *Poisson statistics via the Chinese remainder theorem*]
  [arXiv:math/0412135v2], В§3.2
-/

open Finset BigOperators Real

namespace PoissonCRT

/-! ### В§3.2 Partition Definitions -/

/-- The local weight for a natural number `p` with savings exponent `Оө`:
`tauLocalWeight Оө p = 2 * p ^ (-Оө)`.

In the context of В§3.2 of GranvilleвҖ“Kurlberg, when a prime `p` is "activated"
in a П„-partition, it contributes this weight to the optimization bound. -/
noncomputable def tauLocalWeight (Оө : в„қ) (p : в„•) : в„қ :=
  2 * (p : в„қ) ^ (-Оө)

/-- The dimension `v(П„)` of a П„-partition is the cardinality of the active set `T`.
This counts the number of primes contributing to the well-distribution savings. -/
def tauDimension (T : Finset в„•) : в„• := T.card

/-- The weight `w(П„, Оө)` of a П„-partition: the accumulated savings
`вҲ‘_{p вҲҲ T} p^{-Оө}` from the active primes. -/
noncomputable def tauWeight (Оө : в„қ) (T : Finset в„•) : в„қ :=
  вҲ‘ p вҲҲ T, (p : в„қ) ^ (-Оө)

/-- The partition sum over a finset `S`:
`tauPartitionSum Оө S = вҲ‘_{T вҠҶ S} вҲҸ_{p вҲҲ T} tauLocalWeight Оө p`.

This is the total optimization weight from В§3.2, summing over all possible
П„-partitions (subsets of the prime factor set). -/
noncomputable def tauPartitionSum (Оө : в„қ) (S : Finset в„•) : в„қ :=
  вҲ‘ T вҲҲ S.powerset, вҲҸ p вҲҲ T, tauLocalWeight Оө p

/-- The convergent bound constant `C(Оө) = exp(вҲ‘' n, tauLocalWeight Оө n)`.
For `Оө > 1`, this is a finite positive constant that bounds the partition sum
for all finsets `S`. -/
noncomputable def tauBoundConstant (Оө : в„қ) : в„қ :=
  exp (вҲ‘' n : в„•, tauLocalWeight Оө n)

/-! ### Basic Properties -/

/-- The local weight is nonneg for any `Оө` and `p : в„•`. -/
theorem tauLocalWeight_nonneg (Оө : в„қ) (p : в„•) : 0 вүӨ tauLocalWeight Оө p :=
  mul_nonneg (by norm_num) (rpow_nonneg (Nat.cast_nonneg p) (-Оө))

/-- The partition sum is nonneg. -/
theorem tauPartitionSum_nonneg (Оө : в„қ) (S : Finset в„•) : 0 вүӨ tauPartitionSum Оө S :=
  Finset.sum_nonneg fun _ _ =>
    Finset.prod_nonneg fun p _ => tauLocalWeight_nonneg Оө p

/-! ### The Factorization Identity -/

/-- **Factorization identity**: The partition sum factors as a product over primes:
`вҲ‘_{T вҠҶ S} вҲҸ_{p вҲҲ T} (2 В· p^{-Оө}) = вҲҸ_{p вҲҲ S} (1 + 2 В· p^{-Оө})`.

This is the combinatorial heart of the В§3.2 optimization, reducing the sum over
exponentially many partitions to a product over individual primes. -/
theorem tauPartitionSum_eq_prod (Оө : в„қ) (S : Finset в„•) :
    tauPartitionSum Оө S = вҲҸ p вҲҲ S, (1 + tauLocalWeight Оө p) :=
  (Finset.prod_one_add S).symm

/-! ### Exponential Bound -/

/-- Each factor `1 + tauLocalWeight Оө p вүҘ 0`. -/
private theorem one_add_tauLocalWeight_nonneg (Оө : в„қ) (p : в„•) :
    0 вүӨ 1 + tauLocalWeight Оө p :=
  le_trans zero_le_one (le_add_of_nonneg_right (tauLocalWeight_nonneg Оө p))

/-- **Exponential bound on the partition sum**:
`tauPartitionSum Оө S вүӨ exp(вҲ‘_{p вҲҲ S} tauLocalWeight Оө p)`.

Since `1 + x вүӨ exp(x)` for all real `x`, each factor in the product is bounded
by the corresponding exponential, giving a product-to-exp comparison. -/
theorem tauPartitionSum_le_exp (Оө : в„қ) (S : Finset в„•) :
    tauPartitionSum Оө S вүӨ exp (вҲ‘ p вҲҲ S, tauLocalWeight Оө p) := by
  rw [tauPartitionSum_eq_prod, exp_sum]
  exact Finset.prod_le_prod
    (fun i _ => one_add_tauLocalWeight_nonneg Оө i)
    (fun i _ => by linarith [add_one_le_exp (tauLocalWeight Оө i)])

/-! ### Summability and Convergence -/

/-
For `Оө > 1`, the function `n вҶҰ (n : в„қ) ^ (-Оө)` is summable over `в„•`.
-/
private theorem summable_natCast_rpow_neg {Оө : в„қ} (hОө : 1 < Оө) :
    Summable (fun n : в„• => (n : в„қ) ^ (-Оө)) := by
  convert Real.summable_nat_rpow_inv.mpr hОө using 1;
  simp +contextual [ Real.rpow_neg ]

/-
For `Оө > 1`, the local weight function is summable over `в„•`.
-/
theorem tauLocalWeight_summable {Оө : в„қ} (hОө : 1 < Оө) :
    Summable (fun n : в„• => tauLocalWeight Оө n) := by
  exact Summable.mul_left _ <| Real.summable_nat_rpow.2 <| by linarith;

/-- For `Оө > 1`, the bound constant `C(Оө)` is positive. -/
theorem tauBoundConstant_pos (Оө : в„қ) : 0 < tauBoundConstant Оө :=
  exp_pos _

/-- The finite sum of local weights over any finset is bounded by the tsum
when the series converges. -/
private theorem sum_le_tsum_tauLocalWeight (Оө : в„қ) (S : Finset в„•)
    (hs : Summable (fun n : в„• => tauLocalWeight Оө n)) :
    вҲ‘ p вҲҲ S, tauLocalWeight Оө p вүӨ вҲ‘' n, tauLocalWeight Оө n :=
  hs.sum_le_tsum S (fun i _ => tauLocalWeight_nonneg Оө i)

/-! ### The Main Bound -/

/-- **The q-independent bound**: For `Оө > 1`, the partition sum
`вҲ‘_{T вҠҶ S} вҲҸ_{p вҲҲ T} (2 В· p^{-Оө})`
is bounded above by the convergent constant
`C(Оө) = exp(вҲ‘' n, 2 В· n^{-Оө})`
for ALL finsets `S` (and in particular for `S = primeFactors(q)` for any `q`).

This is the abstract form of the main result of В§3.2: the optimization sum
converges uniformly over all squarefree integers. -/
theorem tauPartitionSum_le_bound {Оө : в„қ} (hОө : 1 < Оө) (S : Finset в„•) :
    tauPartitionSum Оө S вүӨ tauBoundConstant Оө :=
  calc tauPartitionSum Оө S
      вүӨ exp (вҲ‘ p вҲҲ S, tauLocalWeight Оө p) := tauPartitionSum_le_exp Оө S
    _ вүӨ exp (вҲ‘' n, tauLocalWeight Оө n) :=
        exp_le_exp.mpr (sum_le_tsum_tauLocalWeight Оө S (tauLocalWeight_summable hОө))
    _ = tauBoundConstant Оө := rfl

/-- **Strict bound**: For `Оө > 1`, the partition sum is strictly less than
`C(Оө) + 1`. -/
theorem tauPartitionSum_lt_bound_add_one {Оө : в„қ} (hОө : 1 < Оө) (S : Finset в„•) :
    tauPartitionSum Оө S < tauBoundConstant Оө + 1 :=
  lt_of_le_of_lt (tauPartitionSum_le_bound hОө S) (lt_add_one _)

/-! ### Specialization to Prime Factors -/

/-- For a squarefree integer `q`, the partition sum over its prime factors
is bounded by `C(Оө)`. -/
theorem tauPartitionSum_primeFactors_le {Оө : в„қ} (hОө : 1 < Оө) (q : в„•) :
    tauPartitionSum Оө q.primeFactors вүӨ tauBoundConstant Оө :=
  tauPartitionSum_le_bound hОө q.primeFactors

/-! ### Monotonicity -/

/-
The partition sum is monotone in the finset: if `S вҠҶ S'`, then
`tauPartitionSum Оө S вүӨ tauPartitionSum Оө S'`.

This reflects the fact that enlarging the set of prime factors (increasing `q`)
can only increase the optimization sum.
-/
theorem tauPartitionSum_mono (Оө : в„қ) {S S' : Finset в„•} (h : S вҠҶ S') :
    tauPartitionSum Оө S вүӨ tauPartitionSum Оө S' := by
  rw [tauPartitionSum_eq_prod, tauPartitionSum_eq_prod, вҶҗ Finset.prod_sdiff h]
  exact le_mul_of_one_le_left
    (Finset.prod_nonneg fun _ _ =>
      add_nonneg zero_le_one (tauLocalWeight_nonneg _ _))
    (le_trans (by norm_num)
      (Finset.prod_le_prod (fun _ _ => by norm_num)
        fun _ _ => le_add_of_nonneg_right (tauLocalWeight_nonneg _ _)))

/-! ### Simple Evaluations -/

/-- The partition sum of the empty set is 1. -/
@[simp]
theorem tauPartitionSum_empty (Оө : в„қ) : tauPartitionSum Оө вҲ… = 1 := by
  simp [tauPartitionSum]

/-- The partition sum of a singleton `{p}` is `1 + 2 В· p^{-Оө}`. -/
@[simp]
theorem tauPartitionSum_singleton (Оө : в„қ) (p : в„•) :
    tauPartitionSum Оө {p} = 1 + tauLocalWeight Оө p := by
  rw [tauPartitionSum_eq_prod, Finset.prod_singleton]

end PoissonCRT
