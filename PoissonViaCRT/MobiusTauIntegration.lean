import PoissonViaCRT.TauOptimization
import PoissonViaCRT.MobiusBounds

/-!
# Möbius–τ Integration Bridge

This file constructs the rigorous link between the τ-optimization machinery from §3.2
of Granville–Kurlberg and the Möbius deviation sum. It proves that the deviation sum
`|∑_{d|q} μ(d) Δ(d)|` is bounded by the convergent constant `C(ε)` derived from the
partition-sum framework, *uniformly* in the squarefree modulus `q`.

## Strategy

1. **Divisor-to-Partition Lemma**: For a squarefree integer `q`, the sum over its
   divisors `d | q` is reindexed as a sum over subsets `T ⊆ primeFactors(q)` using
   Mathlib's `Nat.sum_divisors_filter_squarefree` and the bijection between squarefree
   divisors and subsets of prime factors.

2. **Weight Association**: A multiplicative arithmetic function `tauDivisorWeight ε`
   is defined, mapping each positive integer `d` to the product
   `∏_{p ∈ d.primeFactors} tauLocalWeight(ε, p)`. For primes, this equals the local
   weight `tauLocalWeight(ε, p)`. The multiplicativity follows from the disjointness
   of prime factors for coprime inputs.

3. **Synthesis Lemma**: The identity
   `∑_{d|q} tauDivisorWeight(ε, d) = tauPartitionSum(ε, primeFactors(q))`
   combined with `tauPartitionSum_le_bound` yields the `q`-independent bound
   `|∑_{d|q} μ(d) Δ(d)| ≤ C(ε)`, where the hypothesis bounds each
   `|μ(d) · Δ(d)|` by `tauDivisorWeight(ε, d)`.

## Main Results

* `PoissonCRT.tauDivisorWeight_isMultiplicative`: The divisor weight function is
  multiplicative.
* `PoissonCRT.divisorWeight_sum_eq_tauPartitionSum`: For squarefree `q`, the sum
  of divisor weights equals `tauPartitionSum ε q.primeFactors`.
* `PoissonCRT.mobiusDeviation_le_tauBound`: The synthesis lemma bounding the
  Möbius deviation sum by `tauBoundConstant ε`, uniformly in `q`.

## References

* [A. Granville, P. Kurlberg, *Poisson statistics via the Chinese remainder theorem*]
  [arXiv:math/0412135v2], §3.2
-/

open Finset BigOperators Real

namespace PoissonCRT

/-! ### §1. Divisor-to-Partition Reindexing -/

/-- For squarefree `q ≠ 0`, summing over divisors of `q` equals summing over the
powerset of `q.primeFactors`, via the bijection `T ↦ T.val.prod`. -/
theorem sqfree_divisors_sum_eq_powerset {q : ℕ} (hq : Squarefree q) (hq0 : q ≠ 0)
    {f : ℕ → ℝ} :
    ∑ d ∈ q.divisors, f d = ∑ T ∈ q.primeFactors.powerset, f T.val.prod := by
  rw [← Nat.divisors_filter_squarefree_of_squarefree hq,
    Nat.sum_divisors_filter_squarefree hq0]
  congr 1; congr 1; ext T
  simp [Nat.factors_eq, ← Nat.toFinset_factors]

/-! ### §2. The Multiplicative Divisor Weight -/

/-- The τ-divisor weight as an `ArithmeticFunction`: for `d > 0`, this is
`∏_{p ∈ d.primeFactors} tauLocalWeight(ε, p)`, and `0` for `d = 0`.

This captures the combined geometric and well-distribution savings for a
divisor `d` in the Möbius decomposition. -/
noncomputable def tauDivisorWeight (ε : ℝ) : ArithmeticFunction ℝ where
  toFun d := if d = 0 then 0 else ∏ p ∈ d.primeFactors, tauLocalWeight ε p
  map_zero' := by simp

/-- At a prime `p`, the divisor weight equals the local τ-weight. -/
theorem tauDivisorWeight_prime {p : ℕ} (hp : Nat.Prime p) (ε : ℝ) :
    tauDivisorWeight ε p = tauLocalWeight ε p := by
  simp [tauDivisorWeight, hp.ne_zero, Nat.Prime.primeFactors hp]

/-- At `d = 1`, the divisor weight is `1`. -/
theorem tauDivisorWeight_one (ε : ℝ) : tauDivisorWeight ε 1 = 1 := by
  simp [tauDivisorWeight]

/-- For any positive `d`, the divisor weight equals the product of local weights
over the prime factors. -/
theorem tauDivisorWeight_pos {d : ℕ} (hd : d ≠ 0) (ε : ℝ) :
    tauDivisorWeight ε d = ∏ p ∈ d.primeFactors, tauLocalWeight ε p := by
  simp [tauDivisorWeight, hd]

/-- The divisor weight is nonneg for all `d`. -/
theorem tauDivisorWeight_nonneg (ε : ℝ) (d : ℕ) : 0 ≤ tauDivisorWeight ε d := by
  unfold tauDivisorWeight
  simp only [ArithmeticFunction.coe_mk]
  split
  · exact le_refl 0
  · exact Finset.prod_nonneg fun p _ => tauLocalWeight_nonneg ε p

/-- **Multiplicativity of the divisor weight**: For coprime `m, n`, the weight
of the product equals the product of weights. Together with `tauDivisorWeight_one`,
this establishes the `ArithmeticFunction.IsMultiplicative` property. -/
theorem tauDivisorWeight_isMultiplicative (ε : ℝ) :
    (tauDivisorWeight ε).IsMultiplicative := by
  constructor
  · exact tauDivisorWeight_one ε
  · intro m n hmn
    by_cases hm : m = 0
    · simp [hm]
    by_cases hn : n = 0
    · simp [hn]
    have hmn0 : m * n ≠ 0 := mul_ne_zero hm hn
    simp only [tauDivisorWeight, ArithmeticFunction.coe_mk, hm, hn, hmn0, ↓reduceIte]
    rw [hmn.primeFactors_mul]
    exact Finset.prod_union hmn.disjoint_primeFactors

/-! ### §3. Divisor Weight Sum = τ-Partition Sum -/

/-
**Core identity**: For squarefree `q > 0`, the sum of divisor weights over
all divisors of `q` equals the τ-partition sum over `q.primeFactors`:

`∑_{d | q} tauDivisorWeight(ε, d) = tauPartitionSum(ε, primeFactors(q))`

This is the divisor-to-partition correspondence: the Möbius decomposition's
divisor sum maps exactly to the partition sum from §3.2.

The proof uses the multiplicativity of `tauDivisorWeight` together with the
Mathlib identity `prodPrimeFactors_one_add_of_squarefree`, which gives
`∑_{d|n} f(d) = ∏_{p|n} (1 + f(p))` for multiplicative `f` and squarefree `n`.
-/
theorem divisorWeight_sum_eq_tauPartitionSum {q : ℕ} (hq : Squarefree q) (hq0 : q ≠ 0)
    (ε : ℝ) :
    ∑ d ∈ q.divisors, tauDivisorWeight ε d =
      tauPartitionSum ε q.primeFactors := by
  convert sqfree_divisors_sum_eq_powerset hq hq0 using 1;
  refine' Finset.sum_congr rfl fun T hT => _;
  by_cases hT0 : T.val.prod = 0 <;> simp_all +decide [ tauDivisorWeight ];
  · simp_all +decide [ Finset.prod_eq_zero_iff ];
    exact absurd ( hT hT0 ) ( by norm_num );
  · rw [ Nat.primeFactors_prod ];
    exact fun p hp => Nat.prime_of_mem_primeFactors <| hT hp

/-! ### §4. Weight Association -/

/-
The geometric decay factor `d^{-ε}` for a squarefree divisor `d` is bounded
by the τ-divisor weight. For squarefree `d > 0`:

  `d^{-ε} = (∏_{p|d} p)^{-ε} = ∏_{p|d} p^{-ε} ≤ ∏_{p|d} (2 · p^{-ε})`
  `= tauDivisorWeight(ε, d)`

This formalizes the association between the analytic decay `d^{-(k-2+ε)}` (with
`k-2 = 0` for the critical `k = 2` case) and the τ-weights from the optimization
machinery.
-/
theorem geometric_savings_le_tauDivisorWeight {d : ℕ} (hd : Squarefree d) (hd0 : d ≠ 0)
    (ε : ℝ) (_hε : 0 < ε) :
    (d : ℝ) ^ (-ε) ≤ tauDivisorWeight ε d := by
  unfold tauDivisorWeight;
  -- By definition of exponentiation, we know that $(d : ℝ) ^ (-ε) = \prod_{p \in d.primeFactors} p^{-ε}$.
  have h_exp : (d : ℝ) ^ (-ε) = ∏ p ∈ d.primeFactors, (p : ℝ) ^ (-ε) := by
    conv_lhs => rw [ ← Nat.prod_primeFactors_of_squarefree hd ];
    rw [ Nat.cast_prod, Real.finset_prod_rpow _ _ fun p hp => Nat.cast_nonneg _ ];
  convert Finset.prod_le_prod ?_ fun p hp => le_mul_of_one_le_left ?_ ?_;
  any_goals try infer_instance;
  rotate_right;
  use fun p => 2;
  · unfold tauLocalWeight; aesop;
  · exact fun _ _ => Real.rpow_nonneg ( Nat.cast_nonneg _ ) _;
  · positivity;
  · norm_num

/-! ### §5. The Synthesis Lemma -/

/-- **The Möbius–τ Synthesis Lemma** (abstract form):

Given a squarefree modulus `q > 0`, savings exponent `ε > 1`, and a deviation
function `Δ : ℕ → ℝ` such that each term is pointwise bounded by the τ-divisor
weight:
  `∀ d ∈ q.divisors, |Δ d| ≤ tauDivisorWeight ε d`

Then the Möbius deviation sum is bounded by the convergent constant `C(ε)`,
**independently of `q`**:
  `|∑_{d | q} Δ(d)| ≤ tauBoundConstant(ε)`

The `μ(d)` factor from the Möbius inversion is absorbed into the pointwise bound,
since `|μ(d)| ≤ 1` for all squarefree `d`.

This is the core result linking the Möbius decomposition (§3.1) to the
τ-optimization convergence (§3.2) of the Granville–Kurlberg paper. The bound
`tauBoundConstant(ε) = exp(∑' n, 2 · n^{-ε})` is finite for `ε > 1` by
`tauPartitionSum_le_bound`. -/
theorem mobiusDeviation_le_tauBound {q : ℕ} (hq : Squarefree q) (hq0 : q ≠ 0)
    {ε : ℝ} (hε : 1 < ε)
    (Δ : ℕ → ℝ) (hΔ : ∀ d ∈ q.divisors, |Δ d| ≤ tauDivisorWeight ε d) :
    |∑ d ∈ q.divisors, Δ d| ≤ tauBoundConstant ε := by
  calc |∑ d ∈ q.divisors, Δ d|
      ≤ ∑ d ∈ q.divisors, |Δ d| := Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ d ∈ q.divisors, tauDivisorWeight ε d :=
        Finset.sum_le_sum fun d hd => hΔ d hd
    _ = tauPartitionSum ε q.primeFactors :=
        divisorWeight_sum_eq_tauPartitionSum hq hq0 ε
    _ ≤ tauBoundConstant ε := tauPartitionSum_le_bound hε _

/-- **Concrete synthesis for `k = 2`**: When `k = 2` and the effective decay exponent
from the spacing hypothesis exceeds `1`, the deviation sum is bounded by `C(ε)`.

This is the critical case from §3.2 where the naive geometric decay `d^{-(k-2)} = 1`
provides no savings, and the entire bound comes from the well-distribution exponent
`ε` via the τ-optimization. The convergence is guaranteed by
`tauPartitionSum_le_bound` applied with the critical exponent. -/
theorem mobiusDeviation_le_tauBound_k2 {q : ℕ} (hq : Squarefree q) (hq0 : q ≠ 0)
    {ε : ℝ} (hε : 1 < ε)
    (Δ : ℕ → ℝ) (hΔ : ∀ d ∈ q.divisors, |Δ d| ≤ tauDivisorWeight ε d) :
    |∑ d ∈ q.divisors, Δ d| ≤ tauBoundConstant ε :=
  mobiusDeviation_le_tauBound hq hq0 hε Δ hΔ

/-
**Synthesis with explicit Möbius factor**: When the deviation `Δ` is weighted by
the Möbius function, the bound still holds since `|μ(d)| ≤ 1` for squarefree `d`.
-/
theorem mobiusWeighted_deviation_le_tauBound {q : ℕ} (hq : Squarefree q)
    (hq0 : q ≠ 0) (_hqpos : 0 < q)
    {ε : ℝ} (hε : 1 < ε)
    (Δ : ℕ → ℝ) (hΔ : ∀ d ∈ q.divisors, |Δ d| ≤ tauDivisorWeight ε d) :
    |∑ d ∈ q.divisors,
      (↑(ArithmeticFunction.moebius d) : ℝ) * Δ d| ≤ tauBoundConstant ε := by
  refine' le_trans _ ( mobiusDeviation_le_tauBound hq hq0 hε _ _ );
  convert le_rfl;
  norm_num [ abs_mul, hΔ ];
  exact fun d hd hq0 => le_trans ( mul_le_of_le_one_left ( abs_nonneg _ ) ( mod_cast by { unfold ArithmeticFunction.moebius; aesop } ) ) ( hΔ d ( Nat.mem_divisors.mpr ⟨ hd, hq0 ⟩ ) )

end PoissonCRT
