import PoissonViaCRT.Combinatorics

/-!
# Gamma-Range Summation Bounds (В§3.1 Integration)

This file builds on the combinatorial bounds in `Combinatorics.lean` to prove
integrated summation bounds on `M_Оі(H)` over ranges of `Оі`. These are needed
for the large-divisor regime in the deviation bound (Proposition 3.7).

## Main Results

* `countTuplesWithGammaProd_le_sum`: For any finite set `S` of Gamma structures
  with `Оі(О“) = Оі` that covers all tuples, `M_Оі(H) вүӨ вҲ‘_{О“ вҲҲ S} M_О“(H)`.
* `countTuplesWithGamma_bound_of_gammaProd_le`: Per-О“ bound:
  `M_О“(H) вүӨ 2^k В· H^k / Оі` when `Оі(О“) вүӨ H`.
* `countTuplesWithGammaProd_small_gamma`: Combined small-Оі bound:
  `M_Оі(H) вүӨ C(k+1,2)^{Пү(Оі)} В· 2^k В· H^k / Оі` when `Оі вүӨ H`.

## References

* GranvilleвҖ“Kurlberg В§3.1, equations (вҳ…3)вҖ“(вҳ…4)
-/

open Finset BigOperators Nat

namespace PoissonCRT

variable {k : в„•}

/-! ### Helper lemmas -/

/-- Each `gammaRow` value divides `gammaProd`. -/
lemma gammaRow_dvd_gammaProd (О“ : GammaStructure (k + 1)) (j : Fin (k + 1)) :
    О“.gammaRow j вҲЈ О“.gammaProd :=
  Finset.dvd_prod_of_mem _ (Finset.mem_univ j)

/-- Each `gammaRow` value is at most `gammaProd`. -/
lemma gammaRow_le_gammaProd (О“ : GammaStructure (k + 1)) (j : Fin (k + 1)) :
    О“.gammaRow j вүӨ О“.gammaProd :=
  Nat.le_of_dvd (GammaStructure.gammaProd_pos О“) (gammaRow_dvd_gammaProd О“ j)

/-- When `gammaProd вүӨ H`, all `gammaRow` values are `вүӨ H`. -/
lemma gammaRow_le_of_gammaProd_le (О“ : GammaStructure (k + 1)) (H : в„•)
    (h : О“.gammaProd вүӨ H) (i : Fin k) :
    О“.gammaRow i.succ вүӨ H :=
  le_trans (gammaRow_le_gammaProd О“ i.succ) h

/-! ### Per-О“ small gamma bound -/

/-- For any О“ with `gammaProd = Оі вүӨ H`, `M_О“(H) вүӨ 2^k В· H^k / Оі`. This is
a direct corollary of `countTuples_bound_small_gamma` combined with
`gammaRow_le_of_gammaProd_le`. -/
theorem countTuplesWithGamma_bound_of_gammaProd_le
    (О“ : GammaStructure (k + 1)) (Оі H : в„•) (hО“ : О“.gammaProd = Оі)
    (hОі_le : Оі вүӨ H) :
    (countTuplesWithGamma О“ H : в„қ) вүӨ 2 ^ k * (H : в„қ) ^ k / Оі := by
  convert countTuples_bound_small_gamma О“ H _;
  В· grind;
  В· exact fun i => le_trans ( gammaRow_le_of_gammaProd_le О“ H ( by linarith ) i ) ( by linarith )

/-! ### Decomposition of M_Оі(H) -/

/-- **Decomposition lemma (reformulated)**: `M_Оі(H)` is bounded by the sum of
`M_О“(H)` over any finite set `S` of Gamma structures with `Оі(О“) = Оі` that
covers all tuples in the counting set. The formulation using
`Finset.univ` is not available since `GammaStructure` is not `Fintype`
(diagonal entries are unconstrained). -/
theorem countTuplesWithGammaProd_le_sum (Оі H : в„•) (_hОі : 0 < Оі) (_hH : 0 < H)
    (S : Finset (GammaStructure (k + 1)))
    (_hS_prod : вҲҖ О“ вҲҲ S, О“.gammaProd = Оі)
    (hS_cover : вҲҖ h : Fin (k + 1) вҶ’ в„Ө,
      h 0 = 0 вҶ’
      (вҲҖ i j, i вү  j вҶ’ h i вү  h j) вҶ’
      (вҲҖ i, 0 вүӨ h i вҲ§ h i вүӨ H) вҶ’
      (вҲғ О“ : GammaStructure (k + 1), О“.gammaProd = Оі вҲ§
        вҲҖ i j, i вү  j вҶ’
          Nat.gcd О“.sqfreepart (Int.natAbs (h j - h i)) = О“.gamma i j) вҶ’
      вҲғ О“ вҲҲ S, вҲҖ i j, i вү  j вҶ’
        Nat.gcd О“.sqfreepart (Int.natAbs (h j - h i)) = О“.gamma i j) :
    (countTuplesWithGammaProd k Оі H : в„қ) вүӨ
      вҲ‘ О“ вҲҲ S, (countTuplesWithGamma О“ H : в„қ) := by
  norm_cast;
  refine' le_trans _ ( Finset.card_biUnion_le );
  refine' le_trans _ ( Finset.card_mono _ );
  rotate_left;
  exact Finset.filter ( fun h => h 0 = 0 вҲ§ ( вҲҖ i j, В¬i = j вҶ’ h i вү  h j ) вҲ§ ( вҲҖ i, 0 вүӨ h i вҲ§ h i вүӨ H ) вҲ§ вҲғ О“ вҲҲ S, вҲҖ i j, В¬i = j вҶ’ О“.sqfreepart.gcd ( h j - h i |> Int.natAbs ) = О“.gamma i j ) ( Fintype.piFinset fun _ => Finset.Icc 0 H );
  В· simp +contextual [ Finset.subset_iff ];
  В· rw [ вҶҗ Set.ncard_coe_finset ];
    apply_rules [ Set.ncard_le_ncard ];
    В· intro h hh; specialize hS_cover h; aesop;
    В· exact Set.toFinite _

/-! ### Small-Оі bound on M_Оі(H) -/

/-- **Small-Оі bound**: `M_Оі(H) вүӨ (2^C(k+1,2))^{Пү(Оі)} В· 2^k В· H^k / Оі` when `Оі вүӨ H`.
Combines `countTuplesWithGammaProd_le_sum` (decomposition over Gamma structures),
`countTuplesWithGamma_bound_of_gammaProd_le` (per-structure bound), and
`countGammaStructures_le` (structure-counting bound). -/
theorem countTuplesWithGammaProd_small_gamma (Оі H : в„•)
    (hОі : 0 < Оі) (hH : 0 < H) (hОі_le : Оі вүӨ H) :
    (countTuplesWithGammaProd k Оі H : в„қ) вүӨ
      ((2 ^ (k + 1).choose 2) : в„қ) ^ Оі.primeFactors.card *
        2 ^ k * (H : в„қ) ^ k / Оі := by
  refine le_trans (countTuplesWithGammaProd_le_sum Оі H hОі hH ?_ ?_ ?_) ?_
  exact finsetGammaStructures Оі
  В· exact fun О“ hО“ => by simpa using hО“
  В· exact fun h hhвӮҒ hhвӮӮ hhвӮғ hhвӮ„ =>
      вҹЁhhвӮ„.choose, mem_finsetGammaStructures.mpr hhвӮ„.choose_spec.1, hhвӮ„.choose_spec.2вҹ©
  В· refine le_trans (Finset.sum_le_sum fun О“ hО“ =>
      show (countTuplesWithGamma О“ H : в„қ) вүӨ 2 ^ k * H ^ k / Оі from ?_) ?_
    В· convert countTuplesWithGamma_bound_of_gammaProd_le О“ Оі H _ _ using 1 <;> aesop
    В· norm_num [mul_assoc, mul_div_assoc]
      gcongr
      exact_mod_cast countGammaStructures_le Оі hОі

end PoissonCRT
