/-! ### The main symmetric-difference bound -/

/-
The symmetric-difference cardinality bound.
-/
lemma inScaledBox_symmDiff_card_le (m : ℕ) (X : Box m) :
    ∃ D : ℝ, 0 ≤ D ∧ ∀ (v : Fin m → ℝ), (∀ i, 0 ≤ v i ∧ v i ≤ 1) → ∀ (s : ℝ), 1 ≤ s →
      let N := ⌈s * ∑ i, X.sides i⌉
      let S_v := (piBox m N).filter (fun h => inScaledBox X s v h)
      let S_0 := (piBox m N).filter (fun h => inScaledBox X s (fun _ => 0) h)
      ((S_v \ S_0).card : ℝ) + ((S_0 \ S_v).card : ℝ) ≤ D * s ^ ((m : ℤ) - 1) := by
  rcases m with ( _ | m ) <;> norm_num at *;
  · refine' ⟨ 1, by norm_num, fun s hs => _ ⟩ ; norm_num [ Finset.filter_singleton, inScaledBox ];
    finiteness;
  · use 4 * ( m + 1 ) * ( ∑ i, X.sides i + 1 ) ^ m;
    refine' ⟨ by exact mul_nonneg ( by positivity ) ( pow_nonneg ( add_nonneg ( Finset.sum_nonneg fun _ _ => le_of_lt ( X.sides_pos _ ) ) zero_le_one ) _ ), fun v hv s hs => _ ⟩;
    refine' le_trans ( add_le_add ( sdiff_card_le_sum_boundary _ _ _ _ _ _ ) ( sdiff_card_le_sum_boundary_rev _ _ _ _ _ _ ) ) _;
    · linarith;
    · assumption;
    · linarith;
    · assumption;
    · -- Simplify the right-hand side of the inequality.
      suffices h_simp : (⌈s * ∑ i, X.sides i⌉.toNat : ℝ) ^ m ≤ (∑ i, X.sides i + 1) ^ m * s ^ m by
        norm_num at * ; nlinarith;
      rw [ ← mul_pow ];
      gcongr;
      nlinarith [ Int.ceil_lt_add_one ( s * ∑ i, X.sides i ), show ( ⌈s * ∑ i, X.sides i⌉.toNat : ℝ ) ≤ ⌈s * ∑ i, X.sides i⌉ by exact_mod_cast Int.toNat_of_nonneg ( Int.ceil_nonneg ( mul_nonneg ( by positivity ) ( Finset.sum_nonneg fun _ _ => le_of_lt ( X.sides_pos _ ) ) ) ) |> le_of_eq, show ( ∑ i, X.sides i : ℝ ) ≥ 0 by exact Finset.sum_nonneg fun _ _ => le_of_lt ( X.sides_pos _ ) ]

