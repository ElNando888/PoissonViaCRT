/-
The reverse excess: integers in `(0, L] \ (α, α+L]` also has at most 2 elements.
-/
lemma int_excess_count_rev (α L : ℝ) (hL : 0 < L) (hα : |α| ≤ 1) :
    ({d : ℤ | (0 : ℝ) < (d : ℝ) ∧ (d : ℝ) ≤ L ∧ ¬(α < (d : ℝ) ∧ (d : ℝ) ≤ α + L)}).Finite ∧
    Set.ncard {d : ℤ | (0 : ℝ) < (d : ℝ) ∧ (d : ℝ) ≤ L ∧ ¬(α < (d : ℝ) ∧ (d : ℝ) ≤ α + L)} ≤ 2 := by
  have h_bounds : ∃ a b : ℤ, {d : ℤ | 0 < (d : ℝ) ∧ (d : ℝ) ≤ L ∧ ¬(α < (d : ℝ) ∧ (d : ℝ) ≤ α + L)} ⊆ {a, b} := by
    by_cases hα_neg : α < 0;
    · use Int.floor (α + L) + 1, Int.floor (α + L) + 2;
      intro d hd; simp_all +decide
      by_cases h : α < d <;> simp_all +decide [ abs_le ];
      · exact Or.inl ( eq_add_of_sub_eq ( eq_comm.mp <| Int.floor_eq_iff.mpr ⟨ by norm_num; linarith, by norm_num; linarith ⟩ ) );
      · linarith [ show ( d : ℝ ) ≥ 1 by exact_mod_cast hd.1 ];
    · use 1, 0; intro d hd; simp_all +decide
      rcases d with ⟨ _ | _ | d ⟩ <;> norm_num at *;
      linarith [ hd.2.2 ( by linarith [ abs_le.mp hα ] ), abs_le.mp hα ];
  obtain ⟨ a, b, h ⟩ := h_bounds; exact ⟨ Set.Finite.subset ( Set.toFinite { a, b } ) h, le_trans ( Set.ncard_le_ncard h ) ( Set.ncard_insert_le _ _ ) |> le_trans <| by norm_num ⟩ ;

